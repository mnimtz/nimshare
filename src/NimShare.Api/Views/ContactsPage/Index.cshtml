@model List<NimShare.Core.Entities.Contact>
@{
    ViewData["Title"] = T["contacts.title"];
    Layout = "_AppShell";
}
<div class="page-header">
    <div>
        <a href="/signatures" class="muted" style="text-decoration:none">← @T["nav.signatures"]</a>
        <h1 style="margin-top:6px">👥 @T["contacts.title"]</h1>
        <p class="lede">@T["contacts.lede"]</p>
    </div>
    <button class="btn btn-primary" onclick="openEditor(null)">+ @T["contacts.new"]</button>
</div>

@* v1.10.74: Segmented Tabs — persönliche Kontakte vs. NimShare-User-Directory *@
<div class="card" style="margin-bottom:12px">
    <div class="row" style="gap:8px;align-items:center">
        <div class="seg" role="tablist" style="display:inline-flex;gap:2px;background:var(--tw-gray-100,#eef);padding:3px;border-radius:6px">
            <button id="tab-mine" class="seg-btn active" role="tab" onclick="setMode('mine')"
                    style="padding:6px 14px;border:0;background:var(--tw-primary,#085a9c);color:#fff;border-radius:4px;cursor:pointer">
                👤 @T["contacts.tab_mine"]
            </button>
            <button id="tab-dir" class="seg-btn" role="tab" onclick="setMode('dir')"
                    style="padding:6px 14px;border:0;background:transparent;color:var(--tw-text,#333);border-radius:4px;cursor:pointer">
                🌍 @T["contacts.tab_directory"]
            </button>
        </div>
        <input id="q" placeholder="@T["contacts.search_ph"]" style="flex:1" oninput="reload()"/>
    </div>
</div>

<div class="card">
    <div id="list">
        @if (!Model.Any())
        {
            <p class="muted">@T["contacts.empty"]</p>
        }
    </div>
</div>

<div class="modal-backdrop" id="editor">
  <div class="modal-panel" style="max-width:520px">
    <form onsubmit="return saveContact(event)">
        <h3 style="margin-top:0" id="editor-title">@T["contacts.editor_title"]</h3>
        <input type="hidden" id="c-id"/>
        <div class="field">
            <label>@T["contacts.email"]</label>
            <input id="c-email" type="email" required placeholder="alice@firma.com"/>
        </div>
        <div class="field">
            <label>@T["contacts.name"]</label>
            <input id="c-name" required placeholder="Alice Beispiel"/>
        </div>
        <div class="field">
            <label>@T["contacts.company"]</label>
            <input id="c-company" placeholder="Firma GmbH"/>
        </div>
        <div class="field">
            <label>@T["contacts.tags"]</label>
            <input id="c-tags" placeholder="kunde, vip, legal"/>
            <div class="helper">@T["contacts.tags_hint"]</div>
        </div>
        <div class="field">
            <label>@T["contacts.notes"]</label>
            <textarea id="c-notes" rows="3"></textarea>
        </div>
        <div class="actions">
            <button type="button" class="btn btn-ghost" onclick="closeDlg('editor')">@T["common.cancel"]</button>
            <button class="btn btn-primary">💾 @T["common.save"]</button>
        </div>
    </form>
  </div>
</div>

@section Scripts {
<script>
// Use the app-wide .modal-backdrop pattern instead of <dialog>+showModal;
// the native dialog element renders as inline block in the top-left on
// iOS Safari and some mobile Chromes.
function openDlg(id){ document.getElementById(id).classList.add('open'); }
function closeDlg(id){ document.getElementById(id).classList.remove('open'); }
async function api(m,u,b){const o={method:m,headers:{}};if(b){o.headers['Content-Type']='application/json';o.body=JSON.stringify(b)}const r=await fetch(u,o);if(!r.ok)throw new Error(await r.text());return r.status===204?null:r.json()}
function esc(s){return String(s??'').replace(/[<>&"']/g,c=>({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c]))}
function fmt(d){return d?new Date(d).toLocaleDateString():'—'}
// v1.10.74: zwei Modi — "mine" (persönlich, editierbar) und "dir"
// (NimShare-User-Directory, read-only mit "Als Kontakt speichern"-Aktion).
let currentMode = 'mine';
function setMode(m) {
    currentMode = m;
    document.getElementById('tab-mine').style.background = m === 'mine' ? 'var(--tw-primary, #085a9c)' : 'transparent';
    document.getElementById('tab-mine').style.color      = m === 'mine' ? '#fff' : 'var(--tw-text, #333)';
    document.getElementById('tab-dir').style.background  = m === 'dir'  ? 'var(--tw-primary, #085a9c)' : 'transparent';
    document.getElementById('tab-dir').style.color       = m === 'dir'  ? '#fff' : 'var(--tw-text, #333)';
    reload();
}
async function reload() {
    const q = document.getElementById('q').value.trim();
    const el = document.getElementById('list');
    if (currentMode === 'mine') {
        const rows = await api('GET', '/api/v1/contacts' + (q ? '?q=' + encodeURIComponent(q) : ''));
        if (rows.length === 0) { el.innerHTML = '<p class="muted">' + @Json.Serialize(T["contacts.empty"].Value) + '</p>'; return; }
        el.innerHTML = '<table class="fm-list"><thead><tr><th>' +
            @Json.Serialize(T["common.name"].Value) + '</th><th>' +
            @Json.Serialize(T["contacts.email"].Value) + '</th><th>' +
            @Json.Serialize(T["contacts.company"].Value) + '</th><th>' +
            @Json.Serialize(T["contacts.tags"].Value) + '</th><th>' +
            @Json.Serialize(T["contacts.last_used"].Value) + '</th><th></th></tr></thead><tbody>' +
            rows.map(c => `<tr><td><strong>${esc(c.name)}</strong></td><td class="mono">${esc(c.email)}</td><td class="muted">${esc(c.company||'')}</td><td>${(c.tags||'').split(',').filter(t=>t.trim()).map(t=>'<span class="chip">'+esc(t.trim())+'</span>').join(' ')}</td><td class="muted">${fmt(c.lastUsedAt)}${c.useCount?' ('+c.useCount+'×)':''}</td><td><button class="btn btn-ghost btn-sm" onclick="openEditor('${c.id}')">✎</button> <button class="btn btn-ghost btn-sm" style="color:var(--status-critical)" onclick="delContact('${c.id}')">🗑</button></td></tr>`).join('') +
            '</tbody></table>';
    } else {
        // Directory-Modus: alle NimShare-User (read-only)
        let rows;
        try { rows = await api('GET', '/api/v1/contacts/directory' + (q ? '?q=' + encodeURIComponent(q) : '')); }
        catch (e) { el.innerHTML = '<p class="muted">' + esc(e.message) + '</p>'; return; }
        if (rows.length === 0) { el.innerHTML = '<p class="muted">' + @Json.Serialize(T["contacts.directory_empty"].Value) + '</p>'; return; }
        el.innerHTML = '<table class="fm-list"><thead><tr><th>' +
            @Json.Serialize(T["common.name"].Value) + '</th><th>' +
            @Json.Serialize(T["contacts.email"].Value) + '</th><th></th></tr></thead><tbody>' +
            rows.map(u => `<tr><td><strong>${esc(u.name)}</strong></td><td class="mono">${esc(u.email)}</td><td><button class="btn btn-ghost btn-sm" title="${@Json.Serialize(T["contacts.save_as_mine"].Value)}" onclick='saveAsMine(${JSON.stringify(u.email)}, ${JSON.stringify(u.name)})'>➕ ${@Json.Serialize(T["contacts.save_as_mine"].Value)}</button></td></tr>`).join('') +
            '</tbody></table>';
    }
}

async function saveAsMine(email, name) {
    try {
        await api('POST', '/api/v1/contacts', { email, name, company: null, tags: null, notes: null });
        setMode('mine');
        nimToast(@Json.Serialize(T["contacts.saved_ok"].Value), { kind: 'success' });
    } catch (e) { nimAlert(e.message, { kind: 'error' }); }
}
async function openEditor(id) {
    if (id === null) {
        document.getElementById('c-id').value = '';
        document.getElementById('c-email').value = '';
        document.getElementById('c-name').value = '';
        document.getElementById('c-company').value = '';
        document.getElementById('c-tags').value = '';
        document.getElementById('c-notes').value = '';
    } else {
        const rows = await api('GET', '/api/v1/contacts');
        const c = rows.find(x => x.id === id);
        if (!c) return;
        document.getElementById('c-id').value = c.id;
        document.getElementById('c-email').value = c.email;
        document.getElementById('c-name').value = c.name;
        document.getElementById('c-company').value = c.company || '';
        document.getElementById('c-tags').value = c.tags || '';
        document.getElementById('c-notes').value = '';
    }
    openDlg('editor');
}
async function saveContact(ev) {
    ev.preventDefault();
    const id = document.getElementById('c-id').value;
    const body = {
        email: document.getElementById('c-email').value.trim(),
        name: document.getElementById('c-name').value.trim(),
        company: document.getElementById('c-company').value.trim() || null,
        tags: document.getElementById('c-tags').value.trim() || null,
        notes: document.getElementById('c-notes').value.trim() || null,
    };
    try {
        if (id) await api('PATCH', '/api/v1/contacts/' + id, body);
        else await api('POST', '/api/v1/contacts', body);
        closeDlg('editor');
        reload();
    } catch (e) { nimAlert(@Json.Serialize(T["common.error"].Value) + ': ' + e.message, { kind: 'error' }); }
    return false;
}
async function delContact(id) {
    if (!confirm(@Json.Serialize(T["common.confirm_delete"].Value))) return;
    try { await api('DELETE', '/api/v1/contacts/' + id); reload(); }
    catch (e) { nimAlert(e.message, { kind: 'error' }); }
}
reload();
</script>
}
