@model NimShare.Core.Entities.ShareLink
@using NimShare.Core.Entities
@using NimShare.Api.Controllers
@{
    ViewData["Title"] = "Link · " + Model.Slug;
    Layout = "_AppShell";
    var events = (List<ShareLinkAccess>)ViewData["Events"]!;
    var allEventCount = (int)(ViewData["AllEventCount"] ?? events.Count);
    var buckets = (List<LinkReportController.DailyBucket>)ViewData["Buckets"]!;
    var uniques = (int)ViewData["UniqueVisitors"]!;
    var referrers = (List<LinkReportController.ReferrerRow>)ViewData["Referrers"]!;
    var countries = (List<LinkReportController.CountRow>)ViewData["Countries"]!;
    var cities = (List<LinkReportController.CountRow>)ViewData["Cities"]!;
    var devices = (List<LinkReportController.CountRow>)ViewData["Devices"]!;
    var timezones = (List<LinkReportController.CountRow>)ViewData["Timezones"]!;
    var heatCells = (List<LinkReportController.HourHeatmapCell>)ViewData["HeatCells"]!;
    var medianTtd = (TimeSpan?)ViewData["MedianTtd"];
    var storeFullIp = (bool)ViewData["StoreFullIp"]!;
    var maxY = Math.Max(1, buckets.Max(b => Math.Max(b.Landings, Math.Max(b.Downloads, b.PasswordFails))));
    var target = Model.File?.Name ?? Model.Folder?.Name ?? "—";
    var isActive = !Model.IsRevoked && (Model.ExpiresAt is null || Model.ExpiresAt > DateTimeOffset.UtcNow);
    var landingUrl = Context.Request.PublicUrl($"/s/{Model.Slug}");

    string DeviceIcon(string d) => d switch
    {
        "Desktop" => "🖥",
        "Mobile" => "📱",
        "Tablet" => "📲",
        "Bot" => "🤖",
        _ => "❔",
    };
    string FormatTtd(TimeSpan t)
    {
        if (t.TotalSeconds < 60) return $"{(int)t.TotalSeconds} s";
        if (t.TotalMinutes < 60) return $"{(int)t.TotalMinutes} min";
        if (t.TotalHours < 24) return $"{t.TotalHours:F1} h";
        return $"{t.TotalDays:F1} d";
    }
}
<div class="page-header">
    <div>
        <a href="/links" class="muted" style="text-decoration:none">← Alle Links</a>
        <h1 style="margin-top:6px">📊 @Model.Slug</h1>
        <p class="lede">
            @target ·
            @if (Model.MaxDownloads is int m)
            {
                <span>@Model.DownloadCount / @m Downloads</span>
            }
            else
            {
                <span>@Model.DownloadCount Downloads</span>
            }
            · @Model.HitCount Aufrufe · @uniques einzigartige Besucher
        </p>
    </div>
    <div class="row" style="gap:6px">
        <span class="chip @(isActive ? "chip-ok" : Model.IsRevoked ? "chip-critical" : "chip-warn")">
            @(isActive ? "Aktiv" : Model.IsRevoked ? "Widerrufen" : "Abgelaufen")
        </span>
        <button class="btn btn-secondary btn-sm" onclick="navigator.clipboard.writeText('@landingUrl')">🔗 Kopieren</button>
    </div>
</div>

<div class="row" style="gap:16px;align-items:stretch;margin-bottom:16px;flex-wrap:wrap">
    <div class="card" style="flex:1;min-width:180px">
        <div class="muted">Aufrufe (Landing)</div>
        <div style="font-size:1.9rem;font-weight:700;color:var(--tw-primary)">@Model.HitCount</div>
    </div>
    <div class="card" style="flex:1;min-width:180px">
        <div class="muted">Downloads</div>
        <div style="font-size:1.9rem;font-weight:700;color:var(--tw-primary)">@Model.DownloadCount</div>
    </div>
    <div class="card" style="flex:1;min-width:180px">
        <div class="muted">Einzigartige Besucher</div>
        <div style="font-size:1.9rem;font-weight:700;color:var(--tw-primary)">@uniques</div>
    </div>
    @* v1.10.158: neue Kachel – Median-Zeit zwischen Landing und Download *@
    <div class="card" style="flex:1;min-width:180px">
        <div class="muted">@T["report.tile.ttd"]</div>
        <div style="font-size:1.9rem;font-weight:700;color:var(--tw-primary)">
            @(medianTtd is TimeSpan ttd ? FormatTtd(ttd) : "—")
        </div>
    </div>
    <div class="card" style="flex:1;min-width:180px">
        <div class="muted">Letzter Zugriff</div>
        <div style="font-size:1rem;color:var(--tw-primary)">@(Model.LastAccessAt?.ToString("dd.MM.yyyy HH:mm") ?? "—")</div>
    </div>
</div>

<!-- ─────────── 30-Tage-Chart ─────────── -->
<div class="card" style="margin-bottom:16px">
    <h2 class="card-title">Verlauf · letzte 30 Tage</h2>
    <div style="overflow-x:auto">
        <svg viewBox="0 0 600 200" preserveAspectRatio="none" style="width:100%;height:220px;background:var(--tw-gray-100);border-radius:6px">
            @{
                var W = 600.0; var H = 200.0; var pad = 18.0;
                var barW = (W - 2 * pad) / buckets.Count;
                for (int i = 0; i < buckets.Count; i++)
                {
                    var b = buckets[i];
                    double x = pad + i * barW;
                    double landings = (b.Landings / (double)maxY) * (H - 2 * pad);
                    double downloads = (b.Downloads / (double)maxY) * (H - 2 * pad);
                    var yLand = H - pad - landings;
                    var yDown = H - pad - downloads;
                    var bw = Math.Max(2.0, barW - 3.0);
                    <rect x="@x.ToString("0.0")" y="@yLand.ToString("0.0")" width="@bw.ToString("0.0")" height="@landings.ToString("0.0")" fill="#00A0FB" opacity="0.5"><title>@b.Day: @b.Landings Aufrufe</title></rect>
                    <rect x="@x.ToString("0.0")" y="@yDown.ToString("0.0")" width="@bw.ToString("0.0")" height="@downloads.ToString("0.0")" fill="#00EB86"><title>@b.Day: @b.Downloads Downloads</title></rect>
                }
                <line x1="@pad.ToString("0.0")" y1="@(H - pad).ToString("0.0")" x2="@(W - pad).ToString("0.0")" y2="@(H - pad).ToString("0.0")" stroke="#8094AA" stroke-width="1"/>
            }
        </svg>
    </div>
    <div class="row" style="gap:16px;font-size:.8rem;margin-top:6px">
        <span><span style="display:inline-block;width:12px;height:12px;background:#00A0FB;opacity:.5;border-radius:2px;vertical-align:middle;margin-right:4px"></span>Aufrufe</span>
        <span><span style="display:inline-block;width:12px;height:12px;background:#00EB86;border-radius:2px;vertical-align:middle;margin-right:4px"></span>Downloads</span>
        <span class="muted">Skala 0–@maxY</span>
    </div>
</div>

<!-- ─────────── v1.10.158: Country + City + Device + Timezone ─────────── -->
<div class="row" style="gap:16px;align-items:flex-start;flex-wrap:wrap;margin-bottom:16px">
    <!-- Länder -->
    <div class="card" style="flex:1;min-width:260px">
        <h2 class="card-title">🌍 @T["report.card.countries"]</h2>
        @if (!countries.Any())
        {
            <p class="muted">@T["report.empty.countries"]</p>
        }
        else
        {
            var total = countries.Sum(c => c.Count);
            <div style="display:flex;flex-direction:column;gap:6px">
                @foreach (var c in countries)
                {
                    var pct = total == 0 ? 0 : (int)Math.Round(100.0 * c.Count / total);
                    <div style="display:flex;align-items:center;gap:8px">
                        <span style="width:32px;font-size:1.2rem;text-align:center">@LinkReportController.CountryFlag(c.Key)</span>
                        <span style="flex:1;font-size:.9rem" class="mono">@c.Key</span>
                        <div style="flex:2;height:8px;background:var(--tw-gray-200);border-radius:4px;overflow:hidden">
                            <div style="height:100%;width:@(pct)%;background:var(--tw-primary)"></div>
                        </div>
                        <span style="width:44px;text-align:right;font-size:.85rem">@c.Count</span>
                    </div>
                }
            </div>
        }
    </div>
    <!-- Städte -->
    <div class="card" style="flex:1;min-width:260px">
        <h2 class="card-title">🏙 @T["report.card.cities"]</h2>
        @if (!cities.Any())
        {
            <p class="muted">@T["report.empty.cities"]</p>
        }
        else
        {
            var total = cities.Sum(c => c.Count);
            <div style="display:flex;flex-direction:column;gap:6px">
                @foreach (var c in cities)
                {
                    var pct = total == 0 ? 0 : (int)Math.Round(100.0 * c.Count / total);
                    <div style="display:flex;align-items:center;gap:8px">
                        <span style="flex:1;font-size:.9rem">@c.Key</span>
                        <div style="flex:2;height:8px;background:var(--tw-gray-200);border-radius:4px;overflow:hidden">
                            <div style="height:100%;width:@(pct)%;background:var(--tw-primary-alt)"></div>
                        </div>
                        <span style="width:44px;text-align:right;font-size:.85rem">@c.Count</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

<div class="row" style="gap:16px;align-items:flex-start;flex-wrap:wrap;margin-bottom:16px">
    <!-- Geräte -->
    <div class="card" style="flex:1;min-width:260px">
        <h2 class="card-title">📱 @T["report.card.devices"]</h2>
        @if (!devices.Any())
        {
            <p class="muted">@T["report.empty.devices"]</p>
        }
        else
        {
            var total = devices.Sum(d => d.Count);
            <div style="display:flex;flex-direction:column;gap:6px">
                @foreach (var d in devices)
                {
                    var pct = total == 0 ? 0 : (int)Math.Round(100.0 * d.Count / total);
                    <div style="display:flex;align-items:center;gap:8px">
                        <span style="width:32px;font-size:1.2rem;text-align:center">@DeviceIcon(d.Key)</span>
                        <span style="flex:1;font-size:.9rem">@d.Key</span>
                        <div style="flex:2;height:8px;background:var(--tw-gray-200);border-radius:4px;overflow:hidden">
                            <div style="height:100%;width:@(pct)%;background:#00A0FB"></div>
                        </div>
                        <span style="width:44px;text-align:right;font-size:.85rem">@d.Count (@pct%)</span>
                    </div>
                }
            </div>
        }
    </div>
    <!-- Zeitzonen -->
    <div class="card" style="flex:1;min-width:260px">
        <h2 class="card-title">🕒 @T["report.card.timezones"]</h2>
        @if (!timezones.Any())
        {
            <p class="muted">@T["report.empty.timezones"]</p>
        }
        else
        {
            var total = timezones.Sum(t => t.Count);
            <div style="display:flex;flex-direction:column;gap:6px">
                @foreach (var t in timezones)
                {
                    var pct = total == 0 ? 0 : (int)Math.Round(100.0 * t.Count / total);
                    <div style="display:flex;align-items:center;gap:8px">
                        <span style="flex:1;font-size:.85rem" class="mono">@t.Key</span>
                        <div style="flex:2;height:8px;background:var(--tw-gray-200);border-radius:4px;overflow:hidden">
                            <div style="height:100%;width:@(pct)%;background:#00EB86"></div>
                        </div>
                        <span style="width:44px;text-align:right;font-size:.85rem">@t.Count</span>
                    </div>
                }
            </div>
        }
    </div>
</div>

<!-- ─────────── Peak-Hour-Heatmap ─────────── -->
<div class="card" style="margin-bottom:16px">
    <h2 class="card-title">🔥 @T["report.card.peak_hours"]</h2>
    @{
        var heatMax = Math.Max(1, heatCells.Max(c => c.Count));
        // Wochentag-Kürzel — .NET-invariant Sun/Mon/…; über Localizer auf die Landessprache.
        var dayLabels = new[] {
            T["report.day.sun"].Value, T["report.day.mon"].Value, T["report.day.tue"].Value,
            T["report.day.wed"].Value, T["report.day.thu"].Value, T["report.day.fri"].Value,
            T["report.day.sat"].Value };
    }
    <div style="overflow-x:auto">
        <table style="border-collapse:separate;border-spacing:2px;font-size:.7rem">
            <thead>
                <tr>
                    <th style="width:32px"></th>
                    @for (int h = 0; h < 24; h++)
                    {
                        <th style="width:24px;text-align:center;color:var(--tw-gray-500);font-weight:normal">@h</th>
                    }
                </tr>
            </thead>
            <tbody>
                @for (int dow = 0; dow < 7; dow++)
                {
                    <tr>
                        <td class="muted" style="padding-right:6px;font-weight:600">@dayLabels[dow]</td>
                        @for (int h = 0; h < 24; h++)
                        {
                            var cell = heatCells.First(c => c.DayOfWeek == dow && c.Hour == h);
                            var intensity = cell.Count == 0 ? 0.0 : (cell.Count / (double)heatMax);
                            var alpha = 0.08 + 0.92 * intensity;
                            <td title="@dayLabels[dow] @h:00 UTC · @cell.Count Zugriffe"
                                style="width:24px;height:20px;background:rgba(0,235,134,@alpha.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture));border-radius:2px"></td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
    <div class="muted" style="font-size:.75rem;margin-top:6px">@string.Format(T["report.heatmap.legend"].Value, heatMax)</div>
</div>

<!-- ─────────── Referrer + Zeitreihe ─────────── -->
<div class="row" style="gap:16px;align-items:flex-start;flex-wrap:wrap">
    <div class="card" style="flex:1;min-width:280px">
        <h2 class="card-title">Herkunft</h2>
        @if (!referrers.Any())
        {
            <p class="muted">Keine Referrer erfasst.</p>
        }
        else
        {
            var total = referrers.Sum(r => r.Count);
            <div style="display:flex;flex-direction:column;gap:6px">
                @foreach (var r in referrers)
                {
                    var pct = total == 0 ? 0 : (int)Math.Round(100.0 * r.Count / total);
                    <div style="display:flex;align-items:center;gap:8px">
                        <span style="flex:1;font-size:.9rem" class="mono">@r.Source</span>
                        <div style="flex:2;height:8px;background:var(--tw-gray-200);border-radius:4px;overflow:hidden">
                            <div style="height:100%;width:@(pct)%;background:var(--tw-primary-alt)"></div>
                        </div>
                        <span style="width:60px;text-align:right;font-size:.85rem">@r.Count</span>
                    </div>
                }
            </div>
        }
    </div>
    <div class="card" style="flex:2;min-width:320px">
        <h2 class="card-title">@string.Format(T["report.card.events"].Value, events.Count, allEventCount)</h2>
        @if (!events.Any())
        {
            <p class="muted">Noch keine Zugriffe.</p>
        }
        else
        {
            <div style="max-height:400px;overflow-y:auto">
                <table class="table" style="font-size:.85rem">
                    <thead>
                        <tr>
                            <th>Wann</th>
                            <th>Typ</th>
                            <th>Ort</th>
                            <th>Gerät</th>
                            @* v1.10.158: IP-Spalte nur wenn Betreiber-Toggle
                               ShareLinks:StoreFullIp=true aktiv ist. *@
                            @if (storeFullIp)
                            {
                                <th>IP</th>
                            }
                            <th>Herkunft</th>
                        </tr>
                    </thead>
                    <tbody>
                    @foreach (var e in events.Take(200))
                    {
                        var badge = e.Kind switch
                        {
                            ShareLinkAccessKind.Download => "chip-ok",
                            ShareLinkAccessKind.PasswordFail => "chip-critical",
                            _ => "chip-warn",
                        };
                        var loc = !string.IsNullOrEmpty(e.City)
                            ? (!string.IsNullOrEmpty(e.CountryCode) ? $"{e.City}, {e.CountryCode}" : e.City)
                            : (e.CountryCode ?? "—");
                        <tr>
                            <td class="muted">@e.At.ToString("dd.MM. HH:mm:ss")</td>
                            <td><span class="chip @badge">@e.Kind</span></td>
                            <td>@loc</td>
                            <td>@(string.IsNullOrEmpty(e.DeviceType) || e.DeviceType == "Unknown" ? "—" : e.DeviceType)</td>
                            @if (storeFullIp)
                            {
                                <td class="mono" style="font-size:.75rem">@(e.IpAddress ?? "—")</td>
                            }
                            <td class="mono" style="font-size:.75rem" title="@e.UserAgent">
                                @(string.IsNullOrEmpty(e.Referer) ? "(direct)" : e.Referer)
                            </td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
            @if (storeFullIp)
            {
                <div class="muted" style="font-size:.75rem;margin-top:6px">
                    @Html.Raw(T["report.ip_notice_html"].Value)
                </div>
            }
        }
    </div>
</div>

<div style="margin-top:20px" class="muted">
    Der Link-Slug: <span class="mono">@Model.Slug</span> ·
    URL: <a href="/s/@Model.Slug" class="mono">@landingUrl</a>
</div>
