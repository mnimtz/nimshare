@model IEnumerable<NimShare.Core.Entities.User>
@{
    ViewData["Title"] = T["users.title"]; Layout = "_AppShell";
    var groups = (List<NimShare.Core.Entities.Group>)(ViewData["Groups"] ?? new List<NimShare.Core.Entities.Group>());
    var invites = (List<NimShare.Core.Entities.Invitation>)(ViewData["Invitations"] ?? new List<NimShare.Core.Entities.Invitation>());
    var now = DateTimeOffset.UtcNow;
    (string cls, string label, string icon) InviteStatus(NimShare.Core.Entities.Invitation i) {
        if (i.UsedAt is not null) return ("chip-ok", "Angenommen", "✓");
        if (i.RevokedAt is not null) return ("chip", "Widerrufen", "✕");
        if (i.ExpiresAt < now) return ("chip-warn", "Abgelaufen", "⌛");
        return ("chip-info", "Offen", "…");
    }
}
<div class="page-header">
    <div>
        <h1>@T["users.title"]</h1>
        <p class="lede">@T["users.lede"]</p>
    </div>
</div>

@if (TempData["Notice"] is string n)
{
    <div class="card" style="border-left:3px solid var(--status-ok);background:rgba(0,235,134,.06)">@n</div>
}
@if (TempData["Error"] is string err)
{
    <div class="card" style="border-left:3px solid var(--status-critical);background:rgba(220,38,38,.06)">@err</div>
}

<div class="card">
    <h2 class="card-title">@T["users.invite"]</h2>
    <p class="muted">@T["users.invite.lede"]</p>
    <form method="post" action="/settings/users/invite" class="row" style="align-items:flex-end;gap:var(--sp-4);flex-wrap:wrap;margin-top:var(--sp-2)">
    @Html.AntiForgeryToken()
        <div class="field" style="flex:2;min-width:220px">
            <label>@T["auth.email"]</label>
            <input type="email" name="email" required placeholder="new.user@example.com"/>
        </div>
        <div class="field" style="flex:2;min-width:180px">
            <label>@T["auth.display_name"]</label>
            <input type="text" name="displayName"/>
        </div>
        <div class="field" style="width:140px">
            <label>@T["users.role"]</label>
            <select name="role">
                <option value="User">@T["users.role.user"]</option>
                <option value="Admin">@T["users.role.admin"]</option>
            </select>
        </div>
        <button type="submit" class="btn btn-primary">@T["users.invite.send"]</button>
    </form>
</div>

@* v1.10.92: „Get-Link"-Toast — Admin-Copy des Accept-Link, falls Email
   nicht angekommen ist. Wird nur EINMAL nach der Redirect-Aktion gezeigt. *@
@if (TempData["InviteLink"] is string invLink)
{
    <div class="card" style="border-left:3px solid var(--tw-accent);background:rgba(50,110,255,.05)">
        <strong>Einladungs-Link für @(TempData["InviteLinkEmail"] as string):</strong>
        <div style="margin-top:6px;display:flex;gap:8px;align-items:center;flex-wrap:wrap">
            <input type="text" value="@invLink" readonly onclick="this.select()"
                   style="flex:1;min-width:280px;font-family:var(--font-mono);font-size:.8rem;padding:6px 8px"/>
            <button type="button" class="btn btn-secondary btn-sm"
                    onclick="navigator.clipboard.writeText(this.previousElementSibling.value).then(()=>this.textContent='✓ Kopiert')">
                Kopieren
            </button>
        </div>
        <div class="muted" style="margin-top:6px;font-size:.75rem">Der Link ist 7 Tage gültig und wird nach Annahme unbrauchbar. Er wurde neu generiert — ein evtl. vorher versandter Link ist damit ungültig.</div>
    </div>
}

@* v1.10.92: Einladungs-Übersicht — Marcus's Bug: „sendet man eine Einladung,
   kann man garnicht den Status sehen". Zeigt letzte 60 Tage mit Status,
   Ablauf, Aktionen (Widerrufen, Neu senden, Link kopieren). *@
<div class="card">
    <h2 class="card-title">Einladungen (@invites.Count)</h2>
    @if (!invites.Any())
    {
        <p class="muted" style="margin:0">Noch keine Einladungen in den letzten 60 Tagen versendet.</p>
    }
    else
    {
        <div style="overflow-x:auto">
        <table class="table" style="margin:0;font-size:.88rem">
            <thead>
                <tr>
                    <th>Status</th>
                    <th>Email</th>
                    <th>Rolle</th>
                    <th>Eingeladen von</th>
                    <th>Gesendet</th>
                    <th>Läuft ab</th>
                    <th style="text-align:right">Aktionen</th>
                </tr>
            </thead>
            <tbody>
            @foreach (var i in invites)
            {
                var (cls, label, icon) = InviteStatus(i);
                var isOpen = i.UsedAt is null && i.RevokedAt is null && i.ExpiresAt >= now;
                var isPending = i.UsedAt is null && i.RevokedAt is null;
                <tr>
                    <td><span class="chip @cls">@icon @label</span></td>
                    <td><code>@i.Email</code></td>
                    <td>@i.Role</td>
                    <td>@(i.InvitedBy?.DisplayName ?? "—")</td>
                    <td style="white-space:nowrap">@i.CreatedAt.LocalDateTime.ToString("dd.MM.yyyy HH:mm")</td>
                    <td style="white-space:nowrap">@i.ExpiresAt.LocalDateTime.ToString("dd.MM.yyyy")
                        @if (i.UsedAt is DateTimeOffset used)
                        {
                            <div class="muted" style="font-size:.7rem">angen.: @used.LocalDateTime.ToString("dd.MM. HH:mm")</div>
                        }
                    </td>
                    <td style="text-align:right;white-space:nowrap">
                        @if (isPending)
                        {
                            <form method="post" action="/settings/users/invite/@i.Id/get-link" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-ghost btn-sm" title="Neuen Link generieren und anzeigen">🔗 Link</button>
                            </form>
                            <form method="post" action="/settings/users/invite/@i.Id/resend" style="display:inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-ghost btn-sm" title="Email erneut senden (neuer Token)">📧 Neu senden</button>
                            </form>
                            <form method="post" action="/settings/users/invite/@i.Id/revoke" style="display:inline"
                                  onsubmit="return confirm('Einladung an @i.Email widerrufen?')">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-ghost btn-sm" style="color:var(--status-critical)">✕</button>
                            </form>
                        }
                        else
                        {
                            <span class="muted" style="font-size:.75rem">—</span>
                        }
                    </td>
                </tr>
            }
            </tbody>
        </table>
        </div>
    }
</div>

<details class="card">
    <summary style="cursor:pointer;font-weight:700;color:var(--tw-primary)">@T["users.create_new"]</summary>
    <p class="muted" style="margin-top:var(--sp-3)">@T["users.create_new.lede"]</p>
    <form method="post" action="/settings/users/create" class="row" style="align-items:flex-end;gap:var(--sp-4);flex-wrap:wrap;margin-top:var(--sp-3)">
    @Html.AntiForgeryToken()
        <div class="field" style="flex:1;min-width:200px">
            <label>@T["auth.email"]</label>
            <input type="email" name="email" required/>
        </div>
        <div class="field" style="flex:1;min-width:180px">
            <label>@T["auth.display_name"]</label>
            <input type="text" name="displayName" required/>
        </div>
        <div class="field" style="flex:1;min-width:180px">
            <label>@T["auth.password"]</label>
            <input type="text" name="password" required minlength="8"/>
        </div>
        <div class="field" style="width:130px">
            <label>@T["users.role"]</label>
            <select name="role">
                <option value="User">@T["users.role.user"]</option>
                <option value="Admin">@T["users.role.admin"]</option>
            </select>
        </div>
        <button type="submit" class="btn btn-ghost">@T["users.create"]</button>
    </form>
</details>

@{
    // Membership map: userId -> set of groupIds — driven by the same Groups list
    // already loaded above, so no extra query.
    var membership = groups
        .SelectMany(g => g.Members.Select(m => new { m.UserId, GroupId = g.Id }))
        .GroupBy(x => x.UserId)
        .ToDictionary(g => g.Key, g => g.Select(x => x.GroupId).ToHashSet());
}
<table class="table">
    <thead>
    <tr>
        <th>@T["auth.email"]</th>
        <th>@T["auth.display_name"]</th>
        <th>@T["users.role"]</th>
        <th>@T["users.quota"]</th>
        <th>@T["nav.groups"]</th>
        <th>@T["users.state"]</th>
        <th>@T["users.type"]</th>
        <th>@T["users.last_login"]</th>
        <th>@T["users.actions"]</th>
    </tr>
    </thead>
    <tbody>
    @foreach (var u in Model)
    {
        var quotaGb = u.QuotaBytes / 1024 / 1024 / 1024;
        var mine = membership.TryGetValue(u.Id, out var mset) ? mset : new HashSet<Guid>();
        <tr>
            <td class="mono">@u.Email</td>
            <td>@u.DisplayName</td>
            <td>
                <span class="chip @(u.Role.ToString() == "Admin" ? "chip-warn" : "")">
                    @T[u.Role.ToString() == "Admin" ? "users.role.admin" : "users.role.user"]
                </span>
            </td>
            <td>
                <form method="post" action="/settings/users/@u.Id/set-quota" class="row" style="gap:4px;align-items:center">
    @Html.AntiForgeryToken()
                    <input type="number" name="quotaGb" value="@quotaGb" min="1" max="10240" style="width:80px;padding:4px 6px"/>
                    <span class="muted">GB</span>
                    <button class="btn btn-ghost btn-sm">@T["users.quota.save"]</button>
                </form>
            </td>
            <td>
                <details>
                    <summary style="cursor:pointer">@mine.Count @T["groups.members"]</summary>
                    <form method="post" action="/settings/users/@u.Id/set-groups" style="margin-top:6px;display:flex;flex-direction:column;gap:4px">
                        @Html.AntiForgeryToken()
                        @foreach (var g in groups)
                        {
                            <label style="display:flex;align-items:center;gap:6px;font-weight:400">
                                <input type="checkbox" name="groupIds" value="@g.Id" @(mine.Contains(g.Id) ? "checked" : "")/> @g.Name
                            </label>
                        }
                        <button type="submit" class="btn btn-ghost btn-sm" style="align-self:flex-start">@T["users.quota.save"]</button>
                    </form>
                </details>
            </td>
            <td>
                @if (u.IsActive)
                {
                    <span class="chip chip-ok">@T["users.active"]</span>
                }
                else
                {
                    <span class="chip chip-warn">@T["users.disabled"]</span>
                }
            </td>
            <td class="muted">
                @if (!string.IsNullOrEmpty(u.EntraOid))
                {
                    <span class="chip">Entra</span>
                }
                @if (u.PasswordHash is not null)
                {
                    <span class="chip">Local</span>
                }
            </td>
            <td class="muted" style="white-space:nowrap">
                @if (u.LastLoginAt is DateTimeOffset ll)
                {
                    <span title="@ll.UtcDateTime.ToString("u")">@ll.ToLocalTime().ToString("g")</span>
                }
                else
                {
                    <text>@T["users.never"]</text>
                }
            </td>
            <td>
                <a class="btn btn-secondary btn-sm" href="/settings/users/@u.Id">✎ @T["users.edit"]</a>
                <form method="post" action="/settings/users/@u.Id/toggle-active" style="display:inline">
    @Html.AntiForgeryToken()
                    <button class="btn btn-ghost btn-sm">@(u.IsActive ? @T["users.action.disable"] : @T["users.action.enable"])</button>
                </form>
                @* v1.10.109: onsubmit einfach-quotiert — @@Json.Serialize liefert literale ",
                   die ein "-Attribut vorzeitig beenden; sonst löscht der Button ohne Rückfrage. *@
                <form method="post" action="/settings/users/@u.Id/delete" style="display:inline"
                      onsubmit='const f=this;event.preventDefault();(async()=>{if(await nimConfirm(@Json.Serialize(T["users.confirm.delete"].Value),{danger:true}))f.submit();})();return false;'>
    @Html.AntiForgeryToken()
                    <button class="btn btn-ghost btn-sm" style="color:var(--status-critical)">🗑</button>
                </form>
            </td>
        </tr>
    }
    </tbody>
</table>

<div style="height:var(--sp-8)"></div>

<div class="page-header">
    <div>
        <h1 id="groups">@T["groups.title"]</h1>
        <p class="lede">@T["groups.lede"]</p>
    </div>
</div>

<div class="card">
    <h2 class="card-title">@T["groups.create_new"]</h2>
    <form method="post" action="/groups/create" class="row" style="align-items:flex-end;gap:var(--sp-4);flex-wrap:wrap">
        @Html.AntiForgeryToken()
        <div class="field" style="flex:1;min-width:220px">
            <label>@T["groups.name"]</label>
            <input type="text" name="name" required maxlength="120"/>
        </div>
        <div class="field" style="flex:2;min-width:280px">
            <label>@T["groups.description"]</label>
            <input type="text" name="description" maxlength="2000"/>
        </div>
        <button type="submit" class="btn btn-primary">@T["groups.create"]</button>
    </form>
</div>

@if (!groups.Any())
{
    <div class="card"><p class="muted">@T["groups.empty"]</p></div>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>@T["groups.name"]</th>
            <th>@T["groups.description"]</th>
            <th>@T["groups.members"]</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var g in groups)
        {
            <tr>
                <td><a href="/groups/@g.Id">@g.Name</a></td>
                <td class="muted">@g.Description</td>
                <td>
                    @g.Members.Count
                    @foreach (var m in g.Members.Take(3))
                    {
                        <span class="chip" style="margin-left:4px">@m.User.DisplayName</span>
                    }
                    @if (g.Members.Count > 3)
                    {
                        <span class="muted" style="margin-left:4px">+@(g.Members.Count - 3)</span>
                    }
                </td>
                <td>
                    <a class="btn btn-ghost btn-sm" href="/groups/@g.Id">@T["users.action.manage"]</a>
                    <a class="btn btn-ghost btn-sm" href="/browse/group/@g.Id">@T["groups.open_files"]</a>
                </td>
            </tr>
        }
        </tbody>
    </table>
}
