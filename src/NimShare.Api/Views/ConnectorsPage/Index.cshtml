@{
    ViewData["Title"] = T["connectors.title"].Value;
    Layout = "_AppShell";
}
<div class="workspace-inner" style="max-width:1000px;margin:0 auto">
    <div class="page-head">
        <h1>🔌 @T["connectors.title"]</h1>
        <p class="muted">@T["connectors.lede"]</p>
    </div>

    @if (TempData["Notice"] is string notice)
    {
        <div class="card" style="background:#e6f7ec;border-left:3px solid #0a7f2e;margin:12px 0">@notice</div>
    }
    @if (TempData["Error"] is string err)
    {
        <div class="card" style="background:#fdecea;border-left:3px solid #c22;margin:12px 0">@err</div>
    }

    <div class="row" style="gap:8px;margin:16px 0;flex-wrap:wrap">
        <a href="/settings/connectors/onedrive/start" class="btn btn-primary">☁️ @T["connectors.add.onedrive"]</a>
    </div>

    <div class="card">
        <table class="table" id="connectorList">
            <thead>
                <tr>
                    <th>@T["connectors.col.name"]</th>
                    <th>@T["connectors.col.type"]</th>
                    <th>@T["connectors.col.connected"]</th>
                    <th></th>
                </tr>
            </thead>
            <tbody><tr><td colspan="4" class="muted">@T["connectors.loading"]</td></tr></tbody>
        </table>
    </div>
</div>

<!-- Browse + Import Modal -->
<div class="modal-backdrop" id="modalBrowse">
    <div class="modal-panel" style="max-width:820px">
        <h2>📂 <span id="browseTitle">@T["connectors.browse.title"]</span></h2>
        <div class="row" style="gap:6px;font-size:.85rem;color:var(--tw-primary)" id="breadcrumb">
            <a href="#" onclick="return browseTo(null, T_root)">🏠 <span id="rootLabel">@T["connectors.browse.root"]</span></a>
        </div>

        <div class="card" id="browseList" style="max-height:400px;overflow-y:auto;margin-top:12px">
            <p class="muted">@T["connectors.loading"]</p>
        </div>

        <div class="field" style="margin-top:12px">
            <label>@T["connectors.import.target_folder"]</label>
            <select id="targetFolder"><option>@T["connectors.loading"]</option></select>
        </div>
        <label style="display:flex;align-items:center;gap:6px;font-size:.9rem;margin-top:8px">
            <input type="checkbox" id="preserveStructure" checked/> @T["connectors.import.preserve_structure"]
        </label>

        <div class="row" style="gap:8px;margin-top:16px;justify-content:flex-end">
            <button class="btn btn-ghost" onclick="closeBrowse()">@T["modal.cancel"]</button>
            <button class="btn btn-primary" id="btnImport" onclick="doImport()" disabled>
                ⬇️ <span id="importLabel">@T["connectors.import.button"]</span>
            </button>
        </div>
    </div>
</div>

<script>
    const T_root = @Json.Serialize(T["connectors.browse.root"].Value);
    const T_folder = @Json.Serialize(T["connectors.browse.folder"].Value);
    const T_file = @Json.Serialize(T["connectors.browse.file"].Value);
    const T_confirm_delete = @Json.Serialize(T["connectors.confirm.delete"].Value);
    const T_running = @Json.Serialize(T["connectors.import.running"].Value);
    const T_done = @Json.Serialize(T["connectors.import.done"].Value);
    const T_error = @Json.Serialize(T["connectors.import.error"].Value);
    const T_selected_pattern = @Json.Serialize(T["connectors.import.selected"].Value);

    let currentConnector = null;
    let currentPath = [{ id: null, name: T_root }];
    const selected = new Set();

    async function loadConnectors() {
        const r = await fetch('/api/v1/connectors', { credentials: 'same-origin' });
        const items = r.ok ? await r.json() : [];
        const tb = document.querySelector('#connectorList tbody');
        if (!items.length) {
            tb.innerHTML = `<tr><td colspan="4" class="muted">@T["connectors.empty"]</td></tr>`;
            return;
        }
        tb.innerHTML = items.map(c => `
            <tr>
                <td><strong>${escapeHtml(c.displayName)}</strong></td>
                <td>${typeLabel(c.type)}</td>
                <td class="muted">${new Date(c.createdAt).toLocaleString()}</td>
                <td style="text-align:right">
                    <button class="btn btn-sm btn-secondary" onclick="openBrowse('${c.id}', '${escapeHtml(c.displayName)}', ${c.preserveFolderStructure})">📂 @T["connectors.action.browse"]</button>
                    <button class="btn btn-sm btn-ghost" onclick="disconnectConnector('${c.id}', '${escapeHtml(c.displayName)}')">✕ @T["connectors.action.disconnect"]</button>
                </td>
            </tr>
        `).join('');
    }

    function typeLabel(t) {
        if (t === 1 || t === 'OneDriveBusiness') return '☁️ OneDrive Business';
        return '?';
    }

    function escapeHtml(s) {
        return String(s).replace(/[&<>"']/g, ch => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[ch]));
    }

    async function disconnectConnector(id, name) {
        if (!confirm(T_confirm_delete.replace('{0}', name))) return;
        const r = await fetch(`/api/v1/connectors/${id}`, { method: 'DELETE', credentials: 'same-origin' });
        if (r.ok) loadConnectors();
        else alert('Fehler: HTTP ' + r.status);
    }

    async function openBrowse(id, name, preserveDefault) {
        currentConnector = id;
        document.getElementById('browseTitle').textContent = name;
        document.getElementById('preserveStructure').checked = preserveDefault;
        selected.clear();
        currentPath = [{ id: null, name: T_root }];
        await loadTargetFolders();
        document.getElementById('modalBrowse').classList.add('open');
        await browseTo(null, T_root);
    }

    function closeBrowse() {
        document.getElementById('modalBrowse').classList.remove('open');
        currentConnector = null;
    }

    async function loadTargetFolders() {
        const r = await fetch('/api/v1/folders/writable-all', { credentials: 'same-origin' });
        const folders = r.ok ? await r.json() : [];
        const sel = document.getElementById('targetFolder');
        sel.innerHTML = folders.map(f => `<option value="${f.id}">${escapeHtml(f.displayPath || f.name)}</option>`).join('');
    }

    async function browseTo(remoteFolderId, label) {
        // Breadcrumb-Update
        if (remoteFolderId === null) {
            currentPath = [{ id: null, name: T_root }];
        } else {
            const existing = currentPath.findIndex(p => p.id === remoteFolderId);
            if (existing >= 0) currentPath = currentPath.slice(0, existing + 1);
            else currentPath.push({ id: remoteFolderId, name: label });
        }
        renderBreadcrumb();
        const q = remoteFolderId ? `?remoteFolderId=${encodeURIComponent(remoteFolderId)}` : '';
        const r = await fetch(`/api/v1/connectors/${currentConnector}/browse${q}`, { credentials: 'same-origin' });
        if (!r.ok) {
            document.getElementById('browseList').innerHTML = `<p style="color:#c22">${T_error}: HTTP ${r.status}</p>`;
            return false;
        }
        const items = await r.json();
        renderBrowseList(items);
        return false;
    }

    function renderBreadcrumb() {
        const bc = document.getElementById('breadcrumb');
        bc.innerHTML = currentPath.map((p, i) => {
            if (i === currentPath.length - 1) return `<span>${escapeHtml(p.name)}</span>`;
            return `<a href="#" onclick="return browseTo('${p.id ?? ''}', '${escapeHtml(p.name)}')">${escapeHtml(p.name)}</a> ›`;
        }).join(' ');
    }

    function renderBrowseList(items) {
        const list = document.getElementById('browseList');
        if (!items.length) {
            list.innerHTML = `<p class="muted">@T["connectors.browse.empty"]</p>`;
            return;
        }
        list.innerHTML = items.map(it => `
            <div style="display:flex;align-items:center;gap:8px;padding:6px 4px;border-bottom:1px solid var(--tw-gray-100)">
                <input type="checkbox" id="sel_${it.id}" ${selected.has(it.id) ? 'checked' : ''} onchange="toggleSelect('${it.id}')"/>
                <span style="font-size:1.1rem">${it.isFolder ? '📁' : '📄'}</span>
                <label for="sel_${it.id}" style="flex:1;cursor:pointer">
                    ${it.isFolder
                        ? `<a href="#" onclick="return browseTo('${it.id}', '${escapeHtml(it.name)}')">${escapeHtml(it.name)}</a>`
                        : escapeHtml(it.name)}
                </label>
                ${!it.isFolder ? `<span class="muted" style="font-size:.8rem">${formatSize(it.sizeBytes)}</span>` : ''}
            </div>
        `).join('');
        updateImportBtn();
    }

    function toggleSelect(id) {
        if (selected.has(id)) selected.delete(id); else selected.add(id);
        updateImportBtn();
    }

    function updateImportBtn() {
        const btn = document.getElementById('btnImport');
        btn.disabled = selected.size === 0;
        document.getElementById('importLabel').textContent = T_selected_pattern.replace('{0}', selected.size);
    }

    function formatSize(n) {
        if (n < 1024) return n + ' B';
        if (n < 1024 * 1024) return (n / 1024).toFixed(1) + ' KB';
        if (n < 1024 * 1024 * 1024) return (n / 1024 / 1024).toFixed(1) + ' MB';
        return (n / 1024 / 1024 / 1024).toFixed(2) + ' GB';
    }

    async function doImport() {
        if (selected.size === 0) return;
        const target = document.getElementById('targetFolder').value;
        const preserve = document.getElementById('preserveStructure').checked;
        const btn = document.getElementById('btnImport');
        btn.disabled = true;
        btn.textContent = '⏳ ' + T_running;
        try {
            const r = await fetch(`/api/v1/connectors/${currentConnector}/import`, {
                method: 'POST', credentials: 'same-origin',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({
                    remoteItemIds: Array.from(selected),
                    targetFolderId: target,
                    preserveStructure: preserve,
                })
            });
            if (r.ok) {
                alert(T_done);
                closeBrowse();
            } else {
                const t = await r.text();
                alert(T_error + ': ' + t);
                btn.disabled = false;
                updateImportBtn();
            }
        } catch (e) {
            alert(T_error + ': ' + e);
            btn.disabled = false;
            updateImportBtn();
        }
    }

    loadConnectors();
</script>
