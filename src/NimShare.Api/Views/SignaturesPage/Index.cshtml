@model IEnumerable<NimShare.Core.Entities.SignatureRequest>
@{
    ViewData["Title"] = T["sig.title"];
    Layout = "_AppShell";
    var latestNote = (Dictionary<(Guid RequestId, Guid ParticipantId), string?>)(ViewData["LatestInviteNote"] ?? new Dictionary<(Guid, Guid), string?>());
    // v1.10.46: Drei Sektionen statt zwei. Marcus's Feedback: unter
    // "Abgeschlossen" sollte NUR Completed stehen, nicht auch abgelehnte /
    // abgebrochene Vorgänge — die verwirren, weil sie nicht "fertig
    // unterschrieben" sind. Aufteilung:
    //   🔄 In Bearbeitung: Draft + Sent
    //   ✅ Abgeschlossen: Completed
    //   ✕ Abgelehnt/Abgebrochen: Declined + Cancelled (eigene Sektion,
    //      kollabierbar denkbar, aber erstmal einfach unten)
    var activeList = Model.Where(r =>
        r.Status == NimShare.Core.Entities.SignatureRequestStatus.Draft
        || r.Status == NimShare.Core.Entities.SignatureRequestStatus.Sent)
        .OrderByDescending(r => r.CreatedAt).ToList();
    var doneList = Model.Where(r =>
        r.Status == NimShare.Core.Entities.SignatureRequestStatus.Completed)
        .OrderByDescending(r => r.CompletedAt ?? r.CreatedAt).ToList();
    var abandonedList = Model.Where(r =>
        r.Status == NimShare.Core.Entities.SignatureRequestStatus.Declined
        || r.Status == NimShare.Core.Entities.SignatureRequestStatus.Cancelled)
        .OrderByDescending(r => r.CompletedAt ?? r.CreatedAt).ToList();
}
<div class="page-header">
    <div>
        <h1>✍ @T["sig.title"]</h1>
        <p class="lede">@T["sig.lede"]</p>
    </div>
    <a class="btn btn-primary" href="/signatures/new">+ @T["sig.new_request"]</a>
</div>

@if (!Model.Any())
{
    <div class="fm-empty">
        <div class="fm-empty-art">✍</div>
        <div class="fm-empty-title">@T["sig.none.title"]</div>
        <div class="fm-empty-hint">@T["sig.none.body"]</div>
    </div>
}
else
{
    <h2 style="margin-top:0;font-size:1.05rem;color:var(--tw-muted-blue,#5a6b7f)">🔄 @T["sig.section.active"]</h2>
    @if (activeList.Count == 0)
    {
        <p class="muted" style="margin:8px 0 24px 0">@T["sig.none.body"]</p>
    }
    else
    {
        @await Html.PartialAsync("_SignatureTable", activeList, new ViewDataDictionary(ViewData) { ["LatestInviteNote"] = latestNote })
    }

    <h2 style="margin-top:32px;font-size:1.05rem;color:var(--tw-muted-blue,#5a6b7f)">✅ @T["sig.section.completed"]</h2>
    @if (doneList.Count == 0)
    {
        <p class="muted" style="margin:8px 0 24px 0">@T["sig.section.completed_empty"]</p>
    }
    else
    {
        @await Html.PartialAsync("_SignatureTable", doneList, new ViewDataDictionary(ViewData) { ["LatestInviteNote"] = latestNote })
    }

    @* v1.10.46: dritte Sektion — abgelehnte/abgebrochene Vorgänge, klar
       getrennt von "abgeschlossen" (Marcus's Feedback). Nur einblenden
       wenn's welche gibt — auf einer sauberen Übersicht kein leeres
       Section-Rauschen. *@
    @if (abandonedList.Count > 0)
    {
        <h2 style="margin-top:32px;font-size:1.05rem;color:var(--tw-muted-blue,#5a6b7f)">✕ @T["sig.section.abandoned"]</h2>
        @await Html.PartialAsync("_SignatureTable", abandonedList, new ViewDataDictionary(ViewData) { ["LatestInviteNote"] = latestNote })
    }
}

@section Scripts {
<script>
async function sigDelete(id) {
    if (!confirm(@Json.Serialize(T["sig.confirm_delete"].Value))) return;
    const r = await fetch('/api/v1/signatures/' + id, {
        method: 'DELETE', credentials: 'same-origin',
    });
    if (r.ok) location.reload();
    else alert('Fehler: ' + r.status + ' — ' + (await r.text()));
}

// v1.10.40: manueller Finalize-Trigger für gestrandete Vorgänge.
// Der Endpoint liefert ein strukturiertes JSON mit Diagnose (welche
// Beteiligten noch fehlen, oder eine Exception-Details wenn's beim
// Merge kracht). Wir zeigen dem User beides in Klartext.
async function sigFinalize(id) {
    const r = await fetch('/api/v1/signatures/' + id + '/finalize', {
        method: 'POST', credentials: 'same-origin',
        headers: { 'Accept': 'application/json' },
    });
    let d;
    try { d = await r.json(); } catch { d = null; }
    if (!r.ok || !d) {
        alert(@Json.Serialize(T["sig.finalize_failed"].Value) + '\n\n' +
            (d && d.detail ? d.detail : ('HTTP ' + r.status)));
        return;
    }
    if (d.status === 'Completed') {
        // Fertig — Seite neu laden, dann steht der Vorgang unten in
        // "Abgeschlossen" und der 📥-Button geht direkt aufs PDF.
        location.reload();
        return;
    }
    if (Array.isArray(d.pending) && d.pending.length > 0) {
        const lines = d.pending.map(p => `• ${p.name || p.email} (${p.role}) — ${p.status}`);
        alert(@Json.Serialize(T["sig.finalize_pending"].Value) + '\n\n' + lines.join('\n'));
        return;
    }
    alert(@Json.Serialize(T["sig.finalize_stuck"].Value) + '\n\n' + (d.note || ''));
}
</script>
}
