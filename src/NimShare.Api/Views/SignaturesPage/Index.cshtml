@model IEnumerable<NimShare.Core.Entities.SignatureRequest>
@{
    ViewData["Title"] = @T["sig.title"];
    Layout = "_AppShell";
    var latestNote = (Dictionary<(Guid RequestId, Guid ParticipantId), string?>)(ViewData["LatestInviteNote"] ?? new Dictionary<(Guid, Guid), string?>());
}
<div class="page-header">
    <div>
        <h1>✍ @T["sig.title"]</h1>
        <p class="lede">@T["sig.lede"]</p>
    </div>
    <a class="btn btn-primary" href="/signatures/new">+ @T["sig.new_request"]</a>
</div>

@if (!Model.Any())
{
    <div class="fm-empty">
        <div class="fm-empty-art">✍</div>
        <div class="fm-empty-title">@T["sig.none.title"]</div>
        <div class="fm-empty-hint">@T["sig.none.body"]</div>
    </div>
}
else
{
    <table class="table">
        <thead>
            <tr>
                <th>@T["sig.col.document"]</th>
                <th>@T["sig.col.recipients"]</th>
                <th>@T["sig.col.status"]</th>
                <th>@T["sig.col.created"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var r in Model)
        {
            var statusChip = r.Status switch
            {
                NimShare.Core.Entities.SignatureRequestStatus.Completed => ("chip-ok", @T["sig.status.completed"].Value),
                NimShare.Core.Entities.SignatureRequestStatus.Sent => ("chip-warn", @T["sig.status.sent"].Value),
                NimShare.Core.Entities.SignatureRequestStatus.Declined => ("chip-critical", @T["sig.status.declined"].Value),
                NimShare.Core.Entities.SignatureRequestStatus.Cancelled => ("chip", @T["sig.status.cancelled"].Value),
                _ => ("chip", @T["sig.status.draft"].Value),
            };
            var doneCount = r.Participants.Count(p =>
                p.Status == NimShare.Core.Entities.SignatureParticipantStatus.Signed
                || (p.Role == NimShare.Core.Entities.SignatureParticipantRole.Viewer && p.Status == NimShare.Core.Entities.SignatureParticipantStatus.Viewed));
            <tr>
                <td>@r.Title</td>
                <td>
                    @doneCount / @r.Participants.Count
                    @{
                        // Show per-participant email-delivery status inline —
                        // hover for the exact error text on failed rows.
                        var failed = new List<string>();
                        foreach (var p in r.Participants)
                        {
                            if (latestNote.TryGetValue((r.Id, p.Id), out var note)
                                && !string.IsNullOrEmpty(note)
                                && note.StartsWith("email-failed:"))
                            {
                                failed.Add($"{p.Name} ({p.Email}): {note["email-failed:".Length..].Trim()}");
                            }
                        }
                    }
                    @if (failed.Count > 0)
                    {
                        <span class="chip chip-critical" style="margin-left:4px;cursor:help"
                              title="@string.Join("\n", failed)">
                            ⚠ @T["sig.email_failed_short"]
                        </span>
                    }
                </td>
                <td><span class="chip @statusChip.Item1">@statusChip.Item2</span></td>
                <td class="muted">@r.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                <td>
                    <div class="row" style="gap:6px;justify-content:flex-end;flex-wrap:wrap">
                        @if (r.FinalFileId is Guid ff)
                        {
                            <a class="btn btn-secondary btn-sm" href="/browse/personal">📥 @T["sig.signed_pdf"]</a>
                        }
                        else
                        {
                            <a class="btn btn-ghost btn-sm" href="/signatures/@r.Id">@T["sig.detail.title"]</a>
                        }
                        <button class="btn btn-ghost btn-sm" onclick="sigDelete('@r.Id')" title="@T["actions.delete"]" style="color:var(--status-critical,#d33)">🗑</button>
                    </div>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@section Scripts {
<script>
async function sigDelete(id) {
    if (!confirm(@Json.Serialize(T["sig.confirm_delete"].Value))) return;
    const r = await fetch('/api/v1/signatures/' + id, {
        method: 'DELETE', credentials: 'same-origin',
    });
    if (r.ok) location.reload();
    else alert('Fehler: ' + r.status + ' — ' + (await r.text()));
}
</script>
}
