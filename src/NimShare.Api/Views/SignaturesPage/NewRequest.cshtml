@using NimShare.Core.Entities
@{
    ViewData["Title"] = T["sig.new.title"];
    Layout = "_AppShell";
    var pdfs = (List<StorageFile>)ViewData["Pdfs"]!;
    var preselectId = (Guid?)ViewData["PreselectFileId"];
}
<div class="page-header">
    <div>
        <a href="/signatures" class="muted" style="text-decoration:none">← @T["nav.signatures"]</a>
        <h1 style="margin-top:6px">✍ @T["sig.new_request"]</h1>
    </div>
</div>

<!-- Step 1: PDF + Metadaten -->
<div id="wizStep1" class="card"
    data-t-pick-pdf="@T["sig.new.err.pick_pdf"]"
    data-t-pdf-only="@T["sig.new.err.pdf_only"]"
    data-t-upload-init="@T["sig.new.err.upload_init"]"
    data-t-upload-finalize="@T["sig.new.err.upload_finalize"]"
    data-t-upload-prep="@T["sig.new.upload_prep"]"
    data-t-upload-running="@T["sig.new.upload_running"]"
    data-t-upload-processing="@T["sig.new.upload_processing"]"
    data-t-upload-done="@T["sig.new.upload_done"]"
    data-t-email-name="@T["sig.new.err.email_name"]"
    data-t-min-signer="@T["sig.new.err.min_signer"]"
    data-t-no-sigfield="@T["sig.new.err.no_sigfield_confirm"]"
    data-t-network="@T["sig.new.err.network"]"
    data-t-chip-signer="@T["sig.new.chip_signer"]"
    data-t-chip-viewer="@T["sig.new.chip_viewer"]"
    data-t-click-drag="@T["sig.new.click_drag_hint"]"
    data-t-page-of="@T["sig.new.page_of"]"
    data-t-error="@T["common.error"]">
    <h2 class="card-title">@T["sig.new.step1"]</h2>
    <div class="tabs" style="display:flex;gap:4px;border-bottom:1px solid var(--tw-gray-300);margin-bottom:12px">
        <button type="button" id="tabExisting" class="tab-btn active" onclick="switchTab('existing')" style="padding:8px 14px;background:none;border:0;border-bottom:2px solid var(--tw-blue);font-weight:500;cursor:pointer">@T["sig.new.tab_existing"]</button>
        <button type="button" id="tabUpload" class="tab-btn" onclick="switchTab('upload')" style="padding:8px 14px;background:none;border:0;border-bottom:2px solid transparent;font-weight:500;cursor:pointer;color:var(--tw-gray-600)">@T["sig.new.tab_upload"]</button>
    </div>
    <div id="paneExisting" class="field">
        <label>@T["sig.new.select_pdf"]</label>
        <select id="pdf">
            @if (!pdfs.Any())
            {
                <option value="">@T["sig.new.no_pdfs_hint"]</option>
            }
            @foreach (var f in pdfs)
            {
                var isSel = preselectId == f.Id;
                if (isSel)
                {
                    <option value="@f.Id" data-name="@f.Name" selected>@f.Name (@((f.SizeBytes / 1024).ToString("N0")) KB)</option>
                }
                else
                {
                    <option value="@f.Id" data-name="@f.Name">@f.Name (@((f.SizeBytes / 1024).ToString("N0")) KB)</option>
                }
            }
        </select>
        <div class="helper" style="margin-top:6px">@T["sig.new.hint_upload_tab"]</div>
    </div>
    <div id="paneUpload" class="field" style="display:none">
        <label>@T["sig.new.upload_pdf_label"]</label>
        <input type="file" id="uploadFile" accept="application/pdf,.pdf"/>
        <div class="helper" style="margin-top:6px">@T["sig.new.upload_hint"]</div>
        <div id="uploadProgress" class="muted" style="display:none;margin-top:6px">
            <span id="uploadStatus">@T["sig.new.upload_running"]</span>
            <div style="height:4px;background:var(--tw-gray-200);border-radius:2px;overflow:hidden;margin-top:4px">
                <div id="uploadBar" style="height:100%;width:0%;background:var(--tw-blue);transition:width 0.2s"></div>
            </div>
        </div>
    </div>
    <div class="field">
        <label>@T["sig.new.title_label"]</label>
        <input type="text" id="reqTitle" placeholder="@T["sig.new.title_placeholder"]"/>
    </div>
    <div class="field">
        <label>@T["sig.new.message_label"]</label>
        <textarea id="reqMsg" rows="2"></textarea>
    </div>
    <div class="field">
        <label style="display:flex;justify-content:space-between;align-items:center">
            <span>✉ @T["sig.new.email_template"]</span>
            <a href="/signatures/templates" target="_blank" class="muted" style="font-size:.85rem">@T["sig.new.manage_templates"] →</a>
        </label>
        <select id="templateId">
            <option value="">— @T["sig.new.default_template"] —</option>
        </select>
        <div class="helper" style="margin-top:6px">@T["sig.new.template_hint"]</div>
    </div>
    <div class="row" style="justify-content:flex-end">
        <button class="btn btn-primary" onclick="goStep2()">@T["sig.new.next"]</button>
    </div>
</div>

<!-- Step 2: Teilnehmer -->
<div id="wizStep2" class="card" style="display:none">
    <h2 class="card-title">@T["sig.new.step2"]</h2>
    <p class="muted">@T["sig.new.step2_lede"]</p>
    <div id="pList" style="display:flex;flex-direction:column;gap:6px;margin:12px 0"></div>
    <div class="row" style="gap:6px;flex-wrap:wrap">
        <div style="flex:1;min-width:200px;position:relative">
            <input type="email" id="pEmail" placeholder="@T["sig.new.email_ph"]" list="contactsList" style="width:100%" autocomplete="off"/>
            <datalist id="contactsList"></datalist>
        </div>
        <input type="text" id="pName" placeholder="@T["sig.new.name_ph"]" style="flex:1;min-width:180px"/>
        <select id="pRole">
            <option value="Signer">@T["sig.new.role_signer"]</option>
            <option value="Viewer">@T["sig.new.role_viewer"]</option>
        </select>
        <button class="btn btn-secondary" onclick="addP()">+</button>
    </div>
    <div class="row" style="justify-content:space-between;margin-top:16px">
        <button class="btn btn-ghost" onclick="show(1)">← @T["common.back"]</button>
        <button class="btn btn-primary" onclick="goStep3()">@T["sig.new.next_fields"]</button>
    </div>
</div>

<!-- Step 3: Visual field placement -->
<div id="wizStep3" class="card" style="display:none">
    <h2 class="card-title">@T["sig.new.step3"]</h2>
    <p class="muted">@T["sig.new.step3_lede"]</p>
    <div id="fieldSummary" style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px"></div>
    <div class="row" style="gap:8px;flex-wrap:wrap;align-items:center;margin-bottom:8px">
        <label>@T["sig.new.for_label"]</label>
        <select id="fParticipant" onchange="updateFieldSummary()"></select>
        <label>@T["sig.new.type_label"]</label>
        <select id="fType">
            <option value="Signature">@T["sig.new.type_signature"]</option>
            <option value="Text">@T["sig.new.type_text"]</option>
            <option value="Date">@T["sig.new.type_date"]</option>
            <option value="Checkbox">@T["sig.new.type_checkbox"]</option>
        </select>
        <span class="muted" style="margin-left:auto" id="pageInfo"></span>
    </div>
    <div id="pdfWrap" style="border:1px solid var(--tw-gray-300);border-radius:6px;overflow:hidden;background:#eee;user-select:none;position:relative"></div>
    <div class="row" style="gap:6px;margin-top:8px;justify-content:center">
        <button class="btn btn-ghost btn-sm" onclick="prevPage()">◀</button>
        <span id="pgLabel" class="muted"></span>
        <button class="btn btn-ghost btn-sm" onclick="nextPage()">▶</button>
    </div>
    <div class="row" style="justify-content:space-between;margin-top:16px">
        <button class="btn btn-ghost" onclick="show(2)">← @T["common.back"]</button>
        <button class="btn btn-primary" onclick="sendReq()">@T["sig.new.send"]</button>
    </div>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs" type="module"></script>
<script type="module">
import * as pdfjsLib from "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs";
pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs";
window.pdfjsLib = pdfjsLib;
</script>
<script>
const T = document.getElementById('wizStep1').dataset;
let requestId = null;
let participants = [];
let fields = [];
let pdfDoc = null;
let curPage = 1;
let pageViewport = null;

// Load email templates + contacts on page open so the dropdowns are ready.
(async () => {
    try {
        const tpls = await fetch('/api/v1/email-templates?kind=SignatureInvite', { credentials: 'same-origin' }).then(r => r.json());
        const sel = document.getElementById('templateId');
        for (const t of tpls) {
            const o = document.createElement('option');
            o.value = t.id;
            o.textContent = t.name + ' (' + t.locale + ')' + (t.isDefault ? ' ★' : '');
            if (t.isDefault) o.selected = true;
            sel.appendChild(o);
        }
    } catch {}
    try {
        const contacts = await fetch('/api/v1/contacts?limit=200', { credentials: 'same-origin' }).then(r => r.json());
        const dl = document.getElementById('contactsList');
        for (const c of contacts) {
            const o = document.createElement('option');
            o.value = c.email;
            o.label = c.name + (c.company ? ' — ' + c.company : '');
            dl.appendChild(o);
        }
        // When user picks an email from the datalist, auto-fill the name field.
        window.__contactByEmail = new Map(contacts.map(c => [c.email, c.name]));
    } catch {}
})();

document.addEventListener('DOMContentLoaded', () => {
    const emailEl = document.getElementById('pEmail');
    if (!emailEl) return;
    emailEl.addEventListener('change', () => {
        const map = window.__contactByEmail;
        if (!map) return;
        const name = map.get(emailEl.value.trim().toLowerCase()) || map.get(emailEl.value.trim());
        const nameEl = document.getElementById('pName');
        if (name && !nameEl.value) nameEl.value = name;
    });
});

function show(n) {
    for (const i of [1,2,3]) document.getElementById('wizStep' + i).style.display = i === n ? '' : 'none';
}

let uploadMode = 'existing';
function switchTab(m) {
    uploadMode = m;
    document.getElementById('paneExisting').style.display = m === 'existing' ? '' : 'none';
    document.getElementById('paneUpload').style.display = m === 'upload' ? '' : 'none';
    for (const [id, tab] of [['tabExisting','existing'],['tabUpload','upload']]) {
        const el = document.getElementById(id);
        el.style.borderBottomColor = m === tab ? 'var(--tw-blue)' : 'transparent';
        el.style.color = m === tab ? '' : 'var(--tw-gray-600)';
    }
}

async function ensureUploadedSourceId() {
    if (uploadMode === 'existing') {
        const sel = document.getElementById('pdf');
        if (!sel.value) { alert(T.tPickPdf); return null; }
        return sel.value;
    }
    const f = document.getElementById('uploadFile').files[0];
    if (!f) { alert(T.tPickPdf); return null; }
    if (!f.name.toLowerCase().endsWith('.pdf') && f.type !== 'application/pdf') {
        alert(T.tPdfOnly); return null;
    }
    document.getElementById('uploadProgress').style.display = '';
    document.getElementById('uploadStatus').textContent = T.tUploadPrep;
    document.getElementById('uploadBar').style.width = '10%';

    const init = await fetch('/api/v1/signatures/upload-source', {
        method:'POST', headers:{'Content-Type':'application/json'}, credentials:'same-origin',
        body: JSON.stringify({ name: f.name, sizeBytes: f.size, contentType: 'application/pdf' })
    });
    if (!init.ok) { alert(T.tUploadInit + await init.text()); return null; }
    const iData = await init.json();

    document.getElementById('uploadStatus').textContent = T.tUploadRunning;
    await new Promise((res, rej) => {
        const xhr = new XMLHttpRequest();
        xhr.open(iData.uploadMethod || 'PUT', iData.uploadUrl, true);
        xhr.setRequestHeader('x-ms-blob-type', 'BlockBlob');
        xhr.setRequestHeader('Content-Type', 'application/pdf');
        xhr.upload.onprogress = e => {
            if (e.lengthComputable) {
                const pct = 10 + Math.round(80 * e.loaded / e.total);
                document.getElementById('uploadBar').style.width = pct + '%';
            }
        };
        xhr.onload = () => xhr.status >= 200 && xhr.status < 300 ? res() : rej(new Error('HTTP ' + xhr.status));
        xhr.onerror = () => rej(new Error(T.tNetwork));
        xhr.send(f);
    });

    document.getElementById('uploadStatus').textContent = T.tUploadProcessing;
    document.getElementById('uploadBar').style.width = '95%';
    const done = await fetch('/api/v1/files/' + iData.fileId + '/complete', {
        method:'POST', credentials:'same-origin',
    });
    if (!done.ok) { alert(T.tUploadFinalize); return null; }
    document.getElementById('uploadBar').style.width = '100%';
    document.getElementById('uploadStatus').textContent = T.tUploadDone;
    return iData.fileId;
}

async function goStep2() {
    // If we already POSTed a draft in this session, skip re-creating it —
    // otherwise a Back → Next in the wizard would spam the DB with orphaned
    // draft rows and leak the participants across them.
    if (requestId) { show(2); return; }
    const sourceId = await ensureUploadedSourceId();
    if (!sourceId) return;
    const r = await fetch('/api/v1/signatures', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials:'same-origin',
        body: JSON.stringify({
            sourceFileId: sourceId,
            title: document.getElementById('reqTitle').value || null,
            message: document.getElementById('reqMsg').value || null,
            deliveryOrder: 'Parallel',
        })
    });
    if (!r.ok) { alert(T.tError + ': ' + r.status); return; }
    const d = await r.json();
    requestId = d.id;
    show(2);
}

async function addP() {
    const email = document.getElementById('pEmail').value.trim();
    const name = document.getElementById('pName').value.trim();
    const role = document.getElementById('pRole').value;
    if (!email || !name) { alert(T.tEmailName); return; }
    const r = await fetch('/api/v1/signatures/' + requestId + '/participants', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials:'same-origin',
        body: JSON.stringify({ email, name, role, order: participants.length }),
    });
    if (!r.ok) return alert(T.tError + ': ' + r.status);
    const p = await r.json();
    participants.push({ id: p.id, email, name, role });
    document.getElementById('pEmail').value = '';
    document.getElementById('pName').value = '';
    renderPList();
}

function esc(s){return String(s??'').replace(/[<>&"']/g,c=>({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c]))}

function renderPList() {
    document.getElementById('pList').innerHTML = participants.map(p =>
        `<div style="display:flex;align-items:center;gap:8px;padding:6px 10px;background:var(--tw-gray-100);border-radius:6px">
            <span style="flex:1">${p.role === 'Signer' ? '✍' : '👁'} <strong>${esc(p.name)}</strong> · ${esc(p.email)}</span>
            <span class="chip">${p.role === 'Signer' ? T.tChipSigner : T.tChipViewer}</span>
        </div>`).join('');
    const fp = document.getElementById('fParticipant');
    fp.innerHTML = participants.filter(p => p.role === 'Signer' || document.getElementById('fType').value !== 'Signature')
        .map(p => `<option value="${p.id}">${esc(p.name)}</option>`).join('');
}

async function goStep3() {
    if (participants.filter(p => p.role === 'Signer').length === 0) return alert(T.tMinSigner);
    show(3);
    const src = '/api/v1/signatures/' + requestId + '/source-pdf';
    pdfDoc = await pdfjsLib.getDocument(src).promise;
    curPage = 1;
    await renderPage();
}

async function renderPage() {
    document.getElementById('pgLabel').textContent = T.tPageOf.replace('{0}', curPage).replace('{1}', pdfDoc.numPages);
    document.getElementById('pageInfo').textContent = T.tClickDrag.replace('{0}', curPage);
    const page = await pdfDoc.getPage(curPage);
    const viewport = page.getViewport({ scale: 1.4 });
    pageViewport = viewport;
    const wrap = document.getElementById('pdfWrap');
    wrap.innerHTML = '';
    const canvas = document.createElement('canvas');
    canvas.width = viewport.width; canvas.height = viewport.height;
    canvas.style.display = 'block'; canvas.style.margin = '0 auto';
    wrap.appendChild(canvas);
    const overlay = document.createElement('div');
    overlay.style.cssText = `position:absolute;left:0;top:0;width:${viewport.width}px;height:${viewport.height}px;margin:auto;cursor:crosshair`;
    overlay.id = 'ovl';
    wrap.appendChild(overlay);
    wrap.style.height = viewport.height + 'px';
    overlay.style.left = ((wrap.clientWidth - viewport.width) / 2) + 'px';
    await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;
    setupDrag(overlay);
    redrawFields(overlay);
}

function setupDrag(overlay) {
    let start = null, box = null;

    // Convert mouse OR touch/pointer event to overlay-relative coords.
    function coords(e) {
        const rect = overlay.getBoundingClientRect();
        const cx = e.touches ? e.touches[0].clientX : e.clientX;
        const cy = e.touches ? e.touches[0].clientY : e.clientY;
        return { x: cx - rect.left, y: cy - rect.top };
    }

    function begin(e) {
        e.preventDefault();
        const c = coords(e);
        start = c;
        box = document.createElement('div');
        box.style.cssText = 'position:absolute;border:2px dashed #002854;background:rgba(0,160,251,.12);touch-action:none';
        overlay.appendChild(box);
    }
    function move(e) {
        if (!start) return;
        e.preventDefault();
        const c = coords(e);
        const x = Math.min(start.x, c.x), y = Math.min(start.y, c.y);
        const w = Math.abs(c.x - start.x), h = Math.abs(c.y - start.y);
        Object.assign(box.style, { left: x + 'px', top: y + 'px', width: w + 'px', height: h + 'px' });
    }
    async function end(e) {
        if (!start) return;
        e.preventDefault();
        // Use last known coords (touch has no coords on touchend).
        const c = e.changedTouches ? { x: e.changedTouches[0].clientX - overlay.getBoundingClientRect().left,
                                       y: e.changedTouches[0].clientY - overlay.getBoundingClientRect().top }
                                    : coords(e);
        const x = Math.min(start.x, c.x), y = Math.min(start.y, c.y);
        const w = Math.abs(c.x - start.x), h = Math.abs(c.y - start.y);
        start = null;
        if (w < 20 || h < 15) { box.remove(); return; }
        const pdfX = x / pageViewport.scale;
        const pdfY = (pageViewport.height - (y + h)) / pageViewport.scale;
        const pdfW = w / pageViewport.scale, pdfH = h / pageViewport.scale;
        const participantId = document.getElementById('fParticipant').value;
        const type = document.getElementById('fType').value;
        // Only 1 signature field per signer makes sense — a person doesn't sign
        // in two spots. Warn (not block) so power-users can still add multiple
        // for edge cases (initials + full signature).
        if (type === 'Signature'
            && fields.some(f => f.participantId === participantId && f.type === 'Signature')) {
            const p = participants.find(x => x.id === participantId);
            if (!await nimConfirm((T.tDuplicateSigField || 'Es gibt bereits ein Signaturfeld für {0}. Trotzdem hinzufügen?').replace('{0}', p ? p.name : '?'))) {
                box.remove(); return;
            }
        }
        const r = await fetch('/api/v1/signatures/' + requestId + '/fields', {
            method: 'POST', headers: {'Content-Type':'application/json'}, credentials:'same-origin',
            body: JSON.stringify({ participantId, type, page: curPage, anchor: 'BottomCenter',
                x: pdfX, y: pdfY, width: pdfW, height: pdfH })
        });
        if (!r.ok) { alert(T.tError + ': ' + r.status); box.remove(); return; }
        const d = await r.json();
        fields.push({ id: d.id, participantId, type, page: curPage, x, y, w, h });
        styleField(box, type, participantId);
        // Delete affordance: visible × button on top-right + tap/right-click.
        const del = document.createElement('button');
        del.type = 'button';
        del.textContent = '×';
        del.style.cssText = 'position:absolute;top:-10px;right:-10px;width:22px;height:22px;border-radius:50%;background:#c22;color:#fff;border:0;font-size:16px;line-height:1;cursor:pointer;padding:0;box-shadow:0 1px 3px rgba(0,0,0,.3);z-index:2';
        del.addEventListener('click', async ev => {
            ev.preventDefault(); ev.stopPropagation();
            const idx = fields.findIndex(x => x.id === d.id);
            if (idx >= 0) {
                await fetch('/api/v1/signatures/' + requestId + '/fields/' + d.id, {
                    method: 'DELETE', credentials: 'same-origin'
                });
                fields.splice(idx, 1);
            }
            box.remove();
            updateFieldSummary();
        });
        box.appendChild(del);
        box.addEventListener('contextmenu', ev => { ev.preventDefault(); del.click(); });
        updateFieldSummary();
    }

    // Colour rotation so each participant's fields are visually distinct on
    // the PDF — solves "wer gehört zu welchem Feld".
    const PALETTE = [
        { border: '#002854', bg: 'rgba(0,40,84,.14)', fg: '#002854' },   // Tungsten blue
        { border: '#c53030', bg: 'rgba(197,48,48,.12)', fg: '#c53030' },  // red
        { border: '#2f855a', bg: 'rgba(47,133,90,.12)', fg: '#2f855a' },  // green
        { border: '#805ad5', bg: 'rgba(128,90,213,.14)', fg: '#805ad5' },  // purple
        { border: '#d69e2e', bg: 'rgba(214,158,46,.14)', fg: '#8a5a00' },  // amber
        { border: '#0987a0', bg: 'rgba(9,135,160,.14)', fg: '#0987a0' },   // teal
    ];
    function colorFor(participantId) {
        const idx = Math.max(0, participants.findIndex(p => p.id === participantId));
        return PALETTE[idx % PALETTE.length];
    }
    function styleField(box, type, participantId) {
        const col = colorFor(participantId);
        const p = participants.find(x => x.id === participantId);
        const icon = type === 'Signature' ? '✍' : (type === 'Text' ? 'T' : (type === 'Date' ? '📅' : '☑'));
        box.style.borderStyle = 'solid';
        box.style.borderColor = col.border;
        box.style.background = col.bg;
        box.style.color = col.fg;
        box.style.fontWeight = '700';
        box.style.display = 'flex';
        box.style.alignItems = 'center';
        box.style.justifyContent = 'center';
        box.style.fontSize = '.75rem';
        box.style.textAlign = 'center';
        box.style.lineHeight = '1.1';
        box.style.padding = '2px 4px';
        box.textContent = ''; // reset — we're rebuilding with icon + name
        const label = document.createElement('div');
        label.innerHTML = `<div style="font-size:1.15rem">${icon}</div><div style="font-size:.65rem;font-weight:600;opacity:.85">${esc((p && p.name) || '?')}</div>`;
        box.appendChild(label);
    }

    overlay.addEventListener('mousedown', begin);
    overlay.addEventListener('mousemove', move);
    overlay.addEventListener('mouseup', end);
    overlay.addEventListener('touchstart', begin, { passive: false });
    overlay.addEventListener('touchmove', move, { passive: false });
    overlay.addEventListener('touchend', end, { passive: false });
}

function redrawFields(overlay) {
    for (const f of fields.filter(x => x.page === curPage)) {
        const b = document.createElement('div');
        b.style.cssText = `position:absolute;left:${f.x}px;top:${f.y}px;width:${f.w}px;height:${f.h}px;border:2px solid #002854`;
        styleField(b, f.type, f.participantId);
        overlay.appendChild(b);
    }
    updateFieldSummary();
}

// Live "who has how many fields" summary above the PDF so you know what's
// still missing without scrolling every page.
function updateFieldSummary() {
    const el = document.getElementById('fieldSummary');
    if (!el) return;
    if (!participants.length) { el.innerHTML = ''; return; }
    const parts = participants.map(p => {
        const sigCount = fields.filter(f => f.participantId === p.id && f.type === 'Signature').length;
        const otherCount = fields.filter(f => f.participantId === p.id && f.type !== 'Signature').length;
        const col = colorFor(p.id);
        const badge = p.role === 'Signer'
            ? (sigCount > 0 ? `✍ ${sigCount}` : '⚠ ' + (T.tNoSigYet || 'kein Feld'))
            : '👁';
        return `<span style="display:inline-flex;align-items:center;gap:4px;padding:3px 8px;border-radius:12px;border:1.5px solid ${col.border};background:${col.bg};color:${col.fg};font-size:.78rem;font-weight:600">${badge} ${esc(p.name)}${otherCount ? ` <span style="opacity:.7">+${otherCount}</span>` : ''}</span>`;
    }).join(' ');
    el.innerHTML = parts;
}

function prevPage() { if (curPage > 1) { curPage--; renderPage(); } }
function nextPage() { if (curPage < pdfDoc.numPages) { curPage++; renderPage(); } }

async function sendReq() {
    if (fields.filter(f => f.type === 'Signature').length === 0) {
        if (!await nimConfirm(T.tNoSigfield, { danger: true })) return;
    }
    const tpl = document.getElementById('templateId').value;
    const r = await fetch('/api/v1/signatures/' + requestId + '/send' + (tpl ? '?templateId=' + encodeURIComponent(tpl) : ''), {
        method: 'POST', credentials: 'same-origin',
    });
    if (!r.ok) { alert(T.tError + ': ' + r.status + ' ' + await r.text()); return; }
    // Show per-recipient email-delivery status before navigating away —
    // the wizard is the LAST chance to warn "email failed to X".
    try {
        const d = await r.json();
        if (Array.isArray(d.delivery)) {
            const failed = d.delivery.filter(x => !x.ok);
            if (failed.length > 0) {
                const lines = failed.map(x => `• ${x.name} (${x.email}): ${x.error}`).join('\n');
                alert(
                    (@Json.Serialize(@T["sig.new.send.email_failed_prefix"].Value)) +
                    '\n\n' + lines +
                    '\n\n' + (@Json.Serialize(@T["sig.new.send.check_email_gateway"].Value))
                );
            }
        }
    } catch {}
    location.href = '/signatures';
}

document.getElementById('fType').addEventListener('change', renderPList);
</script>
