@{
    ViewData["Title"] = "Support — NimShare";
    Layout = "_AppShell";
}
@* T kommt bereits aus _ViewImports.cshtml — kein zweiter @inject. *@

<div class="card" style="max-width:820px;margin:0 auto">
    <h1>@T["support.title"]</h1>
    <p>@T["support.intro"]</p>

    <h2>@T["support.contact.title"]</h2>
    <p>@Html.Raw(@T["support.contact.body"].Value)</p>

    <h2>@T["support.faq.title"]</h2>

    <details style="margin:12px 0">
        <summary style="cursor:pointer;font-weight:600">@T["support.faq.reset_password.q"]</summary>
        <p style="margin-top:8px">@T["support.faq.reset_password.a"]</p>
    </details>

    <details style="margin:12px 0">
        <summary style="cursor:pointer;font-weight:600">@T["support.faq.delete_account.q"]</summary>
        <p style="margin-top:8px">@T["support.faq.delete_account.a"]</p>
    </details>

    <details style="margin:12px 0">
        <summary style="cursor:pointer;font-weight:600">@T["support.faq.2fa.q"]</summary>
        <p style="margin-top:8px">@T["support.faq.2fa.a"]</p>
    </details>

    <details style="margin:12px 0">
        <summary style="cursor:pointer;font-weight:600">@T["support.faq.share_link.q"]</summary>
        <p style="margin-top:8px">@T["support.faq.share_link.a"]</p>
    </details>

    <details style="margin:12px 0">
        <summary style="cursor:pointer;font-weight:600">@T["support.faq.report_block.q"]</summary>
        <p style="margin-top:8px">@T["support.faq.report_block.a"]</p>
    </details>

    <details style="margin:12px 0">
        <summary style="cursor:pointer;font-weight:600">@T["support.faq.signature.q"]</summary>
        <p style="margin-top:8px">@T["support.faq.signature.a"]</p>
    </details>

    <hr>
    <p class="muted" style="font-size:.85rem">
        <a href="/privacy">@T["nav.privacy"]</a> ·
        <a href="/imprint">@T["nav.imprint"]</a>
    </p>
</div>
