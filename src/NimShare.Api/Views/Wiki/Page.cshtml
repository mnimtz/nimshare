@model NimShare.Core.Entities.WikiPage
@{
    ViewData["Title"] = Model.Title;
    Layout = "_AppShell";
    var html = (string)(ViewData["HTML"] ?? "");
    var siblings = (List<NimShare.Core.Entities.WikiPage>)(ViewData["Siblings"] ?? new List<NimShare.Core.Entities.WikiPage>());
    var canWrite = (bool)(ViewData["CanWrite"] ?? false);
}
<div class="page-header">
    <div>
        <a href="/wiki" class="muted" style="text-decoration:none">← @T["wiki.title"]</a>
        <h1 style="margin-top:6px">📄 @Model.Title</h1>
        <p class="muted" style="font-size:.85rem">@string.Format(@T["wiki.last_edited"].Value, Model.UpdatedAt.ToString("yyyy-MM-dd HH:mm"), Model.LastEditedByUser?.DisplayName ?? "")</p>
    </div>
    @if (canWrite)
    {
        <div class="row" style="gap:6px">
            <button class="btn btn-secondary" onclick="toggleEdit()">✎ @T["common.edit"]</button>
            <form method="post" action="/api/v1/wiki/pages/@Model.Id" style="display:inline">
                <button type="button" class="btn btn-ghost" style="color:var(--status-critical)" onclick="delPage()">🗑 @T["common.delete"]</button>
            </form>
        </div>
    }
</div>

<div class="row" style="gap:16px;align-items:flex-start;flex-wrap:wrap">
    <aside class="card" style="flex:1;min-width:220px">
        <div class="muted" style="font-size:.75rem;text-transform:uppercase;letter-spacing:.06em;margin-bottom:6px">@T["wiki.page.pages_heading"]</div>
        <div style="display:flex;flex-direction:column;gap:2px">
        @foreach (var s in siblings)
        {
            <a href="/wiki/@s.Id" style="padding:5px 8px;text-decoration:none;color:@(s.Id == Model.Id ? "var(--tw-primary-alt)" : "var(--tw-primary)");background:@(s.Id == Model.Id ? "rgba(0,160,251,.12)" : "transparent");border-radius:4px;font-weight:@(s.Id == Model.Id ? "600" : "400")">📄 @s.Title</a>
        }
        </div>
    </aside>

    <main class="card" style="flex:3;min-width:320px" id="pageContent">
        <div id="viewMode" class="wiki-body">@Html.Raw(html)</div>
        <div id="editMode" style="display:none">
            <div class="field">
                <label>@T["wiki.page.title_label"]</label>
                <input type="text" id="editTitle" value="@Model.Title"/>
            </div>
            <div class="field">
                <label>@T["wiki.page.content_label"]</label>
                <textarea id="editContent" rows="20" style="font-family:var(--font-mono);font-size:.9rem">@Model.ContentMarkdown</textarea>
            </div>
            <div class="actions">
                <button class="btn btn-ghost" onclick="toggleEdit()">@T["common.cancel"]</button>
                <button class="btn btn-primary" onclick="save()">💾 @T["common.save"]</button>
            </div>
        </div>
    </main>
</div>

<style>
.wiki-body { line-height: 1.7; }
.wiki-body h1 { margin-top: 0; }
.wiki-body h2 { margin-top: 24px; border-bottom: 1px solid var(--tw-gray-200); padding-bottom: 4px; }
.wiki-body pre { background: var(--tw-gray-100); padding: 12px; border-radius: 6px; overflow-x: auto; font-family: var(--font-mono); font-size: .88rem; }
.wiki-body code { background: var(--tw-gray-100); padding: 1px 4px; border-radius: 3px; font-family: var(--font-mono); font-size: .88rem; }
.wiki-body blockquote { border-left: 3px solid var(--tw-gray-300); padding-left: 12px; color: var(--tw-muted-blue); }
</style>

<script>
let originalTitle = @Json.Serialize(Model.Title);
let originalBody  = @Json.Serialize(Model.ContentMarkdown ?? "");
function isDirty() {
    const t = document.getElementById('editTitle');
    const c = document.getElementById('editContent');
    if (!t || !c) return false;
    return t.value !== originalTitle || c.value !== originalBody;
}
// Warn on page navigation while unsaved changes are in the editor.
window.addEventListener('beforeunload', ev => {
    if (isDirty()) { ev.preventDefault(); ev.returnValue = ''; }
});
function toggleEdit() {
    const v = document.getElementById('viewMode'), e = document.getElementById('editMode');
    const showEdit = v.style.display !== 'none';
    // Leaving edit mode with unsaved changes → confirm.
    if (!showEdit && isDirty()) {
        const msg = @Json.Serialize(@T["wiki.page.confirm_discard"].Value);
        if (!confirm(msg)) return;
        // Discard: reset the textarea state so beforeunload no longer fires.
        document.getElementById('editTitle').value = originalTitle;
        document.getElementById('editContent').value = originalBody;
    }
    v.style.display = showEdit ? 'none' : '';
    e.style.display = showEdit ? '' : 'none';
}
async function save() {
    const r = await fetch('/api/v1/wiki/pages/@Model.Id', {
        method: 'PATCH',
        headers: {'Content-Type':'application/json'},
        credentials: 'same-origin',
        body: JSON.stringify({
            title: document.getElementById('editTitle').value,
            contentMarkdown: document.getElementById('editContent').value,
        })
    });
    if (!r.ok) { alert(@Json.Serialize(@T["common.error"].Value) + ': ' + r.status); return; }
    // Clear the dirty state so beforeunload doesn't block the reload.
    originalTitle = document.getElementById('editTitle').value;
    originalBody = document.getElementById('editContent').value;
    location.reload();
}
async function delPage() {
    if (!confirm(@Json.Serialize(@T["wiki.page.confirm_delete"].Value))) return;
    const r = await fetch('/api/v1/wiki/pages/@Model.Id', {
        method: 'DELETE', credentials: 'same-origin'
    });
    if (r.ok) location.href = '/wiki';
    else alert(@Json.Serialize(@T["common.error"].Value) + ': ' + r.status);
}
</script>
