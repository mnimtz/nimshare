@model IEnumerable<NimShare.Core.Entities.StorageFile>
@{ ViewData["Title"] = T["dashboard.title"]; Layout = "_AppShell"; }
@{
    var usedBytes = (long)ViewData["UsedBytes"]!;
    var quotaBytes = (long)ViewData["QuotaBytes"]!;
    var pct = quotaBytes > 0 ? Math.Min(100, (double)usedBytes / quotaBytes * 100) : 0;
    string Bytes(long b)
    {
        string[] u = { "B","KB","MB","GB","TB" };
        double v = b; int i = 0;
        while (v >= 1024 && i < u.Length - 1) { v /= 1024; i++; }
        return $"{v:0.##} {u[i]}";
    }
}
<div class="workspace-inner">
    <div class="page-header">
        <div>
            <h1>@T["dashboard.greeting"], @ViewData["UserName"]</h1>
            <p class="lede">@T["dashboard.lede"]</p>
        </div>
        <a class="btn btn-primary" href="/upload">@T["dashboard.new_upload"]</a>
    </div>

    <div class="row" style="gap:var(--sp-6);align-items:stretch">
        <div class="card" style="flex:1;min-width:220px">
            <div class="muted">@T["dashboard.stat.files"]</div>
            <div style="font-size:1.9rem;font-weight:700;color:var(--tw-primary)">@ViewData["FileCount"]</div>
        </div>
        <div class="card" style="flex:1;min-width:220px">
            <div class="muted">@T["dashboard.stat.links"]</div>
            <div style="font-size:1.9rem;font-weight:700;color:var(--tw-primary)">@ViewData["LinkCount"]</div>
        </div>
        <div class="card" style="flex:2;min-width:280px">
            <div class="muted">@T["dashboard.stat.usage"]</div>
            <div style="font-size:1rem;color:var(--tw-primary);margin-bottom:6px">
                @Bytes(usedBytes) / @Bytes(quotaBytes)
            </div>
            <div style="height:8px;background:var(--tw-gray-200);border-radius:4px;overflow:hidden">
                <div style="height:100%;width:@pct.ToString("0")%;background:var(--pillar-gradient-h)"></div>
            </div>
        </div>
    </div>

    <div class="card" style="margin-top:var(--sp-8)">
        <h2 class="card-title">@T["dashboard.recent_files"]</h2>
        @if (!Model.Any())
        {
            <p class="muted">@T["dashboard.no_files"]</p>
        }
        else
        {
            <table class="table">
                <thead>
                <tr>
                    <th>@T["file.name"]</th>
                    <th>@T["file.size"]</th>
                    <th>@T["file.type"]</th>
                    <th>@T["file.uploaded"]</th>
                    <th></th>
                </tr>
                </thead>
                <tbody>
                @foreach (var f in Model)
                {
                    <tr>
                        <td>@f.Name</td>
                        <td>@Bytes(f.SizeBytes)</td>
                        <td class="muted mono">@f.ContentType</td>
                        <td class="muted">@f.CreatedAt.ToString("u")</td>
                        <td>
                            <button type="button" class="btn btn-ghost btn-sm" data-id="@f.Id" data-name="@f.Name" onclick="quickShare(this.dataset.id, this.dataset.name)">@T["file.share"]</button>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>
</div>

<dialog id="quickShareDlg" style="border:0;border-radius:12px;padding:0;max-width:520px;width:92%"
    data-heading="@T["dashboard.share.heading"]"
    data-title-prefix="@T["dashboard.share.title_prefix"]"
    data-busy="@T["dashboard.share.busy"]"
    data-copy="@T["common.copy"]"
    data-copied="@T["common.copied"]"
    data-manage="@T["dashboard.share.manage"]"
    data-close="@T["common.close"]"
    data-error="@T["common.error"]">
    <div style="padding:20px">
        <h3 style="margin-top:0" id="qsTitle">@T["dashboard.share.heading"]</h3>
        <div id="qsBusy" class="muted">@T["dashboard.share.busy"]</div>
        <div id="qsResult" style="display:none">
            <div class="field">
                <label>@T["dashboard.share.link_label"]</label>
                <input type="text" id="qsUrl" readonly style="font-family:monospace;font-size:13px" onclick="this.select()"/>
            </div>
            <div class="actions" style="gap:8px">
                <button class="btn btn-primary" id="qsCopy">📋 @T["common.copy"]</button>
                <a class="btn" id="qsManage" href="/links">@T["dashboard.share.manage"]</a>
                <button type="button" class="btn btn-ghost" onclick="document.getElementById('quickShareDlg').close()">@T["common.close"]</button>
            </div>
        </div>
        <div id="qsError" style="display:none;color:var(--tw-danger,#c00);margin-top:10px"></div>
    </div>
</dialog>

@section Scripts {
<script>
async function quickShare(fileId, name) {
    const dlg = document.getElementById('quickShareDlg');
    const T = dlg.dataset;
    document.getElementById('qsTitle').textContent = T.titlePrefix + name;
    document.getElementById('qsBusy').style.display = '';
    document.getElementById('qsResult').style.display = 'none';
    document.getElementById('qsError').style.display = '';
    document.getElementById('qsError').style.display = 'none';
    dlg.showModal();
    try {
        const r = await fetch('/api/v1/links', {
            method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
            body: JSON.stringify({ fileId: fileId, notifyOnAccess: false })
        });
        if (!r.ok) throw new Error('HTTP ' + r.status);
        const d = await r.json();
        document.getElementById('qsUrl').value = d.url || (location.origin + '/s/' + d.slug);
        document.getElementById('qsBusy').style.display = 'none';
        document.getElementById('qsResult').style.display = '';
        const cp = document.getElementById('qsCopy');
        cp.textContent = '📋 ' + T.copy;
        cp.onclick = () => { navigator.clipboard.writeText(document.getElementById('qsUrl').value); cp.textContent = '✓ ' + T.copied; };
    } catch (e) {
        document.getElementById('qsBusy').style.display = 'none';
        document.getElementById('qsError').textContent = T.error + ': ' + e.message;
        document.getElementById('qsError').style.display = '';
    }
}
</script>
}
