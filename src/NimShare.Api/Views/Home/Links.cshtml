@model IEnumerable<NimShare.Core.Entities.ShareLink>
@{
    ViewData["Title"] = T["links.title"];
    Layout = "_AppShell";
    var publicLinks = (List<NimShare.Core.Entities.ShareLink>)(ViewData["PublicLinks"] ?? new List<NimShare.Core.Entities.ShareLink>());
    var isAdmin = (bool)(ViewData["IsAdmin"] ?? false);
}
<div class="page-header">
    <div>
        <h1>@T["links.title"]</h1>
        <p class="lede">@T["links.lede"]</p>
    </div>
    <a class="btn btn-primary" href="/upload">@T["dashboard.new_upload"]</a>
</div>

<h2 style="margin-top:8px">🔗 @T["links.mine.section"]</h2>

@if (!Model.Any())
{
    <div class="card"><p class="muted">@T["links.empty"]</p></div>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>@T["links.slug"]</th>
            <th>@T["file.name"]</th>
            <th>@T["links.downloads"]</th>
            <th>@T["links.expires"]</th>
            <th>@T["links.state"]</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var l in Model)
        {
            var state = l.IsRevoked
                ? ("chip-critical", @T["links.revoked"].Value)
                : l.ExpiresAt is not null && l.ExpiresAt <= DateTimeOffset.UtcNow
                    ? ("chip-warn", @T["links.expired"].Value)
                    : ("chip-ok", @T["links.active"].Value);
            <tr>
                <td><a href="/s/@l.Slug" class="mono">@l.Slug</a></td>
                <td>@(l.File?.Name ?? (l.FolderId is not null ? T["links.folder_target"].Value : "—"))</td>
                <td>@l.DownloadCount @(l.MaxDownloads is int m ? $" / {m}" : "")</td>
                <td class="muted">@(l.ExpiresAt?.ToString("u") ?? "—")</td>
                <td><span class="chip @state.Item1">@state.Item2</span></td>
                <td>
                    @if (l.IsPublic)
                    {
                        <span class="chip chip-warn" title="@T["links.public.hint"]">🌐 @T["links.public.badge"]</span>
                    }
                    <a class="btn btn-secondary btn-sm" href="/links/@l.Id">📊 @T["links.action.report"]</a>
                    <button class="btn btn-ghost btn-sm" data-copy="@(Url.RouteUrl(new { controller = "Share", action = "Landing", slug = l.Slug }) ?? $"/s/{l.Slug}")">@T["links.action.copy"]</button>
                    <button class="btn btn-ghost btn-sm" data-email="@l.Id">@T["links.action.email"]</button>
                    @if (isAdmin)
                    {
                        <button class="btn btn-ghost btn-sm" data-toggle-public="@l.Id" data-current="@(l.IsPublic ? "true" : "false")">
                            @(l.IsPublic ? "🔒 " + @T["links.public.unshare"].Value : "🌐 " + @T["links.public.share"].Value)
                        </button>
                    }
                    @if (!l.IsRevoked)
                    {
                        <button class="btn btn-ghost btn-sm" data-revoke="@l.Id">@T["links.action.revoke"]</button>
                    }
                    <button class="btn btn-ghost btn-sm" data-delete="@l.Id">@T["links.action.delete"]</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

@if (publicLinks.Any())
{
    <h2 style="margin-top:32px">🌐 @T["links.public.section"]</h2>
    <p class="muted" style="margin-bottom:8px">@T["links.public.lede"]</p>
    <table class="table">
        <thead>
            <tr>
                <th>@T["links.slug"]</th>
                <th>@T["file.name"]</th>
                <th>@T["links.public.by"]</th>
                <th>@T["links.downloads"]</th>
                <th>@T["links.state"]</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
        @foreach (var l in publicLinks)
        {
            var pstate = l.IsRevoked
                ? ("chip-critical", @T["links.revoked"].Value)
                : l.ExpiresAt is not null && l.ExpiresAt <= DateTimeOffset.UtcNow
                    ? ("chip-warn", @T["links.expired"].Value)
                    : ("chip-ok", @T["links.active"].Value);
            <tr>
                <td><a href="/s/@l.Slug" class="mono">@l.Slug</a></td>
                <td>@(l.File?.Name ?? (l.FolderId is not null ? T["links.folder_target"].Value : "—"))</td>
                <td class="muted">@l.Owner?.DisplayName</td>
                <td>@l.DownloadCount @(l.MaxDownloads is int m2 ? $" / {m2}" : "")</td>
                <td><span class="chip @pstate.Item1">@pstate.Item2</span></td>
                <td>
                    <a class="btn btn-secondary btn-sm" href="/s/@l.Slug" target="_blank">↗ @T["links.action.open"]</a>
                    <button class="btn btn-ghost btn-sm" data-copy="@(Url.RouteUrl(new { controller = "Share", action = "Landing", slug = l.Slug }) ?? $"/s/{l.Slug}")">@T["links.action.copy"]</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<script>
async function api(method, path, body) {
    const r = await fetch(path, {
        method,
        headers: body ? { 'Content-Type': 'application/json' } : {},
        body: body ? JSON.stringify(body) : undefined,
        credentials: 'same-origin'
    });
    return r;
}
document.querySelectorAll('[data-revoke]').forEach(b => {
    b.addEventListener('click', async () => {
        if (!confirm(@Json.Serialize(T["links.confirm.revoke"].Value))) return;
        const r = await api('PATCH', `/api/v1/links/${b.dataset.revoke}`, { isRevoked: true });
        if (r.ok) location.reload(); else alert('Failed: ' + r.status);
    });
});
document.querySelectorAll('[data-toggle-public]').forEach(b => {
    b.addEventListener('click', async () => {
        const currentlyPublic = b.dataset.current === 'true';
        const r = await api('PATCH', `/api/v1/links/${b.dataset.togglePublic}`, { isPublic: !currentlyPublic });
        if (r.ok) location.reload(); else alert('Failed: ' + r.status);
    });
});
document.querySelectorAll('[data-delete]').forEach(b => {
    b.addEventListener('click', async () => {
        if (!confirm(@Json.Serialize(T["links.confirm.delete"].Value))) return;
        const r = await api('DELETE', `/api/v1/links/${b.dataset.delete}`);
        if (r.ok) location.reload(); else alert('Failed: ' + r.status);
    });
});
document.querySelectorAll('[data-copy]').forEach(b => {
    b.addEventListener('click', async () => {
        const url = location.origin + b.dataset.copy;
        try { await navigator.clipboard.writeText(url); b.textContent = '✓'; setTimeout(()=>b.textContent=@Json.Serialize(T["links.action.copy"].Value), 1200); }
        catch {
            // Modern replacement — presents the URL in a proper modal input
            // (selectable, copyable) instead of a native prompt bar.
            if (window.nsPrompt) window.nsPrompt('Copy this URL', '', url);
            else prompt('Copy this URL:', url);
        }
    });
});
document.querySelectorAll('[data-email]').forEach(b => {
    b.addEventListener('click', () => openEmailModal(b.dataset.email));
});
async function openEmailModal(linkId) {
    document.getElementById('emailLinkId').value = linkId;
    document.getElementById('emailTo').value = '';
    document.getElementById('emailMsg').value = '';
    document.getElementById('modalEmail').classList.add('open');
}
async function draftWithAi() {
    const linkId = document.getElementById('emailLinkId').value;
    const btn = document.getElementById('draftBtn');
    btn.disabled = true; btn.textContent = @Json.Serialize(T["links.email.drafting"].Value);
    const r = await fetch('/api/v1/ai/draft-email', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify({ linkId, context: document.getElementById('emailTo').value || null }),
    });
    btn.disabled = false; btn.textContent = @Json.Serialize(T["links.email.draft_ai"].Value);
    if (r.status === 503) { alert(@Json.Serialize(T["links.email.ai_disabled"].Value)); return; }
    if (!r.ok) { alert('Failed: ' + r.status); return; }
    const d = await r.json();
    document.getElementById('emailMsg').value = d.draft || '';
}
async function sendEmail() {
    const linkId = document.getElementById('emailLinkId').value;
    const to = document.getElementById('emailTo').value;
    const msg = document.getElementById('emailMsg').value;
    if (!to) return;
    const r = await api('POST', `/api/v1/links/${linkId}/send-email`, { toEmail: to, message: msg });
    document.getElementById('modalEmail').classList.remove('open');
    if (r.ok) alert(@Json.Serialize(T["links.email.sent"].Value)); else alert('Failed: ' + r.status);
}
</script>

<!-- Send-by-email modal with AI-draft button -->
<div class="modal-backdrop" id="modalEmail" onclick="if(event.target===this)document.getElementById('modalEmail').classList.remove('open')">
    <div class="modal-panel">
        <h2>@T["links.action.email"]</h2>
        <input type="hidden" id="emailLinkId"/>
        <div class="field">
            <label>@T["links.email.to"]</label>
            <input type="email" id="emailTo" required/>
        </div>
        <div class="field">
            <label>@T["links.email.message"]</label>
            <textarea id="emailMsg" rows="6" placeholder="@T["links.email.placeholder"]"></textarea>
        </div>
        <button type="button" id="draftBtn" class="btn btn-ghost" onclick="draftWithAi()">✨ @T["links.email.draft_ai"]</button>
        <div class="actions">
            <button type="button" class="btn btn-ghost" onclick="document.getElementById('modalEmail').classList.remove('open')">@T["modal.cancel"]</button>
            <button type="button" class="btn btn-primary" onclick="sendEmail()">@T["links.email.send"]</button>
        </div>
    </div>
</div>
