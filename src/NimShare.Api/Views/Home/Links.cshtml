@model IEnumerable<NimShare.Core.Entities.ShareLink>
@{ ViewData["Title"] = @T["links.title"]; Layout = "_AppShell"; }
<div class="page-header">
    <div>
        <h1>@T["links.title"]</h1>
        <p class="lede">@T["links.lede"]</p>
    </div>
    <a class="btn btn-primary" href="/upload">@T["dashboard.new_upload"]</a>
</div>

@if (!Model.Any())
{
    <div class="card"><p class="muted">@T["links.empty"]</p></div>
}
else
{
    <table class="table">
        <thead>
        <tr>
            <th>@T["links.slug"]</th>
            <th>@T["file.name"]</th>
            <th>@T["links.downloads"]</th>
            <th>@T["links.expires"]</th>
            <th>@T["links.state"]</th>
            <th></th>
        </tr>
        </thead>
        <tbody>
        @foreach (var l in Model)
        {
            var state = l.IsRevoked
                ? ("chip-critical", @T["links.revoked"].Value)
                : l.ExpiresAt is not null && l.ExpiresAt <= DateTimeOffset.UtcNow
                    ? ("chip-warn", @T["links.expired"].Value)
                    : ("chip-ok", @T["links.active"].Value);
            <tr>
                <td><a href="/s/@l.Slug" class="mono">@l.Slug</a></td>
                <td>@l.File.Name</td>
                <td>@l.DownloadCount @(l.MaxDownloads is int m ? $" / {m}" : "")</td>
                <td class="muted">@(l.ExpiresAt?.ToString("u") ?? "—")</td>
                <td><span class="chip @state.Item1">@state.Item2</span></td>
                <td>
                    @if (!l.IsRevoked)
                    {
                        <button class="btn btn-ghost btn-sm" data-revoke="@l.Id">@T["links.action.revoke"]</button>
                    }
                    <button class="btn btn-ghost btn-sm" data-delete="@l.Id">@T["links.action.delete"]</button>
                </td>
            </tr>
        }
        </tbody>
    </table>
}

<script>
async function api(method, path, body) {
    const r = await fetch(path, {
        method,
        headers: body ? { 'Content-Type': 'application/json' } : {},
        body: body ? JSON.stringify(body) : undefined,
        credentials: 'same-origin'
    });
    return r;
}
document.querySelectorAll('[data-revoke]').forEach(b => {
    b.addEventListener('click', async () => {
        if (!confirm(@Json.Serialize(T["links.confirm.revoke"].Value))) return;
        const r = await api('PATCH', `/api/v1/links/${b.dataset.revoke}`, { isRevoked: true });
        if (r.ok) location.reload(); else alert('Failed: ' + r.status);
    });
});
document.querySelectorAll('[data-delete]').forEach(b => {
    b.addEventListener('click', async () => {
        if (!confirm(@Json.Serialize(T["links.confirm.delete"].Value))) return;
        const r = await api('DELETE', `/api/v1/links/${b.dataset.delete}`);
        if (r.ok) location.reload(); else alert('Failed: ' + r.status);
    });
});
</script>
