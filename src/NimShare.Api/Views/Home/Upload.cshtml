@{ ViewData["Title"] = @T["upload.title"]; Layout = "_AppShell"; }
<div class="page-header">
    <div>
        <h1>@T["upload.title"]</h1>
        <p class="lede">@T["upload.lede"]</p>
    </div>
</div>

<div class="card">
    <h2 class="card-title">@T["upload.step1"]</h2>
    <div class="field">
        <input type="file" id="file"/>
        <div class="helper" id="pickmeta"></div>
    </div>
    <button class="btn btn-secondary" id="upload-btn">@T["upload.button"]</button>
    <div class="helper" id="upload-status"></div>
</div>

<div class="card" id="link-card" style="display:none">
    <h2 class="card-title">@T["upload.step2"]</h2>
    <div class="field">
        <label for="slug">@T["upload.slug"]</label>
        <input type="text" id="slug" placeholder="project-x"/>
        <div class="helper">@T["upload.slug_helper"]</div>
    </div>
    <div class="row">
        <div class="field" style="flex:1;min-width:220px">
            <label for="password">@T["upload.password"]</label>
            <input type="text" id="password" placeholder=""/>
        </div>
        <div class="field" style="flex:1;min-width:220px">
            <label for="maxdl">@T["upload.max_downloads"]</label>
            <input type="number" id="maxdl" min="1" placeholder=""/>
        </div>
        <div class="field" style="flex:1;min-width:220px">
            <label for="expires">@T["upload.expires_at"]</label>
            <input type="datetime-local" id="expires"/>
        </div>
    </div>
    <div class="field">
        <label for="message">@T["upload.message"]</label>
        <textarea id="message" rows="3" placeholder="@T["upload.message_placeholder"]"></textarea>
    </div>
    <div class="field">
        <label><input type="checkbox" id="notify"/> @T["upload.notify_me"]</label>
    </div>
    <button class="btn btn-primary" id="create-link">@T["upload.create_link"]</button>
</div>

<div class="card" id="result-card" style="display:none">
    <h2 class="card-title">@T["upload.done"]</h2>
    <p class="muted">@T["upload.share_this"]</p>
    <div class="row" style="align-items:center;gap:var(--sp-4);margin-top:var(--sp-4)">
        <input id="result-url" readonly style="flex:1"/>
        <button class="btn btn-ghost" id="copy-url">@T["upload.copy"]</button>
    </div>
    <img id="qr" style="width:180px;margin-top:var(--sp-4);border:1px solid var(--tw-gray-300);border-radius:8px;padding:8px;background:var(--tw-white)"/>
</div>

<script>
let currentFileId = null;
const btn = document.getElementById('upload-btn');
const pick = document.getElementById('file');
const status = document.getElementById('upload-status');
const meta = document.getElementById('pickmeta');
pick.addEventListener('change', () => {
    const f = pick.files[0]; if (!f) { meta.textContent=''; return; }
    meta.textContent = `${f.name} · ${(f.size/1024/1024).toFixed(2)} MiB · ${f.type||'application/octet-stream'}`;
});

async function getToken() {
    // In web-mode we already have a cookie session — call the API via same-origin, cookies attached.
    return null;
}

btn.addEventListener('click', async () => {
    const f = pick.files[0]; if (!f) { status.textContent='Pick a file first.'; return; }
    btn.disabled = true; status.textContent = 'Requesting upload slot…';
    const init = await fetch('/api/v1/files', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name: f.name, sizeBytes: f.size, contentType: f.type })
    });
    if (!init.ok) {
        let msg = 'HTTP ' + init.status;
        try { const p = await init.json(); msg = p.title || p.detail || msg; } catch {}
        status.textContent = msg;
        btn.disabled = false; return;
    }
    const { fileId, uploadUrl } = await init.json();
    currentFileId = fileId;
    status.textContent = 'Uploading directly to Azure Blob Storage…';
    const put = await fetch(uploadUrl, { method: 'PUT', headers: {'x-ms-blob-type':'BlockBlob','x-ms-blob-content-type':f.type||'application/octet-stream'}, body: f });
    if (!put.ok) { status.textContent = 'Upload failed'; btn.disabled = false; return; }
    await fetch(`/api/v1/files/${fileId}/complete`, { method: 'POST' });
    status.textContent = 'Upload complete. Configure your link below ↓';
    document.getElementById('link-card').style.display = 'block';
    btn.disabled = false;
});

document.getElementById('create-link').addEventListener('click', async () => {
    if (!currentFileId) return;
    const payload = {
        fileId: currentFileId,
        slug: document.getElementById('slug').value || null,
        password: document.getElementById('password').value || null,
        maxDownloads: parseInt(document.getElementById('maxdl').value, 10) || null,
        expiresAt: document.getElementById('expires').value ? new Date(document.getElementById('expires').value).toISOString() : null,
        message: document.getElementById('message').value || null,
        notifyOnAccess: document.getElementById('notify').checked
    };
    const r = await fetch('/api/v1/links', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
    });
    if (!r.ok) { alert('Failed: ' + (await r.text())); return; }
    const link = await r.json();
    document.getElementById('result-url').value = link.url;
    document.getElementById('qr').src = link.qrCodeUrl;
    document.getElementById('result-card').style.display = 'block';
});
document.getElementById('copy-url').addEventListener('click', () => {
    const u = document.getElementById('result-url'); u.select(); document.execCommand('copy');
});
</script>
