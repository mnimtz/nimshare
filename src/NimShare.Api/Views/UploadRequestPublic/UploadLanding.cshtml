@model NimShare.Api.Controllers.UploadLandingViewModel
@{ ViewData["Title"] = T["upload.landing.title"]; Layout = "_Layout"; }
<div class="landing-shell">
    <div class="landing-card">
        <div class="landing-brand">
            <img src="/img/icon-64.png" width="40" height="40" alt="NimShare" style="border-radius:8px"/>
            <small>@T["upload.landing.request_by"] @Model.OwnerName</small>
        </div>
        @* v1.10.146: Absender-Zertifikat-Zeile *@
        @if (Model.Signer is not null)
        {
            var s = Model.Signer;
            <div style="margin:8px 0 12px;font-size:.9rem;color:var(--tw-primary,#002854)">
                <span style="color:#0a7f2e">✓</span>
                @string.Format(T["share.cert.line"].Value, s.Subject)
                <button type="button" onclick="var e=document.getElementById('certPop');e.style.display=e.style.display==='block'?'none':'block'" style="background:none;border:0;color:inherit;cursor:pointer;padding:0 4px;font-size:1rem">ⓘ</button>
                <div id="certPop" style="display:none;margin-top:6px;background:#fff;border:1px solid #ddd;border-radius:8px;padding:10px 12px;font-size:.85rem;box-shadow:0 4px 12px rgba(0,0,0,.08);max-width:420px">
                    <strong style="display:block;margin-bottom:4px">@T["share.cert.details_title"]</strong>
                    <div>@T["share.cert.subject"]: <span style="font-family:monospace">@s.Subject</span></div>
                    <div>@T["share.cert.issuer"]: <span style="font-family:monospace">@s.Issuer</span></div>
                    <div>@T["share.cert.valid_until"]: @s.NotAfter.ToString("MM/yyyy")</div>
                    <div>@T["share.cert.thumbprint"]: <span style="font-family:monospace;word-break:break-all">@s.Thumbprint</span></div>
                    @if (s.IsSelfIssued) { <div style="margin-top:6px;color:#7a5b00;font-style:italic">@T["share.cert.self_issued"]</div> }
                </div>
            </div>
        }
        <h1>@T["upload.landing.title"]</h1>
        @if (!string.IsNullOrWhiteSpace(Model.MessageHtml))
        {
            <div class="card" style="background:var(--tw-gray-100)">@Html.Raw(Model.MessageHtml)</div>
        }
        <div class="field" style="margin-top:var(--sp-6)">
            <label for="file">@T["upload.landing.pick_file"]</label>
            <input type="file" id="file" name="file"/>
        </div>
        @if (Model.HasPassword)
        {
            <div class="field">
                <label for="password">@T["landing.password.label"]</label>
                <input type="password" id="password"/>
            </div>
        }
        <button id="upload-btn" class="btn btn-primary" style="margin-top:var(--sp-4)">@T["upload.landing.button"]</button>
        <div id="upload-status" class="helper"></div>
    </div>
</div>
<script>
    const slug = @Json.Serialize(Model.Slug);
    const btn = document.getElementById('upload-btn');
    const status = document.getElementById('upload-status');
    btn.addEventListener('click', async () => {
        const f = document.getElementById('file').files[0];
        if (!f) { status.textContent = 'Pick a file first.'; return; }
        const pw = document.getElementById('password')?.value;
        btn.disabled = true; status.textContent = 'Requesting upload slot…';
        const init = await fetch(`/u/${slug}/init`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ filename: f.name, sizeBytes: f.size, contentType: f.type, password: pw })
        });
        if (!init.ok) { status.textContent = 'Rejected: ' + init.status; btn.disabled = false; return; }
        const { fileId, uploadUrl } = await init.json();
        status.textContent = 'Uploading…';
        const put = await fetch(uploadUrl, { method: 'PUT', headers: { 'x-ms-blob-type': 'BlockBlob' }, body: f });
        if (!put.ok) { status.textContent = 'Upload failed'; btn.disabled = false; return; }
        await fetch(`/u/${slug}/complete`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ fileId })
        });
        status.textContent = 'Done — thanks!';
    });
</script>
