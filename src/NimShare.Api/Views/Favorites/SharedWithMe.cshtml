@using NimShare.Core.Entities
@{
    ViewData["Title"] = T["nav.shared_with_me"];
    Layout = "_AppShell";
    var shares = (List<DirectShare>)ViewData["Shares"]!;
}
<div class="page-header">
    <div>
        <h1>🤝 @T["nav.shared_with_me"]</h1>
        <p class="lede">@T["shared.lede"]</p>
    </div>
</div>

@if (!shares.Any())
{
    <div class="fm-empty">
        <div class="fm-empty-art">🤝</div>
        <div class="fm-empty-title">@T["share.none"]</div>
    </div>
}
else
{
    <table class="fm-list">
        <thead>
            <tr>
                <th>@T["file.name"]</th>
                <th style="width:110px">@T["share.perm"]</th>
                <th style="width:180px">@T["shared.by"]</th>
                <th style="width:170px">@T["shared.since"]</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var s in shares)
        {
            var isFile = s.FileId is not null;
            var name = s.File?.Name ?? s.Folder?.Name ?? "?";
            <tr class="fm-row">
                <td>
                    <span class="fm-name">
                        <span class="fm-icon @(isFile ? "fm-icon-file" : "fm-icon-folder")">@(isFile ? "📄" : "📁")</span>
                        @if (isFile)
                        {
                            @* v1.10.109: GUID direkt interpolieren, kein @@Json.Serialize
                               (literale " brechen sonst das onclick-Attribut). *@
                            <a href="#" onclick="event.preventDefault();fetch('/api/v1/files/@s.FileId/preview-url').then(r=>r.json()).then(d=>window.open(d.url,'_blank'))">@name</a>
                        }
                        else
                        {
                            <span>@name</span>
                        }
                    </span>
                </td>
                <td><span class="chip @(s.Permission == DirectSharePermission.Write ? "chip-warn" : "")">@s.Permission</span></td>
                <td class="muted">
                    @s.SharedByUser?.DisplayName
                    @if (s.TargetGroup is not null) { <span class="muted"> (via @s.TargetGroup.Name)</span> }
                </td>
                <td class="muted">@s.CreatedAt.ToDisplay()</td>
            </tr>
        }
        </tbody>
    </table>
}
