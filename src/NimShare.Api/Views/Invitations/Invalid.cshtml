@{ ViewData["Title"] = T["invite.invalid.title"]; Layout = "_Layout"; }
<div class="landing-shell">
    <div class="landing-card" style="max-width:520px">
        <div style="text-align:center;margin-bottom:var(--sp-4)">
            <img src="/img/icon-64.png" width="40" height="40" alt="NimShare" style="border-radius:8px;margin:0 auto"/>
        </div>
        <h1 style="text-align:center">@T["invite.invalid.title"]</h1>
        <p class="landing-meta" style="text-align:center">@T["invite.invalid.body"]</p>
    </div>
</div>
