@model NimShare.Api.Controllers.LandingViewModel
@{
    ViewData["Title"] = Model.Theme.Title ?? Model.FileName;
    Layout = "_Layout";
    var accent = Model.Theme.PrimaryColor ?? "#002854";
}
@if (!string.IsNullOrEmpty(Model.Theme.HeroUrl))
{
    <div style="height:180px;background:@accent url('@Model.Theme.HeroUrl') center/cover;margin-bottom:-40px"></div>
}
<div class="landing-shell">
    <div class="landing-card" style="border-top:4px solid @accent;position:relative">
        @if (!string.IsNullOrEmpty(Model.OwnerAvatarUrl))
        {
            <img src="@Model.OwnerAvatarUrl" alt="@Model.OwnerName" title="@Model.OwnerName"
                 style="position:absolute;top:16px;right:16px;width:44px;height:44px;border-radius:50%;object-fit:cover;box-shadow:0 2px 6px rgba(0,0,0,.15);border:2px solid #fff"/>
        }
        <div class="landing-brand">
            @if (!string.IsNullOrEmpty(Model.Theme.LogoUrl))
            {
                <img src="@Model.Theme.LogoUrl" style="max-height:48px;max-width:200px" alt=""/>
            }
            else
            {
                <img src="/img/icon-64.png" width="40" height="40" alt="NimShare" style="border-radius:8px"/>
            }
            <small>@T["landing.shared_by"] @Model.OwnerName</small>
        </div>

        <h1 style="color:@accent">@(Model.Theme.Title ?? T["landing.title"].Value)</h1>
        @if (!string.IsNullOrEmpty(Model.Theme.Subtitle))
        {
            <p class="lede">@Model.Theme.Subtitle</p>
        }
        @if (!string.IsNullOrEmpty(Model.Theme.BodyMarkdown))
        {
            <div style="margin:var(--sp-4) 0;line-height:1.55">
                @Html.Raw(Markdig.Markdown.ToHtml(Model.Theme.BodyMarkdown))
            </div>
        }
        <p class="landing-meta">
            @if (Model.ExpiresAt is not null)
            {
                <span>@T["landing.expires_at"] <span class="mono">@Model.ExpiresAt.Value.ToString("u")</span></span>
            }
            @if (Model.MaxDownloads is not null)
            {
                <span class="chip">@(Model.MaxDownloads - Model.DownloadCount) / @Model.MaxDownloads @T["landing.downloads_left"]</span>
            }
        </p>

        @if (!string.IsNullOrWhiteSpace(Model.MessageHtml))
        {
            <div class="card" style="background:var(--tw-gray-100);margin-top:var(--sp-6)">
                @Html.Raw(Model.MessageHtml)
            </div>
        }

        <div class="file-tile">
            <div class="icon">@GetExt(Model.FileName)</div>
            <div class="meta">
                <span class="name">@Model.FileName</span>
                <span class="sub">@HumanBytes(Model.SizeBytes) · @Model.ContentType</span>
            </div>
        </div>

        @{
            var ct = (Model.ContentType ?? "").ToLowerInvariant();
            var previewable = ct.StartsWith("image/") || ct == "application/pdf";
        }
        @if (previewable && !Model.HasPassword)
        {
            <div style="margin-top:var(--sp-4);border:1px solid var(--tw-gray-200);border-radius:8px;overflow:hidden;background:var(--tw-gray-100)">
                @if (ct.StartsWith("image/"))
                {
                    <img src="/s/@Model.Slug/preview" alt="@Model.FileName"
                         style="display:block;max-width:100%;max-height:60vh;margin:0 auto;background:#fff"/>
                }
                else
                {
                    <iframe src="/s/@Model.Slug/preview" title="@Model.FileName"
                            style="width:100%;height:60vh;border:0;background:#fff"></iframe>
                }
            </div>
        }
        else if (previewable && Model.HasPassword)
        {
            <div class="muted" style="margin-top:var(--sp-3);font-size:.85rem">🔒 @T["landing.preview_after_password"]</div>
        }

        <div id="aiSummaryBlock" style="margin-top:var(--sp-4)">
            <button type="button" class="btn btn-ghost btn-sm" id="aiSummaryBtn" onclick="loadAiSummary()">✨ @T["landing.ai_summary"]</button>
            <div id="aiSummaryOut" class="muted" style="margin-top:var(--sp-3);font-style:italic;line-height:1.5"></div>
        </div>
        <script>
        async function loadAiSummary() {
            const btn = document.getElementById('aiSummaryBtn');
            const out = document.getElementById('aiSummaryOut');
            btn.disabled = true;
            out.textContent = @Json.Serialize(T["landing.ai_summary.loading"].Value);
            const r = await fetch('/api/v1/ai/summary', {
                method: 'POST',
                headers: {'Content-Type':'application/json'},
                body: JSON.stringify({ slug: @Json.Serialize(Model.Slug) })
            });
            if (r.status === 503) { out.textContent = @Json.Serialize(T["landing.ai_summary.disabled"].Value); btn.style.display='none'; return; }
            if (r.status === 415) { out.textContent = @Json.Serialize(T["landing.ai_summary.unsupported"].Value); return; }
            if (!r.ok) {
                let extra = '';
                try { const p = await r.json(); if (p.detail) extra = ' (' + p.detail + ')'; } catch {}
                out.textContent = @Json.Serialize(T["landing.ai_summary.error"].Value) + extra;
                btn.disabled = false;
                return;
            }
            const d = await r.json();
            out.textContent = d.summary || '';
            btn.style.display='none';
        }
        </script>

        <form method="post" asp-controller="Share" asp-action="Submit" asp-route-slug="@Model.Slug" class="stack">
            @if (Model.HasPassword)
            {
                <div class="field">
                    <label for="password">@T["landing.password.label"]</label>
                    <input type="password" name="password" id="password" required autofocus/>
                    @if (TempData["PasswordError"] is string err)
                    {
                        <div class="helper" style="color:var(--status-critical)">@err</div>
                    }
                </div>
            }
            <button type="submit" class="btn btn-primary" style="background:@accent;color:#fff">@T["landing.download.button"]</button>
        </form>

        @if (!string.IsNullOrEmpty(Model.Theme.FooterText))
        {
            <p class="landing-meta" style="margin-top:var(--sp-6)">@Model.Theme.FooterText</p>
        }
        <p class="landing-meta" style="margin-top:var(--sp-4);font-size:.75rem">
            @T["landing.powered_by"] <strong>NimShare</strong>
        </p>
    </div>
</div>

@functions {
    static string GetExt(string name)
    {
        var ext = System.IO.Path.GetExtension(name).TrimStart('.').ToUpperInvariant();
        return string.IsNullOrEmpty(ext) ? "FILE" : (ext.Length > 4 ? ext[..4] : ext);
    }
    static string HumanBytes(long b)
    {
        string[] u = { "B", "KB", "MB", "GB", "TB" };
        double v = b; int i = 0;
        while (v >= 1024 && i < u.Length - 1) { v /= 1024; i++; }
        return $"{v:0.##} {u[i]}";
    }
}
