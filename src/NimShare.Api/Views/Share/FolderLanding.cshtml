@model NimShare.Api.Controllers.FolderLandingViewModel
@{
    ViewData["Title"] = Model.FolderName;
    Layout = "_Layout";
    var theme = Model.Theme;
    // Same style pattern as Share/Landing.cshtml — inline `style="background:@accent;color:#fff"`
    // on the button instead of a `<style>` block with !important. The old
    // !important approach only overrode `background`, leaving the base
    // `color: var(--tw-primary)` (dark blue) — so a dark-blue brand became
    // dark-blue button + dark-blue text = looked "komplett schwarz".
    var accent = string.IsNullOrWhiteSpace(theme?.PrimaryColor) ? "#002854" : theme!.PrimaryColor!;
    string Bytes(long b)
    {
        string[] u = { "B", "KB", "MB", "GB", "TB" };
        double v = b; int i = 0;
        while (v >= 1024 && i < u.Length - 1) { v /= 1024; i++; }
        return $"{v:0.##} {u[i]}";
    }
}
@if (!string.IsNullOrEmpty(theme?.HeroUrl))
{
    <div style="height:180px;background:@accent url('@theme.HeroUrl') center/cover;margin-bottom:-40px"></div>
}
<div class="landing-shell">
    <div class="landing-card" style="max-width:720px;position:relative;border-top:4px solid @accent">
        @if (!string.IsNullOrEmpty(Model.OwnerAvatarUrl))
        {
            <img src="@Model.OwnerAvatarUrl" alt="@Model.OwnerName" title="@Model.OwnerName"
                 style="position:absolute;top:24px;right:28px;width:72px;height:72px;border-radius:50%;object-fit:cover;box-shadow:0 6px 20px rgba(0,0,0,.18),0 0 0 4px #fff,0 0 0 5px rgba(0,0,0,.06);z-index:2"/>
        }
        <div class="landing-brand">
            @if (!string.IsNullOrWhiteSpace(theme?.LogoUrl))
            {
                <img src="@theme.LogoUrl" alt="Logo" style="max-height:48px;max-width:220px;object-fit:contain"/>
            }
            else
            {
                <img src="/img/icon-64.png" width="40" height="40" alt="NimShare" style="border-radius:8px"/>
            }
            <small>@T["landing.shared_by"] @Model.OwnerName</small>
        </div>
        <h1 style="color:@accent">📁 @(string.IsNullOrWhiteSpace(theme?.Title) ? Model.FolderName : theme!.Title!)</h1>
        @if (!string.IsNullOrWhiteSpace(theme?.Subtitle))
        {
            <p class="lede">@theme.Subtitle</p>
        }
        <p class="landing-meta">@T["landing.folder.lede"] @Model.Files.Count</p>
        @if (!string.IsNullOrWhiteSpace(theme?.BodyMarkdown))
        {
            <div style="margin:var(--sp-4) 0;line-height:1.55">
                @Html.Raw(Markdig.Markdown.ToHtml(theme.BodyMarkdown))
            </div>
        }
        @if (!string.IsNullOrWhiteSpace(Model.MessageHtml))
        {
            <div class="card" style="background:var(--tw-gray-100);margin-top:var(--sp-4)">
                @Html.Raw(Model.MessageHtml)
            </div>
        }
        <table class="table" style="margin-top:var(--sp-6)">
            <thead><tr><th>@T["file.name"]</th><th>@T["file.size"]</th><th></th></tr></thead>
            <tbody>
            @foreach (var f in Model.Files)
            {
                <tr>
                    <td>@f.Name</td>
                    <td class="muted">@Bytes(f.SizeBytes)</td>
                    <td>
                        <form method="post" asp-controller="Share" asp-action="DownloadFolderFile" asp-route-slug="@Model.Slug" asp-route-fileId="@f.Id" style="display:inline">
                            @if (Model.HasPassword)
                            {
                                <input type="hidden" name="password" id="pw-@f.Id" required/>
                                <button type="button" onclick="var pw=prompt('@T["landing.password.label"]');if(pw){document.getElementById('pw-@f.Id').value=pw;this.closest('form').submit()}" class="btn btn-primary btn-sm" style="background:@accent;color:#fff;border-color:@accent">@T["landing.download.button"]</button>
                            }
                            else
                            {
                                <button type="submit" class="btn btn-primary btn-sm" style="background:@accent;color:#fff;border-color:@accent">@T["landing.download.button"]</button>
                            }
                        </form>
                    </td>
                </tr>
            }
            </tbody>
        </table>
        <p class="landing-meta" style="margin-top:var(--sp-6)">
            @if (!string.IsNullOrWhiteSpace(theme?.FooterText))
            {
                @theme.FooterText
            }
            else
            {
                <text>@T["landing.powered_by"] <strong>NimShare</strong></text>
            }
        </p>
    </div>
</div>
