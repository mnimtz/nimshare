@model NimShare.Core.Entities.AiGatewaySettings
@using NimShare.Core.Entities
@{ ViewData["Title"] = T["ai.title"]; Layout = "_AppShell"; }
<div class="page-header">
    <div>
        <h1>@T["ai.title"]</h1>
        <p class="lede">@T["ai.lede"]</p>
    </div>
</div>

@if (TempData["Notice"] is string n)
{
    <div class="card" style="border-left:3px solid var(--status-ok);background:rgba(0,235,134,.06)">@n</div>
}
@if (TempData["Error"] is string err)
{
    <div class="card" style="border-left:3px solid var(--status-critical);background:rgba(220,38,38,.06)">@err</div>
}

<form method="post" action="/settings/ai" class="card" style="max-width:820px">
    @Html.AntiForgeryToken()
    <h2 class="card-title">@T["ai.provider_section"]</h2>
    <div class="row" style="gap:var(--sp-4);flex-wrap:wrap;align-items:flex-end">
        <div class="field" style="flex:1;min-width:200px">
            <label for="Provider">@T["ai.provider"]</label>
            <select name="Provider" id="Provider">
                <option value="Disabled"    selected="@(Model.Provider==AiProvider.Disabled)">@T["ai.provider.disabled"]</option>
                <option value="OpenAi"      selected="@(Model.Provider==AiProvider.OpenAi)">OpenAI</option>
                <option value="Gemini"      selected="@(Model.Provider==AiProvider.Gemini)">Google Gemini</option>
                <option value="Anthropic"   selected="@(Model.Provider==AiProvider.Anthropic)">Anthropic Claude</option>
                <option value="AzureOpenAi" selected="@(Model.Provider==AiProvider.AzureOpenAi)">Azure OpenAI</option>
            </select>
        </div>
        <div class="field" style="flex:1;min-width:200px">
            <label for="Model">@T["ai.model"]</label>
            <select name="Model" id="Model" data-current="@Model.Model">
                @* Options are (re-)populated by JS whenever Provider changes.
                   For form-post we always render the currently persisted value as
                   the initial option so SaveChanges round-trips even if JS is off. *@
                @if (!string.IsNullOrEmpty(Model.Model))
                {
                    <option value="@Model.Model" selected>@Model.Model</option>
                }
            </select>
            <div class="helper" id="modelHelper">@T["ai.model_helper"]</div>
            <div style="display:flex;align-items:center;gap:8px;margin-top:6px">
                <button type="button" id="liveModelsBtn" class="btn btn-ghost" style="padding:4px 10px;font-size:.85rem">🔄 @T["ai.live_models"]</button>
                <span id="liveModelsStatus" class="muted" style="font-size:.85rem"></span>
            </div>
        </div>
    </div>
    <div class="field" id="endpointField" style="display:none">
        <label for="Endpoint">@T["ai.endpoint"]</label>
        <input type="url" name="Endpoint" id="Endpoint" value="@Model.Endpoint" placeholder="https://your-resource.openai.azure.com"/>
    </div>
    <div class="field">
        <label for="ApiKey">@T["ai.api_key"]</label>
        <input type="password" name="ApiKey" id="ApiKey" placeholder="@(string.IsNullOrEmpty(Model.ApiKeyEncrypted) ? "" : T["email_gateway.leave_blank"].Value)"/>
        <div class="helper">@T["ai.api_key_helper"]</div>
        @{
            var keyStatus = ViewData["ApiKeyStatus"] as string;
        }
        @if (!string.IsNullOrEmpty(keyStatus))
        {
            <div class="helper" style="margin-top:6px;padding:8px 12px;border-radius:6px;background:@(keyStatus.StartsWith("OK") ? "rgba(0,235,134,.10)" : "rgba(220,38,38,.10)");border-left:3px solid @(keyStatus.StartsWith("OK") ? "var(--status-ok)" : "var(--status-critical)")">
                <strong>Key-Status:</strong> @keyStatus
            </div>
        }
    </div>

    <h2 class="card-title" style="margin-top:var(--sp-6)">@T["ai.features"]</h2>
    <p class="muted">@T["ai.features_lede"]</p>

    @{
        (string key, bool val, string labelKey, string descKey, string status)[] toggles =
        {
            ("EnableAutoSummary",           Model.EnableAutoSummary,           "ai.feat.auto_summary",             "ai.feat.auto_summary.desc",             "ready"),
            ("EnableSmartTags",             Model.EnableSmartTags,             "ai.feat.smart_tags",               "ai.feat.smart_tags.desc",               "ready"),
            ("EnableSemanticSearch",        Model.EnableSemanticSearch,        "ai.feat.semantic_search",          "ai.feat.semantic_search.desc",          "ready"),
            ("EnableGuidedUploadRequests",  Model.EnableGuidedUploadRequests,  "ai.feat.guided_upload",            "ai.feat.guided_upload.desc",            "ready"),
            ("EnableContentRiskDetection",  Model.EnableContentRiskDetection,  "ai.feat.risk_detect",              "ai.feat.risk_detect.desc",              "ready"),
            ("EnableDraftedShareEmails",    Model.EnableDraftedShareEmails,    "ai.feat.email_drafts",             "ai.feat.email_drafts.desc",             "ready"),
            ("EnableChatWithFiles",         Model.EnableChatWithFiles,         "ai.feat.chat",                     "ai.feat.chat.desc",                     "ready"),
            ("EnableOcr",                   Model.EnableOcr,                   "ai.feat.ocr",                      "ai.feat.ocr.desc",                      "ready"),
        };
    }
    @foreach (var (key, val, labelKey, descKey, status) in toggles)
    {
        <div class="card" style="margin:var(--sp-3) 0;padding:var(--sp-4);background:var(--tw-gray-100)">
            <label style="display:flex;align-items:flex-start;gap:var(--sp-3);font-weight:400;cursor:pointer">
                <input type="checkbox" name="@key" value="true" checked="@val" style="margin-top:4px"/>
                <div style="flex:1">
                    <div style="font-weight:700;color:var(--tw-primary);display:flex;align-items:center;gap:var(--sp-2)">
                        @T[labelKey]
                        @if (status == "preview")
                        {
                            <span class="chip chip-warn">@T["ai.status.preview"]</span>
                        }
                        else
                        {
                            <span class="chip chip-ok">@T["ai.status.ready"]</span>
                        }
                    </div>
                    <div class="muted" style="font-size:.88rem;margin-top:2px">@T[descKey]</div>
                </div>
            </label>
        </div>
    }

    <div style="margin-top:var(--sp-6);padding-top:var(--sp-4);border-top:1px solid var(--tw-gray-200)">
        <button type="submit" class="btn btn-primary">@T["ai.save"]</button>
    </div>
</form>

<div class="card" style="max-width:820px;margin-top:var(--sp-6)">
    <h2 class="card-title">@T["ai.reindex.title"]</h2>
    <p class="muted">@T["ai.reindex.lede"]</p>
    <button type="button" class="btn btn-secondary" id="reindexBtn" onclick="doReindex()">🔄 @T["ai.reindex.button"]</button>
    <span id="reindexStatus" class="muted" style="margin-left:12px"></span>
</div>

<script>
async function doReindex() {
    const btn = document.getElementById('reindexBtn');
    const st = document.getElementById('reindexStatus');
    btn.disabled = true;
    st.textContent = @Json.Serialize(T["ai.reindex.running"].Value);
    try {
        const r = await fetch('/api/v1/ai/reindex', { method: 'POST', credentials: 'same-origin' });
        if (!r.ok) {
            const p = await r.json().catch(() => ({}));
            st.textContent = 'Fehler: ' + (p.detail || p.title || r.status);
            return;
        }
        const d = await r.json();
        st.textContent = (@Json.Serialize(T["ai.reindex.done"].Value)).replace('{0}', d.queued);
    } finally { btn.disabled = false; }
}
</script>

<script>
(function () {
    const providerEl = document.getElementById('Provider');
    const endpointField = document.getElementById('endpointField');
    const modelEl = document.getElementById('Model');
    const modelHelper = document.getElementById('modelHelper');
    const currentModel = modelEl.dataset.current || '';

    // Curated list per provider — ordered from most-recommended to legacy.
    // Vision-capable models are marked with 👁️ so the operator knows which
    // ones support the Auto-Summary + Image-Description features.
    const MODELS = {
        'OpenAi': [
            { v: 'gpt-4o',            label: '👁️ gpt-4o (recommended, vision)' },
            { v: 'gpt-4o-mini',       label: '👁️ gpt-4o-mini (cheap, vision)' },
            { v: 'gpt-4-turbo',       label: '👁️ gpt-4-turbo (vision)' },
            { v: 'o1-mini',           label: 'o1-mini (reasoning, no vision)' },
            { v: 'gpt-3.5-turbo',     label: 'gpt-3.5-turbo (legacy, no vision)' },
        ],
        'AzureOpenAi': [
            { v: 'gpt-4o',            label: '👁️ gpt-4o (recommended, vision) — must match your deployment name' },
            { v: 'gpt-4o-mini',       label: '👁️ gpt-4o-mini (vision)' },
            { v: 'gpt-4-turbo',       label: '👁️ gpt-4-turbo (vision)' },
            { v: 'gpt-35-turbo',      label: 'gpt-35-turbo (legacy, no vision)' },
        ],
        'Gemini': [
            { v: 'gemini-2.5-pro',        label: '👁️ gemini-2.5-pro (recommended, vision)' },
            { v: 'gemini-2.5-flash',      label: '👁️ gemini-2.5-flash (fast, vision)' },
            { v: 'gemini-2.5-flash-lite', label: '👁️ gemini-2.5-flash-lite (cheapest 2.5, vision)' },
            { v: 'gemini-2.0-flash',      label: '👁️ gemini-2.0-flash (vision)' },
            { v: 'gemini-2.0-flash-lite', label: '👁️ gemini-2.0-flash-lite (cheap, vision)' },
            { v: 'gemini-1.5-pro',        label: '👁️ gemini-1.5-pro (legacy, vision)' },
            { v: 'gemini-1.5-flash',      label: '👁️ gemini-1.5-flash (legacy, vision)' },
        ],
        'Anthropic': [
            { v: 'claude-opus-4-8',        label: '👁️ claude-opus-4-8 (most capable, vision)' },
            { v: 'claude-sonnet-5',        label: '👁️ claude-sonnet-5 (recommended, vision)' },
            { v: 'claude-haiku-4-5',       label: '👁️ claude-haiku-4-5 (fast, vision)' },
            { v: 'claude-3-5-sonnet-latest', label: '👁️ claude-3-5-sonnet (legacy, vision)' },
            { v: 'claude-3-5-haiku-latest',  label: '👁️ claude-3-5-haiku (legacy, vision)' },
        ],
        'Disabled': [],
    };

    function apply() {
        const p = providerEl.value;
        endpointField.style.display = p === 'AzureOpenAi' ? '' : 'none';
        const list = MODELS[p] || [];
        // Preserve the currently selected value on top so the form still round-
        // trips even if it's an unusual/custom name we don't know about.
        const known = new Set(list.map(x => x.v));
        modelEl.innerHTML = '';
        if (currentModel && !known.has(currentModel)) {
            const o = document.createElement('option');
            o.value = currentModel; o.textContent = currentModel + ' (current)'; o.selected = true;
            modelEl.appendChild(o);
        }
        for (const m of list) {
            const o = document.createElement('option');
            o.value = m.v; o.textContent = m.label;
            if (m.v === currentModel) o.selected = true;
            modelEl.appendChild(o);
        }
        // If no current value and provider has options, default to the first (recommended).
        if (!currentModel && list.length > 0) modelEl.value = list[0].v;
        if (modelHelper) {
            modelHelper.textContent = list.length > 0
                ? 'Nur Modelle mit 👁️ unterstützen Bild-Zusammenfassungen (Vision).'
                : '';
        }
    }
    providerEl.addEventListener('change', apply);
    apply();

    // ── Live model listing ────────────────────────────────────────
    // The curated list above only covers the marquee models. This button
    // calls the provider's own list-models endpoint (with the currently
    // saved API key) and injects EVERY model the provider actually offers
    // — so operators aren't stuck typing "gemini-2.5-flash-lite" by hand.
    const liveBtn = document.getElementById('liveModelsBtn');
    const liveStatus = document.getElementById('liveModelsStatus');
    if (liveBtn) {
        liveBtn.addEventListener('click', async () => {
            liveBtn.disabled = true;
            liveStatus.textContent = 'Lade…';
            liveStatus.style.color = 'inherit';
            try {
                const r = await fetch('/api/v1/ai/list-models', { credentials: 'same-origin' });
                const d = await r.json();
                if (d.error) {
                    liveStatus.textContent = '⚠ ' + d.error;
                    liveStatus.style.color = 'var(--status-critical, #d33)';
                    return;
                }
                const models = d.models || [];
                if (models.length === 0) {
                    liveStatus.textContent = 'Keine Modelle zurückgegeben.';
                    return;
                }
                // Preserve current selection.
                const cur = modelEl.value;
                modelEl.innerHTML = '';
                for (const m of models) {
                    const o = document.createElement('option');
                    o.value = m; o.textContent = m;
                    if (m === cur) o.selected = true;
                    modelEl.appendChild(o);
                }
                if (cur && !models.includes(cur)) {
                    const o = document.createElement('option');
                    o.value = cur; o.textContent = cur + ' (current)';
                    o.selected = true;
                    modelEl.insertBefore(o, modelEl.firstChild);
                }
                liveStatus.textContent = '✓ ' + models.length + ' Modelle geladen.';
                liveStatus.style.color = 'var(--status-ok, #22a05a)';
            } catch (e) {
                liveStatus.textContent = '⚠ ' + (e.message || e);
                liveStatus.style.color = 'var(--status-critical, #d33)';
            } finally {
                liveBtn.disabled = false;
            }
        });
    }
})();
</script>
