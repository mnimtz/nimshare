@using NimShare.Api.Services
@{
    ViewData["Title"] = T["chat.title"];
    Layout = "_AppShell";
    var enabled = (bool)(ViewData["Enabled"] ?? false);
    var groups = (List<GroupSummary>)(ViewData["Groups"] ?? new List<GroupSummary>());
}
<div class="page-header">
    <div>
        <h1>@T["chat.title"]</h1>
        <p class="lede">@T["chat.lede"]</p>
    </div>
</div>

@if (!enabled)
{
    <div class="card" style="border-left:3px solid var(--status-warn);background:rgba(255,198,0,.06)">
        @T["chat.disabled"]
    </div>
}
else
{
    @* v1.10.111: Chat als vollhohe, luftige Fläche statt kleiner fixer Box.
       Flex-Column füllt den verfügbaren Viewport; Log wächst, Eingabe bleibt
       unten angedockt. *@
    <div class="chat-shell">
        <div class="chat-toolbar">
            <label for="chatScope">@T["chat.scope"]</label>
            @* v1.10.112: Default auf Öffentlich — dort liegt die geteilte
               Dokumentation, über die man typischerweise chattet. *@
            <select id="chatScope">
                <option value="Public" selected>@T["browse.tile.public"]</option>
                <option value="Personal">@T["browse.tile.personal"]</option>
                @foreach (var g in groups)
                {
                    <option value="Group|@g.Id">@g.Name</option>
                }
            </select>
            <span class="chat-toolbar-note muted">@T["chat.note"]</span>
        </div>
        <div id="chatLog" class="chat-log">
            <div class="chat-empty muted">💬 @T["chat.placeholder"]</div>
        </div>
        <div class="chat-input-row">
            <textarea id="chatQ" rows="1" placeholder="@T["chat.placeholder"]"
                      onkeydown="if(event.key==='Enter'&&!event.shiftKey){event.preventDefault();chatSend();}"
                      oninput="chatAutoGrow(this)"></textarea>
            <button class="btn btn-primary" id="chatBtn" onclick="chatSend()">@T["chat.ask"]</button>
        </div>
    </div>
    <style>
        /* Chat füllt den Bereich unter dem Page-Header. 100dvh minus grobe
           Header/Padding-Reserve; auf Mobil greift dvh sauber. */
        .chat-shell {
            display: flex; flex-direction: column;
            height: calc(100dvh - 210px); min-height: 420px;
            max-width: 1100px; background: var(--tw-white);
            border: 1px solid var(--tw-gray-300); border-radius: var(--r-md);
            overflow: hidden;
        }
        .chat-toolbar {
            display: flex; align-items: center; gap: var(--sp-3);
            padding: var(--sp-3) var(--sp-4);
            border-bottom: 1px solid var(--tw-gray-200); flex-wrap: wrap;
        }
        .chat-toolbar label { font-weight: 600; font-size: .85rem; }
        .chat-toolbar select { min-width: 200px; }
        .chat-toolbar-note { font-size: .78rem; margin-left: auto; }
        .chat-log {
            flex: 1; overflow-y: auto; padding: var(--sp-4);
            background: var(--tw-gray-100); display: flex; flex-direction: column;
        }
        .chat-empty { margin: auto; font-size: 1rem; opacity: .7; }
        .chat-input-row {
            display: flex; gap: var(--sp-2); align-items: flex-end;
            padding: var(--sp-3) var(--sp-4);
            border-top: 1px solid var(--tw-gray-200); background: var(--tw-white);
        }
        .chat-input-row textarea {
            flex: 1; resize: none; max-height: 160px; line-height: 1.5;
            padding: 10px 12px; border-radius: var(--r-sm);
            border: 1px solid var(--tw-gray-300); font: inherit;
        }
        .chat-input-row .btn { align-self: stretch; padding-inline: var(--sp-5); }
        @@media (max-width: 640px) {
            .chat-shell { height: calc(100dvh - 170px); }
            .chat-toolbar-note { display: none; }
        }
    </style>
}

<script>
const log = document.getElementById('chatLog');
// v1.10.111: Eingabe-Textarea wächst mit dem Text (bis max-height per CSS).
function chatAutoGrow(el) {
    el.style.height = 'auto';
    el.style.height = Math.min(el.scrollHeight, 160) + 'px';
}
async function chatSend() {
    const qEl = document.getElementById('chatQ');
    const q = qEl.value.trim();
    if (!q) return;
    // Leerstaat-Hinweis beim ersten Senden entfernen.
    log.querySelector('.chat-empty')?.remove();
    const scopeSel = document.getElementById('chatScope').value;
    let scope = scopeSel, groupId = null;
    if (scopeSel.startsWith('Group|')) { scope = 'Group'; groupId = scopeSel.slice(6); }
    appendMsg('you', q);
    qEl.value = '';
    chatAutoGrow(qEl);
    document.getElementById('chatBtn').disabled = true;
    appendMsg('assistant', @Json.Serialize(T["chat.thinking"].Value), 'thinking');
    try {
        const r = await fetch('/api/v1/ai/chat', {
            method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
            body: JSON.stringify({ question: q, scope, groupId }),
        });
        document.querySelector('.msg.thinking')?.remove();
        if (!r.ok) {
            // Show the real reason so users know what to fix (AI disabled,
            // 503, quota, safety, model unavailable). Parse Problem-details
            // JSON, fall back to raw text.
            let detail = '';
            try { const p = await r.json(); detail = p.detail || p.title || ('HTTP ' + r.status); }
            catch { try { detail = await r.text(); } catch { detail = 'HTTP ' + r.status; } }
            appendMsg('assistant', @Json.Serialize(T["chat.error"].Value) + ' — ' + detail);
            return;
        }
        const d = await r.json();
        if (!d.answer) appendMsg('assistant', @Json.Serialize(T["chat.no_context"].Value));
        else {
            appendMsg('assistant', d.answer);
            if (d.citations?.length) {
                const cites = document.createElement('div');
                cites.style.cssText = 'margin-top:6px;font-size:.75rem;color:var(--tw-muted-blue)';
                cites.innerHTML = @Json.Serialize(T["chat.sources"].Value) + ' ' + d.citations.map((c,i)=>`[${i+1}] ${c.name}`).join(', ');
                log.appendChild(cites);
            }
        }
    } finally {
        document.getElementById('chatBtn').disabled = false;
        log.scrollTop = log.scrollHeight;
    }
}
function appendMsg(who, text, extra) {
    const el = document.createElement('div');
    el.className = 'msg ' + who + (extra ? ' ' + extra : '');
    // v1.10.111: Bubbles per align-self statt margin-hack; max-width für
    // angenehme Zeilenlänge im breiteren Fenster.
    el.style.cssText = 'margin:6px 0;padding:10px 14px;border-radius:12px;line-height:1.5;'
        + 'white-space:pre-wrap;max-width:78%;'
        + (who==='you' ? 'background:var(--tw-accent);color:white;align-self:flex-end;border-bottom-right-radius:4px;'
                       : 'background:white;border:1px solid var(--tw-gray-300);align-self:flex-start;border-bottom-left-radius:4px;');
    el.textContent = text;
    log.appendChild(el);
    log.scrollTop = log.scrollHeight;
}
</script>
