@using System.Globalization
@using Microsoft.EntityFrameworkCore
@inject NimShare.Core.Data.NimShareDbContext DbForShell
@{
    Layout = "_Layout";
    var currentPath = Context.Request.Path.Value ?? "/";
    string Active(string startsWith) => currentPath.StartsWith(startsWith, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    string Exact(string p) => string.Equals(currentPath, p, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    var supported = new[] { ("en", "EN"), ("de", "DE"), ("fr", "FR"), ("it", "IT"), ("es", "ES") };
    var cur = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isAdmin = User.IsInRole("Admin");

    var myGroups = new List<(Guid Id, string Name)>();
    var subClaim = User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
    if (Guid.TryParse(subClaim, out var myId))
    {
        myGroups = await DbForShell.GroupMemberships
            .Where(m => m.UserId == myId)
            .OrderBy(m => m.Group.Name)
            .Select(m => new ValueTuple<Guid, string>(m.GroupId, m.Group.Name))
            .ToListAsync();
    }
}
<div class="app-shell">
    <aside class="sidebar">
        <a class="sidebar-brand" href="/dashboard">
            <span class="logo-tile" style="background:var(--tw-white)">
                <svg width="32" height="32" viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg">
                    <rect width="32" height="32" rx="6" fill="var(--tw-primary)"/>
                    <path d="M6 22V10h4l6 8V10h4v12h-4l-6-8v8H6z" fill="var(--tw-white)"/>
                </svg>
            </span>
            <span class="wordmark">
                <span class="name">NimShare</span>
                <span class="product">by Tungsten</span>
            </span>
        </a>

        <nav class="sidebar-nav">
            <a href="/dashboard" class="@Active("/dashboard")">@T["nav.dashboard"]</a>
            <a href="/upload"    class="@Active("/upload")">@T["nav.upload"]</a>
            <a href="/links"     class="@Exact("/links")">@T["nav.links"]</a>

            <div style="height:1px;background:rgba(255,255,255,.08);margin:var(--sp-2) 0"></div>

            <div style="padding:var(--sp-2) var(--sp-4);font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:rgba(255,255,255,.5)">@T["nav.files"]</div>
            <a href="/files/personal" class="@Active("/files/personal")">@T["nav.files.personal"]</a>
            <a href="/files/public"   class="@Active("/files/public")">@T["nav.files.public"]</a>
            <a href="/groups"         class="@Exact("/groups")">@T["nav.groups"]</a>

            @foreach (var (gid, gname) in myGroups)
            {
                var active = currentPath.Contains($"/files/group/{gid}") || currentPath.Contains($"/groups/{gid}") ? "active" : "";
                <a href="/files/group/@gid" class="@active" style="padding-left:var(--sp-8);font-size:.85rem">@gname</a>
            }

            <div style="height:1px;background:rgba(255,255,255,.08);margin:var(--sp-2) 0"></div>

            <a href="/settings"  class="@Exact("/settings")">@T["nav.settings"]</a>
            <a href="/account/password" class="@Active("/account/password")">@T["nav.password"]</a>
            @if (isAdmin)
            {
                <a href="/settings/users" class="@Active("/settings/users")">@T["nav.users"]</a>
            }
        </nav>

        <div class="sidebar-footer">
            <div>@ViewData["UserName"]</div>
            <div class="lang-switcher" style="margin-top:8px">
                @foreach (var (code, label) in supported)
                {
                    var cls = code == cur ? "active" : "";
                    <a href="?ui-culture=@code" class="@cls">@label</a>
                }
            </div>
            <div style="margin-top:12px;display:flex;justify-content:space-between;align-items:center">
                <a href="/logout" style="color:rgba(255,255,255,.7);font-size:.8rem">@T["nav.signout"]</a>
                <span style="color:rgba(255,255,255,.35);font-size:.7rem;font-family:var(--font-mono)">v@(NimShare.Api.BuildInfo.Version)</span>
            </div>
        </div>
    </aside>

    <main class="workspace">
        @RenderBody()
    </main>
</div>
