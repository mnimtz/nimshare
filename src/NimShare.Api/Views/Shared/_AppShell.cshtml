@using System.Globalization
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using NimShare.Core.Entities
@inject NimShare.Core.Data.NimShareDbContext DbForShell
@{
    Layout = "_Layout";
    var currentPath = Context.Request.Path.Value ?? "/";
    string Active(string startsWith) => currentPath.StartsWith(startsWith, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    string Exact(string p) => string.Equals(currentPath, p, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    var supported = new[]
    {
        ("en", "English"),
        ("de", "Deutsch"),
        ("fr", "Français"),
        ("it", "Italiano"),
        ("es", "Español"),
        ("nl", "Nederlands"),
    };
    var cur = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isAdmin = User.IsInRole("Admin");

    // Load the current user + their groups for the sidebar user-card + group list.
    string displayName = User.Identity?.Name ?? "";
    string email = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    string initials = "?";
    string? avatarUrl = null;
    var myGroups = new List<(Guid Id, string Name)>();
    var subClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    if (Guid.TryParse(subClaim, out var myId))
    {
        var u = await DbForShell.Users.FindAsync(myId);
        if (u is not null) { displayName = u.DisplayName; email = u.Email; avatarUrl = u.AvatarUrl; }
        if (!string.IsNullOrWhiteSpace(displayName))
        {
            var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            initials = parts.Length switch
            {
                >= 2 => $"{parts[0][0]}{parts[^1][0]}",
                1 => parts[0].Length > 1 ? parts[0][..2] : parts[0],
                _ => "?"
            };
        }
        myGroups = await DbForShell.GroupMemberships
            .Where(m => m.UserId == myId)
            .OrderBy(m => m.Group.Name)
            .Select(m => new ValueTuple<Guid, string>(m.GroupId, m.Group.Name))
            .ToListAsync(Context.RequestAborted);
    }

    var settingsOpen = currentPath.StartsWith("/settings", StringComparison.OrdinalIgnoreCase)
                       || currentPath.StartsWith("/account", StringComparison.OrdinalIgnoreCase);
    var browseOpen = currentPath.StartsWith("/browse", StringComparison.OrdinalIgnoreCase);

    // Which library scope is currently in view — drives the highlight on the
    // Ablage sub-nav so the user always knows where they are.
    string browseKind = "";
    Guid? browseGroupId = null;
    if (browseOpen)
    {
        var parts = currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            browseKind = parts[1].ToLowerInvariant();
            if (browseKind == "group" && parts.Length >= 3 && Guid.TryParse(parts[2], out var gg)) browseGroupId = gg;
        }
    }
}
<div class="app-shell">
    <!-- Mobile top-bar with hamburger — only shown on narrow screens -->
    <header class="mobile-topbar">
        <button class="mobile-menu-btn" aria-label="@T["nav.menu"]" onclick="document.body.classList.toggle('nav-open')">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <a class="mobile-brand" href="/dashboard">
            <img src="~/img/icon-64.png" width="28" height="28" alt="NimShare"/>
            <span>NimShare</span>
        </a>
        <span style="width:40px"></span>
    </header>
    <div class="nav-backdrop" onclick="document.body.classList.remove('nav-open')"></div>

    <aside class="sidebar">
        <a class="sidebar-brand" href="/dashboard">
            <span class="logo-tile" style="background:transparent;box-shadow:none;padding:0">
                <img src="~/img/icon-64.png" width="44" height="44" alt="NimShare" style="border-radius:8px"/>
            </span>
            <span class="wordmark">
                <span class="name">NimShare</span>
                <span class="product">Share. Upload. Anywhere.</span>
            </span>
        </a>

        <nav class="sidebar-nav">
            <a href="/dashboard" class="@Active("/dashboard")">@T["nav.dashboard"]</a>

            <!-- ── Ablage: expandable with library sub-items ────────────── -->
            <div class="nav-group @(browseOpen ? "" : "collapsed")" onclick="if(!event.target.closest('a'))this.classList.toggle('collapsed')">
                <div class="nav-group-head">
                    <span>📁 @T["nav.storage"]</span>
                    <span class="chevron">▾</span>
                </div>
                <div class="nav-group-body">
                    <a href="/browse/personal" class="nav-sub @(browseOpen && browseKind == "personal" ? "active" : "")">
                        <span class="nav-sub-ic">👤</span>@T["browse.libraries.mine"]
                    </a>
                    <a href="/browse/public" class="nav-sub @(browseOpen && browseKind == "public" ? "active" : "")">
                        <span class="nav-sub-ic">🌐</span>@T["browse.libraries.shared"]
                    </a>
                    @foreach (var (gId, gName) in myGroups)
                    {
                        var isCur = browseOpen && browseKind == "group" && browseGroupId == gId;
                        <a href="/browse/group/@gId" class="nav-sub @(isCur ? "active" : "")">
                            <span class="nav-sub-ic">👥</span>@gName
                        </a>
                    }
                </div>
            </div>

            <a href="/links"     class="@Exact("/links")">🔗 @T["nav.links"]</a>
            <a href="/ai/chat"   class="@Active("/ai/chat")">✨ @T["nav.chat"]</a>

            <div class="nav-section @(settingsOpen ? "" : "collapsed")" style="margin-top:var(--sp-2)" onclick="if(!event.target.closest('a'))this.classList.toggle('collapsed')">
                <span>@T["nav.settings"]</span><span class="chevron">▾</span>
            </div>
            <div class="nav-section-body">
                <a href="/settings/profile" class="@Active("/settings/profile")">@T["nav.profile"]</a>
                @if (isAdmin)
                {
                    <a href="/settings/users" class="@Active("/settings/users")">@T["nav.users"]</a>
                    <a href="/settings/email" class="@Active("/settings/email")">@T["nav.email_gateway"]</a>
                    <a href="/settings/ai" class="@Active("/settings/ai")">@T["nav.ai_gateway"]</a>
                }
                <a href="/settings" class="@Exact("/settings")">@T["nav.domains"]</a>
            </div>
        </nav>

        <div class="sidebar-footer">
            <details class="sidebar-lang">
                <summary>
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="10" cy="10" r="8"/>
                        <path d="M2 10 h16 M10 2 c2.5 3 2.5 13 0 16 M10 2 c-2.5 3-2.5 13 0 16"/>
                    </svg>
                    <span class="label">@(supported.FirstOrDefault(s => s.Item1 == cur).Item2)</span>
                    <svg class="chev" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="12" height="12">
                        <path d="M3 4.5 L6 7.5 L9 4.5"/>
                    </svg>
                </summary>
                <div class="menu" role="menu">
                    @foreach (var (code, label) in supported)
                    {
                        var cls = code == cur ? "current" : "";
                        <a href="?ui-culture=@code" class="@cls">@label</a>
                    }
                </div>
            </details>

            <div class="user-card">
                <div class="avatar">
                    @if (!string.IsNullOrEmpty(avatarUrl))
                    {
                        <img src="@avatarUrl" alt="@displayName"/>
                    }
                    else
                    {
                        @initials
                    }
                </div>
                <div class="name-block">
                    <div class="name">@displayName</div>
                    <div class="email">@email</div>
                </div>
                <a href="/logout" class="signout" title="@T["nav.signout"]" aria-label="@T["nav.signout"]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                </a>
            </div>

            <div style="margin-top:var(--sp-3);color:rgba(255,255,255,.35);font-size:.7rem;font-family:var(--font-mono);text-align:center">
                NimShare v@(NimShare.Api.BuildInfo.Version)
            </div>
        </div>
    </aside>

    <main class="workspace">
        @RenderBody()
    </main>
</div>
<script>
    // Close off-canvas drawer when a nav link is tapped (mobile).
    document.querySelectorAll('.sidebar-nav a, .sidebar-brand').forEach(a => {
        a.addEventListener('click', () => document.body.classList.remove('nav-open'));
    });
</script>
