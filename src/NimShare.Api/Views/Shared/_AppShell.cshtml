@using System.Globalization
@using System.Security.Claims
@using Microsoft.EntityFrameworkCore
@using NimShare.Core.Entities
@inject NimShare.Core.Data.NimShareDbContext DbForShell
@{
    Layout = "_Layout";
    var currentPath = Context.Request.Path.Value ?? "/";
    string Active(string startsWith) => currentPath.StartsWith(startsWith, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    string Exact(string p) => string.Equals(currentPath, p, StringComparison.OrdinalIgnoreCase) ? "active" : "";
    var supported = new[]
    {
        ("en", "English"),
        ("de", "Deutsch"),
        ("fr", "Français"),
        ("it", "Italiano"),
        ("es", "Español"),
        ("nl", "Nederlands"),
    };
    var cur = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isAdmin = User.IsInRole("Admin");

    // Load the current user + their groups for the sidebar user-card + group list.
    string displayName = User.Identity?.Name ?? "";
    string email = User.FindFirst(ClaimTypes.Email)?.Value ?? "";
    string initials = "?";
    string? avatarUrl = null;
    var myGroups = new List<(Guid Id, string Name)>();
    var subClaim = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    if (Guid.TryParse(subClaim, out var myId))
    {
        var u = await DbForShell.Users.FindAsync(myId);
        if (u is not null) { displayName = u.DisplayName; email = u.Email; avatarUrl = u.AvatarUrl; }
        if (!string.IsNullOrWhiteSpace(displayName))
        {
            var parts = displayName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
            initials = parts.Length switch
            {
                >= 2 => $"{parts[0][0]}{parts[^1][0]}",
                1 => parts[0].Length > 1 ? parts[0][..2] : parts[0],
                _ => "?"
            };
        }
        myGroups = await DbForShell.GroupMemberships
            .Where(m => m.UserId == myId)
            .OrderBy(m => m.Group.Name)
            .Select(m => new ValueTuple<Guid, string>(m.GroupId, m.Group.Name))
            .ToListAsync(Context.RequestAborted);
    }

    var settingsOpen = currentPath.StartsWith("/settings", StringComparison.OrdinalIgnoreCase)
                       || currentPath.StartsWith("/account", StringComparison.OrdinalIgnoreCase);
    var browseOpen = currentPath.StartsWith("/browse", StringComparison.OrdinalIgnoreCase);

    // Which library scope is currently in view — drives the highlight on the
    // Ablage sub-nav so the user always knows where they are.
    string browseKind = "";
    Guid? browseGroupId = null;
    if (browseOpen)
    {
        var parts = currentPath.Split('/', StringSplitOptions.RemoveEmptyEntries);
        if (parts.Length >= 2)
        {
            browseKind = parts[1].ToLowerInvariant();
            if (browseKind == "group" && parts.Length >= 3 && Guid.TryParse(parts[2], out var gg)) browseGroupId = gg;
        }
    }
}
<div class="app-shell">
    <!-- Mobile top-bar with hamburger — only shown on narrow screens -->
    <header class="mobile-topbar">
        <button class="mobile-menu-btn" aria-label="@T["nav.menu"]" onclick="document.body.classList.toggle('nav-open')">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
        <a class="mobile-brand" href="/dashboard">
            <img src="~/img/icon-64.png" alt="NimShare"/>
            <span>NimShare</span>
        </a>
        <span style="width:30px"></span>
    </header>
    <div class="nav-backdrop" onclick="document.body.classList.remove('nav-open')"></div>

    <aside class="sidebar">
        <a class="sidebar-brand" href="/dashboard">
            <span class="logo-tile" style="background:transparent;box-shadow:none;padding:0">
                <img src="~/img/icon-64.png" width="44" height="44" alt="NimShare" style="border-radius:8px"/>
            </span>
            <span class="wordmark">
                <span class="name">NimShare</span>
                <span class="product">Share. Upload. Anywhere.</span>
            </span>
        </a>

        <nav class="sidebar-nav">
            <a href="/dashboard" class="@Active("/dashboard")">@T["nav.dashboard"]</a>

            <!-- ── Ablage: expandable with library sub-items ────────────── -->
            <div class="nav-group @(browseOpen ? "" : "collapsed")" onclick="if(!event.target.closest('a'))this.classList.toggle('collapsed')">
                <div class="nav-group-head">
                    <span>📁 @T["nav.storage"]</span>
                    <span class="chevron">▾</span>
                </div>
                <div class="nav-group-body">
                    <a href="/browse/personal" class="nav-sub @(browseOpen && browseKind == "personal" ? "active" : "")">
                        <span class="nav-sub-ic">👤</span>@T["browse.libraries.mine"]
                    </a>
                    <a href="/browse/public" class="nav-sub @(browseOpen && browseKind == "public" ? "active" : "")">
                        <span class="nav-sub-ic">🌐</span>@T["browse.libraries.shared"]
                    </a>
                    @* v1.10.102: Group-Bibliotheken aus Sidebar entfernt.
                       Marcus's Präzisierung: Gruppen sind nur noch Verteiler-
                       Namen für „Teilen mit → Gruppe" (via 🤝), keine eigene
                       Team-Bibliothek mehr. Bestehende Group-Scope-Files bleiben
                       in der DB und via /browse/group/{id} erreichbar (BC), aber
                       tauchen nicht mehr prominent auf. Ordner-ACL für Public
                       kommt in v1.10.103 als eigener Feature-Umbau. *@
                    <a href="/favorites" class="nav-sub @Exact("/favorites")">
                        <span class="nav-sub-ic">⭐</span>@T["nav.favorites"]
                    </a>
                    <a href="/shared-with-me" class="nav-sub @Exact("/shared-with-me")">
                        <span class="nav-sub-ic">🤝</span>@T["nav.shared_with_me"]
                    </a>
                    <a href="/trash" class="nav-sub @Exact("/trash")">
                        <span class="nav-sub-ic">🗑</span>@T["nav.trash"]
                    </a>
                </div>
            </div>

            <a href="/links"     class="@Exact("/links")">🔗 @T["nav.links"]</a>

            @{
                // v1.10.153: Zertifikate aus Signatur-Gruppe rausgezogen zum
                // eigenen Top-Level-Eintrag — sie werden ja nicht nur für
                // Signaturen genutzt, sondern auch für Share-/Upload-Link-
                // Signierung („Verifiziert-Absender"-Landing).
                var sigOpen = currentPath.StartsWith("/signatures", StringComparison.OrdinalIgnoreCase)
                              && !currentPath.StartsWith("/signatures/certificates", StringComparison.OrdinalIgnoreCase);
            }
            <div class="nav-group @(sigOpen ? "" : "collapsed")" onclick="if(!event.target.closest('a'))this.classList.toggle('collapsed')">
                <div class="nav-group-head">
                    <span>✍ @T["nav.signatures"]</span>
                    <span class="chevron">▾</span>
                </div>
                <div class="nav-group-body">
                    <a href="/signatures" class="nav-sub @(currentPath.Equals("/signatures", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                        <span class="nav-sub-ic">📋</span>@T["nav.sig.overview"]
                    </a>
                    <a href="/signatures/templates" class="nav-sub @(currentPath.StartsWith("/signatures/templates", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                        <span class="nav-sub-ic">✉</span>@T["nav.sig.templates"]
                    </a>
                    <a href="/signatures/contacts" class="nav-sub @(currentPath.StartsWith("/signatures/contacts", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                        <span class="nav-sub-ic">👥</span>@T["nav.sig.contacts"]
                    </a>
                </div>
            </div>
            <a href="/signatures/certificates" class="@(currentPath.StartsWith("/signatures/certificates", StringComparison.OrdinalIgnoreCase) ? "active" : "")">🔐 @T["nav.sig.certificates"]</a>

            <a href="/link-collection" class="@Active("/link-collection")">🔗 @T["nav.linkcol"]</a>
            <a href="/notifications" class="@Exact("/notifications")" id="navNotifications">
                🔔 @T["nav.notifications"]
                <span id="navNotifBadge" class="nav-badge" style="display:none"></span>
            </a>
            <a href="/activity"  class="@Exact("/activity")">🕐 @T["nav.activity"]</a>
            <a href="/ai/chat"   class="@Active("/ai/chat")">✨ @T["nav.chat"]</a>

            <div class="nav-section @(settingsOpen ? "" : "collapsed")" style="margin-top:var(--sp-2)" onclick="if(!event.target.closest('a'))this.classList.toggle('collapsed')">
                <span>@T["nav.settings"]</span><span class="chevron">▾</span>
            </div>
            <div class="nav-section-body">
                @* v1.10.93: Nur User-relevante Settings für Nicht-Admins.
                   Marcus's Report: „ich kann als normaler User Domain sehen,
                   sollte man nicht — auch keine API-Tokens". Beide Features
                   sind Admin/Power-User-Krams; Standard-User brauchen sie nie. *@
                <a href="/settings/2fa" class="@Exact("/settings/2fa")">@T["settings.2fa"]</a>
                <a href="/settings/landing/mine" class="@Exact("/settings/landing/mine")">@T["settings.download_page"]</a>
                @if (isAdmin)
                {
                    <a href="/settings/dev" class="@Exact("/settings/dev")">@T["settings.dev"]</a>
                    <a href="/settings" class="@Exact("/settings")">@T["nav.domains"]</a>
                    <a href="/settings/users" class="@Active("/settings/users")">@T["nav.users"]</a>
                    <a href="/settings/landing/global" class="@Exact("/settings/landing/global")">@T["settings.public_download_page"]</a>
                    <a href="/settings/email" class="@Active("/settings/email")">@T["nav.email_gateway"]</a>
                    <a href="/settings/office" class="@Active("/settings/office")">@T["settings.office"]</a>
                    <a href="/settings/ai" class="@Active("/settings/ai")">@T["nav.ai_gateway"]</a>
                    @* v1.10.145: DB-Migration (Azure SQL) vorerst ausgeblendet —
                       der Wizard braucht noch Härtung (Copy-first-switch-last,
                       echte Fehlermeldung, Not-Aus). Route bleibt bestehen,
                       nur nicht mehr verlinkt, damit nichts versehentlich
                       ausgelöst wird. Backup & Restore ist der aktuelle Fokus. *@
                    @* <a href="/settings/database" class="@Active("/settings/database")">@T["nav.database"]</a> *@
                    <a href="/settings/backup" class="@Active("/settings/backup")">💾 @T["nav.backup"]</a>
                    <a href="/settings/moderation" class="@Active("/settings/moderation")">🛡 @T["nav.moderation"]</a>
                }
            </div>
        </nav>

        <div class="sidebar-footer">
            <details class="sidebar-lang">
                <summary>
                    <svg viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="10" cy="10" r="8"/>
                        <path d="M2 10 h16 M10 2 c2.5 3 2.5 13 0 16 M10 2 c-2.5 3-2.5 13 0 16"/>
                    </svg>
                    <span class="label">@(supported.FirstOrDefault(s => s.Item1 == cur).Item2)</span>
                    <svg class="chev" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" width="12" height="12">
                        <path d="M3 4.5 L6 7.5 L9 4.5"/>
                    </svg>
                </summary>
                <div class="menu" role="menu">
                    @{
                        var currentUrl = Context.Request.Path + Context.Request.QueryString;
                    }
                    @foreach (var (code, label) in supported)
                    {
                        var cls = code == cur ? "current" : "";
                        <a href="/set-culture?code=@code&returnUrl=@Uri.EscapeDataString(currentUrl.ToString())" class="@cls">@label</a>
                    }
                </div>
            </details>

            <div class="user-card">
                <div class="avatar">
                    @if (!string.IsNullOrEmpty(avatarUrl))
                    {
                        <img src="@avatarUrl" alt="@displayName"/>
                    }
                    else
                    {
                        @initials
                    }
                </div>
                <div class="name-block">
                    <div class="name">@displayName</div>
                    <div class="email">@email</div>
                </div>
                <a href="/logout" class="signout" title="@T["nav.signout"]" aria-label="@T["nav.signout"]">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
                </a>
            </div>

            <div style="margin-top:var(--sp-3);color:rgba(255,255,255,.35);font-size:.7rem;font-family:var(--font-mono);text-align:center">
                NimShare v@(NimShare.Api.BuildInfo.Version)
            </div>
        </div>
    </aside>

    <main class="workspace">
        @RenderBody()
    </main>
</div>
@* v1.10.53 — nimConfirm/nimAlert/nimToast global verfügbar. `defer`
   damit die Skripte darunter (die noch alte confirm() nutzen bis
   sie migriert sind) trotzdem laden können. *@
<script src="~/js/dialogs.js" defer></script>
<script>
    // Localised labels for the JS helpers below (nsPrompt/nsConfirm/avatar popover).
    window.T_cancel = @Json.Serialize(T["modal.cancel"].Value);
    window.T_profile = @Json.Serialize(T["nav.profile"].Value);
    window.T_logout = @Json.Serialize(T["nav.signout"].Value);
</script>
<script>
    // Close off-canvas drawer when a nav link is tapped (mobile).
    document.querySelectorAll('.sidebar-nav a, .sidebar-brand').forEach(a => {
        a.addEventListener('click', () => document.body.classList.remove('nav-open'));
    });

    // ── Robust modal close ─────────────────────────────────────
    // Historically every .modal-backdrop had `onclick="if(event.target===this)
    // closeModal(id)"`. That closes when a drag starts INSIDE the panel (say,
    // selecting text in an input) and ends OUTSIDE it — the mouseup lands on
    // the backdrop and fires a click there. Track mousedown target too, and
    // only close when BOTH ends of the click were on the backdrop itself.
    (function robustModalClose() {
        let startedOnBackdrop = false;
        document.addEventListener('mousedown', e => {
            const bd = e.target.closest && e.target.closest('.modal-backdrop');
            startedOnBackdrop = !!(bd && e.target === bd);
        }, true);
        document.addEventListener('click', e => {
            const bd = e.target.classList && e.target.classList.contains('modal-backdrop') ? e.target : null;
            if (!bd) return;
            if (!startedOnBackdrop) { e.stopPropagation(); return; }
            // Backdrop click → close. The existing inline `onclick` on many
            // modals still fires afterwards; that's a no-op because we've
            // already closed. Guard for pages without a global closeModal.
            bd.classList.remove('open');
            if (typeof window.closeModal === 'function') try { window.closeModal(bd.id); } catch {}
        }, true);
        // Escape closes the top-most open modal.
        document.addEventListener('keydown', e => {
            if (e.key !== 'Escape') return;
            const open = Array.from(document.querySelectorAll('.modal-backdrop.open'));
            if (!open.length) return;
            open[open.length - 1].classList.remove('open');
        });
    })();

    // ── nsPrompt / nsConfirm — modern replacements for window.prompt/confirm.
    // The browser's native prompt() renders as an ugly alert bar (Chrome) or a
    // full-screen popover (Safari mobile) and can't be styled or i18n'd. These
    // helpers use the app's existing .modal-backdrop pattern, return a Promise
    // and share their DOM across every caller (one element, appended lazily).
    (function () {
        function ensureHost() {
            let host = document.getElementById('nsPromptHost');
            if (host) return host;
            host = document.createElement('div');
            host.id = 'nsPromptHost';
            host.className = 'modal-backdrop';
            host.innerHTML = '<div class="modal-panel" style="max-width:460px">' +
                '<h3 id="nsPromptTitle" style="margin-top:0"></h3>' +
                '<p id="nsPromptMsg" class="muted" style="margin:0 0 10px"></p>' +
                '<div class="field" id="nsPromptField" style="margin:0 0 12px">' +
                    '<input id="nsPromptInput" type="text" style="width:100%" autofocus/>' +
                '</div>' +
                '<div class="actions" style="justify-content:flex-end;gap:8px">' +
                    '<button type="button" class="btn btn-ghost" id="nsPromptCancel">' + (window.T_cancel || 'Abbrechen') + '</button>' +
                    '<button type="button" class="btn btn-primary" id="nsPromptOk">OK</button>' +
                '</div>' +
                '</div>';
            document.body.appendChild(host);
            return host;
        }
        function open(kind, title, message, defaultValue) {
            const host = ensureHost();
            document.getElementById('nsPromptTitle').textContent = title || '';
            document.getElementById('nsPromptMsg').textContent = message || '';
            const field = document.getElementById('nsPromptField');
            const input = document.getElementById('nsPromptInput');
            field.style.display = kind === 'prompt' ? '' : 'none';
            input.value = defaultValue || '';
            host.classList.add('open');
            if (kind === 'prompt') setTimeout(() => input.focus(), 30);
            return new Promise(resolve => {
                function cleanup() {
                    host.classList.remove('open');
                    document.getElementById('nsPromptOk').onclick = null;
                    document.getElementById('nsPromptCancel').onclick = null;
                    document.removeEventListener('keydown', keyHandler, true);
                }
                function keyHandler(e) {
                    if (e.key === 'Escape') { cleanup(); resolve(null); }
                    else if (e.key === 'Enter' && kind === 'prompt') { cleanup(); resolve(input.value); }
                }
                document.addEventListener('keydown', keyHandler, true);
                document.getElementById('nsPromptOk').onclick = () => {
                    const value = kind === 'prompt' ? input.value : true;
                    cleanup();
                    resolve(value);
                };
                document.getElementById('nsPromptCancel').onclick = () => {
                    cleanup();
                    resolve(kind === 'prompt' ? null : false);
                };
            });
        }
        window.nsPrompt = (title, message, defaultValue) => open('prompt', title, message, defaultValue);
        window.nsConfirm = (title, message) => open('confirm', title, message);
    })();

    // ── Unread notification badge — polled every 60 s ─────────
    (function () {
        const el = document.getElementById('navNotifBadge');
        if (!el) return;
        async function refresh() {
            try {
                const r = await fetch('/api/v1/notifications/unread-count', { credentials: 'same-origin' });
                if (!r.ok) return;
                const d = await r.json();
                const n = d.unreadCount || d.count || 0;
                if (n > 0) { el.textContent = n > 99 ? '99+' : String(n); el.style.display = ''; }
                else { el.style.display = 'none'; }
            } catch {}
        }
        refresh();
        setInterval(refresh, 60000);
    })();

    // ── Avatar-popover with profile shortcut ─────────────────────
    // Wraps the sidebar footer avatar in a click-to-open menu (Profil, Log-out).
    // v1.10.9: der alte Selector .sidebar-user existierte nicht im DOM — die
    // sidebar heißt .user-card mit .avatar+.name-block darin. Klick war
    // deswegen NIE gebunden, Marcus's "Profil verschwunden"-Report war
    // korrekt. Bindet jetzt Avatar UND Name (beides Klick-Ziel).
    (function () {
        const card = document.querySelector('.sidebar-footer .user-card');
        if (!card) return;
        const clickable = [card.querySelector('.avatar'), card.querySelector('.name-block')];
        for (const el of clickable) {
            if (!el) continue;
            el.style.cursor = 'pointer';
            el.title = window.T_profile || 'Profil';
            el.addEventListener('click', (e) => {
                // Don't intercept the sign-out button on the right of the card.
                if (e.target.closest('.signout')) return;
                e.preventDefault(); e.stopPropagation();
                let pop = document.getElementById('avatarPop');
                if (pop) { pop.remove(); return; }
                pop = document.createElement('div');
                pop.id = 'avatarPop';
                pop.className = 'avatar-popover';
                pop.innerHTML = '<a href="/settings/profile">👤 ' + (window.T_profile || 'Profil') + '</a>' +
                    '<a href="/logout" class="logout">↩ ' + (window.T_logout || 'Abmelden') + '</a>';
                document.body.appendChild(pop);
                const rect = card.getBoundingClientRect();
                pop.style.left = (rect.right + 8) + 'px';
                pop.style.bottom = (window.innerHeight - rect.bottom - 4) + 'px';
                setTimeout(() => document.addEventListener('click', function close(ev) {
                    if (!pop.contains(ev.target)) { pop.remove(); document.removeEventListener('click', close); }
                }), 0);
            });
        }
    })();
</script>
@await RenderSectionAsync("Scripts", required: false)
