@model NimShare.Api.Controllers.SignDoneViewModel
@{
    ViewData["Title"] = T["sign.done_title"];
    Layout = "_Layout";
    var theme = ViewData["Theme"] as NimShare.Api.Controllers.SignLandingTheme;
    var brandColor = string.IsNullOrWhiteSpace(theme?.PrimaryColor) ? null : theme!.PrimaryColor;
}
@if (brandColor is not null)
{
    <style>
        .landing-shell { --tw-primary: @brandColor; --tw-primary-alt: @brandColor; }
        .btn-primary { background: @brandColor !important; border-color: @brandColor !important; }
    </style>
}
<div class="landing-shell">
    <div class="landing-card" style="max-width:520px;text-align:center;position:relative">
        @if (!string.IsNullOrEmpty(theme?.OwnerAvatarUrl))
        {
            <img src="@theme.OwnerAvatarUrl" alt="@theme.OwnerName" title="@theme.OwnerName"
                 style="position:absolute;top:20px;right:22px;width:64px;height:64px;border-radius:50%;object-fit:cover;box-shadow:0 6px 20px rgba(0,0,0,.18),0 0 0 4px #fff,0 0 0 5px rgba(0,0,0,.06);z-index:2"/>
        }
        @if (!string.IsNullOrWhiteSpace(theme?.LogoUrl))
        {
            <img src="@theme.LogoUrl" alt="Logo" style="max-height:44px;max-width:180px;object-fit:contain;margin-bottom:12px"/>
        }
        <div style="font-size:4rem;line-height:1;margin-bottom:12px">@(Model.Signed ? "✅" : "✕")</div>
        <h1 style="margin-top:0">@(Model.Signed ? T["sign.done_thanks"] : T["sign.done_declined"])</h1>
        <p class="muted">
            @if (Model.Signed)
            {
                <span>@string.Format(T["sign.done_signed_body"].Value, Model.Request.Initiator?.DisplayName ?? "")</span>
            }
            else
            {
                <span>@string.Format(T["sign.done_declined_body"].Value, Model.Request.Title ?? "")</span>
            }
        </p>
        <p class="muted" style="font-size:.75rem;margin-top:24px">
            @if (!string.IsNullOrWhiteSpace(theme?.FooterText))
            {
                @theme.FooterText
            }
            else
            {
                <text>Powered by <strong>NimShare</strong></text>
            }
        </p>
    </div>
</div>
