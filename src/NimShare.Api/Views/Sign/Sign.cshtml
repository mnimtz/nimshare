            return;
        }
        if (r.status === 401 || r.status === 403) {
            info.innerHTML = renderCertNeededLoginHtml();
            return;
        }
        if (r.status === 404) {
            info.innerHTML = window.__sig_i18n.cert_no_default_html;
            return;
        }
        if (!r.ok) { info.textContent = window.__sig_i18n.cert_load_error + ' HTTP ' + r.status; return; }
