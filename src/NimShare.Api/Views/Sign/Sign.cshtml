// Tiny signature pad: capture pointer events, draw lines, expose to hidden input on submit.
(function(){
    const c = document.getElementById('sigPad');
    const ctx = c.getContext('2d');
    let drawing = false, empty = true;
    ctx.lineWidth = 2; ctx.lineCap = 'round'; ctx.strokeStyle = '#001d3d';
    function pos(e){ const r = c.getBoundingClientRect(); return { x: (e.clientX - r.left) * (c.width/r.width), y: (e.clientY - r.top) * (c.height/r.height) }; }
    // Live-mirror the pad drawing into every yellow signature placeholder
    // in the PDF preview so the signer sees exactly what will be stamped
    // onto the document. Each placeholder gets its own <img> lazily.
    function mirrorToPlaceholders() {
        if (empty) return;
        const dataUrl = c.toDataURL('image/png');
        document.querySelectorAll('.sig-placeholder').forEach(p => {
            let img = p.querySelector('img.sig-preview-img');
            if (!img) {
                p.textContent = ''; // clear the "✍ Hier unterschreiben" hint
                p.style.background = 'transparent';
                p.style.border = '2px solid rgba(255,198,0,.55)';
                img = document.createElement('img');
                img.className = 'sig-preview-img';
                img.style.cssText = 'width:100%;height:100%;object-fit:contain;display:block;pointer-events:none';
                p.appendChild(img);
            }
            img.src = dataUrl;
        });
    }
    function restorePlaceholders() {
        document.querySelectorAll('.sig-placeholder').forEach(p => {
            const img = p.querySelector('img.sig-preview-img');
            if (img) img.remove();
            p.style.background = 'rgba(255,198,0,.25)';
            p.style.border = '2px solid #ffc600';
            const w = parseFloat(p.dataset.fieldWidth || '0');
            p.textContent = w > 100 ? ('✍ ' + window.__sig_i18n.placeholder_here) : '✍';
        });
    }
