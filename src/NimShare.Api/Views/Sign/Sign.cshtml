@model NimShare.Api.Controllers.SignViewModel
@using NimShare.Core.Entities
@{
    ViewData["Title"] = Model.Request.Title;
    Layout = "_Layout";
    var isSigner = Model.Me.Role == SignatureParticipantRole.Signer;
}
<div class="landing-shell">
    <div class="landing-card" style="max-width:720px">
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
            <img src="/img/icon-64.png" width="32" height="32" style="border-radius:6px"/>
            <div>
                <div style="font-size:.8rem;color:var(--tw-muted-blue)">NimShare Signatur</div>
                <div style="font-weight:700">@Model.Request.Title</div>
            </div>
        </div>
        <p class="muted">Hallo <strong>@Model.Me.Name</strong>, @Model.Request.Initiator?.DisplayName bittet dich, dieses Dokument @(isSigner ? "zu unterschreiben" : "zur Kenntnis zu nehmen").</p>
        @if (!string.IsNullOrEmpty(Model.Request.Message))
        {
            <div class="card" style="background:var(--tw-gray-100);margin:12px 0">@Model.Request.Message</div>
        }

        <iframe src="/sign/@Model.Me.Id/preview?t=@Model.Token" title="PDF" style="width:100%;height:60vh;border:1px solid var(--tw-gray-300);border-radius:8px;background:#fff"></iframe>

        <form method="post" action="/sign/@Model.Me.Id/submit?t=@Model.Token" style="margin-top:16px" id="signForm">
            @Html.AntiForgeryToken()
            @if (isSigner)
            {
                <div class="field">
                    <label>Dein Name (für die Unterschrift)</label>
                    <input type="text" name="typedName" required value="@Model.Me.Name" maxlength="120"/>
                </div>
                <div class="field">
                    <label>Unterschrift (unten zeichnen)</label>
                    <div style="border:2px dashed var(--tw-gray-300);border-radius:8px;background:#fff;position:relative">
                        <canvas id="sigPad" width="720" height="180" style="width:100%;height:180px;touch-action:none;display:block"></canvas>
                        <button type="button" onclick="clearSig()" style="position:absolute;top:6px;right:6px;background:var(--tw-gray-100);border:0;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:.8rem">Löschen</button>
                    </div>
                </div>
                <input type="hidden" name="signatureData" id="signatureData"/>
            }
            <div class="row" style="justify-content:space-between;margin-top:16px;flex-wrap:wrap;gap:8px">
                <button type="button" class="btn btn-ghost" onclick="declineOpen()">✕ Ablehnen</button>
                <button type="submit" class="btn btn-primary" onclick="return prepareSubmit(this)">
                    @(isSigner ? "✍ Unterschreiben & abschicken" : "✓ Gelesen bestätigen")
                </button>
            </div>
        </form>

        <form method="post" action="/sign/@Model.Me.Id/decline?t=@Model.Token" id="declineForm" style="display:none;margin-top:12px">
            @Html.AntiForgeryToken()
            <div class="field">
                <label>Grund (optional)</label>
                <textarea name="reason" rows="2" maxlength="500"></textarea>
            </div>
            <div class="row" style="justify-content:flex-end;gap:8px">
                <button type="button" class="btn btn-ghost" onclick="declineOpen()">Zurück</button>
                <button type="submit" class="btn btn-primary" style="background:var(--status-critical)">Ablehnen bestätigen</button>
            </div>
        </form>
    </div>
</div>

@if (isSigner)
{
<script>
// Tiny signature pad: capture pointer events, draw lines, expose to hidden input on submit.
(function(){
    const c = document.getElementById('sigPad');
    const ctx = c.getContext('2d');
    let drawing = false, empty = true;
    ctx.lineWidth = 2; ctx.lineCap = 'round'; ctx.strokeStyle = '#001d3d';
    function pos(e){ const r = c.getBoundingClientRect(); return { x: (e.clientX - r.left) * (c.width/r.width), y: (e.clientY - r.top) * (c.height/r.height) }; }
    c.addEventListener('pointerdown', e => { drawing = true; empty = false; const p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); c.setPointerCapture(e.pointerId); });
    c.addEventListener('pointermove', e => { if (!drawing) return; const p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); });
    c.addEventListener('pointerup', () => { drawing = false; });
    window.clearSig = () => { ctx.clearRect(0, 0, c.width, c.height); empty = true; };
    window.prepareSubmit = (btn) => {
        // Even if the signer only typed a name, we send an empty canvas — the
        // server falls back to a stylised typed rendering.
        if (!empty) document.getElementById('signatureData').value = c.toDataURL('image/png');
        btn.disabled = true; btn.textContent = 'Wird gesendet…';
        return true;
    };
})();
window.declineOpen = () => {
    const f = document.getElementById('signForm');
    const d = document.getElementById('declineForm');
    const on = d.style.display === 'none';
    f.style.display = on ? 'none' : '';
    d.style.display = on ? '' : 'none';
};
</script>
}
else
{
<script>
window.prepareSubmit = () => true;
window.declineOpen = () => {
    const f = document.getElementById('signForm'); const d = document.getElementById('declineForm');
    const on = d.style.display === 'none';
    f.style.display = on ? 'none' : '';
    d.style.display = on ? '' : 'none';
};
</script>
}
