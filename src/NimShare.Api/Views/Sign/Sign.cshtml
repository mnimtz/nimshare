@model NimShare.Api.Controllers.SignViewModel
@using NimShare.Core.Entities
@using System.Text.Json
@{
    ViewData["Title"] = Model.Request.Title;
    Layout = "_Layout";
    var isSigner = Model.Me.Role == SignatureParticipantRole.Signer;
    var myFields = (List<SignatureField>)(ViewData["MyFields"] ?? new List<SignatureField>());
    var audits = (List<SignatureAudit>)(ViewData["Audits"] ?? new List<SignatureAudit>());
    var participantsById = (Dictionary<Guid, SignatureParticipant>)(ViewData["ParticipantsById"] ?? new Dictionary<Guid, SignatureParticipant>());
    var theme = ViewData["Theme"] as NimShare.Api.Controllers.SignLandingTheme;
    var brandColor = string.IsNullOrWhiteSpace(theme?.PrimaryColor) ? null : theme!.PrimaryColor;

    string AuditLabel(SignatureAuditKind k) => k switch
    {
        SignatureAuditKind.Invited => "Eingeladen",
        SignatureAuditKind.Viewed => "Geöffnet",
        SignatureAuditKind.Signed => "Unterschrieben",
        SignatureAuditKind.Declined => "Abgelehnt",
        SignatureAuditKind.Cancelled => "Abgebrochen",
        SignatureAuditKind.Finalized => "Abgeschlossen",
        _ => k.ToString(),
    };
    string AuditIcon(SignatureAuditKind k) => k switch
    {
        SignatureAuditKind.Invited => "📧",
        SignatureAuditKind.Viewed => "👁",
        SignatureAuditKind.Signed => "✍",
        SignatureAuditKind.Declined => "✕",
        SignatureAuditKind.Cancelled => "⛔",
        SignatureAuditKind.Finalized => "🏁",
        _ => "·",
    };
    // Serialise fields for the JS overlay — PDF-point coords + page.
    var fieldsJson = JsonSerializer.Serialize(myFields.Select(f => new
    {
        page = f.Page,
        x = f.X,
        y = f.Y,
        width = f.Width,
        height = f.Height,
        type = f.Type.ToString(),
    }));
}
@if (brandColor is not null)
{
    <style>
        .landing-shell { --tw-primary: @brandColor; --tw-primary-alt: @brandColor; }
        .btn-primary { background: @brandColor !important; border-color: @brandColor !important; }
    </style>
}
<div class="landing-shell sig-shell">
  <div class="sig-two-col">
    <div class="landing-card" style="max-width:820px;position:relative">
        @if (!string.IsNullOrEmpty(theme?.OwnerAvatarUrl))
        {
            <img src="@theme.OwnerAvatarUrl" alt="@theme.OwnerName" title="@theme.OwnerName"
                 style="position:absolute;top:24px;right:28px;width:72px;height:72px;border-radius:50%;object-fit:cover;box-shadow:0 6px 20px rgba(0,0,0,.18),0 0 0 4px #fff,0 0 0 5px rgba(0,0,0,.06);z-index:2"/>
        }
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
            @if (!string.IsNullOrWhiteSpace(theme?.LogoUrl))
            {
                <img src="@theme.LogoUrl" alt="Logo" style="max-height:44px;max-width:180px;object-fit:contain"/>
            }
            else
            {
                <img src="/img/icon-64.png" width="32" height="32" style="border-radius:6px"/>
            }
            <div>
                <div style="font-size:.8rem;color:var(--tw-muted-blue)">@(string.IsNullOrWhiteSpace(theme?.Subtitle) ? "NimShare Signatur" : theme!.Subtitle!)</div>
                <div style="font-weight:700">@(string.IsNullOrWhiteSpace(theme?.Title) ? Model.Request.Title : theme!.Title!)</div>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(theme?.HeroUrl))
        {
            <img src="@theme.HeroUrl" alt="" style="width:100%;max-height:200px;object-fit:cover;border-radius:8px;margin-bottom:12px"/>
        }
        @if (!string.IsNullOrWhiteSpace(theme?.BodyMarkdown))
        {
            <div class="card" style="background:var(--tw-gray-100);margin-bottom:12px">
                @Html.Raw(Markdig.Markdown.ToHtml(theme.BodyMarkdown))
            </div>
        }
        <p class="muted">Hallo <strong>@Model.Me.Name</strong>, @Model.Request.Initiator?.DisplayName bittet dich, dieses Dokument @(isSigner ? "zu unterschreiben" : "zur Kenntnis zu nehmen").</p>
        @if (myFields.Count > 0 && isSigner)
        {
            <div class="card" style="background:rgba(255,198,0,.10);border-left:3px solid var(--tw-yellow);margin:12px 0;padding:10px 14px;font-size:.9rem">
                💡 Die gelb umrandeten Felder im Dokument zeigen dir, wo deine Unterschrift eingefügt wird — insgesamt <strong>@myFields.Count</strong> Feld(er).
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.Request.Message))
        {
            <div class="card" style="background:var(--tw-gray-100);margin:12px 0">@Model.Request.Message</div>
        }

        <!-- AI-Zusammenfassung (Empfänger-Hilfe) — nur ein Button + Sprachwahl.
             Der eigentliche Text erscheint erst wenn geklickt wird. -->
        <div class="card sig-summary-card" style="margin:12px 0;padding:10px 14px">
            <div class="row" style="gap:10px;align-items:center;flex-wrap:wrap">
                <button type="button" id="sigSummaryBtn" class="btn btn-secondary btn-sm">✨ Zusammenfassung anzeigen</button>
                <select id="sigSummaryLang" class="btn btn-ghost btn-sm" style="padding:6px 10px">
                    <option value="">Automatisch</option>
                    <option value="de">Deutsch</option>
                    <option value="en">English</option>
                    <option value="fr">Français</option>
                    <option value="it">Italiano</option>
                    <option value="es">Español</option>
                    <option value="nl">Nederlands</option>
                </select>
                <span class="muted" style="font-size:.82rem">KI-Kurzfassung des Dokuments — hilft beim schnellen Verstehen bevor du unterschreibst.</span>
            </div>
            <div id="sigSummaryOut" style="display:none;margin-top:10px;padding:10px;background:var(--tw-gray-100);border-radius:6px;font-size:.92rem;line-height:1.5"></div>
        </div>

        <!-- PDF preview with visible signature placeholders -->
        <div id="pdfPages" style="border:1px solid var(--tw-gray-300);border-radius:8px;background:#e9ecef;padding:12px;max-height:70vh;overflow-y:auto"
             data-src="/sign/@Model.Me.Id/preview?t=@Model.Token"
             data-fields='@Html.Raw(fieldsJson)'>
            <div class="muted" style="text-align:center;padding:40px">Dokument wird geladen …</div>
        </div>

        <form method="post" action="/sign/@Model.Me.Id/submit?t=@Model.Token" style="margin-top:16px" id="signForm">
            @Html.AntiForgeryToken()
            @if (isSigner)
            {
                <div class="field">
                    <label>Dein Name (für die Unterschrift)</label>
                    <input type="text" name="typedName" required value="@Model.Me.Name" maxlength="120"/>
                </div>
                <div class="field">
                    <label style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
                        <span>Unterschrift</span>
                        <span style="display:inline-flex;gap:4px;background:var(--tw-gray-100);border-radius:6px;padding:3px" role="tablist">
                            <button type="button" id="modeDraw" onclick="setSigMode('draw')" class="btn btn-ghost btn-sm" style="padding:4px 10px;font-size:.82rem" aria-pressed="true">🖊 Zeichnen</button>
                            <button type="button" id="modeCert" onclick="setSigMode('cert')" class="btn btn-ghost btn-sm" style="padding:4px 10px;font-size:.82rem" aria-pressed="false">📜 Zertifikat</button>
                        </span>
                    </label>
                    <div id="sigDrawWrap" style="border:2px dashed var(--tw-gray-300);border-radius:8px;background:#fff;position:relative">
                        <canvas id="sigPad" width="720" height="180" style="width:100%;height:180px;touch-action:none;display:block"></canvas>
                        <button type="button" onclick="clearSig()" style="position:absolute;top:6px;right:6px;background:var(--tw-gray-100);border:0;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:.8rem">Löschen</button>
                    </div>
                    <div id="sigCertWrap" style="display:none;border:2px solid var(--tw-gray-300);border-radius:8px;background:#fff;padding:14px">
                        <div id="sigCertInfo" class="muted" style="font-size:.9rem">Lade Zertifikat …</div>
                        <canvas id="sigCertPreview" width="720" height="180" style="width:100%;max-height:180px;border:1px solid var(--tw-gray-200);border-radius:6px;margin-top:10px;display:none"></canvas>
                        <div id="sigCertHint" class="muted" style="font-size:.78rem;margin-top:8px">
                            Wenn du eingeloggt bist und ein Default-Zertifikat unter <a href="/settings/certificates" target="_blank">Einstellungen › Zertifikate</a> hinterlegt hast, wird es hier verwendet.
                            Der Stempel enthält deinen CN, den Thumbprint und Zeitstempel — er wird als Bild ins Signaturfeld eingebettet (wie eine handgezeichnete Unterschrift).
                        </div>
                    </div>
                </div>
                <input type="hidden" name="signatureData" id="signatureData"/>
                <input type="hidden" name="signMode" id="signMode" value="draw"/>
            }
            <div class="row" style="justify-content:space-between;margin-top:16px;flex-wrap:wrap;gap:8px">
                <button type="button" class="btn btn-ghost" onclick="declineOpen()">✕ Ablehnen</button>
                <button type="submit" id="submitBtn" class="btn btn-primary">
                    @(isSigner ? "✍ Unterschreiben & abschicken" : "✓ Gelesen bestätigen")
                </button>
            </div>
        </form>

        <form method="post" action="/sign/@Model.Me.Id/decline?t=@Model.Token" id="declineForm" style="display:none;margin-top:12px">
            @Html.AntiForgeryToken()
            <div class="field">
                <label>Grund (optional)</label>
                <textarea name="reason" rows="2" maxlength="500"></textarea>
            </div>
            <div class="row" style="justify-content:flex-end;gap:8px">
                <button type="button" class="btn btn-ghost" onclick="declineOpen()">Zurück</button>
                <button type="button" class="btn btn-ghost" onclick="reassignOpen()">↪ Weiterleiten stattdessen</button>
                <button type="submit" class="btn btn-primary" style="background:var(--status-critical)">Ablehnen bestätigen</button>
            </div>
        </form>

        @if (isSigner)
        {
        <form method="post" action="/sign/@Model.Me.Id/reassign?t=@Model.Token" id="reassignForm" style="display:none;margin-top:12px">
            @Html.AntiForgeryToken()
            <p class="muted">Du bist nicht die richtige Person? Leite die Signatur an einen Kollegen weiter — die Unterschriftsfelder wandern mit.</p>
            <div class="row" style="gap:12px">
                <div class="field" style="flex:1">
                    <label>Name</label>
                    <input type="text" name="toName" required maxlength="200" autocomplete="off"/>
                </div>
                <div class="field" style="flex:2">
                    <label>E-Mail</label>
                    <input type="email" name="toEmail" required maxlength="250" autocomplete="off"/>
                </div>
            </div>
            <div class="field">
                <label>Notiz für den Empfänger (optional)</label>
                <textarea name="reason" rows="2" maxlength="500" placeholder="z.B. Das gehört ins Legal-Team — kannst du das übernehmen?"></textarea>
            </div>
            <div class="row" style="justify-content:flex-end;gap:8px">
                <button type="button" class="btn btn-ghost" onclick="reassignOpen()">Zurück</button>
                <button type="submit" class="btn btn-primary">↪ Weiterleiten</button>
            </div>
        </form>
        }
    </div>

    <aside class="sig-audit">
        <h3 style="margin-top:0;font-size:1rem">🕐 Verlauf</h3>
        <ol class="sig-audit-list">
            @foreach (var a in audits)
            {
                string who = "";
                if (a.ParticipantId is Guid apid && participantsById.TryGetValue(apid, out var ap))
                    who = $"{ap.Name} <{ap.Email}>";
                else if (a.Kind == SignatureAuditKind.Finalized)
                    who = Model.Request.Initiator?.DisplayName ?? "";
                <li class="sig-audit-item sig-audit-@a.Kind.ToString().ToLower()">
                    <div class="sig-audit-icon">@AuditIcon(a.Kind)</div>
                    <div class="sig-audit-body">
                        <div class="sig-audit-title">@AuditLabel(a.Kind)</div>
                        @if (!string.IsNullOrEmpty(who))
                        {
                            <div class="sig-audit-who muted">@who</div>
                        }
                        @if (!string.IsNullOrEmpty(a.Note))
                        {
                            <div class="sig-audit-note">„@a.Note"</div>
                        }
                        <div class="sig-audit-when muted">@a.At.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                </li>
            }
        </ol>
        @if (audits.Count == 0)
        {
            <p class="muted" style="font-size:.85rem">Noch keine Aktivität.</p>
        }
    </aside>
  </div>
</div>

<!-- pdf.js — same CDN as the requester wizard -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs" type="module"></script>
<script type="module">
import * as pdfjsLib from "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs";
pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs";

const wrap = document.getElementById('pdfPages');
const src = wrap.dataset.src;
const fields = JSON.parse(wrap.dataset.fields || '[]');

async function render() {
    try {
        const pdf = await pdfjsLib.getDocument(src).promise;
        wrap.innerHTML = '';
        for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
            const page = await pdf.getPage(pageNum);
            // Fit page to container width so it's always readable on mobile.
            const containerW = wrap.clientWidth - 24;
            const baseViewport = page.getViewport({ scale: 1 });
            const scale = Math.min(1.6, containerW / baseViewport.width);
            const viewport = page.getViewport({ scale });

            const pageWrap = document.createElement('div');
            pageWrap.style.cssText = `position:relative;margin:0 auto ${pageNum < pdf.numPages ? '14px' : '0'};width:${viewport.width}px;height:${viewport.height}px;box-shadow:0 2px 8px rgba(0,0,0,.15);background:#fff`;
            wrap.appendChild(pageWrap);

            const canvas = document.createElement('canvas');
            canvas.width = viewport.width; canvas.height = viewport.height;
            canvas.style.cssText = 'display:block;width:100%;height:100%';
            pageWrap.appendChild(canvas);

            await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;

            // Overlay the participant's signature fields on this page.
            fields.filter(f => f.page === pageNum).forEach((f, idx) => {
                // PDF coords are bottom-left origin; canvas is top-left. Y flip.
                const left = f.x * scale;
                const width = f.width * scale;
                const height = f.height * scale;
                const top = viewport.height - (f.y + f.height) * scale;
                const box = document.createElement('div');
                box.style.cssText = `position:absolute;left:${left}px;top:${top}px;width:${width}px;height:${height}px;border:2px solid #ffc600;background:rgba(255,198,0,.25);border-radius:3px;display:flex;align-items:center;justify-content:center;font-weight:700;color:#7a5b00;font-size:.85rem;pointer-events:none;text-shadow:0 0 3px #fff`;
                let icon = '';
                let label = '';
                if (f.type === 'Signature') { icon = '✍'; label = 'Hier unterschreiben'; }
                else if (f.type === 'Text') { icon = 'Aa'; label = 'Text'; }
                else if (f.type === 'Date') { icon = '📅'; label = 'Datum'; }
                else if (f.type === 'Checkbox') { icon = '☑'; label = ''; }
                box.textContent = width > 100 ? `${icon} ${label}` : icon;
                if (f.type === 'Signature') {
                    box.style.cursor = 'pointer';
                    box.style.pointerEvents = 'auto';
                    box.title = 'Zum Unterschriftfeld springen';
                    // Tag every signature placeholder so the sig-pad JS can
                    // find them later and mirror the drawing live.
                    box.classList.add('sig-placeholder');
                    box.dataset.fieldWidth = width;
                    box.dataset.fieldHeight = height;
                    box.addEventListener('click', () => {
                        const pad = document.getElementById('sigPad');
                        if (pad) {
                            pad.scrollIntoView({behavior:'smooth', block:'center'});
                            pad.style.boxShadow = '0 0 0 3px var(--tw-yellow, #ffc600)';
                            setTimeout(() => { pad.style.boxShadow = ''; }, 1400);
                            const nm = document.querySelector('input[name=typedName]');
                            if (nm && !document.getSelection().toString()) nm.focus();
                        }
                    });
                }
                pageWrap.appendChild(box);
            });
        }
    } catch (e) {
        wrap.innerHTML = '<div class="muted" style="text-align:center;padding:40px;color:var(--status-critical)">Dokument konnte nicht geladen werden: ' + (e.message || e) + '</div>';
    }
}
render();
</script>

<script>
// ── AI summary button — lets the recipient ask for a quick TL;DR of the
//    document in their language before deciding to sign/decline.
(function () {
    const btn = document.getElementById('sigSummaryBtn');
    const langSel = document.getElementById('sigSummaryLang');
    const out = document.getElementById('sigSummaryOut');
    if (!btn) return;
    btn.addEventListener('click', async () => {
        btn.disabled = true;
        const originalText = btn.textContent;
        btn.textContent = '… wird analysiert';
        out.style.display = 'block';
        out.textContent = '';
        const lang = langSel.value || (navigator.language || '').split('-')[0] || '';
        try {
            const url = '/sign/@Model.Me.Id/summary?t=@Model.Token' + (lang ? '&lang=' + encodeURIComponent(lang) : '');
            const r = await fetch(url, { credentials: 'same-origin' });
            const d = await r.json().catch(() => ({}));
            if (!r.ok) {
                out.textContent = '⚠ ' + (d.detail || d.title || ('HTTP ' + r.status));
                out.style.color = 'var(--status-critical, #d33)';
            } else {
                out.textContent = d.text || '(leere Zusammenfassung)';
                out.style.color = '';
            }
        } catch (e) {
            out.textContent = '⚠ ' + (e.message || e);
            out.style.color = 'var(--status-critical, #d33)';
        } finally {
            btn.disabled = false;
            btn.textContent = originalText;
        }
    });
})();
</script>

@if (isSigner)
{
<script>
// Tiny signature pad: capture pointer events, draw lines, expose to hidden input on submit.
(function(){
    const c = document.getElementById('sigPad');
    const ctx = c.getContext('2d');
    let drawing = false, empty = true;
    ctx.lineWidth = 2; ctx.lineCap = 'round'; ctx.strokeStyle = '#001d3d';
    function pos(e){ const r = c.getBoundingClientRect(); return { x: (e.clientX - r.left) * (c.width/r.width), y: (e.clientY - r.top) * (c.height/r.height) }; }
    // Live-mirror the pad drawing into every yellow signature placeholder
    // in the PDF preview so the signer sees exactly what will be stamped
    // onto the document. Each placeholder gets its own <img> lazily.
    function mirrorToPlaceholders() {
        if (empty) return;
        const dataUrl = c.toDataURL('image/png');
        document.querySelectorAll('.sig-placeholder').forEach(p => {
            let img = p.querySelector('img.sig-preview-img');
            if (!img) {
                p.textContent = ''; // clear the "✍ Hier unterschreiben" hint
                p.style.background = 'transparent';
                p.style.border = '2px solid rgba(255,198,0,.55)';
                img = document.createElement('img');
                img.className = 'sig-preview-img';
                img.style.cssText = 'width:100%;height:100%;object-fit:contain;display:block;pointer-events:none';
                p.appendChild(img);
            }
            img.src = dataUrl;
        });
    }
    function restorePlaceholders() {
        document.querySelectorAll('.sig-placeholder').forEach(p => {
            const img = p.querySelector('img.sig-preview-img');
            if (img) img.remove();
            p.style.background = 'rgba(255,198,0,.25)';
            p.style.border = '2px solid #ffc600';
            const w = parseFloat(p.dataset.fieldWidth || '0');
            p.textContent = w > 100 ? '✍ Hier unterschreiben' : '✍';
        });
    }
    let mirrorPending = false;
    function scheduleMirror() {
        if (mirrorPending) return;
        mirrorPending = true;
        requestAnimationFrame(() => { mirrorPending = false; mirrorToPlaceholders(); });
    }
    c.addEventListener('pointerdown', e => { drawing = true; empty = false; const p = pos(e); ctx.beginPath(); ctx.moveTo(p.x, p.y); c.setPointerCapture(e.pointerId); });
    c.addEventListener('pointermove', e => { if (!drawing) return; const p = pos(e); ctx.lineTo(p.x, p.y); ctx.stroke(); scheduleMirror(); });
    c.addEventListener('pointerup', () => { drawing = false; scheduleMirror(); });
    window.clearSig = () => { ctx.clearRect(0, 0, c.width, c.height); empty = true; restorePlaceholders(); };
    // Bind on the form's submit event, NOT the button's onclick — disabling
    // the submit button in a click handler prevents the form from being
    // submitted in Chrome/Edge/Firefox (that was the "wird gesendet…" hang).
    // Wire the disable via setTimeout(…,0) so it runs AFTER the browser has
    // begun the actual POST.
    document.getElementById('signForm').addEventListener('submit', (ev) => {
        const mode = document.getElementById('signMode')?.value || 'draw';
        if (mode === 'cert') {
            // Cert-Stempel-Modus: nutze die vorbereitete Preview-PNG.
            const certCanvas = document.getElementById('sigCertPreview');
            if (!certCanvas || certCanvas.style.display === 'none' || !window.__certReady) {
                ev.preventDefault();
                alert('Zertifikat konnte nicht geladen werden. Bitte auf "🖊 Zeichnen" wechseln oder Zertifikat unter Einstellungen › Zertifikate anlegen.');
                return;
            }
            document.getElementById('signatureData').value = certCanvas.toDataURL('image/png');
        } else {
            if (!empty) document.getElementById('signatureData').value = c.toDataURL('image/png');
        }
        const btn = document.getElementById('submitBtn');
        setTimeout(() => { if (btn) { btn.disabled = true; btn.textContent = 'Wird gesendet…'; } }, 0);
    });
})();

// ── Signatur-Modus: Zeichnen vs. Zertifikat-Stempel ────────────────
window.__certReady = false;
window.setSigMode = async function (mode) {
    document.getElementById('signMode').value = mode;
    const drawWrap = document.getElementById('sigDrawWrap');
    const certWrap = document.getElementById('sigCertWrap');
    const modeDrawBtn = document.getElementById('modeDraw');
    const modeCertBtn = document.getElementById('modeCert');
    if (!drawWrap || !certWrap) return;
    if (mode === 'cert') {
        drawWrap.style.display = 'none';
        certWrap.style.display = '';
        modeDrawBtn.setAttribute('aria-pressed', 'false');
        modeCertBtn.setAttribute('aria-pressed', 'true');
        modeCertBtn.style.background = 'var(--tw-white)';
        modeCertBtn.style.boxShadow = '0 1px 3px rgba(0,0,0,.1)';
        modeDrawBtn.style.background = '';
        modeDrawBtn.style.boxShadow = '';
        await loadCertPreview();
    } else {
        drawWrap.style.display = '';
        certWrap.style.display = 'none';
        modeDrawBtn.setAttribute('aria-pressed', 'true');
        modeCertBtn.setAttribute('aria-pressed', 'false');
        modeDrawBtn.style.background = 'var(--tw-white)';
        modeDrawBtn.style.boxShadow = '0 1px 3px rgba(0,0,0,.1)';
        modeCertBtn.style.background = '';
        modeCertBtn.style.boxShadow = '';
    }
};
setSigMode('draw'); // set initial pressed style

async function loadCertPreview() {
    const info = document.getElementById('sigCertInfo');
    const canvas = document.getElementById('sigCertPreview');
    window.__certReady = false;
    if (!info || !canvas) return;
    info.textContent = 'Lade Zertifikat …';
    canvas.style.display = 'none';
    try {
        const r = await fetch('/api/v1/certificates/default', { credentials: 'same-origin' });
        if (r.status === 401 || r.status === 403) {
            info.innerHTML = '⚠ Zertifikat-Stempel nur für <strong>angemeldete NimShare-Nutzer</strong> mit hinterlegtem Default-Zertifikat verfügbar. Wechsle zurück auf "🖊 Zeichnen", oder öffne die Signatur-Seite eingeloggt.';
            return;
        }
        if (r.status === 404) {
            info.innerHTML = '⚠ Kein Default-Zertifikat gefunden. Lege eines unter <a href="/settings/certificates" target="_blank">Einstellungen › Zertifikate</a> an und setze es als Default.';
            return;
        }
        if (!r.ok) { info.textContent = 'Fehler beim Laden: HTTP ' + r.status; return; }
        const cert = await r.json();
        renderCertStamp(canvas, cert);
        info.innerHTML = `Verwendetes Zertifikat: <strong>${escapeHtml(cert.name || cert.subjectCommonName)}</strong> — Thumbprint <code>${escapeHtml((cert.thumbprint || '').slice(0, 16))}…</code>`;
        canvas.style.display = '';
        window.__certReady = true;
    } catch (e) {
        info.textContent = 'Fehler beim Laden des Zertifikats: ' + (e.message || e);
    }
}

function escapeHtml(s) {
    return String(s || '').replace(/[<>&"']/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c]));
}

function renderCertStamp(canvas, cert) {
    const ctx = canvas.getContext('2d');
    const w = canvas.width, h = canvas.height;
    // clear
    ctx.clearRect(0, 0, w, h);
    // background
    ctx.fillStyle = '#f7fafc';
    ctx.fillRect(0, 0, w, h);
    // border
    ctx.strokeStyle = '#002854';
    ctx.lineWidth = 3;
    ctx.strokeRect(4, 4, w - 8, h - 8);
    // seal icon area (left)
    ctx.fillStyle = '#002854';
    ctx.font = 'bold 72px sans-serif';
    ctx.textBaseline = 'middle';
    ctx.fillText('🔒', 30, h / 2);
    // headline
    ctx.fillStyle = '#002854';
    ctx.font = 'bold 24px sans-serif';
    ctx.textBaseline = 'top';
    ctx.fillText('Digital signiert', 130, 20);
    // subject
    ctx.font = '18px sans-serif';
    ctx.fillStyle = '#1a202c';
    ctx.fillText((cert.subjectCommonName || cert.name || '').slice(0, 60), 130, 54);
    // meta lines
    ctx.font = '13px "SF Mono", Menlo, monospace';
    ctx.fillStyle = '#4a5568';
    const now = new Date();
    const pad = n => String(n).padStart(2, '0');
    const ts = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())} ${pad(now.getHours())}:${pad(now.getMinutes())}`;
    ctx.fillText('Zeitstempel: ' + ts, 130, 90);
    ctx.fillText('Thumbprint:  ' + (cert.thumbprint || '').slice(0, 32).match(/.{1,4}/g)?.join(' '), 130, 110);
    ctx.fillText('Aussteller:  ' + (cert.isSelfIssued ? 'Selbstausgestellt (NimShare)' : 'CA-signiert'), 130, 130);
    // footer strip
    ctx.font = 'italic 11px sans-serif';
    ctx.fillStyle = '#718096';
    ctx.fillText('Signiert via NimShare — Nachweis siehe Audit-Trail', 130, 154);
}
window.declineOpen = () => {
    const f = document.getElementById('signForm');
    const d = document.getElementById('declineForm');
    const r = document.getElementById('reassignForm');
    const on = d.style.display === 'none';
    f.style.display = on ? 'none' : '';
    d.style.display = on ? '' : 'none';
    if (r) r.style.display = 'none';
};
window.reassignOpen = () => {
    const f = document.getElementById('signForm');
    const d = document.getElementById('declineForm');
    const r = document.getElementById('reassignForm');
    if (!r) return;
    const on = r.style.display === 'none';
    f.style.display = on ? 'none' : '';
    d.style.display = 'none';
    r.style.display = on ? '' : 'none';
};
</script>
}
else
{
<script>
document.getElementById('signForm').addEventListener('submit', () => {
    const btn = document.getElementById('submitBtn');
    setTimeout(() => { if (btn) { btn.disabled = true; btn.textContent = 'Wird gesendet…'; } }, 0);
});
window.declineOpen = () => {
    const f = document.getElementById('signForm'); const d = document.getElementById('declineForm');
    const on = d.style.display === 'none';
    f.style.display = on ? 'none' : '';
    d.style.display = on ? '' : 'none';
};
</script>
}
