        btn.textContent = window.__sig_i18n.summary_analyzing;
        out.style.display = 'block';
        out.textContent = '';
        const lang = langSel.value || (navigator.language || '').split('-')[0] || '';
        try {
            const url = '/sign/@Model.Me.Id/summary?t=@Model.Token' + (lang ? '&lang=' + encodeURIComponent(lang) : '');
            const r = await fetch(url, { credentials: 'same-origin' });
            const d = await r.json().catch(() => ({}));
            if (!r.ok) {
                out.textContent = '⚠ ' + (d.detail || d.title || ('HTTP ' + r.status));
                out.style.color = 'var(--status-critical, #d33)';
            } else {
                out.textContent = d.text || window.__sig_i18n.summary_empty;
                out.style.color = '';
            }
        } catch (e) {
            out.textContent = '⚠ ' + (e.message || e);
            out.style.color = 'var(--status-critical, #d33)';
        } finally {
            btn.disabled = false;
            btn.textContent = originalText;
        }
    });
})();
</script>

