@model NimShare.Api.Controllers.SignViewModel
@using NimShare.Core.Entities
@using System.Text.Json
@{
    ViewData["Title"] = Model.Request.Title;
    Layout = "_Layout";
    var isSigner = Model.Me.Role == SignatureParticipantRole.Signer;
    var myFields = (List<SignatureField>)(ViewData["MyFields"] ?? new List<SignatureField>());
    var otherFields = myFields.Where(f => f.Type != SignatureFieldType.Signature).ToList();
    var audits = (List<SignatureAudit>)(ViewData["Audits"] ?? new List<SignatureAudit>());
    var participantsById = (Dictionary<Guid, SignatureParticipant>)(ViewData["ParticipantsById"] ?? new Dictionary<Guid, SignatureParticipant>());
    var theme = ViewData["Theme"] as NimShare.Api.Controllers.SignLandingTheme;
    var brandColor = string.IsNullOrWhiteSpace(theme?.PrimaryColor) ? null : theme!.PrimaryColor;

    string AuditLabel(SignatureAuditKind k) => k switch
    {
        SignatureAuditKind.Invited => T["sign.audit_invited"].Value,
        SignatureAuditKind.Viewed => T["sign.audit_viewed"].Value,
        SignatureAuditKind.Signed => T["sign.audit_signed"].Value,
        SignatureAuditKind.Declined => T["sign.audit_declined"].Value,
        SignatureAuditKind.Cancelled => T["sign.audit_cancelled"].Value,
        SignatureAuditKind.Finalized => T["sign.audit_finalized"].Value,
        _ => k.ToString(),
    };
    string AuditIcon(SignatureAuditKind k) => k switch
    {
        SignatureAuditKind.Invited => "📧",
        SignatureAuditKind.Viewed => "👁",
        SignatureAuditKind.Signed => "✍",
        SignatureAuditKind.Declined => "✕",
        SignatureAuditKind.Cancelled => "⛔",
        SignatureAuditKind.Finalized => "🏁",
        _ => "·",
    };
    // Serialise fields for the JS overlay — PDF-point coords + page.
    var fieldsJson = JsonSerializer.Serialize(myFields.Select(f => new
    {
        page = f.Page,
        x = f.X,
        y = f.Y,
        width = f.Width,
        height = f.Height,
        type = f.Type.ToString(),
    }));
}
@if (brandColor is not null)
{
    <style>
        .landing-shell { --tw-primary: @brandColor; --tw-primary-alt: @brandColor; }
        .landing-shell .btn-primary {
            background: @brandColor !important;
            border-color: @brandColor !important;
            color: #fff !important;
        }
        .landing-shell .btn-primary:hover:not(:disabled) { filter: brightness(1.1); }
    </style>
}
<div class="landing-shell sig-shell">
  <div class="sig-two-col">
    <div class="landing-card" style="max-width:820px;position:relative">
        @if (!string.IsNullOrEmpty(theme?.OwnerAvatarUrl))
        {
            <img src="@theme.OwnerAvatarUrl" alt="@theme.OwnerName" title="@theme.OwnerName"
                 style="position:absolute;top:24px;right:28px;width:72px;height:72px;border-radius:50%;object-fit:cover;box-shadow:0 6px 20px rgba(0,0,0,.18),0 0 0 4px #fff,0 0 0 5px rgba(0,0,0,.06);z-index:2"/>
        }
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px">
            @if (!string.IsNullOrWhiteSpace(theme?.LogoUrl))
            {
                <img src="@theme.LogoUrl" alt="Logo" style="max-height:44px;max-width:180px;object-fit:contain"/>
            }
            else
            {
                <img src="/img/icon-64.png" width="32" height="32" style="border-radius:6px"/>
            }
            <div>
                <div style="font-size:.8rem;color:var(--tw-muted-blue)">@(string.IsNullOrWhiteSpace(theme?.Subtitle) ? T["sign.brand_subtitle_default"].Value : theme!.Subtitle!)</div>
                <div style="font-weight:700">@(string.IsNullOrWhiteSpace(theme?.Title) ? Model.Request.Title : theme!.Title!)</div>
            </div>
        </div>
        @if (!string.IsNullOrWhiteSpace(theme?.HeroUrl))
        {
            <img src="@theme.HeroUrl" alt="" style="width:100%;max-height:200px;object-fit:cover;border-radius:8px;margin-bottom:12px"/>
        }
        @if (!string.IsNullOrWhiteSpace(theme?.BodyMarkdown))
        {
            <div class="card" style="background:var(--tw-gray-100);margin-bottom:12px">
                @Html.Raw(Markdig.Markdown.ToHtml(theme.BodyMarkdown))
            </div>
        }
        <p class="muted">@T["sign.hello"] <strong>@Model.Me.Name</strong>, @Model.Request.Initiator?.DisplayName @(isSigner ? T["sign.asks_you_to_sign"].Value : T["sign.asks_you_to_ack"].Value)</p>
        @if (myFields.Count > 0 && isSigner)
        {
            <div class="card" style="background:rgba(255,198,0,.10);border-left:3px solid var(--tw-yellow);margin:12px 0;padding:10px 14px;font-size:.9rem">
                💡 @Html.Raw(string.Format(T["sign.field_hint"].Value, $"<strong>{myFields.Count}</strong>"))
            </div>
        }
        @if (!string.IsNullOrEmpty(Model.Request.Message))
        {
            <div class="card" style="background:var(--tw-gray-100);margin:12px 0">@Model.Request.Message</div>
        }

        <!-- AI-Zusammenfassung (Empfänger-Hilfe) — nur ein Button + Sprachwahl.
             Der eigentliche Text erscheint erst wenn geklickt wird. -->
        <div class="card sig-summary-card" style="margin:12px 0;padding:10px 14px">
            <div class="row" style="gap:10px;align-items:center;flex-wrap:wrap">
                <button type="button" id="sigSummaryBtn" class="btn btn-secondary btn-sm">@T["sign.summary_show"]</button>
                <select id="sigSummaryLang" class="btn btn-ghost btn-sm" style="padding:6px 10px">
                    <option value="">@T["sign.summary_auto"]</option>
                    <option value="de">Deutsch</option>
                    <option value="en">English</option>
                    <option value="fr">Français</option>
                    <option value="it">Italiano</option>
                    <option value="es">Español</option>
                    <option value="nl">Nederlands</option>
                </select>
                <span class="muted" style="font-size:.82rem">@T["sign.summary_helper"]</span>
            </div>
            <div id="sigSummaryOut" style="display:none;margin-top:10px;padding:10px;background:var(--tw-gray-100);border-radius:6px;font-size:.92rem;line-height:1.5"></div>
        </div>

        <!-- PDF preview with visible signature placeholders -->
        <div id="pdfPages" style="border:1px solid var(--tw-gray-300);border-radius:8px;background:#e9ecef;padding:12px;max-height:70vh;overflow-y:auto"
             data-src="/sign/@Model.Me.Id/preview?t=@Model.Token"
             data-fields='@Html.Raw(fieldsJson)'>
            <div class="muted" style="text-align:center;padding:40px">@T["sign.doc_loading"]</div>
        </div>

        <form method="post" action="/sign/@Model.Me.Id/submit?t=@Model.Token" style="margin-top:16px" id="signForm">
            @Html.AntiForgeryToken()
            @if (isSigner)
            {
                <div class="field">
                    <label>@T["sign.your_name"]</label>
                    <input type="text" name="typedName" required value="@Model.Me.Name" maxlength="120"/>
                </div>
                <div class="field">
                    @* v1.10.33: Toggle immer sichtbar. Der Cert-Button lädt on-
                       demand /api/v1/certificates/default. Ist der Signer nicht
                       eingeloggt oder hat kein Default-Cert, zeigt die JS eine
                       sprechende Info-Zeile UND lässt "🖊 Zeichnen" als
                       funktionierende Alternative offen. Kein server-side hide
                       mehr — sonst sieht auch der eingeloggte Initiator seinen
                       eigenen Toggle nicht auf dem anonymen Sign-Link. *@
                    <label style="display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:8px">
                        <span>@T["sign.signature_label"]</span>
                        <span style="display:inline-flex;gap:4px;background:var(--tw-gray-100);border-radius:6px;padding:3px;flex-wrap:wrap" role="tablist">
                            <button type="button" id="modeDraw" onclick="setSigMode('draw')" class="btn btn-ghost btn-sm" style="padding:4px 10px;font-size:.82rem" aria-pressed="true">@T["sign.mode_draw"]</button>
                            <button type="button" id="modeCert" onclick="setSigMode('cert')" class="btn btn-ghost btn-sm" style="padding:4px 10px;font-size:.82rem" aria-pressed="false">@T["sign.mode_cert"]</button>
                            <button type="button" id="modeByo" onclick="setSigMode('byo')" class="btn btn-ghost btn-sm" style="padding:4px 10px;font-size:.82rem" aria-pressed="false">@T["sign.mode_byo"]</button>
                        </span>
                    </label>
                    <div id="sigDrawWrap" style="border:2px dashed var(--tw-gray-300);border-radius:8px;background:#fff;position:relative">
                        <canvas id="sigPad" width="720" height="180" style="width:100%;height:180px;touch-action:none;display:block"></canvas>
                        <button type="button" onclick="clearSig()" style="position:absolute;top:6px;right:6px;background:var(--tw-gray-100);border:0;padding:4px 8px;border-radius:4px;cursor:pointer;font-size:.8rem">@T["sign.pad_clear"]</button>
                    </div>
                    <div id="sigCertWrap" style="display:none;border:2px solid var(--tw-gray-300);border-radius:8px;background:#fff;padding:14px">
                        <div id="sigCertInfo" class="muted" style="font-size:.9rem">@T["sign.cert_loading"]</div>
                        <canvas id="sigCertPreview" width="720" height="180" style="width:100%;max-height:180px;border:1px solid var(--tw-gray-200);border-radius:6px;margin-top:10px;display:none"></canvas>
                        <div id="sigCertHint" class="muted" style="font-size:.78rem;margin-top:8px">
                            @Html.Raw(T["sign.cert_hint_html"].Value)
                        </div>
                    </div>
                    @* v1.10.36 — Bring-Your-Own-Cert: externer Empfänger lädt
                       PFX/P12 + Passwort hoch. Server parst rein im Speicher,
                       verwirft SOFORT, gibt Metadata für den Stempel zurück.
                       Beim Submit sendet der Browser die Datei ein zweites Mal
                       (Doppel-Upload statt Server-side-Cache — sicherer). *@
                    <div id="sigByoWrap" style="display:none;border:2px solid var(--tw-gray-300);border-radius:8px;background:#fff;padding:14px">
                        <p class="muted" style="font-size:.8rem;margin:0 0 10px 0">@T["sign.byo_hint"]</p>
                        <div class="row" style="gap:10px;flex-wrap:wrap;align-items:flex-end">
                            <div class="field" style="flex:2;min-width:200px;margin:0">
                                <label style="font-size:.8rem">@T["sign.byo_file"]</label>
                                <input type="file" id="byoFile" accept=".pfx,.p12,application/x-pkcs12"/>
                            </div>
                            <div class="field" style="flex:1;min-width:140px;margin:0">
                                <label style="font-size:.8rem">@T["sign.byo_password"]</label>
                                <input type="password" id="byoPassword" autocomplete="off"/>
                            </div>
                            <button type="button" id="byoValidateBtn" class="btn btn-secondary btn-sm" onclick="validateByoCert()">@T["sign.byo_validate"]</button>
                        </div>
                        <div id="byoInfo" class="muted" style="font-size:.9rem;margin-top:10px"></div>
                        <canvas id="byoPreview" width="720" height="180" style="width:100%;max-height:180px;border:1px solid var(--tw-gray-200);border-radius:6px;margin-top:10px;display:none"></canvas>
                        <p class="muted" style="font-size:.72rem;margin:8px 0 0 0;font-style:italic">🔒 @T["sign.byo_no_persist_note"]</p>
                    </div>
                </div>
                <input type="hidden" name="signatureData" id="signatureData"/>
                <input type="hidden" name="signMode" id="signMode" value="draw"/>

                @* Sonstige Felder (Text/Datum/Checkbox), die der Initiator platziert hat —
                   der Signer muss sie hier ausfüllen. Signature-Felder werden über die
                   Zeichen-/Cert-Bild-Logik gefüllt, also hier nur die anderen zeigen. *@
                @if (otherFields.Count > 0)
                {
                    <div class="field">
                        <label>@T["sign.extra_fields"]</label>
                        <div style="display:grid;grid-template-columns:1fr;gap:10px">
                        @foreach (var f in otherFields)
                        {
                            var lbl = string.IsNullOrWhiteSpace(f.Label)
                                ? (f.Type == SignatureFieldType.Date ? T["sign.field_type_date"].Value : (f.Type == SignatureFieldType.Checkbox ? T["sign.field_type_checkbox"].Value : T["sign.field_type_text"].Value))
                                : f.Label;
                            <div style="display:flex;flex-direction:column;gap:4px;padding:10px 12px;border:1px solid var(--tw-gray-300);border-radius:6px;background:#fff">
                                <span class="muted" style="font-size:.75rem">@string.Format(T["sign.field_page"].Value, f.Page) · @f.Type</span>
                                <label style="font-weight:500;font-size:.9rem">@lbl</label>
                                @if (f.Type == SignatureFieldType.Checkbox)
                                {
                                    <label style="display:inline-flex;align-items:center;gap:8px;cursor:pointer">
                                        <input type="checkbox" name="fieldValue_@f.Id" value="true" style="width:18px;height:18px"/>
                                        <span>@T["sign.field_confirmed"]</span>
                                    </label>
                                }
                                else if (f.Type == SignatureFieldType.Date)
                                {
                                    <input type="date" name="fieldValue_@f.Id" value="@DateTime.UtcNow.ToString("yyyy-MM-dd")"/>
                                }
                                else
                                {
                                    <input type="text" name="fieldValue_@f.Id" maxlength="500" placeholder="@lbl"/>
                                }
                            </div>
                        }
                        </div>
                    </div>
                }
            }
            <div class="row" style="justify-content:space-between;margin-top:16px;flex-wrap:wrap;gap:8px">
                <button type="button" class="btn btn-ghost" onclick="declineOpen()">@T["sign.decline"]</button>
                <button type="submit" id="submitBtn" class="btn btn-primary">
                    @(isSigner ? T["sign.submit_sign"].Value : T["sign.submit_ack"].Value)
                </button>
            </div>
        </form>

        <form method="post" action="/sign/@Model.Me.Id/decline?t=@Model.Token" id="declineForm" style="display:none;margin-top:12px">
            @Html.AntiForgeryToken()
            <div class="field">
                <label>@T["sign.reason_optional"]</label>
                <textarea name="reason" rows="2" maxlength="500"></textarea>
            </div>
            <div class="row" style="justify-content:flex-end;gap:8px">
                <button type="button" class="btn btn-ghost" onclick="declineOpen()">@T["sign.back"]</button>
                <button type="button" class="btn btn-ghost" onclick="reassignOpen()">@T["sign.forward_instead"]</button>
                <button type="submit" class="btn btn-primary" style="background:var(--status-critical)">@T["sign.confirm_decline"]</button>
            </div>
        </form>

        @if (isSigner)
        {
        <form method="post" action="/sign/@Model.Me.Id/reassign?t=@Model.Token" id="reassignForm" style="display:none;margin-top:12px">
            @Html.AntiForgeryToken()
            <p class="muted">@T["sign.reassign_hint"]</p>
            <div class="row" style="gap:12px">
                <div class="field" style="flex:1">
                    <label>@T["sign.reassign_name"]</label>
                    <input type="text" name="toName" required maxlength="200" autocomplete="off"/>
                </div>
                <div class="field" style="flex:2">
                    <label>@T["sign.reassign_email"]</label>
                    <input type="email" name="toEmail" required maxlength="250" autocomplete="off"/>
                </div>
            </div>
            <div class="field">
                <label>@T["sign.reassign_note_optional"]</label>
                <textarea name="reason" rows="2" maxlength="500" placeholder="@T["sign.reassign_note_ph"]"></textarea>
            </div>
            <div class="row" style="justify-content:flex-end;gap:8px">
                <button type="button" class="btn btn-ghost" onclick="reassignOpen()">@T["sign.back"]</button>
                <button type="submit" class="btn btn-primary">@T["sign.reassign_do"]</button>
            </div>
        </form>
        }
    </div>

    <aside class="sig-audit">
        <h3 style="margin-top:0;font-size:1rem">@T["sign.audit_title"]</h3>
        <ol class="sig-audit-list">
            @foreach (var a in audits)
            {
                string who = "";
                if (a.ParticipantId is Guid apid && participantsById.TryGetValue(apid, out var ap))
                    who = $"{ap.Name} <{ap.Email}>";
                else if (a.Kind == SignatureAuditKind.Finalized)
                    who = Model.Request.Initiator?.DisplayName ?? "";
                <li class="sig-audit-item sig-audit-@a.Kind.ToString().ToLower()">
                    <div class="sig-audit-icon">@AuditIcon(a.Kind)</div>
                    <div class="sig-audit-body">
                        <div class="sig-audit-title">@AuditLabel(a.Kind)</div>
                        @if (!string.IsNullOrEmpty(who))
                        {
                            <div class="sig-audit-who muted">@who</div>
                        }
                        @if (!string.IsNullOrEmpty(a.Note))
                        {
                            <div class="sig-audit-note">„@a.Note"</div>
                        }
                        <div class="sig-audit-when muted">@a.At.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                    </div>
                </li>
            }
        </ol>
        @if (audits.Count == 0)
        {
            <p class="muted" style="font-size:.85rem">@T["sign.audit_empty"]</p>
        }
    </aside>
  </div>
</div>

<!-- v1.10.34: alle JS-Strings die dem Benutzer angezeigt werden landen
     hier zentral, per @@Json.Serialize aus dem IStringLocalizer. So laufen
     "Wird gesendet…", "Hier unterschreiben", "Digital signiert" etc.
     automatisch in der Browser-Sprache — kein hardcoded Deutsch mehr. -->
<script>
window.__sig_i18n = {
    doc_load_failed: @Json.Serialize(T["sign.doc_load_failed"].Value),
    placeholder_here: @Json.Serialize(T["sign.placeholder_here"].Value),
    placeholder_jump: @Json.Serialize(T["sign.placeholder_jump"].Value),
    field_type_text: @Json.Serialize(T["sign.field_type_text"].Value),
    field_type_date: @Json.Serialize(T["sign.field_type_date"].Value),
    summary_analyzing: @Json.Serialize(T["sign.summary_analyzing"].Value),
    summary_empty: @Json.Serialize(T["sign.summary_empty"].Value),
    sending: @Json.Serialize(T["sign.sending"].Value),
    cert_loading: @Json.Serialize(T["sign.cert_loading"].Value),
    cert_used_html: @Json.Serialize(T["sign.cert_used_html"].Value),
    cert_needed_login_html: @Json.Serialize(T["sign.cert_needed_login_html"].Value),
    cert_no_default_html: @Json.Serialize(T["sign.cert_no_default_html"].Value),
    cert_load_error: @Json.Serialize(T["sign.cert_load_error"].Value),
    cert_missing_alert: @Json.Serialize(T["sign.cert_missing_alert"].Value),
    byo_verifying: @Json.Serialize(T["sign.byo_verifying"].Value),
    byo_invalid: @Json.Serialize(T["sign.byo_invalid"].Value),
    byo_valid_html: @Json.Serialize(T["sign.byo_valid_html"].Value),
    byo_validate: @Json.Serialize(T["sign.byo_validate"].Value),
    login_as_user: @Json.Serialize(T["sign.login_as_user"].Value),
    stamp_headline: @Json.Serialize(T["sign.stamp_headline"].Value),
    stamp_time_prefix: @Json.Serialize(T["sign.stamp_time_prefix"].Value),
    stamp_thumb_prefix: @Json.Serialize(T["sign.stamp_thumb_prefix"].Value),
    stamp_issuer_prefix: @Json.Serialize(T["sign.stamp_issuer_prefix"].Value),
    stamp_issuer_self: @Json.Serialize(T["sign.stamp_issuer_self"].Value),
    stamp_issuer_ca: @Json.Serialize(T["sign.stamp_issuer_ca"].Value),
    stamp_footer: @Json.Serialize(T["sign.stamp_footer"].Value),
};
</script>

<!-- pdf.js — same CDN as the requester wizard -->
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs" type="module"></script>
<script type="module">
import * as pdfjsLib from "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.min.mjs";
pdfjsLib.GlobalWorkerOptions.workerSrc = "https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.0.379/pdf.worker.min.mjs";

const wrap = document.getElementById('pdfPages');
const src = wrap.dataset.src;
const fields = JSON.parse(wrap.dataset.fields || '[]');

async function render() {
    try {
        const pdf = await pdfjsLib.getDocument(src).promise;
        wrap.innerHTML = '';
        for (let pageNum = 1; pageNum <= pdf.numPages; pageNum++) {
            const page = await pdf.getPage(pageNum);
            // Fit page to container width so it's always readable on mobile.
            const containerW = wrap.clientWidth - 24;
            const baseViewport = page.getViewport({ scale: 1 });
            const scale = Math.min(1.6, containerW / baseViewport.width);
            const viewport = page.getViewport({ scale });

            const pageWrap = document.createElement('div');
            pageWrap.style.cssText = `position:relative;margin:0 auto ${pageNum < pdf.numPages ? '14px' : '0'};width:${viewport.width}px;height:${viewport.height}px;box-shadow:0 2px 8px rgba(0,0,0,.15);background:#fff`;
            wrap.appendChild(pageWrap);

            const canvas = document.createElement('canvas');
            canvas.width = viewport.width; canvas.height = viewport.height;
            canvas.style.cssText = 'display:block;width:100%;height:100%';
            pageWrap.appendChild(canvas);

            await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;

            // Overlay the participant's signature fields on this page.
            fields.filter(f => f.page === pageNum).forEach((f, idx) => {
                // PDF coords are bottom-left origin; canvas is top-left. Y flip.
                const left = f.x * scale;
                const width = f.width * scale;
                const height = f.height * scale;
                const top = viewport.height - (f.y + f.height) * scale;
                const box = document.createElement('div');
                box.style.cssText = `position:absolute;left:${left}px;top:${top}px;width:${width}px;height:${height}px;border:2px solid #ffc600;background:rgba(255,198,0,.25);border-radius:3px;display:flex;align-items:center;justify-content:center;font-weight:700;color:#7a5b00;font-size:.85rem;pointer-events:none;text-shadow:0 0 3px #fff`;
                let icon = '';
                let label = '';
                if (f.type === 'Signature') { icon = '✍'; label = window.__sig_i18n.placeholder_here; }
                else if (f.type === 'Text') { icon = 'Aa'; label = window.__sig_i18n.field_type_text; }
                else if (f.type === 'Date') { icon = '📅'; label = window.__sig_i18n.field_type_date; }
                else if (f.type === 'Checkbox') { icon = '☑'; label = ''; }
                box.textContent = width > 100 ? `${icon} ${label}` : icon;
                if (f.type === 'Signature') {
                    box.style.cursor = 'pointer';
                    box.style.pointerEvents = 'auto';
                    box.title = window.__sig_i18n.placeholder_jump;
                    // Tag every signature placeholder so the sig-pad JS can
                    // find them later and mirror the drawing live.
                    box.classList.add('sig-placeholder');
                    box.dataset.fieldWidth = width;
                    box.dataset.fieldHeight = height;
                    box.addEventListener('click', () => {
                        const pad = document.getElementById('sigPad');
                        if (pad) {
                            pad.scrollIntoView({behavior:'smooth', block:'center'});
                            pad.style.boxShadow = '0 0 0 3px var(--tw-yellow, #ffc600)';
                            setTimeout(() => { pad.style.boxShadow = ''; }, 1400);
                            const nm = document.querySelector('input[name=typedName]');
                            if (nm && !document.getSelection().toString()) nm.focus();
                        }
                    });
                }
                pageWrap.appendChild(box);
            });
        }
    } catch (e) {
        wrap.innerHTML = '<div class="muted" style="text-align:center;padding:40px;color:var(--status-critical)">' + window.__sig_i18n.doc_load_failed + ' ' + (e.message || e) + '</div>';
    }
}
render();
</script>

<script>
// ── AI summary button — lets the recipient ask for a quick TL;DR of the
//    document in their language before deciding to sign/decline.
(function () {
    const btn = document.getElementById('sigSummaryBtn');
    const langSel = document.getElementById('sigSummaryLang');
    const out = document.getElementById('sigSummaryOut');
    if (!btn) return;
    btn.addEventListener('click', async () => {
        btn.disabled = true;
