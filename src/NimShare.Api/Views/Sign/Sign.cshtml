async function loadCertPreview() {
    const info = document.getElementById('sigCertInfo');
    const canvas = document.getElementById('sigCertPreview');
    window.__certReady = false;
    if (!info || !canvas) return;
    info.textContent = window.__sig_i18n.cert_loading;
    canvas.style.display = 'none';
