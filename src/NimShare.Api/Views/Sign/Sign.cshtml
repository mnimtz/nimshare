// ── Bring-Your-Own-Cert flow ────────────────────────────────────────
// Upload PFX+password to /sign/{pid}/validate-cert. Server parses in
// memory, returns metadata JSON, wipes bytes. On success we render the
// stamp locally on <canvas id="byoPreview">. The actual PFX file stays
// selected on the file-input — at Submit time the form is re-serialised
// as FormData so the file rides along a second time. No server-side
// cache: per Marcus, wir speichern kein fremdes Zertifikat.
window.validateByoCert = async function () {
    const info = document.getElementById('byoInfo');
    const canvas = document.getElementById('byoPreview');
    const btn = document.getElementById('byoValidateBtn');
    const fileEl = document.getElementById('byoFile');
    const pwEl = document.getElementById('byoPassword');
    window.__byoReady = false;
    if (!info || !canvas || !btn || !fileEl || !pwEl) return;
    if (!fileEl.files || fileEl.files.length === 0) {
        info.textContent = window.__sig_i18n.byo_invalid;
        info.style.color = 'var(--status-critical, #d33)';
        return;
    }
