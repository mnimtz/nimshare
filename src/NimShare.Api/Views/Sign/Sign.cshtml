        // {1}=Thumbprint — both HTML-escaped before substitution because
        // the outer string carries <strong>/<code> tags we want to preserve.
        const tpl = window.__sig_i18n.cert_used_html;
        const name = escapeHtml(cert.name || cert.subjectCommonName || '');
        const thumb = escapeHtml((cert.thumbprint || '').slice(0, 16)) + '…';
        info.innerHTML = tpl.replace('{0}', name).replace('{1}', thumb);
        canvas.style.display = '';
        window.__certReady = true;
    } catch (e) {
        info.textContent = window.__sig_i18n.cert_load_error + ' ' + (e.message || e);
    }
}

function escapeHtml(s) {
    return String(s || '').replace(/[<>&"']/g, c => ({'<':'&lt;','>':'&gt;','&':'&amp;','"':'&quot;',"'":'&#39;'}[c]));
}

// v1.10.36: injects a real <a> anchor into the "not signed in" template.
// The template contains {loginLink} — we swap in a link that carries the
// current sign URL (path + query = pid + token) so the login page can
// return the visitor exactly where they were.
function renderCertNeededLoginHtml() {
    const tpl = window.__sig_i18n.cert_needed_login_html;
    const returnUrl = encodeURIComponent(location.pathname + location.search);
    const linkText = escapeHtml(window.__sig_i18n.login_as_user || 'Sign in');
    const link = '<a href="/login?returnUrl=' + returnUrl + '">' + linkText + '</a>';
