}

function renderCertStamp(canvas, cert) {
    const ctx = canvas.getContext('2d');
    const w = canvas.width, h = canvas.height;
    // clear
    ctx.clearRect(0, 0, w, h);
    // background
    ctx.fillStyle = '#f7fafc';
    ctx.fillRect(0, 0, w, h);
    // border
    ctx.strokeStyle = '#002854';
    ctx.lineWidth = 3;
    ctx.strokeRect(4, 4, w - 8, h - 8);
    // seal icon area (left)
    ctx.fillStyle = '#002854';
    ctx.font = 'bold 72px sans-serif';
    ctx.textBaseline = 'middle';
    ctx.fillText('🔒', 30, h / 2);
    // headline
    ctx.fillStyle = '#002854';
    ctx.font = 'bold 24px sans-serif';
    ctx.textBaseline = 'top';
    ctx.fillText(window.__sig_i18n.stamp_headline, 130, 20);
    // subject
    ctx.font = '18px sans-serif';
    ctx.fillStyle = '#1a202c';
    ctx.fillText((cert.subjectCommonName || cert.name || '').slice(0, 60), 130, 54);
    // meta lines
    ctx.font = '13px "SF Mono", Menlo, monospace';
    ctx.fillStyle = '#4a5568';
    const now = new Date();
    const pad = n => String(n).padStart(2, '0');
    const ts = `${now.getFullYear()}-${pad(now.getMonth()+1)}-${pad(now.getDate())} ${pad(now.getHours())}:${pad(now.getMinutes())}`;
    ctx.fillText(window.__sig_i18n.stamp_time_prefix + ts, 130, 90);
    ctx.fillText(window.__sig_i18n.stamp_thumb_prefix + (cert.thumbprint || '').slice(0, 32).match(/.{1,4}/g)?.join(' '), 130, 110);
    ctx.fillText(window.__sig_i18n.stamp_issuer_prefix + (cert.isSelfIssued ? window.__sig_i18n.stamp_issuer_self : window.__sig_i18n.stamp_issuer_ca), 130, 130);
    // footer strip
    ctx.font = 'italic 11px sans-serif';
    ctx.fillStyle = '#718096';
    ctx.fillText(window.__sig_i18n.stamp_footer, 130, 154);
}
