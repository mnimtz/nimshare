@using NimShare.Api.Services
@{
    ViewData["Title"] = @T["browse.root.title"];
    Layout = "_AppShell";
    var groups = (List<GroupSummary>)(ViewData["Groups"] ?? new List<GroupSummary>());
}
<div class="page-header">
    <div>
        <h1>@T["browse.root.title"]</h1>
        <p class="lede">@T["browse.root.lede"]</p>
    </div>
</div>

<div class="library-section-title">
    <span>📁</span> @T["browse.libraries.mine"]
</div>
<div class="library-grid">
    <a href="/browse/personal" class="library-tile personal">
        <div class="icon">👤</div>
        <div class="info">
            <div class="title">@T["browse.tile.personal"]</div>
            <div class="sub">@T["browse.tile.personal.lede"]</div>
        </div>
    </a>
</div>

<div class="library-section-title">
    <span>🌐</span> @T["browse.libraries.shared"]
</div>
<div class="library-grid">
    <a href="/browse/public" class="library-tile public">
        <div class="icon">🌐</div>
        <div class="info">
            <div class="title">@T["browse.tile.public"]</div>
            <div class="sub">@T["browse.tile.public.lede"]</div>
        </div>
    </a>
</div>

<div class="library-section-title">
    <span>👥</span> @T["browse.libraries.groups"]
</div>
@if (!groups.Any())
{
    <div class="card"><p class="muted">@T["browse.tile.groups.empty"]</p></div>
}
else
{
    <div class="library-grid">
        @foreach (var g in groups)
        {
            <a href="/browse/group/@g.Id" class="library-tile group">
                <div class="icon">@(g.Name.Length > 0 ? g.Name[0].ToString().ToUpper() : "G")</div>
                <div class="info">
                    <div class="title">@g.Name</div>
                    <div class="sub">@(g.MyRole == NimShare.Core.Entities.GroupRole.Manager ? @T["groups.role.manager"].Value : @T["groups.role.member"].Value)</div>
                </div>
            </a>
        }
    </div>
}
