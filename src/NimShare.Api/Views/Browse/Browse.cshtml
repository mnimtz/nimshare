@model IEnumerable<NimShare.Core.Entities.StorageFile>
@using NimShare.Core.Entities
@{
    var scope = (FileScope)ViewData["Scope"]!;
    var groupId = ViewData["GroupId"] as Guid?;
    var groupName = ViewData["GroupName"] as string;
    var canManageGroup = (bool)(ViewData["CanManageGroup"] ?? false);
    var titleKey = scope switch
    {
        FileScope.Personal => "browse.personal",
        FileScope.Public => "browse.public",
        FileScope.Group => "browse.group",
        _ => "browse.personal"
    };
    var uploadScope = scope switch
    {
        FileScope.Personal => "Personal",
        FileScope.Public => "Public",
        FileScope.Group => "Group",
        _ => "Personal"
    };
    var displayTitle = scope == FileScope.Group ? groupName ?? T[titleKey].Value : T[titleKey].Value;
    ViewData["Title"] = displayTitle;
    Layout = "_AppShell";
    string Bytes(long b)
    {
        string[] u = { "B", "KB", "MB", "GB", "TB" };
        double v = b; int i = 0;
        while (v >= 1024 && i < u.Length - 1) { v /= 1024; i++; }
        return $"{v:0.##} {u[i]}";
    }
}
<div class="page-header">
    <div>
        <h1>@displayTitle</h1>
        <p class="lede">
            @switch (scope)
            {
                case FileScope.Personal: @T["browse.personal.lede"]; break;
                case FileScope.Public:   @T["browse.public.lede"]; break;
                case FileScope.Group:    @T["browse.group.lede"]; break;
            }
        </p>
    </div>
</div>

<div class="card">
    <h2 class="card-title">@T["browse.upload_here"]</h2>
    <div class="field">
        <input type="file" id="pick"/>
        <div class="helper" id="pickmeta"></div>
    </div>
    <button class="btn btn-primary" id="uploadBtn">@T["upload.button"]</button>
    <div class="helper" id="uploadStatus"></div>
</div>

<div class="card">
    <h2 class="card-title">@T["browse.files"] (@Model.Count())</h2>
    @if (!Model.Any())
    {
        <p class="muted">@T["browse.empty"]</p>
    }
    else
    {
        <table class="table">
            <thead>
            <tr>
                <th>@T["file.name"]</th>
                <th>@T["file.size"]</th>
                <th>@T["file.uploaded"]</th>
                @if (scope != FileScope.Personal) { <th>@T["groups.uploaded_by"]</th> }
                <th></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var f in Model)
            {
                <tr>
                    <td>@f.Name</td>
                    <td>@Bytes(f.SizeBytes)</td>
                    <td class="muted">@f.CreatedAt.ToString("u")</td>
                    @if (scope != FileScope.Personal) { <td class="muted">@f.Owner.DisplayName</td> }
                    <td>
                        <a class="btn btn-ghost btn-sm" href="/upload?fileId=@f.Id">@T["file.share"]</a>
                    </td>
                </tr>
            }
            </tbody>
        </table>
    }
</div>

<script>
const scope = @Html.Raw(Json.Serialize(uploadScope));
const groupId = @Html.Raw(groupId is null ? "null" : "\"" + groupId + "\"");
const btn = document.getElementById('uploadBtn');
const pick = document.getElementById('pick');
const status = document.getElementById('uploadStatus');
const meta = document.getElementById('pickmeta');
pick.addEventListener('change', () => {
    const f = pick.files[0]; if (!f) { meta.textContent=''; return; }
    meta.textContent = `${f.name} · ${(f.size/1024/1024).toFixed(2)} MiB · ${f.type||'application/octet-stream'}`;
});
btn.addEventListener('click', async () => {
    const f = pick.files[0]; if (!f) { status.textContent = 'Pick a file first.'; return; }
    btn.disabled = true; status.textContent = 'Requesting upload slot…';
    const init = await fetch('/api/v1/files', {
        method: 'POST',
        headers: {'Content-Type':'application/json'},
        credentials: 'same-origin',
        body: JSON.stringify({ name: f.name, sizeBytes: f.size, contentType: f.type, scope, groupId })
    });
    if (!init.ok) { status.textContent = 'Rejected: ' + init.status; btn.disabled = false; return; }
    const { fileId, uploadUrl } = await init.json();
    status.textContent = 'Uploading directly to storage…';
    const put = await fetch(uploadUrl, {method:'PUT', headers:{'x-ms-blob-type':'BlockBlob','x-ms-blob-content-type':f.type||'application/octet-stream'}, body: f});
    if (!put.ok) { status.textContent = 'Upload failed'; btn.disabled = false; return; }
    await fetch(`/api/v1/files/${fileId}/complete`, {method:'POST', credentials:'same-origin'});
    status.textContent = 'Done ✓ — reloading…';
    setTimeout(() => location.reload(), 600);
});
</script>
