@using NimShare.Core.Entities
@{
    var scope = (FileScope)ViewData["Scope"]!;
    var groupId = ViewData["GroupId"] as Guid?;
    var groupName = ViewData["GroupName"] as string;
    var current = (Folder)ViewData["Current"]!;
    var ancestry = (List<Folder>)ViewData["Ancestry"]!;
    var subs = (List<Folder>)ViewData["Subfolders"]!;
    var files = (List<StorageFile>)ViewData["Files"]!;
    var canWrite = (bool)(ViewData["CanWrite"] ?? false);
    var canManage = (bool)(ViewData["CanManage"] ?? false);
    var urlBase = (string)ViewData["UrlBase"]!;
    var currentUrl = Context.Request.Path.Value ?? urlBase;

    string scopeTitle = scope switch
    {
        FileScope.Personal => T["browse.tile.personal"].Value,
        FileScope.Public => T["browse.tile.public"].Value,
        FileScope.Group => groupName ?? T["browse.tile.groups"].Value,
        _ => "",
    };
    ViewData["Title"] = current.ParentFolderId is null ? scopeTitle : current.Name;
    Layout = "_AppShell";

    string Bytes(long b)
    {
        string[] u = { "B", "KB", "MB", "GB", "TB" };
        double v = b; int i = 0;
        while (v >= 1024 && i < u.Length - 1) { v /= 1024; i++; }
        return $"{v:0.##} {u[i]}";
    }
    string TypeClass(string name)
    {
        var ext = System.IO.Path.GetExtension(name).TrimStart('.').ToLowerInvariant();
        return ext switch
        {
            "pdf" => "pdf",
            "doc" or "docx" or "odt" => "doc",
            "xls" or "xlsx" or "csv" or "ods" => "xls",
            "ppt" or "pptx" or "odp" => "ppt",
            "png" or "jpg" or "jpeg" or "gif" or "webp" or "svg" or "heic" => "img",
            "mp4" or "mov" or "avi" or "mkv" or "webm" => "vid",
            "zip" or "7z" or "rar" or "tar" or "gz" => "zip",
            "txt" or "md" or "log" => "txt",
            _ => ""
        };
    }
    string TypeLabel(string name)
    {
        var ext = System.IO.Path.GetExtension(name).TrimStart('.').ToUpperInvariant();
        return string.IsNullOrEmpty(ext) ? "FILE" : (ext.Length > 4 ? ext[..4] : ext);
    }
    string SegPath(int upTo)
    {
        var parts = ancestry.Skip(1).Take(upTo).Select(a => Uri.EscapeDataString(a.Name));
        return string.Join('/', parts);
    }
}
<div class="page-header">
    <div>
        <div class="breadcrumb">
            <a href="/browse">@T["browse.root.title"]</a>
            <span class="sep">/</span>
            @for (var i = 0; i < ancestry.Count; i++)
            {
                var isLast = i == ancestry.Count - 1;
                var name = i == 0 ? scopeTitle : ancestry[i].Name;
                var url = i == 0 ? urlBase : (urlBase + "/" + SegPath(i));
                if (isLast)
                {
                    <span class="current">@name</span>
                }
                else
                {
                    <a href="@url">@name</a>
                    <span class="sep">/</span>
                }
            }
        </div>
        <h1>@(current.ParentFolderId is null ? scopeTitle : current.Name)</h1>
    </div>
    <div class="view-toggle" id="viewToggle">
        <button data-view="list" class="active" title="@T["browse.view.list"]">☰</button>
        <button data-view="grid" title="@T["browse.view.grid"]">▦</button>
    </div>
</div>

@if (TempData["Notice"] is string n) { <div class="card" style="border-left:3px solid var(--status-ok);background:rgba(0,235,134,.06)">@n</div> }
@if (TempData["Error"] is string err) { <div class="card" style="border-left:3px solid var(--status-critical);background:rgba(220,38,38,.06)">@err</div> }

<div class="browse-toolbar">
    @if (canWrite)
    {
        <button class="btn btn-primary" onclick="openNewFolderModal()">+ @T["browse.new_folder"]</button>
        <button class="btn btn-secondary" onclick="document.getElementById('quickPick').click()">↑ @T["browse.upload"]</button>
        <input type="file" id="quickPick" multiple style="display:none"/>
    }
    <button class="btn btn-ghost" onclick="openShareFolderModal('@current.Id')">🔗 @T["browse.share_this"]</button>
    <button class="btn btn-ghost" onclick="openUploadRequestModal('@current.Id')">📥 @T["browse.request_upload"]</button>
</div>

<div class="bulk-toolbar" id="bulkBar">
    <span class="count" id="bulkCount">0 @T["bulk.selected"]</span>
    @if (canWrite)
    {
        <button onclick="openMoveModal()">↦ @T["bulk.move"]</button>
    }
    <button onclick="bulkDelete()">🗑 @T["bulk.delete"]</button>
    <button onclick="clearSelection()" style="margin-left:auto">✕ @T["bulk.clear"]</button>
</div>

<div class="dropzone" id="dropzone" data-drop-label="@T["browse.drop_hint"]">
    @if (!subs.Any() && !files.Any())
    {
        <div class="card"><p class="muted">@T["browse.empty"]</p></div>
    }
    else
    {
        <table class="table" id="listView">
            <thead>
            <tr>
                <th style="width:32px"><input type="checkbox" id="selectAll"/></th>
                <th style="width:44px"></th>
                <th>@T["file.name"]</th>
                <th style="width:100px">@T["file.size"]</th>
                <th style="width:200px">@T["file.uploaded"]</th>
                @if (scope != FileScope.Personal) { <th style="width:180px">@T["groups.uploaded_by"]</th> }
                <th style="width:80px"></th>
            </tr>
            </thead>
            <tbody>
            @foreach (var sub in subs)
            {
                <tr data-folder-id="@sub.Id">
                    <td></td>
                    <td><div class="file-icon folder">📁</div></td>
                    <td class="browse-name"><a href="@(urlBase + (current.ParentFolderId is null ? "/" : "/" + SegPath(ancestry.Count - 1) + "/") + Uri.EscapeDataString(sub.Name))">@sub.Name</a></td>
                    <td class="muted">—</td>
                    <td class="muted">@sub.CreatedAt.ToString("u")</td>
                    @if (scope != FileScope.Personal) { <td></td> }
                    <td>
                        <div class="actions-menu">
                            <button onclick="toggleMenu(this)">⋯</button>
                            <div class="menu">
                                <button onclick="openShareFolderModal('@sub.Id')">🔗 @T["actions.share_link"]</button>
                                <button onclick="openUploadRequestModal('@sub.Id')">📥 @T["actions.request_upload"]</button>
                                @if (canManage)
                                {
                                    <div class="divider"></div>
                                    <button onclick="openRenameFolderModal('@sub.Id', @Json.Serialize(sub.Name))">✎ @T["actions.rename"]</button>
                                    <form method="post" action="/browse/folders/@sub.Id/delete" onsubmit="return confirm('@T["actions.confirm_delete"]')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentUrl"/>
                                        <button type="submit">🗑 @T["actions.delete"]</button>
                                    </form>
                                }
                            </div>
                        </div>
                    </td>
                </tr>
            }
            @foreach (var f in files)
            {
                <tr data-file-id="@f.Id" data-file-name="@f.Name">
                    <td><input type="checkbox" class="row-check" value="@f.Id"/></td>
                    <td><div class="file-icon @TypeClass(f.Name)">@TypeLabel(f.Name)</div></td>
                    <td class="browse-name">@f.Name</td>
                    <td>@Bytes(f.SizeBytes)</td>
                    <td class="muted">@f.CreatedAt.ToString("u")</td>
                    @if (scope != FileScope.Personal) { <td class="muted">@f.Owner.DisplayName</td> }
                    <td>
                        <div class="actions-menu">
                            <button onclick="toggleMenu(this)">⋯</button>
                            <div class="menu">
                                <button onclick="openShareFileModal('@f.Id')">🔗 @T["actions.share_link"]</button>
                                @if (canWrite)
                                {
                                    <button onclick="openMoveSingle('@f.Id')">↦ @T["actions.move"]</button>
                                }
                                <div class="divider"></div>
                                <button onclick="deleteFile('@f.Id')">🗑 @T["actions.delete"]</button>
                            </div>
                        </div>
                    </td>
                </tr>
            }
            </tbody>
        </table>

        <div class="grid-view" id="gridView" style="display:none">
            @foreach (var sub in subs)
            {
                <div class="grid-tile">
                    <input type="checkbox" class="check" disabled/>
                    <div class="icon-big file-icon folder" style="font-size:2rem">📁</div>
                    <a href="@(urlBase + (current.ParentFolderId is null ? "/" : "/" + SegPath(ancestry.Count - 1) + "/") + Uri.EscapeDataString(sub.Name))" style="color:var(--tw-primary);text-decoration:none">
                        <div class="name">@sub.Name</div>
                    </a>
                    <div class="meta">@T["browse.folder_type"]</div>
                </div>
            }
            @foreach (var f in files)
            {
                <div class="grid-tile" data-file-id="@f.Id" onclick="toggleGridSelect(this,'@f.Id')">
                    <input type="checkbox" class="check row-check" value="@f.Id"/>
                    <div class="icon-big file-icon @TypeClass(f.Name)" style="font-size:1.3rem">@TypeLabel(f.Name)</div>
                    <div class="name">@f.Name</div>
                    <div class="meta">@Bytes(f.SizeBytes)</div>
                </div>
            }
        </div>
    }
</div>

<partial name="_LinkModals" model="@current" />

<!-- Move modal -->
<div class="modal-backdrop" id="modalMove" onclick="if(event.target===this)closeModal('modalMove')">
    <div class="modal-panel">
        <h2>@T["move.title"]</h2>
        <p class="muted" id="moveHint"></p>
        <div class="field">
            <label>@T["move.target"]</label>
            <select id="moveTarget"></select>
            <div class="helper">@T["move.helper"]</div>
        </div>
        <div class="actions">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modalMove')">@T["modal.cancel"]</button>
            <button type="button" class="btn btn-primary" onclick="performMove()">@T["move.button"]</button>
        </div>
    </div>
</div>

<script>
const FOLDER_ID = @Json.Serialize(current.Id);
const RETURN_URL = @Json.Serialize(currentUrl);
const SCOPE = @Json.Serialize(scope.ToString());

// ── View toggle (persisted in localStorage) ────────────────────────────
const listView = document.getElementById('listView');
const gridView = document.getElementById('gridView');
const viewToggle = document.getElementById('viewToggle');
function setView(v) {
    localStorage.setItem('browse.view', v);
    if (!listView || !gridView) return;
    listView.style.display = v === 'list' ? '' : 'none';
    gridView.style.display = v === 'grid' ? '' : 'none';
    viewToggle.querySelectorAll('button').forEach(b => b.classList.toggle('active', b.dataset.view === v));
}
setView(localStorage.getItem('browse.view') || 'list');
viewToggle.addEventListener('click', (e) => { const b = e.target.closest('button'); if (b) setView(b.dataset.view); });

// ── Actions menu ───────────────────────────────────────────────────────
function toggleMenu(btn) {
    const menu = btn.closest('.actions-menu');
    document.querySelectorAll('.actions-menu[open]').forEach(m => { if (m !== menu) m.removeAttribute('open'); });
    if (menu.hasAttribute('open')) menu.removeAttribute('open'); else menu.setAttribute('open', '');
}
document.addEventListener('click', (e) => {
    if (!e.target.closest('.actions-menu')) {
        document.querySelectorAll('.actions-menu[open]').forEach(m => m.removeAttribute('open'));
    }
});

// ── Single file delete ─────────────────────────────────────────────────
async function deleteFile(id) {
    if (!confirm(@Json.Serialize(T["actions.confirm_delete"].Value))) return;
    const r = await fetch('/api/v1/files/' + id, { method: 'DELETE', credentials: 'same-origin' });
    if (r.ok) location.reload(); else alert('Failed: ' + r.status);
}

// ── Bulk selection ─────────────────────────────────────────────────────
const bulkBar = document.getElementById('bulkBar');
const bulkCount = document.getElementById('bulkCount');
const selAll = document.getElementById('selectAll');

function updateSelection() {
    const boxes = document.querySelectorAll('.row-check');
    const selected = Array.from(boxes).filter(b => b.checked).length;
    bulkCount.textContent = selected + ' ' + @Json.Serialize(T["bulk.selected"].Value);
    bulkBar.classList.toggle('on', selected > 0);
    // Sync grid tiles' .selected class
    document.querySelectorAll('.grid-tile[data-file-id]').forEach(t => {
        const cb = t.querySelector('.row-check');
        if (cb) t.classList.toggle('selected', cb.checked);
    });
}
document.querySelectorAll('.row-check').forEach(cb => cb.addEventListener('change', updateSelection));
if (selAll) selAll.addEventListener('change', () => {
    document.querySelectorAll('#listView .row-check').forEach(cb => cb.checked = selAll.checked);
    updateSelection();
});
function toggleGridSelect(tile, id) {
    const cb = document.querySelector('.row-check[value="' + id + '"]');
    if (cb) { cb.checked = !cb.checked; updateSelection(); }
}
function selectedIds() {
    return Array.from(document.querySelectorAll('.row-check'))
        .filter(b => b.checked).map(b => b.value)
        // Deduplicate between list + grid checkboxes for the same file.
        .filter((v, i, a) => a.indexOf(v) === i);
}
function clearSelection() {
    document.querySelectorAll('.row-check').forEach(cb => cb.checked = false);
    if (selAll) selAll.checked = false;
    updateSelection();
}
async function bulkDelete() {
    const ids = selectedIds();
    if (!ids.length) return;
    const template = @Json.Serialize(T["bulk.confirm.delete"].Value);
    if (!confirm(template.replace("{n}", ids.length))) return;
    const r = await fetch('/api/v1/files/bulk-delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        credentials: 'same-origin',
        body: JSON.stringify({ ids }),
    });
    if (r.ok) location.reload(); else alert('Failed: ' + r.status);
}

// ── Move (single or multiple) ──────────────────────────────────────────
let moveIds = [];
async function openMoveModal() {
    moveIds = selectedIds();
    if (!moveIds.length) return;
    await populateMoveTargets();
    {
        const tpl = @Json.Serialize(T["move.hint.multi"].Value);
        document.getElementById('moveHint').textContent = tpl.replace("{n}", moveIds.length);
    }
    document.getElementById('modalMove').classList.add('open');
}
async function openMoveSingle(id) {
    moveIds = [id];
    await populateMoveTargets();
    document.getElementById('moveHint').textContent = @Json.Serialize(T["move.hint.single"].Value);
    document.getElementById('modalMove').classList.add('open');
}
async function populateMoveTargets() {
    // A flat list of the caller's writable folders in this scope. The API returns them.
    const r = await fetch('/api/v1/folders/writable?scope=' + SCOPE + '&exclude=' + FOLDER_ID, { credentials: 'same-origin' });
    if (!r.ok) return;
    const items = await r.json();
    const sel = document.getElementById('moveTarget');
    sel.innerHTML = '';
    items.forEach(x => { const opt = document.createElement('option'); opt.value = x.id; opt.textContent = x.path; sel.appendChild(opt); });
}
async function performMove() {
    const folderId = document.getElementById('moveTarget').value;
    if (!folderId) return;
    let ok = 0, fail = 0;
    for (const id of moveIds) {
        const r = await fetch('/api/v1/files/' + id + '/move', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            credentials: 'same-origin',
            body: JSON.stringify({ folderId }),
        });
        if (r.ok) ok++; else fail++;
    }
    document.getElementById('modalMove').classList.remove('open');
    if (fail) alert(ok + ' moved, ' + fail + ' failed'); else location.reload();
}

// ── Drag-drop + quick upload ───────────────────────────────────────────
const dropzone = document.getElementById('dropzone');
const quickPick = document.getElementById('quickPick');
if (dropzone) {
    ['dragenter','dragover'].forEach(ev => dropzone.addEventListener(ev, e => { e.preventDefault(); dropzone.classList.add('drag-over'); }));
    ['dragleave','drop'].forEach(ev => dropzone.addEventListener(ev, e => { e.preventDefault(); dropzone.classList.remove('drag-over'); }));
    dropzone.addEventListener('drop', async (e) => {
        const files = Array.from(e.dataTransfer?.files || []);
        if (files.length) await uploadFiles(files);
    });
}
if (quickPick) quickPick.addEventListener('change', async () => { if (quickPick.files.length) await uploadFiles(Array.from(quickPick.files)); });

async function uploadFiles(files) {
    const total = files.length;
    let done = 0;
    // Show a lightweight toast so the user sees progress.
    const toast = document.createElement('div');
    toast.style.cssText = 'position:fixed;bottom:20px;right:20px;background:var(--tw-primary);color:var(--tw-white);padding:10px 16px;border-radius:8px;box-shadow:var(--shadow-lg);z-index:100';
    document.body.appendChild(toast);
    for (const f of files) {
        toast.textContent = `Uploading ${++done} / ${total}: ${f.name}…`;
        const init = await fetch('/api/v1/files', {
            method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
            body: JSON.stringify({ name: f.name, sizeBytes: f.size, contentType: f.type, folderId: FOLDER_ID }),
        });
        if (!init.ok) continue;
        const { fileId, uploadUrl } = await init.json();
        const put = await fetch(uploadUrl, { method: 'PUT', headers: {'x-ms-blob-type':'BlockBlob','x-ms-blob-content-type':f.type||'application/octet-stream'}, body: f });
        if (!put.ok) continue;
        await fetch('/api/v1/files/' + fileId + '/complete', { method: 'POST', credentials: 'same-origin' });
    }
    toast.textContent = 'Done ✓ — reloading…';
    setTimeout(() => location.reload(), 400);
}
</script>
