@using NimShare.Core.Entities
@using NimShare.Api.Services
@{
    var scope = (FileScope)ViewData["Scope"]!;
    var groupId = ViewData["GroupId"] as Guid?;
    var groupName = ViewData["GroupName"] as string;
    var current = (Folder)ViewData["Current"]!;
    var ancestry = (List<Folder>)ViewData["Ancestry"]!;
    var subs = (List<Folder>)ViewData["Subfolders"]!;
    var files = (List<StorageFile>)ViewData["Files"]!;
    var pinnedFiles = (ViewData["PinnedFiles"] as List<StorageFile>) ?? new();
    var pinnedIds = (ViewData["PinnedIds"] as HashSet<Guid>) ?? new();
    var me = ViewData["Me"] as User;
    var canWrite = (bool)(ViewData["CanWrite"] ?? false);
    var canManage = (bool)(ViewData["CanManage"] ?? false);
    var urlBase = (string)ViewData["UrlBase"]!;
    var currentUrl = Context.Request.Path.Value ?? urlBase;

    string scopeTitle = scope switch
    {
        FileScope.Personal => T["browse.tile.personal"].Value,
        FileScope.Public => T["browse.tile.public"].Value,
        FileScope.Group => groupName ?? T["browse.tile.groups"].Value,
        _ => "",
    };
    ViewData["Title"] = current.ParentFolderId is null ? scopeTitle : current.Name;
    Layout = "_AppShell";

    string Bytes(long b)
    {
        string[] u = { "B", "KB", "MB", "GB", "TB" };
        double v = b; int i = 0;
        while (v >= 1024 && i < u.Length - 1) { v /= 1024; i++; }
        return $"{v:0.##} {u[i]}";
    }
    string TypeClass(string name)
    {
        var ext = System.IO.Path.GetExtension(name).TrimStart('.').ToLowerInvariant();
        return ext switch
        {
            "pdf" => "pdf",
            "doc" or "docx" or "odt" => "doc",
            "xls" or "xlsx" or "csv" or "ods" => "xls",
            "ppt" or "pptx" or "odp" => "ppt",
            "png" or "jpg" or "jpeg" or "gif" or "webp" or "svg" or "heic" => "img",
            "mp4" or "mov" or "avi" or "mkv" or "webm" => "vid",
            "zip" or "7z" or "rar" or "tar" or "gz" => "zip",
            "txt" or "md" or "log" => "txt",
            _ => ""
        };
    }
    string TypeLabel(string name)
    {
        var ext = System.IO.Path.GetExtension(name).TrimStart('.').ToUpperInvariant();
        return string.IsNullOrEmpty(ext) ? "F" : ext[..1];
    }
    string SegPath(int upTo)
    {
        var parts = ancestry.Skip(1).Take(upTo).Select(a => Uri.EscapeDataString(a.Name));
        return string.Join('/', parts);
    }
    // Folder-URLs go through /browse/folder/{id} so names with trailing dots
    // ("Business - Production.") or unusual chars don't trip IIS's
    // request-filtering (which blocks trailing "." segments before ASP.NET
    // Core routing sees them). ID-based navigation is dot-safe AND survives
    // renames — see BrowseController.ByFolderId.
    string FolderUrl(Folder sub) => $"/browse/folder/{sub.Id}";
    string AncestryUrl(int i)
    {
        // Root of the scope keeps the pretty URL; deeper crumbs go by ID.
        return i == 0 ? urlBase : $"/browse/folder/{ancestry[i].Id}";
    }
}

<div class="fm fm-with-tree">
    <aside class="fm-tree" id="fmTree"
           data-scope="@scope"
           data-group-id="@(groupId?.ToString() ?? "")"
           data-current-id="@current.Id"
           data-url-base="@urlBase">
        <div class="muted" style="padding:12px">@T["browse.tree.loading"]</div>
    </aside>
    <section class="fm-main" id="dropzone" data-drop-label="@T["browse.drop_hint"]">
        <header class="fm-header">
            <div class="fm-breadcrumb">
                @for (var i = 0; i < ancestry.Count; i++)
                {
                    var isLast = i == ancestry.Count - 1;
                    var name = i == 0 ? scopeTitle : ancestry[i].Name;
                    var url = AncestryUrl(i);
                    if (isLast) { <span class="fm-crumb-current">@name</span> }
                    else { <a href="@url">@name</a> <span class="fm-crumb-sep">›</span> }
                }
            </div>
            <div class="fm-toolbar">
                @* v1.10.52: Mobile-Tree-Toggle. Auf Desktop weggeblendet
                   (CSS media-query), auf Mobile öffnet er den fmTree als
                   Bottom-Sheet-Overlay. *@
                <button class="fm-btn fm-tree-toggle" type="button" title="@T["browse.tree.mobile_toggle"]" onclick="openMobileTree()" aria-label="@T["browse.tree.mobile_toggle"]">
                    <span>📁</span>
                </button>
                @if (canWrite)
                {
                    <button class="fm-btn" title="@T["browse.new_folder"]" onclick="openNewFolderModal()">
                        <span>📁+</span>
                    </button>
                    <button class="fm-btn fm-btn-primary" title="@T["browse.upload"]" onclick="document.getElementById('quickPick').click()">
                        <span>↑ @T["browse.upload"]</span>
                    </button>
                    <input type="file" id="quickPick" multiple style="display:none"/>
                }
                <button class="fm-btn" title="@T["browse.share_this"]" onclick="openShareFolderModal('@current.Id')">🔗</button>
                <button class="fm-btn" title="@T["browse.request_upload"]" onclick="openUploadRequestModal('@current.Id')">📥</button>
            </div>
        </header>

        <div class="fm-searchbar">
            <span class="fm-search-icon">🔍</span>
            <input type="text" id="searchQ" placeholder="@T["browse.search.placeholder"]" onkeydown="if(event.key==='Enter')doSearch()"/>
        </div>
        <div class="fm-search-results" id="searchResults" style="display:none"></div>

        @if (TempData["Notice"] is string n) { <div class="fm-flash fm-flash-ok">@n</div> }
        @if (TempData["Error"] is string err) { <div class="fm-flash fm-flash-err">@err</div> }

        <div class="fm-bulkbar" id="bulkBar">
            <span class="count" id="bulkCount">0 @T["bulk.selected"]</span>
            <button onclick="bulkZip()">📦 @T["bulk.download_zip"]</button>
            @if (canWrite) { <button onclick="openMoveModal()">↦ @T["bulk.move"]</button> }
            <button onclick="bulkDelete()">🗑 @T["bulk.delete"]</button>
            <button onclick="clearSelection()" style="margin-left:auto">✕ @T["bulk.clear"]</button>
        </div>

        @if (!subs.Any() && !files.Any())
        {
            <div class="fm-empty">
                <div class="fm-empty-art">📂</div>
                <div class="fm-empty-title">@T["browse.empty"]</div>
                @if (canWrite)
                {
                    <div class="fm-empty-hint">@T["browse.drop_hint"]</div>
                }
            </div>
        }
        else
        {
            <table class="fm-list">
                <thead>
                    <tr>
                        <th class="col-check"><input type="checkbox" id="selectAll"/></th>
                        <th class="col-name fm-sort" data-sort="name">@T["file.name"] <span class="fm-sort-caret">▴</span></th>
                        <th class="col-size fm-sort" data-sort="size">@T["file.size"] <span class="fm-sort-caret"></span></th>
                        <th class="col-date fm-sort" data-sort="date">@T["file.uploaded"] <span class="fm-sort-caret"></span></th>
                        @if (scope != FileScope.Personal) { <th class="col-owner">@T["groups.uploaded_by"]</th> }
                        <th class="col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in subs)
                    {
                        <tr class="ctx fm-row fm-row-folder" data-kind="folder" data-id="@sub.Id" data-name="@sub.Name" data-emoji="@(sub.Emoji ?? "")" data-color="@(sub.Color ?? "")" data-size="-1" data-date="@sub.CreatedAt.ToUnixTimeSeconds()" data-scope="@sub.Scope.ToString().ToLowerInvariant()" data-is-private="@(sub.IsPrivate ? "1" : "0")" data-mine="@(me != null && sub.CreatedByUserId == me.Id ? "1" : "0")" ondblclick="location.href='@FolderUrl(sub)'">
                            <td class="col-check"></td>
                            <td class="col-name">
                                <a class="fm-name" href="@FolderUrl(sub)">
                                    @if (!string.IsNullOrEmpty(sub.Emoji))
                                    {
                                        <span class="fm-icon fm-icon-folder" style="background:transparent;font-size:1.6rem">@sub.Emoji</span>
                                    }
                                    else
                                    {
                                        <span class="fm-icon fm-icon-folder" style="@(string.IsNullOrEmpty(sub.Color) ? "" : $"background:#{sub.Color}")">📁</span>
                                    }
                                    <span class="fm-name-text">@sub.Name</span>
                                    @if (sub.IsPrivate)
                                    {
                                        @* v1.10.104: Schloss-Badge — signalisiert dass dieser Public-
                                           Ordner nur für explizit Berechtigte sichtbar ist. *@
                                        <span class="ai-tag fm-badge-lock" title="@T["permissions.private_hint"]">🔒 @T["permissions.private"]</span>
                                    }
                                </a>
                            </td>
                            <td class="col-size muted">—</td>
                            <td class="col-date muted">@sub.CreatedAt.ToDisplay()</td>
                            @if (scope != FileScope.Personal) { <td class="col-owner"></td> }
                            <td class="col-actions">
                                <div class="fm-row-actions">
                                    <button title="@T["actions.download_zip"]" aria-label="@T["actions.download_zip"]" onclick="event.stopPropagation();downloadFolderZip('@sub.Id', @Json.Serialize(sub.Name))">⬇</button>
                                    <button title="@T["actions.share_link"]" aria-label="@T["actions.share_link"]" onclick="event.stopPropagation();openShareFolderModal('@sub.Id')">🔗</button>
                                    @* v1.10.94: Direct-Share (Berechtigungen für User/Gruppen) auch als Hover-Icon.
                                       Marcus's Report: „in iOS kann ich Berechtigungen auf Ordner setzen, im Web nicht"
                                       — im Web WAR das nur über Rechtsklick erreichbar, der 🤝-Button fehlte in der
                                       Hover-Row. Jetzt sichtbar auf allen Ordnern. *@
                                    <button title="@T["share.direct"]" aria-label="@T["share.direct"]" onclick="event.stopPropagation();openDirectShare({id:'@sub.Id', name:@Json.Serialize(sub.Name), kind:'folder'})">🤝</button>
                                    @* v1.10.107: Berechtigungen-Icon für ALLE Public-Ordner —
                                       vorher nur Owner/Admin, was bei Ordnern mit historisch
                                       leerem CreatedByUserId das Icon versteckte. Das Modal
                                       zeigt sich read-only wenn der Server canManage=false
                                       liefert; der eigentliche Schutz sitzt serverseitig. *@
                                    @if (sub.Scope == FileScope.Public)
                                    {
                                        <button title="@T["actions.permissions"]" aria-label="@T["actions.permissions"]" onclick="event.stopPropagation();openPermissionsModal('@sub.Id')">🔒</button>
                                    }
                                    <button title="@T["actions.request_upload"]" aria-label="@T["actions.request_upload"]" onclick="event.stopPropagation();openUploadRequestModal('@sub.Id')">📥</button>
                                    @if (canManage)
                                    {
                                        @* v1.10.96: Rename ruft jetzt tatsächlich einen Handler auf (openRenameFolderModal
                                           war früher undefined → Stift-Button war stumm). Delete ist jetzt zweistufig:
                                           bei nicht-leerem Ordner fragt der Handler explizit ob mit Inhalt gelöscht werden soll. *@
                                        <button title="@T["actions.rename"]" aria-label="@T["actions.rename"]"
                                                onclick="event.stopPropagation();nimRenameFolder('@sub.Id', @Json.Serialize(sub.Name))">✎</button>
                                        <button title="@T["actions.delete"]" aria-label="@T["actions.delete"]"
                                                onclick="event.stopPropagation();nimDeleteFolder('@sub.Id', @Json.Serialize(sub.Name), @Json.Serialize(currentUrl))">🗑</button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var f in files)
                    {
                        var isMine = me != null && f.OwnerId == me.Id;
                        var alreadyPinned = pinnedIds.Contains(f.Id);
                        <tr class="ctx fm-row fm-row-file" data-kind="file" data-id="@f.Id" data-name="@f.Name" data-size="@f.SizeBytes" data-content-type="@f.ContentType" data-date="@f.CreatedAt.ToUnixTimeSeconds()" data-owner-id="@f.OwnerId" data-mine="@(isMine ? "1" : "0")" data-pinned="@(alreadyPinned ? "1" : "0")" ondblclick="openPreview('@f.Id')">
                            <td class="col-check"><input type="checkbox" class="row-check" value="@f.Id" onclick="event.stopPropagation()"/></td>
                            <td class="col-name">
                                <div class="fm-name" style="cursor:pointer" onclick="openPreview('@f.Id')">
                                    <span class="fm-icon fm-icon-file @TypeClass(f.Name)">@TypeLabel(f.Name)</span>
                                    <span class="fm-name-text">@f.Name</span>
                                    @if (!string.IsNullOrEmpty(f.AiRiskFlag) && f.AiRiskFlag != "clean" && f.AiRiskFlag != "unknown")
                                    {
                                        <span class="ai-risk" title="AI-detected risk">⚠ @f.AiRiskFlag</span>
                                    }
                                    @if (!string.IsNullOrEmpty(f.AiTags))
                                    {
                                        foreach (var tag in f.AiTags.Split(',').Take(3))
                                        {
                                            <span class="ai-tag">@tag.Trim()</span>
                                        }
                                    }
                                </div>
                            </td>
                            <td class="col-size">@Bytes(f.SizeBytes)</td>
                            <td class="col-date muted">@f.CreatedAt.ToDisplay()</td>
                            @if (scope != FileScope.Personal) { <td class="col-owner muted">@f.Owner.DisplayName</td> }
                            <td class="col-actions">
                                <div class="fm-row-actions">
                                    <button title="@T["actions.download"]" aria-label="@T["actions.download"]" onclick="event.stopPropagation();downloadFile('@f.Id')">⬇</button>
                                    <button title="@T["actions.share_link"]" aria-label="@T["actions.share_link"]" onclick="event.stopPropagation();openShareFileModal('@f.Id')">🔗</button>
                                    @* v1.10.94: Direct-Share auch für Files als Hover-Icon *@
                                    <button title="@T["share.direct"]" aria-label="@T["share.direct"]" onclick="event.stopPropagation();openDirectShare({id:'@f.Id', name:@Json.Serialize(f.Name), kind:'file'})">🤝</button>
                                    @if (canWrite) { <button title="@T["actions.move"]" aria-label="@T["actions.move"]" onclick="event.stopPropagation();openMoveSingle('@f.Id')">↦</button> }
                                    <button title="@T["actions.delete"]" aria-label="@T["actions.delete"]" onclick="event.stopPropagation();deleteFile('@f.Id')">🗑</button>
                                </div>
                            </td>
                        </tr>
                    }
                    @* Angepinnte Files nur im Personal-Root — als Referenz-Zeilen mit 📌 Badge. *@
                    @foreach (var f in pinnedFiles)
                    {
                        <tr class="ctx fm-row fm-row-file fm-row-pinned" data-kind="file" data-id="@f.Id" data-name="@f.Name" data-size="@f.SizeBytes" data-content-type="@f.ContentType" data-date="@f.CreatedAt.ToUnixTimeSeconds()" data-owner-id="@f.OwnerId" data-mine="0" data-pinned="1" ondblclick="openPreview('@f.Id')">
                            <td class="col-check"></td>
                            <td class="col-name">
                                <div class="fm-name" style="cursor:pointer" onclick="openPreview('@f.Id')">
                                    <span class="fm-icon fm-icon-file @TypeClass(f.Name)">@TypeLabel(f.Name)</span>
                                    <span class="fm-name-text">@f.Name</span>
                                    <span class="ai-tag" title="@T["pin.badge_hint"]">📌 @T["pin.badge"]</span>
                                </div>
                            </td>
                            <td class="col-size">@Bytes(f.SizeBytes)</td>
                            <td class="col-date muted">@f.CreatedAt.ToDisplay()</td>
                            <td class="col-actions">
                                <div class="fm-row-actions">
                                    <button title="@T["actions.download"]" aria-label="@T["actions.download"]" onclick="event.stopPropagation();downloadFile('@f.Id')">⬇</button>
                                    <button title="@T["actions.share_link"]" aria-label="@T["actions.share_link"]" onclick="event.stopPropagation();openShareFileModal('@f.Id')">🔗</button>
                                    <button title="@T["pin.unpin"]" aria-label="@T["pin.unpin"]" onclick="event.stopPropagation();unpinFile('@f.Id')">📌✕</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

<!-- Preview modal -->
<div class="modal-backdrop" id="modalPreview" onclick="if(event.target===this)closeModal('modalPreview')">
    <div class="modal-panel" style="max-width:900px">
        <h2 id="previewTitle"></h2>
        <div id="previewBody" style="margin-top:var(--sp-4)"></div>
        <div class="actions"><button class="btn btn-ghost" onclick="closeModal('modalPreview')">@T["modal.close"]</button></div>
    </div>
</div>

<!-- Right-click context menu -->
<div class="ctx-menu" id="ctxMenu">
    <button data-act="open" style="display:none">📂 @T["ctx.open"]</button>
    <button data-act="preview" style="display:none">👁 Preview</button>
    <button data-act="share">🔗 @T["actions.share_link"]</button>
    <button data-act="directShare">🤝 @T["share.direct"]</button>
    @* v1.10.104: Berechtigungen (Windows-ACL-Style) — nur im Public-Scope für
       Ordner-Owner/Admin sichtbar. Wird per JS ein-/ausgeblendet. *@
    <button data-act="permissions" style="display:none">🔒 @T["actions.permissions"]</button>
    <button data-act="sign" style="display:none">✍ @T["nav.signatures"]</button>
    <button data-act="uploadReq" style="display:none">📥 @T["actions.request_upload"]</button>
    <button data-act="downloadZip" style="display:none">⬇ @T["actions.download_zip"]</button>
    <button data-act="favorite">⭐ @T["actions.star"]</button>
    <div class="divider"></div>
    <button data-act="move" style="display:none">↦ @T["actions.move"]</button>
    <button data-act="copy" style="display:none">📋 @T["actions.copy"]</button>
    <button data-act="pin" style="display:none">📌 @T["pin.copy_to_personal"]</button>
    <button data-act="unpin" style="display:none">📌✕ @T["pin.unpin"]</button>
    <button data-act="rename" style="display:none">✎ @T["actions.rename"]</button>
    <button data-act="icon" style="display:none">🎨 @T["actions.change_icon"]</button>
    <button data-act="newSubfolder" style="display:none">📁+ @T["browse.new_subfolder"]</button>
    <button data-act="delete">🗑 @T["actions.delete"]</button>
</div>

@* v1.10.64: separates Kontextmenü für Rechtsklick auf die LEERE Fläche
   der Ordnerliste — nur globale "hier neu anlegen"-Aktionen, kein
   Datei-/Ordner-bezogenes Zeug. Marcus's Wunsch: rechte Maustaste →
   Neuer Ordner soll intuitiv im Browser funktionieren. *@
<div class="ctx-menu" id="ctxMenuEmpty">
    @if (canWrite)
    {
        <button data-act="newFolder">📁+ @T["browse.new_folder"]</button>
        <button data-act="upload">↑ @T["browse.upload"]</button>
    }
</div>

<!-- Folder-icon modal — swaps emoji + colour via /api/v1/folders/{id}/icon -->
<div class="modal-backdrop" id="modalFolderIcon" onclick="if(event.target===this)closeModal('modalFolderIcon')">
    <div class="modal-panel" style="max-width:520px">
        <h2>🎨 @T["folder_icon.title"] — <span id="fiTargetName" class="muted"></span></h2>
        <p class="muted" style="margin-top:0">@T["folder_icon.hint"]</p>
        <div class="field">
            <label>@T["folder_icon.emoji"]</label>
            <div id="fiEmojiGrid" class="emoji-grid"></div>
        </div>
        <div class="field">
            <label>@T["folder_icon.color"]</label>
            <div id="fiColorGrid" class="color-grid"></div>
        </div>
        <div class="actions" style="justify-content:space-between">
            <button class="btn btn-ghost" onclick="fi_reset()">↺ @T["folder_icon.reset"]</button>
            <div class="row" style="gap:8px">
                <button class="btn btn-ghost" onclick="closeModal('modalFolderIcon')">@T["modal.close"]</button>
                <button class="btn btn-primary" onclick="fi_save()">@T["modal.save"]</button>
            </div>
        </div>
    </div>
</div>

<!-- Direct-share modal (share to specific users / groups) -->
<div class="modal-backdrop" id="modalDirectShare" onclick="if(event.target===this)closeModal('modalDirectShare')">
    <div class="modal-panel" style="max-width:640px">
        <h2>🤝 @T["share.direct"] — <span id="dsTargetName" class="muted"></span></h2>
        <div class="field">
            <label>@T["share.target.user"] / @T["share.target.group"]</label>
            <div class="row" style="gap:6px">
                <select id="dsKind">
                    <option value="user">👤 @T["share.target.user"]</option>
                    <option value="group">👥 @T["share.target.group"]</option>
                </select>
                <input type="text" id="dsPicker" placeholder="@T["share.search_users"]" style="flex:1" list="dsUserList"/>
                <select id="dsGroupSel" style="flex:1;display:none"></select>
                <datalist id="dsUserList"></datalist>
                <select id="dsPerm">
                    <option value="Read">@T["share.perm.read"]</option>
                    <option value="Write">@T["share.perm.write"]</option>
                </select>
                <button class="btn btn-primary" onclick="ds_add()">@T["share.add"]</button>
            </div>
        </div>
        <div class="stack" id="dsList" style="margin-top:12px"></div>
        <div class="actions">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modalDirectShare')">@T["modal.close"]</button>
        </div>
    </div>
</div>

@* v1.10.104 (Stage 2 „Windows-ACL"): Berechtigungen-Modal für Public-
   Ordner. Nutzt PATCH /api/v1/folders/{id}/privacy für den Toggle und die
   bestehende /api/v1/direct-shares-API für Grants. Ownership + Admin-Check
   passieren serverseitig. *@
<div class="modal-backdrop" id="modalPermissions" onclick="if(event.target===this)closeModal('modalPermissions')">
    <div class="modal-panel" style="max-width:640px">
        <h2>🔒 @T["permissions.title"] — <span id="pmFolderName" class="muted"></span></h2>
        <p class="muted" style="margin-top:-6px">@T["permissions.explain"]</p>
        <div class="field" style="margin-top:12px">
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
                <input type="checkbox" id="pmPrivate" onchange="pm_togglePrivate()"/>
                <span><strong>@T["permissions.private_toggle"]</strong><br/>
                    <span class="muted" style="font-size:.85rem">@T["permissions.private_hint"]</span>
                </span>
            </label>
        </div>
        <hr style="margin:16px 0;border:none;border-top:1px solid var(--tw-gray-200)"/>
        <div class="field">
            <label>@T["permissions.add_row"]</label>
            <div class="row" style="gap:6px">
                <select id="pmKind">
                    <option value="user">👤 @T["share.target.user"]</option>
                    <option value="group">👥 @T["share.target.group"]</option>
                </select>
                <input type="text" id="pmPicker" placeholder="@T["share.search_users"]" style="flex:1" list="pmUserList"/>
                <select id="pmGroupSel" style="flex:1;display:none"></select>
                <datalist id="pmUserList"></datalist>
                <select id="pmPerm">
                    <option value="Read">@T["share.perm.read"]</option>
                    <option value="Write">@T["share.perm.write"]</option>
                </select>
                <button class="btn btn-primary" onclick="pm_add()">@T["share.add"]</button>
            </div>
        </div>
        <div class="stack" id="pmList" style="margin-top:12px"></div>
        <div class="actions">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modalPermissions')">@T["modal.close"]</button>
        </div>
    </div>
</div>

<partial name="_LinkModals" model="@current" />

@* v1.10.67: Move + Copy nutzen jetzt einen echten Ordner-Browser statt
   einer flachen Dropdown-Liste. Marcus's Feedback: "langes fixes Dropdown
   an Ordnern - nicht wirklich state of the art". Der Browser zeigt eine
   Baum-Struktur mit aufklappbaren Ordnern, aktueller Pfad wird prominent
   angezeigt, Zielordner wird per Klick markiert (highlight). *@
<div class="modal-backdrop" id="modalMove" onclick="if(event.target===this)closeModal('modalMove')">
    <div class="modal-panel folder-picker-panel">
        <h2>@T["move.title"]</h2>
        <p class="muted" id="moveHint"></p>
        <div class="folder-picker" id="movePicker" data-mode="move"></div>
        <div class="folder-picker-target">
            <span class="muted">@T["move.target"]:</span>
            <strong id="moveTargetLabel">—</strong>
        </div>
        <div class="actions">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modalMove')">@T["modal.cancel"]</button>
            <button type="button" class="btn btn-primary" onclick="performMove()" id="moveBtn" disabled>@T["move.button"]</button>
        </div>
    </div>
</div>

<div class="modal-backdrop" id="modalCopy" onclick="if(event.target===this)closeModal('modalCopy')">
    <div class="modal-panel folder-picker-panel">
        <h2>@T["copy.title"]</h2>
        <p class="muted" id="copyHint"></p>
        <div class="folder-picker" id="copyPicker" data-mode="copy"></div>
        <div class="folder-picker-target">
            <span class="muted">@T["move.target"]:</span>
            <strong id="copyTargetLabel">—</strong>
        </div>
        <div class="actions">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modalCopy')">@T["modal.cancel"]</button>
            <button type="button" class="btn btn-primary" onclick="performCopy()" id="copyBtn" disabled>@T["copy.button"]</button>
        </div>
    </div>
</div>

<script>
const FOLDER_ID = @Json.Serialize(current.Id);
const RETURN_URL = @Json.Serialize(currentUrl);
const SCOPE = @Json.Serialize(scope.ToString());
const CAN_WRITE = @(canWrite ? "true" : "false");
const CAN_MANAGE = @(canManage ? "true" : "false");

// ── Row selection ─────────────────────────────────────────────
const bulkBar = document.getElementById('bulkBar');
const bulkCount = document.getElementById('bulkCount');
const selAll = document.getElementById('selectAll');

function updateSelection() {
    const boxes = document.querySelectorAll('.row-check');
    const selected = Array.from(boxes).filter(b => b.checked).length;
    bulkCount.textContent = selected + ' ' + @Json.Serialize(T["bulk.selected"].Value);
    bulkBar.classList.toggle('on', selected > 0);
    document.querySelectorAll('tr.ctx[data-kind="file"]').forEach(tr => {
        const cb = tr.querySelector('.row-check');
        if (cb) tr.classList.toggle('selected', cb.checked);
    });
}
document.querySelectorAll('.row-check').forEach(cb => cb.addEventListener('change', updateSelection));
if (selAll) selAll.addEventListener('change', () => {
    document.querySelectorAll('.row-check').forEach(cb => cb.checked = selAll.checked);
    updateSelection();
});
function selectedIds() {
    return Array.from(document.querySelectorAll('.row-check')).filter(b => b.checked).map(b => b.value);
}
function clearSelection() {
    document.querySelectorAll('.row-check').forEach(cb => cb.checked = false);
    if (selAll) selAll.checked = false;
    updateSelection();
}

// v1.10.96: Fix „Stift ohne Funktion" — openRenameFolderModal wurde nur
// aufgerufen, aber nie definiert. Ersetzt durch nimRenameFolder: fragt via
// nimPrompt (window.prompt-Fallback), postet an /browse/folders/{id}/rename.
async function nimRenameFolder(id, currentName) {
    const newName = window.prompt(@Json.Serialize(T["actions.rename"].Value), currentName);
    if (!newName || newName === currentName) return;
    const csrf = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    const form = new FormData();
    form.append('name', newName);
    form.append('returnUrl', window.location.pathname + window.location.search);
    form.append('__RequestVerificationToken', csrf);
    const r = await fetch('/browse/folders/' + id + '/rename', { method: 'POST', body: form, credentials: 'same-origin' });
    if (r.ok || r.redirected) window.location.reload();
    else nimAlert('Rename fehlgeschlagen: ' + r.status, { kind: 'error' });
}

// v1.10.96: Fix Marcus's Delete-Bug — vorher warf der Delete bei nicht-leerem
// Ordner nur eine Fehlermeldung. Jetzt: Content-Count via API holen, dann
// abhängig davon einstufige oder zweistufige Confirmation.
async function nimDeleteFolder(id, name, returnUrl) {
    let count = { files: 0, subfolders: 0 };
    try {
        const r = await fetch('/api/v1/folders/' + id + '/contents-count', { credentials: 'same-origin' });
        if (r.ok) count = await r.json();
    } catch {}
    const nonEmpty = count.files > 0 || count.subfolders > 0;
    let msg;
    if (nonEmpty) {
        const parts = [];
        if (count.files > 0) parts.push(count.files + ' Datei' + (count.files === 1 ? '' : 'en'));
        if (count.subfolders > 0) parts.push(count.subfolders + ' Unterordner');
        msg = 'Der Ordner „' + name + '" enthält ' + parts.join(' und ') + '. Wirklich alles in den Papierkorb verschieben?';
    } else {
        msg = 'Ordner „' + name + '" wirklich löschen?';
    }
    if (!await nimConfirm(msg, { danger: true })) return;
    // POST an Delete-Endpoint mit force=true wenn nicht leer
    const csrf = document.querySelector('input[name="__RequestVerificationToken"]')?.value || '';
    const form = new FormData();
    form.append('returnUrl', returnUrl);
    if (nonEmpty) form.append('force', 'true');
    form.append('__RequestVerificationToken', csrf);
    const r = await fetch('/browse/folders/' + id + '/delete', { method: 'POST', body: form, credentials: 'same-origin' });
    if (r.ok || r.redirected) window.location.reload();
    else nimAlert('Löschen fehlgeschlagen: ' + r.status, { kind: 'error' });
}

async function bulkDelete() {
    const ids = selectedIds();
    if (!ids.length) return;
    const tpl = @Json.Serialize(T["bulk.confirm.delete"].Value);
    if (!await nimConfirm(tpl.replace("{n}", ids.length), { danger: true })) return;
    const r = await fetch('/api/v1/files/bulk-delete', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify({ ids }),
    });
    if (r.ok) location.reload(); else nimAlert('Failed: ' + r.status, { kind: 'error' });
}

async function bulkZip() {
    // Files-only for the moment (folder zipping is a future feature).
    const fileIds = Array.from(document.querySelectorAll('tr.ctx.selected[data-kind="file"]'))
        .map(tr => tr.dataset.id);
    if (!fileIds.length) {
        nimAlert(@Json.Serialize(T["bulk.zip.no_files"].Value));
        return;
    }
    // POST returns a chunked zip stream — use a hidden form so the browser
    // handles the download dialog itself (fetch would buffer in memory).
    const form = document.createElement('form');
    form.method = 'POST'; form.action = '/api/v1/files/bulk-zip';
    form.style.display = 'none';
    // JSON body via a fetch → blob → download-anchor because form-post can't
    // send JSON. Instead of the form workaround, do the fetch + save flow.
    document.body.appendChild(form);

    const busy = @Json.Serialize(T["bulk.zip.preparing"].Value);
    const oldTitle = document.title;
    document.title = busy;
    try {
        const r = await fetch('/api/v1/files/bulk-zip', {
            method: 'POST', headers: {'Content-Type':'application/json'},
            credentials: 'same-origin',
            body: JSON.stringify({ fileIds, archiveName: null })
        });
        if (!r.ok) { nimAlert(@Json.Serialize(T["common.error"].Value) + ': ' + r.status, { kind: 'error' }); return; }
        const blob = await r.blob();
        const cd = r.headers.get('Content-Disposition') || '';
        const m = /filename="?([^"]+)"?/.exec(cd);
        const name = m ? m[1] : 'nimshare.zip';
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = name;
        document.body.appendChild(a); a.click(); a.remove();
        setTimeout(() => URL.revokeObjectURL(a.href), 30000);
    } finally { document.title = oldTitle; form.remove(); }
}

async function deleteFile(id) {
    if (!confirm(@Json.Serialize(T["actions.confirm_delete"].Value))) return;
    const r = await fetch('/api/v1/files/' + id, { method: 'DELETE', credentials: 'same-origin' });
    if (r.ok) location.reload(); else nimAlert('Failed: ' + r.status, { kind: 'error' });
}

// v1.10.70: Folder-ZIP-Download. Ruft POST /api/v1/folders/{id}/zip
// welcher rekursiv alle lesbaren Files als ZIP-Stream zurückgibt.
// Fetch-basiert (nicht Anchor-basiert) damit wir die Response-Fehler
// vor dem Download sehen (413 "Ordner zu groß" etc.).
async function downloadFolderZip(folderId, folderName) {
    const csrf = document.querySelector('input[name="__RequestVerificationToken"]');
    const busyMsg = @Json.Serialize(T["folder.zip.preparing"].Value);
    const oldTitle = document.title;
    document.title = busyMsg;
    try {
        const r = await fetch('/api/v1/folders/' + folderId + '/zip', {
            method: 'POST',
            credentials: 'same-origin',
            headers: csrf ? { 'X-XSRF-TOKEN': csrf.value } : {},
        });
        if (!r.ok) {
            let msg = 'HTTP ' + r.status;
            try { const b = await r.json(); msg = b.detail || b.title || msg; } catch {}
            nimAlert(msg, { kind: 'error' });
            return;
        }
        const blob = await r.blob();
        const cd = r.headers.get('Content-Disposition') || '';
        const m = /filename="?([^"]+)"?/.exec(cd);
        const name = m ? m[1] : (folderName + '.zip');
        const a = document.createElement('a');
        a.href = URL.createObjectURL(blob);
        a.download = name;
        document.body.appendChild(a); a.click(); a.remove();
        setTimeout(() => URL.revokeObjectURL(a.href), 30000);
    } finally { document.title = oldTitle; }
}

// v1.10.64: Direkt-Download aus der Row-Action-Leiste. Ein-Klick-Weg
// statt "Vorschau öffnen → Download-Anchor klicken". Nutzt den bestehenden
// preview-url-Endpoint, weil dessen SAS bereits ContentDisposition=attachment
// enthält — der Browser lädt also runter statt zu rendern, sobald wir die
// URL öffnen. Kein `download`-Attribut nötig (funktioniert eh nicht cross-
// origin bei Azure Blob URLs).
async function downloadFile(id) {
    try {
        const r = await fetch('/api/v1/files/' + id + '/preview-url', { credentials: 'same-origin' });
        if (!r.ok) { nimAlert('Fehler: ' + r.status, { kind: 'error' }); return; }
        const d = await r.json();
        // Ein unsichtbares Anchor mit target=_blank triggern — bei
        // Content-Disposition:attachment fängt der Browser den Response
        // ab und speichert direkt, ohne das neue Tab überhaupt zu zeigen.
        const a = document.createElement('a');
        a.href = d.url;
        a.rel = 'noopener';
        // download-Attribut ignoriert der Browser cross-origin, aber schadet nicht.
        a.download = d.name || '';
        document.body.appendChild(a); a.click(); a.remove();
    } catch (ex) {
        nimAlert(String(ex), { kind: 'error' });
    }
}

// ── Pin (kopiere ohne Blob-Duplikat in Personal) ─────────────
async function pinFile(fileId) {
    const csrf = document.querySelector('input[name="__RequestVerificationToken"]');
    const r = await fetch('/api/v1/file-pins', {
        method: 'POST', credentials: 'same-origin',
        headers: {
            'Content-Type': 'application/json',
            ...(csrf ? { 'RequestVerificationToken': csrf.value } : {})
        },
        body: JSON.stringify({ fileId: fileId, note: null }),
    });
    if (r.ok) {
        nimToast(@Json.Serialize(T["pin.copied_ok"].Value), { kind: 'success' });
    } else if (r.status === 409) {
        nimAlert(@Json.Serialize(T["pin.copy_conflict"].Value));
    } else {
        nimAlert('Fehler: ' + r.status, { kind: 'error' });
    }
}
async function unpinFile(fileId) {
    if (!await nimConfirm(@Json.Serialize(T["pin.unpin_confirm"].Value), { danger: true })) return;
    const r = await fetch('/api/v1/file-pins/' + fileId, { method: 'DELETE', credentials: 'same-origin' });
    if (r.ok || r.status === 404) location.reload(); else nimAlert('Fehler: ' + r.status, { kind: 'error' });
}

// ── Right-click context menu ──────────────────────────────────
const ctxMenu = document.getElementById('ctxMenu');
let ctxTarget = null;
document.querySelectorAll('tr.ctx').forEach(tr => {
    tr.addEventListener('contextmenu', (e) => {
        e.preventDefault();
        ctxTarget = { kind: tr.dataset.kind, id: tr.dataset.id, name: tr.dataset.name,
                      mine: tr.dataset.mine === '1', pinned: tr.dataset.pinned === '1',
                      folderScope: tr.dataset.scope || '',
                      isPrivate: tr.dataset.isPrivate === '1' };
        const showFor = (id, cond) => ctxMenu.querySelector(`[data-act="${id}"]`).style.display = cond ? '' : 'none';
        const isSignable = ctxTarget.kind === 'file' && (tr.dataset.contentType || '').toLowerCase() === 'application/pdf';
        // "Pin" (=Kopieren-Verweis nach Personal): nur Files, die nicht mir gehören
        // ODER die aus Public/Group stammen. Bereits gepinnte Files bekommen
        // stattdessen "Unpin".
        const canPin = ctxTarget.kind === 'file' && !ctxTarget.pinned && !(SCOPE === 'Personal' && ctxTarget.mine);
        showFor('open',        ctxTarget.kind === 'folder');
        showFor('preview',     ctxTarget.kind === 'file');
        showFor('sign',        isSignable);
        showFor('uploadReq',   ctxTarget.kind === 'folder');
        showFor('downloadZip', ctxTarget.kind === 'folder');
        showFor('rename',      ctxTarget.kind === 'folder' && CAN_MANAGE);
        showFor('icon',        ctxTarget.kind === 'folder' && CAN_MANAGE);
        // v1.10.64: Sub-Ordner direkt aus dem Kontext eines anderen Ordners
        // anlegen — spart einen Navigations-Sprung.
        showFor('newSubfolder', ctxTarget.kind === 'folder' && CAN_WRITE);
        showFor('move',        ctxTarget.kind === 'file'   && CAN_WRITE && !ctxTarget.pinned);
        showFor('copy',        ctxTarget.kind === 'file'   && !ctxTarget.pinned);
        showFor('pin',         canPin);
        showFor('unpin',       ctxTarget.kind === 'file'   && ctxTarget.pinned);
        // Stash colour + emoji on the ctxTarget so the icon modal knows the
        // current state without another server round-trip.
        ctxTarget.emoji = tr.dataset.emoji || '';
        ctxTarget.color = tr.dataset.color || '';
        showFor('share',       true);
        showFor('directShare', true);
        // v1.10.107: Berechtigungen IMMER anbieten — Marcus's Wunsch nach
        // doppeltem Boden, weil die Hover-Icons auf manchen Setups nicht
        // reagieren. Vorher war der Eintrag auf Public-Ordner + Owner/Admin
        // beschränkt; jetzt entscheidet der Klick-Handler welches Modal
        // passt und der Server validiert die eigentliche Berechtigung.
        showFor('permissions', true);
        showFor('favorite',    true);
        // Delete is destructive — it drops the underlying blob. On pinned
        // "shortcut" rows we hide it (Unpin above is the correct action);
        // otherwise the user could nuke a file they don't even own.
        showFor('delete',      ((ctxTarget.kind === 'file' && !ctxTarget.pinned)
                                || (ctxTarget.kind === 'folder' && CAN_MANAGE)));
        const vw = window.innerWidth, vh = window.innerHeight;
        const w = 220, h = ctxMenu.offsetHeight || 200;
        const x = Math.min(e.clientX, vw - w - 10);
        const y = Math.min(e.clientY, vh - h - 10);
        ctxMenu.style.left = x + 'px';
        ctxMenu.style.top = y + 'px';
        ctxMenu.classList.add('open');
    });
});
document.addEventListener('click', () => ctxMenu.classList.remove('open'));
window.addEventListener('scroll', () => ctxMenu.classList.remove('open'), true);

// ── v1.10.64: Rechtsklick auf leere Content-Fläche → "Neuer Ordner" Menü ─
// Marcus's Wunsch: "wäre toll wenn man da auch so rechte maustaste
// drücken könnte 'Neuer Ordner'". Ein zweites, schmales Kontextmenü das
// nur die "Hier neu anlegen"-Aktionen anbietet — kein Datei/Ordner-Zeug.
const ctxMenuEmpty = document.getElementById('ctxMenuEmpty');
if (ctxMenuEmpty) {
    // Auslöser: Rechtsklick auf .fm-main, .fm-empty oder direkt auf die
    // Tabelle wenn NICHT auf einer Row (tr.ctx fängt die eh selbst ab).
    const emptyTargets = document.querySelectorAll('.fm-main, .fm-empty, .fm-list tbody');
    emptyTargets.forEach(el => {
        el.addEventListener('contextmenu', (e) => {
            // Wenn der Klick innerhalb einer Row geschieht, überlassen wir
            // ihn dem regulären ctxMenu (dessen Handler ist auf tr.ctx).
            if (e.target.closest('tr.ctx')) return;
            e.preventDefault();
            ctxMenu.classList.remove('open');
            const vw = window.innerWidth, vh = window.innerHeight;
            const w = 200, h = ctxMenuEmpty.offsetHeight || 100;
            const x = Math.min(e.clientX, vw - w - 10);
            const y = Math.min(e.clientY, vh - h - 10);
            ctxMenuEmpty.style.left = x + 'px';
            ctxMenuEmpty.style.top = y + 'px';
            ctxMenuEmpty.classList.add('open');
        });
    });
    document.addEventListener('click', () => ctxMenuEmpty.classList.remove('open'));
    window.addEventListener('scroll', () => ctxMenuEmpty.classList.remove('open'), true);
    ctxMenuEmpty.querySelectorAll('button').forEach(b => {
        b.addEventListener('click', () => {
            const act = b.dataset.act;
            if (act === 'newFolder') openNewFolderModal();
            else if (act === 'upload') document.getElementById('quickPick').click();
        });
    });
}
ctxMenu.querySelectorAll('button').forEach(b => {
    b.addEventListener('click', () => {
        const act = b.dataset.act;
        if (!ctxTarget) return;
        if (act === 'open' && ctxTarget.kind === 'folder') {
            const url = document.querySelector(`tr.ctx[data-id="${ctxTarget.id}"] a.fm-name`);
            if (url) location.href = url.getAttribute('href');
        }
        if (act === 'preview' && ctxTarget.kind === 'file') openPreview(ctxTarget.id);
        if (act === 'share') {
            if (ctxTarget.kind === 'file') openShareFileModal(ctxTarget.id);
            else openShareFolderModal(ctxTarget.id);
        }
        if (act === 'directShare') openDirectShare(ctxTarget);
        // v1.10.107: Berechtigungen für jeden Row-Typ. Public-Ordner
        // bekommen das ACL-Modal (Privat-Toggle + Grants); alles andere
        // (Personal/Group-Ordner, Dateien) das Direct-Share-Modal — dort
        // IST Direct-Share das Berechtigungskonzept.
        if (act === 'permissions') {
            if (ctxTarget.kind === 'folder' && ctxTarget.folderScope === 'public') {
                openPermissionsModal(ctxTarget.id);
            } else {
                openDirectShare(ctxTarget);
            }
        }
        if (act === 'favorite') toggleFavorite(ctxTarget);
        if (act === 'sign' && ctxTarget.kind === 'file') {
            location.href = '/signatures/new?fileId=' + ctxTarget.id;
        }
        if (act === 'uploadReq' && ctxTarget.kind === 'folder') openUploadRequestModal(ctxTarget.id);
        if (act === 'downloadZip' && ctxTarget.kind === 'folder') downloadFolderZip(ctxTarget.id, ctxTarget.name);
        if (act === 'rename' && ctxTarget.kind === 'folder') nimRenameFolder(ctxTarget.id, ctxTarget.name);
        if (act === 'icon' && ctxTarget.kind === 'folder') openFolderIcon(ctxTarget);
        if (act === 'newSubfolder' && ctxTarget.kind === 'folder') openNewFolderModal(ctxTarget.id);
        if (act === 'move' && ctxTarget.kind === 'file') openMoveSingle(ctxTarget.id);
        if (act === 'copy' && ctxTarget.kind === 'file') openCopySingle(ctxTarget.id);
        if (act === 'pin' && ctxTarget.kind === 'file') pinFile(ctxTarget.id);
        if (act === 'unpin' && ctxTarget.kind === 'file') unpinFile(ctxTarget.id);
        if (act === 'delete') {
            if (ctxTarget.kind === 'file') deleteFile(ctxTarget.id);
            else nimDeleteFolder(ctxTarget.id, ctxTarget.name, RETURN_URL);
        }
    });
});

// ── v1.10.67: Ordner-Browser für Move + Copy ──────────────────
// Marcus's Feedback zu v1.10.66: das lange fixe Dropdown "nicht wirklich
// state of the art" — jetzt ein echter Baum-Picker. Beide Modals nutzen
// dieselbe Render-Logik (openFolderPicker), unterscheiden sich nur in
// (a) welcher Endpoint für die Ordnerliste (writable-all reserviert für
// Copy weil cross-scope, writable?scope=… für Move weil same-scope), und
// (b) welche Action beim Bestätigen läuft.
let moveIds = [];
let copyIds = [];
const pickerState = { move: { target: null, expanded: new Set() },
                       copy: { target: null, expanded: new Set() } };

async function openMoveModal() {
    moveIds = selectedIds();
    if (!moveIds.length) return;
    const tpl = @Json.Serialize(T["move.hint.multi"].Value);
    document.getElementById('moveHint').textContent = tpl.replace("{n}", moveIds.length);
    await openFolderPicker('move', /* scoped */ true);
}
async function openMoveSingle(id) {
    moveIds = [id];
    document.getElementById('moveHint').textContent = @Json.Serialize(T["move.hint.single"].Value);
    await openFolderPicker('move', true);
}
async function openCopySingle(id) {
    copyIds = [id];
    document.getElementById('copyHint').textContent = @Json.Serialize(T["copy.hint.single"].Value);
    await openFolderPicker('copy', /* scoped */ false);
}

/// Renders a fold-out folder tree in modalMove / modalCopy. `scoped`
/// limits the picker to the CURRENT scope (used by Move — cross-scope
/// moves are refused by the server anyway); Copy shows all writable
/// folders across all scopes.
async function openFolderPicker(mode, scoped) {
    pickerState[mode] = { target: null, expanded: new Set() };
    const picker = document.getElementById(mode === 'move' ? 'movePicker' : 'copyPicker');
    picker.innerHTML = '<div class="muted" style="padding:16px">Lädt…</div>';
    const modalId = mode === 'move' ? 'modalMove' : 'modalCopy';
    document.getElementById(modalId).classList.add('open');
    document.getElementById(mode + 'TargetLabel').textContent = '—';
    document.getElementById(mode + 'Btn').disabled = true;

    let items;
    if (scoped) {
        const r = await fetch('/api/v1/folders/writable?scope=' + SCOPE + '&exclude=' + FOLDER_ID, { credentials: 'same-origin' });
        if (!r.ok) { picker.innerHTML = '<div class="muted">Fehler beim Laden</div>'; return; }
        // /writable liefert flache Liste OHNE parentId → wir behandeln
        // sie als flache Liste ohne Baum-Ebenen (kompatibel mit alten
        // Servern). Der neue writable-all hat parentId.
        items = (await r.json()).map(x => ({ id: x.id, name: x.path, scope: SCOPE, parentId: null, isRoot: false }));
    } else {
        const r = await fetch('/api/v1/folders/writable-all', { credentials: 'same-origin' });
        if (!r.ok) { picker.innerHTML = '<div class="muted">Fehler beim Laden</div>'; return; }
        items = await r.json();
    }
    renderFolderPicker(picker, items, mode);
}

function renderFolderPicker(picker, items, mode) {
    // Baumaufbau: parentId → children. Roots sind Nodes ohne parentId
    // (oder deren parentId nicht in items ist — z.B. writable-Fallback).
    const byId = new Map(items.map(x => [x.id, { ...x, children: [] }]));
    const roots = [];
    for (const it of byId.values()) {
        if (it.parentId && byId.has(it.parentId)) {
            byId.get(it.parentId).children.push(it);
        } else {
            roots.push(it);
        }
    }
    // Innerhalb jeder Ebene alphabetisch, aber Roots nach Scope sortieren.
    const scopeRank = { Personal: 0, Public: 1, Group: 2 };
    roots.sort((a, b) => (scopeRank[a.scope] ?? 9) - (scopeRank[b.scope] ?? 9)
                        || (a.name || '').localeCompare(b.name || ''));
    function sortChildren(n) { n.children.sort((a, b) => (a.name || '').localeCompare(b.name || '')); n.children.forEach(sortChildren); }
    roots.forEach(sortChildren);

    picker.innerHTML = '';
    if (roots.length === 0) {
        picker.innerHTML = '<div class="muted" style="padding:16px">Keine Zielordner verfügbar.</div>';
        return;
    }
    const state = pickerState[mode];
    // Roots per Default aufgeklappt.
    roots.forEach(r => state.expanded.add(r.id));

    function nodeEl(n, depth) {
        const wrap = document.createElement('div');
        wrap.className = 'fp-node';
        const row = document.createElement('div');
        row.className = 'fp-row';
        row.style.paddingLeft = (6 + depth * 16) + 'px';
        row.dataset.id = n.id;
        const hasKids = n.children.length > 0;
        const tog = document.createElement('span');
        tog.className = 'fp-toggle';
        tog.textContent = hasKids ? (state.expanded.has(n.id) ? '▾' : '▸') : '·';
        if (hasKids) {
            tog.style.cursor = 'pointer';
            tog.addEventListener('click', (e) => {
                e.stopPropagation();
                if (state.expanded.has(n.id)) state.expanded.delete(n.id);
                else state.expanded.add(n.id);
                renderFolderPicker(picker, [...byId.values()], mode);
            });
        }
        const ico = document.createElement('span');
        ico.className = 'fp-icon';
        ico.textContent = n.isRoot
            ? (n.scope === 'Personal' ? '👤' : n.scope === 'Public' ? '🌍' : '👥')
            : '📁';
        const lbl = document.createElement('span');
        lbl.className = 'fp-label';
        lbl.textContent = n.name || n.path || '(unbenannt)';
        row.appendChild(tog);
        row.appendChild(ico);
        row.appendChild(lbl);
        row.style.cursor = 'pointer';
        row.addEventListener('click', () => {
            state.target = { id: n.id, name: fullPath(n) };
            picker.querySelectorAll('.fp-row.selected').forEach(r => r.classList.remove('selected'));
            row.classList.add('selected');
            document.getElementById(mode + 'TargetLabel').textContent = fullPath(n);
            document.getElementById(mode + 'Btn').disabled = false;
        });
        wrap.appendChild(row);
        if (hasKids && state.expanded.has(n.id)) {
            const kids = document.createElement('div');
            kids.className = 'fp-children';
            n.children.forEach(c => kids.appendChild(nodeEl(c, depth + 1)));
            wrap.appendChild(kids);
        }
        return wrap;
    }
    function fullPath(n) {
        const parts = [n.name || n.path];
        let cur = n;
        while (cur.parentId && byId.has(cur.parentId)) {
            cur = byId.get(cur.parentId);
            parts.unshift(cur.name || cur.path);
        }
        return parts.join(' / ');
    }
    roots.forEach(r => picker.appendChild(nodeEl(r, 0)));
}

async function performMove() {
    const t = pickerState.move.target;
    if (!t) return;
    let ok = 0, fail = 0;
    for (const id of moveIds) {
        const r = await fetch('/api/v1/files/' + id + '/move', {
            method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
            body: JSON.stringify({ folderId: t.id }),
        });
        if (r.ok) ok++; else fail++;
    }
    document.getElementById('modalMove').classList.remove('open');
    if (fail) nimAlert(ok + ' verschoben, ' + fail + ' fehlgeschlagen', { kind: 'warning' });
    else { nimToast('Verschoben nach ' + t.name, { kind: 'success' }); setTimeout(() => location.reload(), 400); }
}

async function performCopy() {
    const t = pickerState.copy.target;
    if (!t) return;
    let ok = 0, fail = 0, errMsg = '';
    for (const id of copyIds) {
        const r = await fetch('/api/v1/files/' + id + '/copy', {
            method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
            body: JSON.stringify({ folderId: t.id }),
        });
        if (r.ok) ok++; else {
            fail++;
            if (!errMsg) {
                try { const d = await r.json(); errMsg = d.detail || d.title || ('HTTP ' + r.status); }
                catch { errMsg = 'HTTP ' + r.status; }
            }
        }
    }
    document.getElementById('modalCopy').classList.remove('open');
    if (fail) nimAlert(ok + ' kopiert, ' + fail + ' fehlgeschlagen: ' + errMsg, { kind: 'error' });
    else { nimToast('Kopiert nach ' + t.name, { kind: 'success' }); setTimeout(() => location.reload(), 500); }
}

// ── Semantic search ───────────────────────────────────────────
async function doSearch() {
    const q = document.getElementById('searchQ').value.trim();
    const out = document.getElementById('searchResults');
    if (!q) { out.style.display = 'none'; return; }
    out.style.display = 'block';
    out.innerHTML = '<div class="muted" style="padding:8px">' + @Json.Serialize(T["browse.search.loading"].Value) + '</div>';
    const r = await fetch('/api/v1/ai/search', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify({ query: q, scope: SCOPE, groupId: null, limit: 10 }),
    });
    if (r.status === 503) { out.innerHTML = '<div class="muted" style="padding:8px">' + @Json.Serialize(T["browse.search.disabled"].Value) + '</div>'; return; }
    if (!r.ok) { out.innerHTML = '<div class="muted" style="padding:8px">' + @Json.Serialize(T["browse.search.error"].Value) + '</div>'; return; }
    const hits = await r.json();
    if (!hits.length) { out.innerHTML = '<div class="muted" style="padding:8px">' + @Json.Serialize(T["browse.search.no_hits"].Value) + '</div>'; return; }
    out.innerHTML = '';
    hits.forEach(h => {
        const row = document.createElement('div');
        row.className = 'hit';
        row.innerHTML = `<div class="fm-icon fm-icon-file">📄</div><div style="flex:1"><div><strong>${escapeHtml(h.name)}</strong> <span class="score">${(h.score*100).toFixed(0)}%</span></div>${h.snippet ? '<div class="muted" style="font-size:.8rem">'+escapeHtml(h.snippet)+'</div>' : ''}</div>`;
        row.onclick = () => openPreview(h.id);
        out.appendChild(row);
    });
}
function escapeHtml(s) { return (s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

// ── Inline preview modal ──────────────────────────────────────
// v1.10.70: Office-Formate (docx/xlsx/pptx/odt/…) laufen zuerst über
// /office-preview — der Server rendert on-demand nach PDF (LibreOffice
// headless, gecacht). Fällt der Endpoint auf 415 zurück, nutzen wir den
// klassischen Download-Link-Fallback. Andere Formate (Bild, PDF direkt)
// laufen weiter über /preview-url wie bisher.
const OFFICE_CTS = new Set([
    'application/vnd.openxmlformats-officedocument.wordprocessingml.document',
    'application/vnd.openxmlformats-officedocument.spreadsheetml.sheet',
    'application/vnd.openxmlformats-officedocument.presentationml.presentation',
    'application/vnd.oasis.opendocument.text',
    'application/vnd.oasis.opendocument.spreadsheet',
    'application/vnd.oasis.opendocument.presentation',
    'application/msword', 'application/vnd.ms-excel', 'application/vnd.ms-powerpoint',
    'application/rtf', 'text/rtf',
]);

async function openPreview(fileId) {
    const rowCt = (document.querySelector(`tr.ctx[data-id="${fileId}"]`)?.dataset.contentType || '').toLowerCase();
    const useOffice = OFFICE_CTS.has(rowCt);
    const endpoint = useOffice ? '/office-preview' : '/preview-url';
    let r = await fetch('/api/v1/files/' + fileId + endpoint, { credentials: 'same-origin' });
    // Office-Endpoint kann bei einem Fehler auf 415/500 gehen — dann normalen Preview versuchen.
    if (useOffice && !r.ok) {
        r = await fetch('/api/v1/files/' + fileId + '/preview-url', { credentials: 'same-origin' });
    }
    if (!r.ok) return;
    const d = await r.json();
    document.getElementById('previewTitle').textContent = d.name;
    const body = document.getElementById('previewBody');
    const ct = (d.contentType || '').toLowerCase();
    if (ct.startsWith('image/')) {
        body.innerHTML = '<img class="preview-image" src="' + d.url + '"/>';
    } else if (ct === 'application/pdf') {
        body.innerHTML = '<iframe class="preview-frame" src="' + d.url + '"></iframe>';
    } else {
        body.innerHTML = '<p class="muted">' + @Json.Serialize(T["preview.unsupported"].Value) + '</p><p><a class="btn btn-primary" href="' + d.url + '" target="_blank">' + @Json.Serialize(T["preview.download"].Value) + '</a></p>';
    }
    document.getElementById('modalPreview').classList.add('open');
}

// ── Drag-drop + quick upload ──────────────────────────────────
const dropzone = document.getElementById('dropzone');
if (dropzone && CAN_WRITE) {
    ['dragenter','dragover'].forEach(ev => dropzone.addEventListener(ev, e => {
        e.preventDefault(); e.stopPropagation(); dropzone.classList.add('drag');
    }));
    ['dragleave','drop'].forEach(ev => dropzone.addEventListener(ev, e => {
        e.preventDefault(); e.stopPropagation(); if (ev === 'dragleave' && e.target !== dropzone) return; dropzone.classList.remove('drag');
    }));
    dropzone.addEventListener('drop', e => uploadFiles(e.dataTransfer.files));
    const quickPick = document.getElementById('quickPick');
    if (quickPick) quickPick.addEventListener('change', () => uploadFiles(quickPick.files));
}
// ── Upload progress overlay ──────────────────────────────────
// A single floating card in the bottom-right corner that stays visible while
// any upload is in flight. Each file gets its own row with a live bar. XHR
// (not fetch) so we can actually observe upload progress on the Blob PUT.
function upEnsurePanel() {
    let panel = document.getElementById('upPanel');
    if (panel) return panel;
    panel = document.createElement('div');
    panel.id = 'upPanel';
    panel.className = 'up-panel';
    panel.innerHTML = '<div class="up-panel-head"><span id="upTitle">Upload läuft…</span>' +
        '<button type="button" class="up-panel-close" title="Schließen" onclick="this.closest(\'.up-panel\').remove()">✕</button></div>' +
        '<div class="up-panel-body" id="upBody"></div>';
    document.body.appendChild(panel);
    return panel;
}
function upFmtBytes(b) {
    if (!isFinite(b) || b < 0) return '';
    const u = ['B','KB','MB','GB','TB']; let i = 0;
    while (b >= 1024 && i < u.length - 1) { b /= 1024; i++; }
    return b.toFixed(b < 10 && i > 0 ? 1 : 0) + ' ' + u[i];
}
function upFmtEta(sec) {
    if (!isFinite(sec) || sec < 0) return '';
    if (sec < 60) return Math.ceil(sec) + ' s';
    if (sec < 3600) return Math.floor(sec/60) + ' min ' + Math.round(sec%60) + ' s';
    return Math.floor(sec/3600) + ' h ' + Math.floor((sec%3600)/60) + ' min';
}
function upAddRow(name, sizeBytes) {
    upEnsurePanel();
    const body = document.getElementById('upBody');
    const row = document.createElement('div');
    row.className = 'up-row';
    row.dataset.startedAt = String(performance.now());
    row.dataset.size = String(sizeBytes || 0);
    row.innerHTML = '<div class="up-row-head">' +
            '<div class="up-row-name" title="' + name.replace(/"/g,'&quot;') + '">' + name + '</div>' +
            '<div class="up-row-status">0%</div>' +
        '</div>' +
        '<div class="up-row-bar"><div class="up-row-bar-fill"></div></div>' +
        '<div class="up-row-meta">' +
            '<span class="up-row-bytes">0 / ' + upFmtBytes(sizeBytes) + '</span>' +
            '<span class="up-row-speed"></span>' +
            '<span class="up-row-eta"></span>' +
        '</div>';
    body.appendChild(row);
    return row;
}
function upSetProgress(row, pct, label) {
    const p = Math.max(0, Math.min(100, pct));
    const fill = row.querySelector('.up-row-bar-fill');
    const st = row.querySelector('.up-row-status');
    if (fill) fill.style.width = p + '%';
    if (st) st.textContent = label || (Math.round(p) + '%');
    // Speed + ETA — computed from elapsed time and the row's known size.
    const size = parseInt(row.dataset.size, 10) || 0;
    if (size > 0 && !label) {
        const started = parseFloat(row.dataset.startedAt) || performance.now();
        const elapsed = (performance.now() - started) / 1000;
        const doneBytes = size * (p / 100);
        const bytesEl = row.querySelector('.up-row-bytes');
        const speedEl = row.querySelector('.up-row-speed');
        const etaEl = row.querySelector('.up-row-eta');
        if (bytesEl) bytesEl.textContent = upFmtBytes(doneBytes) + ' / ' + upFmtBytes(size);
        if (elapsed > 0.5 && p > 0.5 && p < 100) {
            const speed = doneBytes / elapsed;                 // bytes/sec
            const remaining = (size - doneBytes) / speed;      // seconds
            if (speedEl) speedEl.textContent = upFmtBytes(speed) + '/s';
            if (etaEl) etaEl.textContent = '⏱ ' + upFmtEta(remaining);
        }
    }
}
function upSetDone(row, ok, msg) {
    upSetProgress(row, 100, ok ? '✓' : '✕');
    row.classList.add(ok ? 'up-row-ok' : 'up-row-err');
    const speedEl = row.querySelector('.up-row-speed');
    const etaEl = row.querySelector('.up-row-eta');
    const bytesEl = row.querySelector('.up-row-bytes');
    if (ok) {
        const size = parseInt(row.dataset.size, 10) || 0;
        const started = parseFloat(row.dataset.startedAt) || performance.now();
        const elapsed = (performance.now() - started) / 1000;
        if (bytesEl) bytesEl.textContent = upFmtBytes(size) + ' — ' + upFmtEta(elapsed);
        if (speedEl) speedEl.textContent = elapsed > 0 ? '⌀ ' + upFmtBytes(size / elapsed) + '/s' : '';
        if (etaEl) etaEl.textContent = '';
    } else {
        if (speedEl) speedEl.textContent = '';
        if (etaEl) etaEl.textContent = '';
    }
    if (msg) row.querySelector('.up-row-status').title = msg;
}
function xhrPut(url, blob, contentType, onProgress, extraHeaders) {
    return new Promise((resolve, reject) => {
        const x = new XMLHttpRequest();
        x.open('PUT', url);
        x.setRequestHeader('Content-Type', contentType);
        (extraHeaders || []).forEach(h => x.setRequestHeader(h[0], h[1]));
        x.upload.onprogress = e => { if (e.lengthComputable && onProgress) onProgress(e.loaded / e.total * 100); };
        x.onload = () => (x.status >= 200 && x.status < 300) ? resolve(x) : reject(new Error('HTTP ' + x.status));
        x.onerror = () => reject(new Error('Netzwerkfehler'));
        x.send(blob);
    });
}
async function putWithRetry(url, blob, contentType, onProgress, extraHeaders) {
    let lastErr = null;
    for (let attempt = 1; attempt <= 4; attempt++) {
        try {
            return await xhrPut(url, blob, contentType, onProgress, extraHeaders || [['x-ms-blob-type', 'BlockBlob']]);
        } catch (e) {
            lastErr = e;
            const s = String(e && e.message || e);
            // Retry only on transient 5xx / network drops. 4xx = client error, stop.
            if (!/50\d|Netz|Timeout|502|503|504/.test(s)) throw e;
            await new Promise(r => setTimeout(r, 800 * attempt));
        }
    }
    throw lastErr;
}
// Chunked upload for large files. Splits into 4 MB blocks, PUTs each with a
// short-lived block ID, then commits with Put Block List. Each chunk retries
// on 5xx — a proxy blip in the middle of a 500 MB upload no longer aborts
// the whole file.
async function chunkedBlockUpload(baseUrl, file, onProgress) {
    const BLOCK = 4 * 1024 * 1024;
    const total = file.size;
    const blockIds = [];
    let uploaded = 0;
    for (let start = 0, idx = 0; start < total; start += BLOCK, idx++) {
        const end = Math.min(start + BLOCK, total);
        const chunk = file.slice(start, end);
        // Block IDs must be same length base64. Pad the ordinal, then encode.
        const raw = 'block-' + String(idx).padStart(8, '0');
        const id = btoa(raw);
        blockIds.push(id);
        const putUrl = baseUrl + (baseUrl.includes('?') ? '&' : '?') +
            'comp=block&blockid=' + encodeURIComponent(id);
        await putWithRetry(putUrl, chunk, 'application/octet-stream', pct => {
            const chunkPct = uploaded + (end - start) * (pct / 100);
            onProgress(chunkPct / total * 100);
        }, []);
        uploaded += (end - start);
        onProgress(uploaded / total * 100);
    }
    // Commit
    const listUrl = baseUrl + (baseUrl.includes('?') ? '&' : '?') + 'comp=blocklist';
    const xml = '<?xml version="1.0" encoding="utf-8"?><BlockList>' +
        blockIds.map(b => '<Latest>' + b + '</Latest>').join('') +
        '</BlockList>';
    await putWithRetry(listUrl, new Blob([xml], {type: 'application/xml'}),
        'application/xml', null,
        [['x-ms-blob-content-type', file.type || 'application/octet-stream']]);
}
async function uploadFiles(fileList) {
    if (!fileList || !fileList.length) return;
    upEnsurePanel();
    const total = fileList.length;
    let done = 0, failed = 0;
    document.getElementById('upTitle').textContent = '↑ 0 / ' + total;
    for (const file of fileList) {
        const row = upAddRow(file.name, file.size);
        try {
            upSetProgress(row, 0, 'vorbereiten…');
            const initR = await fetch('/api/v1/files', {
                method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
                body: JSON.stringify({ folderId: FOLDER_ID, name: file.name, contentType: file.type || 'application/octet-stream', sizeBytes: file.size }),
            });
            if (!initR.ok) {
                let msg = 'HTTP ' + initR.status;
                try { const p = await initR.json(); msg = p.title || p.detail || msg; } catch {}
                upSetDone(row, false, msg);
                failed++; done++;
                document.getElementById('upTitle').textContent = '↑ ' + done + ' / ' + total;
                continue;
            }
            const { fileId, uploadUrl } = await initR.json();
            // Files > 32 MB use block-blob upload (4 MB chunks with per-block
            // retry). A single monolithic PUT of a 500 MB ZIP through a slow
            // uplink gets killed by every proxy along the way; splitting it
            // keeps each request short and lets us retry individual failures.
            if (file.size > 32 * 1024 * 1024) {
                await chunkedBlockUpload(uploadUrl, file, pct => upSetProgress(row, pct));
            } else {
                await putWithRetry(uploadUrl, file, file.type || 'application/octet-stream',
                    pct => upSetProgress(row, pct));
            }
            upSetProgress(row, 99, 'finalisieren…');
            const cR = await fetch('/api/v1/files/' + fileId + '/complete', { method: 'POST', credentials: 'same-origin' });
            if (!cR.ok) {
                let msg = 'HTTP ' + cR.status;
                try { const p = await cR.json(); msg = p.title || p.detail || msg; } catch {}
                upSetDone(row, false, msg);
                failed++;
            } else {
                upSetDone(row, true);
            }
        } catch (e) {
            upSetDone(row, false, String(e && e.message || e));
            failed++;
        }
        done++;
        document.getElementById('upTitle').textContent = '↑ ' + done + ' / ' + total + (failed ? ' (' + failed + ' Fehler)' : '');
    }
    // Give the user 800 ms to see the "done" ticks before we refresh.
    setTimeout(() => location.reload(), 800);
}

// Modal helpers used from generated onclicks.
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// ── Direct share modal ────────────────────────────────────────
let dsCurrent = null; // { kind: 'file'|'folder', id, name }
async function openDirectShare(target) {
    dsCurrent = target;
    document.getElementById('dsTargetName').textContent = target.name;
    document.getElementById('modalDirectShare').classList.add('open');
    document.getElementById('dsKind').value = 'user';
    ds_switchKind();
    await ds_loadGroups();
    await ds_loadShares();
}
document.getElementById('dsKind').addEventListener('change', ds_switchKind);
function ds_switchKind() {
    const kind = document.getElementById('dsKind').value;
    document.getElementById('dsPicker').style.display = kind === 'user' ? '' : 'none';
    document.getElementById('dsGroupSel').style.display = kind === 'group' ? '' : 'none';
}
let dsUserCache = new Map();
document.getElementById('dsPicker').addEventListener('input', async (e) => {
    const q = e.target.value;
    const r = await fetch('/api/v1/direct-shares/users?q=' + encodeURIComponent(q), { credentials: 'same-origin' });
    if (!r.ok) return;
    const items = await r.json();
    const dl = document.getElementById('dsUserList');
    dl.innerHTML = '';
    dsUserCache.clear();
    items.forEach(u => {
        const o = document.createElement('option');
        o.value = u.displayName + ' <' + u.email + '>';
        dl.appendChild(o);
        dsUserCache.set(o.value, u.id);
    });
});
async function ds_loadGroups() {
    const r = await fetch('/api/v1/direct-shares/groups', { credentials: 'same-origin' });
    if (!r.ok) return;
    const items = await r.json();
    const sel = document.getElementById('dsGroupSel');
    sel.innerHTML = '';
    items.forEach(g => { const o = document.createElement('option'); o.value = g.id; o.textContent = g.name; sel.appendChild(o); });
    // If the user isn't in any group there's nothing to grant to — hide the
    // "group" option in the kind picker so a bad POST can't be sent.
    const kindSel = document.getElementById('dsKind');
    const groupOpt = kindSel.querySelector('option[value="group"]');
    if (groupOpt) groupOpt.disabled = items.length === 0;
    if (items.length === 0 && kindSel.value === 'group') { kindSel.value = 'user'; ds_switchKind(); }
}
async function ds_add() {
    if (!dsCurrent) return;
    const kind = document.getElementById('dsKind').value;
    const perm = document.getElementById('dsPerm').value;
    const body = { permission: perm };
    if (dsCurrent.kind === 'file') body.fileId = dsCurrent.id;
    else body.folderId = dsCurrent.id;
    if (kind === 'user') {
        const val = document.getElementById('dsPicker').value;
        const uid = dsUserCache.get(val);
        if (!uid) { nimAlert('Pick a user from the suggestions.'); return; }
        body.userId = uid;
    } else {
        body.groupId = document.getElementById('dsGroupSel').value;
    }
    const r = await fetch('/api/v1/direct-shares', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify(body),
    });
    if (!r.ok) { nimAlert('Failed: ' + r.status, { kind: 'error' }); return; }
    document.getElementById('dsPicker').value = '';
    await ds_loadShares();
}
async function ds_loadShares() {
    if (!dsCurrent) return;
    const url = dsCurrent.kind === 'file'
        ? '/api/v1/direct-shares/for-file/' + dsCurrent.id
        : '/api/v1/direct-shares/for-folder/' + dsCurrent.id;
    const r = await fetch(url, { credentials: 'same-origin' });
    if (!r.ok) { document.getElementById('dsList').innerHTML = ''; return; }
    const items = await r.json();
    const out = document.getElementById('dsList');
    if (!items.length) { out.innerHTML = '<p class="muted">' + @Json.Serialize(T["share.none"].Value) + '</p>'; return; }
    out.innerHTML = items.map(i => `
        <div class="row" style="justify-content:space-between;padding:6px 8px;border:1px solid var(--tw-gray-200);border-radius:6px">
            <span>${i.userId ? '👤' : '👥'} ${escapeHtml(i.userDisplayName || i.groupName || '?')}</span>
            <span class="chip ${i.permission === 'Write' ? 'chip-warn' : ''}">${i.permission}</span>
            <button class="btn btn-ghost" onclick="ds_revoke('${i.id}')">✕</button>
        </div>`).join('');
}
async function ds_revoke(id) {
    const r = await fetch('/api/v1/direct-shares/' + id, { method: 'DELETE', credentials: 'same-origin' });
    if (r.ok) await ds_loadShares();
}

// ── v1.10.104: Permissions modal (Public-Folder ACL) ──────────
let pmCurrent = null; // { id, name, isPrivate, canManage }
let pmUserCache = new Map();
async function openPermissionsModal(folderId) {
    const r = await fetch('/api/v1/folders/' + folderId + '/permissions', { credentials: 'same-origin' });
    if (!r.ok) { nimAlert(@Json.Serialize(T["permissions.load_failed"].Value) + ' (' + r.status + ')', { kind: 'error' }); return; }
    const d = await r.json();
    pmCurrent = { id: d.folderId, name: d.folderName, isPrivate: d.isPrivate, canManage: d.canManage };
    document.getElementById('pmFolderName').textContent = d.folderName;
    document.getElementById('pmPrivate').checked = d.isPrivate;
    document.getElementById('pmPrivate').disabled = !d.canManage;
    document.getElementById('pmKind').value = 'user';
    pm_switchKind();
    await pm_loadGroups();
    pm_render(d);
    document.getElementById('modalPermissions').classList.add('open');
}
document.getElementById('pmKind').addEventListener('change', pm_switchKind);
function pm_switchKind() {
    const kind = document.getElementById('pmKind').value;
    document.getElementById('pmPicker').style.display = kind === 'user' ? '' : 'none';
    document.getElementById('pmGroupSel').style.display = kind === 'group' ? '' : 'none';
}
document.getElementById('pmPicker').addEventListener('input', async (e) => {
    const q = e.target.value;
    const r = await fetch('/api/v1/direct-shares/users?q=' + encodeURIComponent(q), { credentials: 'same-origin' });
    if (!r.ok) return;
    const items = await r.json();
    const dl = document.getElementById('pmUserList');
    dl.innerHTML = '';
    pmUserCache.clear();
    items.forEach(u => {
        const o = document.createElement('option');
        o.value = u.displayName + ' <' + u.email + '>';
        dl.appendChild(o);
        pmUserCache.set(o.value, u.id);
    });
});
async function pm_loadGroups() {
    const r = await fetch('/api/v1/direct-shares/groups', { credentials: 'same-origin' });
    if (!r.ok) return;
    const items = await r.json();
    const sel = document.getElementById('pmGroupSel');
    sel.innerHTML = '';
    items.forEach(g => { const o = document.createElement('option'); o.value = g.id; o.textContent = g.name; sel.appendChild(o); });
    const kindSel = document.getElementById('pmKind');
    const groupOpt = kindSel.querySelector('option[value="group"]');
    if (groupOpt) groupOpt.disabled = items.length === 0;
    if (items.length === 0 && kindSel.value === 'group') { kindSel.value = 'user'; pm_switchKind(); }
}
async function pm_togglePrivate() {
    if (!pmCurrent) return;
    const wanted = document.getElementById('pmPrivate').checked;
    const r = await fetch('/api/v1/folders/' + pmCurrent.id + '/privacy', {
        method: 'PATCH', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify({ isPrivate: wanted }),
    });
    if (!r.ok) {
        document.getElementById('pmPrivate').checked = pmCurrent.isPrivate;
        nimAlert(@Json.Serialize(T["permissions.toggle_failed"].Value) + ' (' + r.status + ')', { kind: 'error' });
        return;
    }
    const d = await r.json();
    pmCurrent.isPrivate = d.isPrivate;
    // Marcus's Ansage: die Sicht-Änderung ist wirkungsvoll erst nach Reload,
    // weil die Row-Liste server-gerendert ist. Wir markieren die Row
    // stattdessen sofort mit Badge, damit der User Feedback bekommt.
    const row = document.querySelector('tr.ctx.fm-row-folder[data-id="' + pmCurrent.id + '"]');
    if (row) row.dataset.isPrivate = d.isPrivate ? '1' : '0';
}
async function pm_add() {
    if (!pmCurrent) return;
    if (!pmCurrent.canManage) { nimAlert(@Json.Serialize(T["permissions.no_manage"].Value)); return; }
    const kind = document.getElementById('pmKind').value;
    const perm = document.getElementById('pmPerm').value;
    const body = { permission: perm, folderId: pmCurrent.id };
    if (kind === 'user') {
        const val = document.getElementById('pmPicker').value;
        const uid = pmUserCache.get(val);
        if (!uid) { nimAlert(@Json.Serialize(T["share.pick_user"].Value)); return; }
        body.userId = uid;
    } else {
        body.groupId = document.getElementById('pmGroupSel').value;
    }
    const r = await fetch('/api/v1/direct-shares', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify(body),
    });
    if (!r.ok) { nimAlert('HTTP ' + r.status, { kind: 'error' }); return; }
    document.getElementById('pmPicker').value = '';
    await pm_reload();
}
async function pm_reload() {
    if (!pmCurrent) return;
    const r = await fetch('/api/v1/folders/' + pmCurrent.id + '/permissions', { credentials: 'same-origin' });
    if (!r.ok) return;
    pm_render(await r.json());
}
function pm_render(d) {
    const out = document.getElementById('pmList');
    const rows = [];
    (d.userGrants || []).forEach(g => rows.push({ id: g.id, label: '👤 ' + (g.displayName || g.email || '?'), perm: g.permission }));
    (d.groupGrants || []).forEach(g => rows.push({ id: g.id, label: '👥 ' + (g.displayName || '?'), perm: g.permission }));
    if (rows.length === 0) {
        out.innerHTML = '<p class="muted">' + @Json.Serialize(T["permissions.no_grants"].Value) + '</p>';
        return;
    }
    out.innerHTML = rows.map(r => `
        <div class="row" style="justify-content:space-between;padding:6px 8px;border:1px solid var(--tw-gray-200);border-radius:6px">
            <span>${escapeHtml(r.label)}</span>
            <span class="chip ${r.perm === 'write' ? 'chip-warn' : ''}">${r.perm === 'write' ? @Json.Serialize(T["share.perm.write"].Value) : @Json.Serialize(T["share.perm.read"].Value)}</span>
            <button class="btn btn-ghost" onclick="pm_revoke('${r.id}')">✕</button>
        </div>`).join('');
}
async function pm_revoke(id) {
    const r = await fetch('/api/v1/direct-shares/' + id, { method: 'DELETE', credentials: 'same-origin' });
    // v1.10.108: Fehler nicht mehr stumm schlucken — 403 heißt "du darfst
    // diesen Grant nicht entziehen", das muss der User sehen.
    if (!r.ok) { nimAlert('HTTP ' + r.status, { kind: 'error' }); return; }
    await pm_reload();
}

// ── Favorite toggle ───────────────────────────────────────────
async function toggleFavorite(target) {
    const body = target.kind === 'file' ? { fileId: target.id } : { folderId: target.id };
    const r = await fetch('/api/v1/favorites/toggle', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify(body),
    });
    if (r.ok) {
        const d = await r.json();
        const row = document.querySelector(`tr.ctx[data-id="${target.id}"]`);
        if (row) row.classList.toggle('is-fav', d.starred);
    }
}

// ── Column sorting (click header, folders always stay grouped on top) ──
(function () {
    let sortKey = 'name', sortDir = 1;
    const tbody = document.querySelector('.fm-list tbody');
    if (!tbody) return;
    const sorters = {
        name: (a, b) => a.dataset.name.localeCompare(b.dataset.name, undefined, { numeric: true, sensitivity: 'base' }),
        size: (a, b) => Number(a.dataset.size) - Number(b.dataset.size),
        date: (a, b) => Number(a.dataset.date) - Number(b.dataset.date),
    };
    function apply() {
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const folders = rows.filter(r => r.dataset.kind === 'folder');
        const files   = rows.filter(r => r.dataset.kind === 'file');
        folders.sort((a, b) => sorters[sortKey](a, b) * sortDir);
        files.sort((a, b) => sorters[sortKey](a, b) * sortDir);
        tbody.innerHTML = '';
        [...folders, ...files].forEach(r => tbody.appendChild(r));
        document.querySelectorAll('.fm-sort .fm-sort-caret').forEach(el => el.textContent = '');
        const active = document.querySelector(`.fm-sort[data-sort="${sortKey}"] .fm-sort-caret`);
        if (active) active.textContent = sortDir === 1 ? '▴' : '▾';
    }
    document.querySelectorAll('.fm-sort').forEach(th => {
        th.addEventListener('click', () => {
            const key = th.dataset.sort;
            if (key === sortKey) sortDir = -sortDir; else { sortKey = key; sortDir = 1; }
            apply();
        });
    });
    // Server already returns name-sorted — no initial reflow needed.
})();

// ── Folder-icon modal ────────────────────────────────────────
const FI_EMOJIS = ['📁','📂','📊','📈','📉','📆','📅','🗂','🗃','🗄','🗒','📋','📌','📎','🎨','🎯','🎬','🎵','🖼','📷','💼','💰','💡','⭐','🔥','⚡','🚀','🏆','🎁','💎','🔒','🔑','🛠','🧾','📝','📜','📚','📖','🧠','🧪','🧬','🌍','🌐','🗺','🏢','🏠','☑','⚠','🔴','🟠','🟡','🟢','🔵','🟣','🟤','⚫','⚪'];
const FI_COLORS = ['ffc600','ff8c00','e02828','d81b60','8e24aa','5e35b1','1e88e5','039be5','00acc1','00897b','43a047','7cb342','795548','546e7a','78909c'];
let fiTarget = null;
function openFolderIcon(target) {
    fiTarget = target;
    document.getElementById('fiTargetName').textContent = target.name;
    const eg = document.getElementById('fiEmojiGrid');
    eg.innerHTML = '';
    // First tile is "no emoji" — falls back to the default folder icon.
    const none = document.createElement('button');
    none.type = 'button'; none.className = 'emoji-tile' + (target.emoji ? '' : ' selected');
    none.dataset.emoji = ''; none.title = 'Standard';
    none.textContent = '📁';
    none.onclick = () => fi_pickEmoji(none);
    eg.appendChild(none);
    FI_EMOJIS.forEach(e => {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'emoji-tile' + (target.emoji === e ? ' selected' : '');
        b.dataset.emoji = e; b.textContent = e;
        b.onclick = () => fi_pickEmoji(b);
        eg.appendChild(b);
    });
    const cg = document.getElementById('fiColorGrid');
    cg.innerHTML = '';
    const cnone = document.createElement('button');
    cnone.type = 'button'; cnone.className = 'color-tile color-none' + (target.color ? '' : ' selected');
    cnone.dataset.color = ''; cnone.title = 'Standard'; cnone.textContent = '✕';
    cnone.onclick = () => fi_pickColor(cnone);
    cg.appendChild(cnone);
    FI_COLORS.forEach(c => {
        const b = document.createElement('button');
        b.type = 'button'; b.className = 'color-tile' + (target.color === c ? ' selected' : '');
        b.dataset.color = c; b.style.background = '#' + c;
        b.onclick = () => fi_pickColor(b);
        cg.appendChild(b);
    });
    document.getElementById('modalFolderIcon').classList.add('open');
}
function fi_pickEmoji(btn) {
    document.querySelectorAll('#fiEmojiGrid .emoji-tile').forEach(t => t.classList.remove('selected'));
    btn.classList.add('selected');
}
function fi_pickColor(btn) {
    document.querySelectorAll('#fiColorGrid .color-tile').forEach(t => t.classList.remove('selected'));
    btn.classList.add('selected');
}
function fi_reset() {
    document.querySelectorAll('#fiEmojiGrid .emoji-tile').forEach(t => t.classList.remove('selected'));
    document.querySelector('#fiEmojiGrid .emoji-tile[data-emoji=""]')?.classList.add('selected');
    document.querySelectorAll('#fiColorGrid .color-tile').forEach(t => t.classList.remove('selected'));
    document.querySelector('#fiColorGrid .color-tile[data-color=""]')?.classList.add('selected');
}
async function fi_save() {
    if (!fiTarget) return;
    const emoji = document.querySelector('#fiEmojiGrid .emoji-tile.selected')?.dataset.emoji || null;
    const color = document.querySelector('#fiColorGrid .color-tile.selected')?.dataset.color || null;
    const r = await fetch('/api/v1/folders/' + fiTarget.id + '/icon', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify({ emoji: emoji || null, color: color || null }),
    });
    if (!r.ok) { nimAlert('Speichern fehlgeschlagen: ' + r.status); return; }
    location.reload();
}

// ── Folder tree — left panel (collapsible) ────────────────────
// v1.10.64: stale-while-revalidate Cache im sessionStorage. Marcus's
// Feedback: "Baum links wirkt sehr behäbig, langsam". Ursache: jeder
// Navigations-Klick reloadet die Seite und den Tree per Netzwerk-
// Roundtrip. Fix: den zuletzt gesehenen Baum aus sessionStorage sofort
// rendern (perceived latency ~0ms) und im Hintergrund frisch nachladen.
// Nur wenn frisch !== cached wird neu gerendert (kein Flicker).
(async function loadFolderTree() {
    const panel = document.getElementById('fmTree');
    if (!panel) return;
    const scope = panel.dataset.scope;
    const groupId = panel.dataset.groupId || '';
    const currentId = panel.dataset.currentId;
    const url = '/api/v1/folders/tree?scope=' + encodeURIComponent(scope) + (groupId ? '&groupId=' + groupId : '');
    const cacheKey = 'nimshare.tree.' + scope + '.' + groupId;

    let cached = null;
    try {
        const raw = sessionStorage.getItem(cacheKey);
        if (raw) cached = JSON.parse(raw);
    } catch { /* Storage disabled */ }

    let rendered = false;
    if (Array.isArray(cached) && cached.length > 0) {
        renderTree(panel, cached, currentId);
        rendered = true;
    }

    // Live-Refresh — updated der DOM nur wenn sich der Baum tatsächlich
    // geändert hat, um Flackern zu vermeiden.
    let roots;
    try {
        const r = await fetch(url, { credentials: 'same-origin' });
        if (!r.ok) throw new Error(r.status);
        roots = await r.json();
    } catch (e) {
        if (!rendered) panel.innerHTML = '<div class="muted" style="padding:12px">Baum nicht geladen</div>';
        return;
    }
    try { sessionStorage.setItem(cacheKey, JSON.stringify(roots)); } catch { }
    if (!rendered || JSON.stringify(roots) !== JSON.stringify(cached)) {
        renderTree(panel, roots, currentId);
    }
})();

function renderTree(panel, roots, currentId) {
    // Precompute the path from root → currentId so we can auto-expand the trail.
    const trail = new Set();
    function findPath(node, path) {
        const next = [...path, node.id];
        if (node.id === currentId) { next.forEach(id => trail.add(id)); return true; }
        for (const c of (node.children || [])) if (findPath(c, next)) return true;
        return false;
    }
    roots.forEach(r => findPath(r, []));
    function render(node, depth) {
        const wrap = document.createElement('div');
        wrap.className = 'ft-node';
        const row = document.createElement('div');
        row.className = 'ft-row' + (node.id === currentId ? ' active' : '');
        row.style.paddingLeft = (6 + depth * 12) + 'px';
        const hasKids = (node.children || []).length > 0;
        const tog = document.createElement('span');
        tog.className = 'ft-toggle';
        tog.textContent = hasKids ? (trail.has(node.id) ? '▾' : '▸') : '·';
        row.appendChild(tog);
        const ico = document.createElement('span');
        ico.className = 'ft-icon';
        ico.textContent = node.emoji || '📁';
        if (!node.emoji && node.color) ico.style.color = '#' + node.color;
        row.appendChild(ico);
        const lbl = document.createElement('a');
        lbl.className = 'ft-label';
        lbl.textContent = node.name;
        lbl.href = '#'; // Set below once we know the ancestry.
        lbl.dataset.id = node.id;
        row.appendChild(lbl);
        wrap.appendChild(row);
        if (hasKids) {
            const kids = document.createElement('div');
            kids.className = 'ft-children' + (trail.has(node.id) ? '' : ' collapsed');
            node.children.forEach(c => kids.appendChild(render(c, depth + 1)));
            wrap.appendChild(kids);
            tog.style.cursor = 'pointer';
            tog.addEventListener('click', (e) => {
                e.preventDefault(); e.stopPropagation();
                const open = kids.classList.toggle('collapsed');
                tog.textContent = open ? '▸' : '▾';
            });
        }
        return wrap;
    }
    panel.innerHTML = '';
    roots.forEach(r => panel.appendChild(render(r, 0)));
    // Wire click-navigation: rebuild the URL from the label path by walking up
    // through the tree JSON.
    const idToPath = {};
    // v1.10.38: vorher wurde JEDER Node dessen Name mit dem Scope-Namen
    // übereinstimmte als "Scope-Wurzel" behandelt (next=[]). Ein
    // User-erstellter Unter-Ordner namens "Public" im Public-Scope bekam
    // damit denselben Link wie die echte Wurzel → Klick brachte zurück
    // zu /browse/public statt in den Ordner → Loop. Der echte Root ist
    // strukturell der oberste Node im JSON, nicht der mit passendem
    // Namen. isScopeRoot=true fließt nur beim allerersten Aufruf.
    function buildPaths(node, path, isScopeRoot) {
        const next = isScopeRoot ? [] : [...path, node.name];
        idToPath[node.id] = next;
        (node.children || []).forEach(c => buildPaths(c, next, false));
    }
    roots.forEach(r => buildPaths(r, [], true));
    const urlBase = panel.dataset.urlBase;
    // Tree links go through /browse/folder/{id} — the pretty-path scheme
    // 404'd on names ending in "." (e.g. "Business - Production.") because
    // Azure/IIS AspNetCoreModule rejects trailing-dot segments before ASP.NET
    // Core routing sees them. ID-based navigation is deterministic AND
    // survives folder renames (bookmarks stay valid).
    panel.querySelectorAll('.ft-label').forEach(a => {
        const parts = idToPath[a.dataset.id] || [];
        // Root of the current scope keeps the pretty URL — no ID needed.
        const href = parts.length === 0 ? urlBase : ('/browse/folder/' + a.dataset.id);
        a.href = href;
        a.addEventListener('click', (e) => {
            e.preventDefault();
            location.href = href;
        });
    });
    // Whole row is clickable too — click on the icon/toggle-padding region
    // still navigates. Toggle keeps its own click handler.
    panel.querySelectorAll('.ft-row').forEach(row => {
        row.style.cursor = 'pointer';
        row.addEventListener('click', (e) => {
            if (e.target.closest('.ft-toggle')) return;
            if (e.target.closest('.ft-label')) return; // label handles its own
            const a = row.querySelector('.ft-label');
            if (a && a.href && !a.href.endsWith('#')) {
                location.href = a.href;
            }
        });
    });
}

// v1.10.64: Cache invalidieren wenn ein Ordner erzeugt/umbenannt/gelöscht
// wurde. Der `location.reload()` nach Create/Rename/Delete rendert dann
// beim nächsten Frame den frischen Baum statt der veralteten Cache-Version.
window.invalidateFolderTreeCache = function () {
    try {
        for (const key of Object.keys(sessionStorage)) {
            if (key.startsWith('nimshare.tree.')) sessionStorage.removeItem(key);
        }
    } catch { }
};

// v1.10.52: Mobile-Tree-Toggle. Auf Desktop ist das Panel immer sichtbar;
// auf Mobile ist es per CSS ausgeblendet. Der 📁-Button in der Toolbar
// setzt die Klasse `mobile-open` auf den Body — CSS schiebt das Panel
// dann als Bottom-Sheet rein. Klick außerhalb (Overlay) schließt.
window.openMobileTree = function () {
    document.body.classList.add('fm-tree-mobile-open');
};
window.closeMobileTree = function () {
    document.body.classList.remove('fm-tree-mobile-open');
};
// Overlay: klick außerhalb schließt. Wir docken einen Klick-Handler an
// das dynamisch generierte Overlay-DIV weil wir eh CSS-only-Insertion
// vermeiden wollen.
document.addEventListener('click', function (ev) {
    if (!document.body.classList.contains('fm-tree-mobile-open')) return;
    // wenn Ziel innerhalb der Sidebar oder des Toggle-Buttons ist → nix
    if (ev.target.closest('.fm-tree')) return;
    if (ev.target.closest('.fm-tree-toggle')) return;
    // sonst schließen
    document.body.classList.remove('fm-tree-mobile-open');
});
// Nach jedem Tree-Node-Klick auch schließen — der User hat navigiert
document.getElementById('fmTree')?.addEventListener('click', function (ev) {
    if (ev.target.closest('a.ft-label') || ev.target.closest('.ft-row')) {
        setTimeout(() => document.body.classList.remove('fm-tree-mobile-open'), 60);
    }
});
</script>
