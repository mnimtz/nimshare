@using NimShare.Core.Entities
@using NimShare.Api.Services
@{
    var scope = (FileScope)ViewData["Scope"]!;
    var groupId = ViewData["GroupId"] as Guid?;
    var groupName = ViewData["GroupName"] as string;
    var current = (Folder)ViewData["Current"]!;
    var ancestry = (List<Folder>)ViewData["Ancestry"]!;
    var subs = (List<Folder>)ViewData["Subfolders"]!;
    var files = (List<StorageFile>)ViewData["Files"]!;
    var canWrite = (bool)(ViewData["CanWrite"] ?? false);
    var canManage = (bool)(ViewData["CanManage"] ?? false);
    var urlBase = (string)ViewData["UrlBase"]!;
    var currentUrl = Context.Request.Path.Value ?? urlBase;

    string scopeTitle = scope switch
    {
        FileScope.Personal => T["browse.tile.personal"].Value,
        FileScope.Public => T["browse.tile.public"].Value,
        FileScope.Group => groupName ?? T["browse.tile.groups"].Value,
        _ => "",
    };
    ViewData["Title"] = current.ParentFolderId is null ? scopeTitle : current.Name;
    Layout = "_AppShell";

    string Bytes(long b)
    {
        string[] u = { "B", "KB", "MB", "GB", "TB" };
        double v = b; int i = 0;
        while (v >= 1024 && i < u.Length - 1) { v /= 1024; i++; }
        return $"{v:0.##} {u[i]}";
    }
    string TypeClass(string name)
    {
        var ext = System.IO.Path.GetExtension(name).TrimStart('.').ToLowerInvariant();
        return ext switch
        {
            "pdf" => "pdf",
            "doc" or "docx" or "odt" => "doc",
            "xls" or "xlsx" or "csv" or "ods" => "xls",
            "ppt" or "pptx" or "odp" => "ppt",
            "png" or "jpg" or "jpeg" or "gif" or "webp" or "svg" or "heic" => "img",
            "mp4" or "mov" or "avi" or "mkv" or "webm" => "vid",
            "zip" or "7z" or "rar" or "tar" or "gz" => "zip",
            "txt" or "md" or "log" => "txt",
            _ => ""
        };
    }
    string TypeLabel(string name)
    {
        var ext = System.IO.Path.GetExtension(name).TrimStart('.').ToUpperInvariant();
        return string.IsNullOrEmpty(ext) ? "F" : ext[..1];
    }
    string SegPath(int upTo)
    {
        var parts = ancestry.Skip(1).Take(upTo).Select(a => Uri.EscapeDataString(a.Name));
        return string.Join('/', parts);
    }
    string FolderUrl(Folder sub)
    {
        var basePart = urlBase + (current.ParentFolderId is null ? "/" : "/" + SegPath(ancestry.Count - 1) + "/");
        return basePart + Uri.EscapeDataString(sub.Name);
    }
}

<div class="fm">
    <section class="fm-main" id="dropzone" data-drop-label="@T["browse.drop_hint"]">
        <header class="fm-header">
            <div class="fm-breadcrumb">
                @for (var i = 0; i < ancestry.Count; i++)
                {
                    var isLast = i == ancestry.Count - 1;
                    var name = i == 0 ? scopeTitle : ancestry[i].Name;
                    var url = i == 0 ? urlBase : (urlBase + "/" + SegPath(i));
                    if (isLast) { <span class="fm-crumb-current">@name</span> }
                    else { <a href="@url">@name</a> <span class="fm-crumb-sep">›</span> }
                }
            </div>
            <div class="fm-toolbar">
                @if (canWrite)
                {
                    <button class="fm-btn" title="@T["browse.new_folder"]" onclick="openNewFolderModal()">
                        <span>📁+</span>
                    </button>
                    <button class="fm-btn fm-btn-primary" title="@T["browse.upload"]" onclick="document.getElementById('quickPick').click()">
                        <span>↑ @T["browse.upload"]</span>
                    </button>
                    <input type="file" id="quickPick" multiple style="display:none"/>
                }
                <button class="fm-btn" title="@T["browse.share_this"]" onclick="openShareFolderModal('@current.Id')">🔗</button>
                <button class="fm-btn" title="@T["browse.request_upload"]" onclick="openUploadRequestModal('@current.Id')">📥</button>
            </div>
        </header>

        <div class="fm-searchbar">
            <span class="fm-search-icon">🔍</span>
            <input type="text" id="searchQ" placeholder="@T["browse.search.placeholder"]" onkeydown="if(event.key==='Enter')doSearch()"/>
        </div>
        <div class="fm-search-results" id="searchResults" style="display:none"></div>

        @if (TempData["Notice"] is string n) { <div class="fm-flash fm-flash-ok">@n</div> }
        @if (TempData["Error"] is string err) { <div class="fm-flash fm-flash-err">@err</div> }

        <div class="fm-bulkbar" id="bulkBar">
            <span class="count" id="bulkCount">0 @T["bulk.selected"]</span>
            @if (canWrite) { <button onclick="openMoveModal()">↦ @T["bulk.move"]</button> }
            <button onclick="bulkDelete()">🗑 @T["bulk.delete"]</button>
            <button onclick="clearSelection()" style="margin-left:auto">✕ @T["bulk.clear"]</button>
        </div>

        @if (!subs.Any() && !files.Any())
        {
            <div class="fm-empty">
                <div class="fm-empty-art">📂</div>
                <div class="fm-empty-title">@T["browse.empty"]</div>
                @if (canWrite)
                {
                    <div class="fm-empty-hint">@T["browse.drop_hint"]</div>
                }
            </div>
        }
        else
        {
            <table class="fm-list">
                <thead>
                    <tr>
                        <th class="col-check"><input type="checkbox" id="selectAll"/></th>
                        <th class="col-name fm-sort" data-sort="name">@T["file.name"] <span class="fm-sort-caret">▴</span></th>
                        <th class="col-size fm-sort" data-sort="size">@T["file.size"] <span class="fm-sort-caret"></span></th>
                        <th class="col-date fm-sort" data-sort="date">@T["file.uploaded"] <span class="fm-sort-caret"></span></th>
                        @if (scope != FileScope.Personal) { <th class="col-owner">@T["groups.uploaded_by"]</th> }
                        <th class="col-actions"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var sub in subs)
                    {
                        <tr class="ctx fm-row fm-row-folder" data-kind="folder" data-id="@sub.Id" data-name="@sub.Name" data-size="-1" data-date="@sub.CreatedAt.ToUnixTimeSeconds()" ondblclick="location.href='@FolderUrl(sub)'">
                            <td class="col-check"></td>
                            <td class="col-name">
                                <a class="fm-name" href="@FolderUrl(sub)">
                                    <span class="fm-icon fm-icon-folder">📁</span>
                                    <span class="fm-name-text">@sub.Name</span>
                                </a>
                            </td>
                            <td class="col-size muted">—</td>
                            <td class="col-date muted">@sub.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            @if (scope != FileScope.Personal) { <td class="col-owner"></td> }
                            <td class="col-actions">
                                <div class="fm-row-actions">
                                    <button title="@T["actions.share_link"]" onclick="event.stopPropagation();openShareFolderModal('@sub.Id')">🔗</button>
                                    <button title="@T["actions.request_upload"]" onclick="event.stopPropagation();openUploadRequestModal('@sub.Id')">📥</button>
                                    @if (canManage)
                                    {
                                        <button title="@T["actions.rename"]" onclick="event.stopPropagation();openRenameFolderModal('@sub.Id', @Json.Serialize(sub.Name))">✎</button>
                                        <form method="post" action="/browse/folders/@sub.Id/delete" style="display:inline" onsubmit="return confirm('@T["actions.confirm_delete"]')" onclick="event.stopPropagation()">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="returnUrl" value="@currentUrl"/>
                                            <button title="@T["actions.delete"]" type="submit">🗑</button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                    @foreach (var f in files)
                    {
                        <tr class="ctx fm-row fm-row-file" data-kind="file" data-id="@f.Id" data-name="@f.Name" data-size="@f.SizeBytes" data-content-type="@f.ContentType" data-date="@f.CreatedAt.ToUnixTimeSeconds()" ondblclick="openPreview('@f.Id')">
                            <td class="col-check"><input type="checkbox" class="row-check" value="@f.Id" onclick="event.stopPropagation()"/></td>
                            <td class="col-name">
                                <div class="fm-name" style="cursor:pointer" onclick="openPreview('@f.Id')">
                                    <span class="fm-icon fm-icon-file @TypeClass(f.Name)">@TypeLabel(f.Name)</span>
                                    <span class="fm-name-text">@f.Name</span>
                                    @if (!string.IsNullOrEmpty(f.AiRiskFlag) && f.AiRiskFlag != "clean" && f.AiRiskFlag != "unknown")
                                    {
                                        <span class="ai-risk" title="AI-detected risk">⚠ @f.AiRiskFlag</span>
                                    }
                                    @if (!string.IsNullOrEmpty(f.AiTags))
                                    {
                                        foreach (var tag in f.AiTags.Split(',').Take(3))
                                        {
                                            <span class="ai-tag">@tag.Trim()</span>
                                        }
                                    }
                                </div>
                            </td>
                            <td class="col-size">@Bytes(f.SizeBytes)</td>
                            <td class="col-date muted">@f.CreatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                            @if (scope != FileScope.Personal) { <td class="col-owner muted">@f.Owner.DisplayName</td> }
                            <td class="col-actions">
                                <div class="fm-row-actions">
                                    <button title="@T["actions.share_link"]" onclick="event.stopPropagation();openShareFileModal('@f.Id')">🔗</button>
                                    @if (canWrite) { <button title="@T["actions.move"]" onclick="event.stopPropagation();openMoveSingle('@f.Id')">↦</button> }
                                    <button title="@T["actions.delete"]" onclick="event.stopPropagation();deleteFile('@f.Id')">🗑</button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </section>
</div>

<!-- Preview modal -->
<div class="modal-backdrop" id="modalPreview" onclick="if(event.target===this)closeModal('modalPreview')">
    <div class="modal-panel" style="max-width:900px">
        <h2 id="previewTitle"></h2>
        <div id="previewBody" style="margin-top:var(--sp-4)"></div>
        <div class="actions"><button class="btn btn-ghost" onclick="closeModal('modalPreview')">@T["modal.close"]</button></div>
    </div>
</div>

<!-- Right-click context menu -->
<div class="ctx-menu" id="ctxMenu">
    <button data-act="open" style="display:none">📂 @T["ctx.open"]</button>
    <button data-act="preview" style="display:none">👁 Preview</button>
    <button data-act="share">🔗 @T["actions.share_link"]</button>
    <button data-act="directShare">🤝 @T["share.direct"]</button>
    <button data-act="sign" style="display:none">✍ @T["nav.signatures"]</button>
    <button data-act="uploadReq" style="display:none">📥 @T["actions.request_upload"]</button>
    <button data-act="favorite">⭐ @T["actions.star"]</button>
    <div class="divider"></div>
    <button data-act="move" style="display:none">↦ @T["actions.move"]</button>
    <button data-act="rename" style="display:none">✎ @T["actions.rename"]</button>
    <button data-act="delete">🗑 @T["actions.delete"]</button>
</div>

<!-- Direct-share modal (share to specific users / groups) -->
<div class="modal-backdrop" id="modalDirectShare" onclick="if(event.target===this)closeModal('modalDirectShare')">
    <div class="modal-panel" style="max-width:640px">
        <h2>🤝 @T["share.direct"] — <span id="dsTargetName" class="muted"></span></h2>
        <div class="field">
            <label>@T["share.target.user"] / @T["share.target.group"]</label>
            <div class="row" style="gap:6px">
                <select id="dsKind">
                    <option value="user">👤 @T["share.target.user"]</option>
                    <option value="group">👥 @T["share.target.group"]</option>
                </select>
                <input type="text" id="dsPicker" placeholder="@T["share.search_users"]" style="flex:1" list="dsUserList"/>
                <select id="dsGroupSel" style="flex:1;display:none"></select>
                <datalist id="dsUserList"></datalist>
                <select id="dsPerm">
                    <option value="Read">@T["share.perm.read"]</option>
                    <option value="Write">@T["share.perm.write"]</option>
                </select>
                <button class="btn btn-primary" onclick="ds_add()">@T["share.add"]</button>
            </div>
        </div>
        <div class="stack" id="dsList" style="margin-top:12px"></div>
        <div class="actions">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modalDirectShare')">@T["modal.close"]</button>
        </div>
    </div>
</div>

<partial name="_LinkModals" model="@current" />

<!-- Move modal -->
<div class="modal-backdrop" id="modalMove" onclick="if(event.target===this)closeModal('modalMove')">
    <div class="modal-panel">
        <h2>@T["move.title"]</h2>
        <p class="muted" id="moveHint"></p>
        <div class="field">
            <label>@T["move.target"]</label>
            <select id="moveTarget"></select>
            <div class="helper">@T["move.helper"]</div>
        </div>
        <div class="actions">
            <button type="button" class="btn btn-ghost" onclick="closeModal('modalMove')">@T["modal.cancel"]</button>
            <button type="button" class="btn btn-primary" onclick="performMove()">@T["move.button"]</button>
        </div>
    </div>
</div>

<script>
const FOLDER_ID = @Json.Serialize(current.Id);
const RETURN_URL = @Json.Serialize(currentUrl);
const SCOPE = @Json.Serialize(scope.ToString());
const CAN_WRITE = @(canWrite ? "true" : "false");
const CAN_MANAGE = @(canManage ? "true" : "false");

// ── Row selection ─────────────────────────────────────────────
const bulkBar = document.getElementById('bulkBar');
const bulkCount = document.getElementById('bulkCount');
const selAll = document.getElementById('selectAll');

function updateSelection() {
    const boxes = document.querySelectorAll('.row-check');
    const selected = Array.from(boxes).filter(b => b.checked).length;
    bulkCount.textContent = selected + ' ' + @Json.Serialize(T["bulk.selected"].Value);
    bulkBar.classList.toggle('on', selected > 0);
    document.querySelectorAll('tr.ctx[data-kind="file"]').forEach(tr => {
        const cb = tr.querySelector('.row-check');
        if (cb) tr.classList.toggle('selected', cb.checked);
    });
}
document.querySelectorAll('.row-check').forEach(cb => cb.addEventListener('change', updateSelection));
if (selAll) selAll.addEventListener('change', () => {
    document.querySelectorAll('.row-check').forEach(cb => cb.checked = selAll.checked);
    updateSelection();
});
function selectedIds() {
    return Array.from(document.querySelectorAll('.row-check')).filter(b => b.checked).map(b => b.value);
}
function clearSelection() {
    document.querySelectorAll('.row-check').forEach(cb => cb.checked = false);
    if (selAll) selAll.checked = false;
    updateSelection();
}

async function bulkDelete() {
    const ids = selectedIds();
    if (!ids.length) return;
    const tpl = @Json.Serialize(T["bulk.confirm.delete"].Value);
    if (!confirm(tpl.replace("{n}", ids.length))) return;
    const r = await fetch('/api/v1/files/bulk-delete', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify({ ids }),
    });
    if (r.ok) location.reload(); else alert('Failed: ' + r.status);
}

async function deleteFile(id) {
    if (!confirm(@Json.Serialize(T["actions.confirm_delete"].Value))) return;
    const r = await fetch('/api/v1/files/' + id, { method: 'DELETE', credentials: 'same-origin' });
    if (r.ok) location.reload(); else alert('Failed: ' + r.status);
}

// ── Right-click context menu ──────────────────────────────────
const ctxMenu = document.getElementById('ctxMenu');
let ctxTarget = null;
document.querySelectorAll('tr.ctx').forEach(tr => {
    tr.addEventListener('contextmenu', (e) => {
        e.preventDefault();
        ctxTarget = { kind: tr.dataset.kind, id: tr.dataset.id, name: tr.dataset.name };
        const showFor = (id, cond) => ctxMenu.querySelector(`[data-act="${id}"]`).style.display = cond ? '' : 'none';
        const isSignable = ctxTarget.kind === 'file' && (tr.dataset.contentType || '').toLowerCase() === 'application/pdf';
        showFor('open',        ctxTarget.kind === 'folder');
        showFor('preview',     ctxTarget.kind === 'file');
        showFor('sign',        isSignable);
        showFor('uploadReq',   ctxTarget.kind === 'folder');
        showFor('rename',      ctxTarget.kind === 'folder' && CAN_MANAGE);
        showFor('move',        ctxTarget.kind === 'file'   && CAN_WRITE);
        showFor('share',       true);
        showFor('directShare', true);
        showFor('favorite',    true);
        showFor('delete',      (ctxTarget.kind === 'file') || (ctxTarget.kind === 'folder' && CAN_MANAGE));
        const vw = window.innerWidth, vh = window.innerHeight;
        const w = 220, h = ctxMenu.offsetHeight || 200;
        const x = Math.min(e.clientX, vw - w - 10);
        const y = Math.min(e.clientY, vh - h - 10);
        ctxMenu.style.left = x + 'px';
        ctxMenu.style.top = y + 'px';
        ctxMenu.classList.add('open');
    });
});
document.addEventListener('click', () => ctxMenu.classList.remove('open'));
window.addEventListener('scroll', () => ctxMenu.classList.remove('open'), true);
ctxMenu.querySelectorAll('button').forEach(b => {
    b.addEventListener('click', () => {
        const act = b.dataset.act;
        if (!ctxTarget) return;
        if (act === 'open' && ctxTarget.kind === 'folder') {
            const url = document.querySelector(`tr.ctx[data-id="${ctxTarget.id}"] a.fm-name`);
            if (url) location.href = url.getAttribute('href');
        }
        if (act === 'preview' && ctxTarget.kind === 'file') openPreview(ctxTarget.id);
        if (act === 'share') {
            if (ctxTarget.kind === 'file') openShareFileModal(ctxTarget.id);
            else openShareFolderModal(ctxTarget.id);
        }
        if (act === 'directShare') openDirectShare(ctxTarget);
        if (act === 'favorite') toggleFavorite(ctxTarget);
        if (act === 'sign' && ctxTarget.kind === 'file') {
            location.href = '/signatures/new?fileId=' + ctxTarget.id;
        }
        if (act === 'uploadReq' && ctxTarget.kind === 'folder') openUploadRequestModal(ctxTarget.id);
        if (act === 'rename' && ctxTarget.kind === 'folder') openRenameFolderModal(ctxTarget.id, ctxTarget.name);
        if (act === 'move' && ctxTarget.kind === 'file') openMoveSingle(ctxTarget.id);
        if (act === 'delete') {
            if (ctxTarget.kind === 'file') deleteFile(ctxTarget.id);
            else {
                if (confirm(@Json.Serialize(T["actions.confirm_delete"].Value))) {
                    const f = document.createElement('form');
                    f.method = 'post';
                    f.action = '/browse/folders/' + ctxTarget.id + '/delete';
                    const csrf = document.querySelector('input[name="__RequestVerificationToken"]');
                    if (csrf) f.appendChild(csrf.cloneNode(true));
                    const rt = document.createElement('input'); rt.name='returnUrl'; rt.value = RETURN_URL; f.appendChild(rt);
                    document.body.appendChild(f);
                    f.submit();
                }
            }
        }
    });
});

// ── Move file(s) ──────────────────────────────────────────────
let moveIds = [];
async function openMoveModal() {
    moveIds = selectedIds();
    if (!moveIds.length) return;
    await populateMoveTargets();
    const tpl = @Json.Serialize(T["move.hint.multi"].Value);
    document.getElementById('moveHint').textContent = tpl.replace("{n}", moveIds.length);
    document.getElementById('modalMove').classList.add('open');
}
async function openMoveSingle(id) {
    moveIds = [id];
    await populateMoveTargets();
    document.getElementById('moveHint').textContent = @Json.Serialize(T["move.hint.single"].Value);
    document.getElementById('modalMove').classList.add('open');
}
async function populateMoveTargets() {
    const r = await fetch('/api/v1/folders/writable?scope=' + SCOPE + '&exclude=' + FOLDER_ID, { credentials: 'same-origin' });
    if (!r.ok) return;
    const items = await r.json();
    const sel = document.getElementById('moveTarget');
    sel.innerHTML = '';
    items.forEach(x => { const opt = document.createElement('option'); opt.value = x.id; opt.textContent = x.path; sel.appendChild(opt); });
}
async function performMove() {
    const folderId = document.getElementById('moveTarget').value;
    if (!folderId) return;
    let ok = 0, fail = 0;
    for (const id of moveIds) {
        const r = await fetch('/api/v1/files/' + id + '/move', {
            method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
            body: JSON.stringify({ folderId }),
        });
        if (r.ok) ok++; else fail++;
    }
    document.getElementById('modalMove').classList.remove('open');
    if (fail) alert(ok + ' moved, ' + fail + ' failed'); else location.reload();
}

// ── Semantic search ───────────────────────────────────────────
async function doSearch() {
    const q = document.getElementById('searchQ').value.trim();
    const out = document.getElementById('searchResults');
    if (!q) { out.style.display = 'none'; return; }
    out.style.display = 'block';
    out.innerHTML = '<div class="muted" style="padding:8px">' + @Json.Serialize(T["browse.search.loading"].Value) + '</div>';
    const r = await fetch('/api/v1/ai/search', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify({ query: q, scope: SCOPE, groupId: null, limit: 10 }),
    });
    if (r.status === 503) { out.innerHTML = '<div class="muted" style="padding:8px">' + @Json.Serialize(T["browse.search.disabled"].Value) + '</div>'; return; }
    if (!r.ok) { out.innerHTML = '<div class="muted" style="padding:8px">' + @Json.Serialize(T["browse.search.error"].Value) + '</div>'; return; }
    const hits = await r.json();
    if (!hits.length) { out.innerHTML = '<div class="muted" style="padding:8px">' + @Json.Serialize(T["browse.search.no_hits"].Value) + '</div>'; return; }
    out.innerHTML = '';
    hits.forEach(h => {
        const row = document.createElement('div');
        row.className = 'hit';
        row.innerHTML = `<div class="fm-icon fm-icon-file">📄</div><div style="flex:1"><div><strong>${escapeHtml(h.name)}</strong> <span class="score">${(h.score*100).toFixed(0)}%</span></div>${h.snippet ? '<div class="muted" style="font-size:.8rem">'+escapeHtml(h.snippet)+'</div>' : ''}</div>`;
        row.onclick = () => openPreview(h.id);
        out.appendChild(row);
    });
}
function escapeHtml(s) { return (s||'').replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c])); }

// ── Inline preview modal ──────────────────────────────────────
async function openPreview(fileId) {
    const r = await fetch('/api/v1/files/' + fileId + '/preview-url', { credentials: 'same-origin' });
    if (!r.ok) return;
    const d = await r.json();
    document.getElementById('previewTitle').textContent = d.name;
    const body = document.getElementById('previewBody');
    const ct = (d.contentType || '').toLowerCase();
    if (ct.startsWith('image/')) {
        body.innerHTML = '<img class="preview-image" src="' + d.url + '"/>';
    } else if (ct === 'application/pdf') {
        body.innerHTML = '<iframe class="preview-frame" src="' + d.url + '"></iframe>';
    } else {
        body.innerHTML = '<p class="muted">' + @Json.Serialize(T["preview.unsupported"].Value) + '</p><p><a class="btn btn-primary" href="' + d.url + '" target="_blank">' + @Json.Serialize(T["preview.download"].Value) + '</a></p>';
    }
    document.getElementById('modalPreview').classList.add('open');
}

// ── Drag-drop + quick upload ──────────────────────────────────
const dropzone = document.getElementById('dropzone');
if (dropzone && CAN_WRITE) {
    ['dragenter','dragover'].forEach(ev => dropzone.addEventListener(ev, e => {
        e.preventDefault(); e.stopPropagation(); dropzone.classList.add('drag');
    }));
    ['dragleave','drop'].forEach(ev => dropzone.addEventListener(ev, e => {
        e.preventDefault(); e.stopPropagation(); if (ev === 'dragleave' && e.target !== dropzone) return; dropzone.classList.remove('drag');
    }));
    dropzone.addEventListener('drop', e => uploadFiles(e.dataTransfer.files));
    const quickPick = document.getElementById('quickPick');
    if (quickPick) quickPick.addEventListener('change', () => uploadFiles(quickPick.files));
}
async function uploadFiles(fileList) {
    if (!fileList || !fileList.length) return;
    for (const file of fileList) {
        try {
            // Endpoint is POST /api/v1/files — the old draft used /init which
            // never existed. Server is idempotent on retry; a wrong path was
            // the source of every "Init failed" complaint.
            const initR = await fetch('/api/v1/files', {
                method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
                body: JSON.stringify({ folderId: FOLDER_ID, name: file.name, contentType: file.type || 'application/octet-stream', sizeBytes: file.size }),
            });
            if (!initR.ok) {
                // Surface the actual server message (Problem-details JSON).
                let msg = 'HTTP ' + initR.status;
                try { const p = await initR.json(); msg = p.title || p.detail || msg; } catch {}
                alert('Upload failed for ' + file.name + ': ' + msg);
                continue;
            }
            const { fileId, uploadUrl } = await initR.json();
            const putR = await fetch(uploadUrl, {
                method: 'PUT', headers: {'x-ms-blob-type':'BlockBlob','Content-Type': file.type || 'application/octet-stream'},
                body: file,
            });
            if (!putR.ok) { alert('Blob PUT failed for ' + file.name + ': HTTP ' + putR.status); continue; }
            const cR = await fetch('/api/v1/files/' + fileId + '/complete', { method: 'POST', credentials: 'same-origin' });
            if (!cR.ok) {
                let msg = 'HTTP ' + cR.status;
                try { const p = await cR.json(); msg = p.title || p.detail || msg; } catch {}
                alert('Complete failed for ' + file.name + ': ' + msg);
            }
        } catch (e) { alert('Error uploading ' + file.name + ': ' + e); }
    }
    location.reload();
}

// Modal helpers used from generated onclicks.
function closeModal(id) { document.getElementById(id).classList.remove('open'); }

// ── Direct share modal ────────────────────────────────────────
let dsCurrent = null; // { kind: 'file'|'folder', id, name }
async function openDirectShare(target) {
    dsCurrent = target;
    document.getElementById('dsTargetName').textContent = target.name;
    document.getElementById('modalDirectShare').classList.add('open');
    document.getElementById('dsKind').value = 'user';
    ds_switchKind();
    await ds_loadGroups();
    await ds_loadShares();
}
document.getElementById('dsKind').addEventListener('change', ds_switchKind);
function ds_switchKind() {
    const kind = document.getElementById('dsKind').value;
    document.getElementById('dsPicker').style.display = kind === 'user' ? '' : 'none';
    document.getElementById('dsGroupSel').style.display = kind === 'group' ? '' : 'none';
}
let dsUserCache = new Map();
document.getElementById('dsPicker').addEventListener('input', async (e) => {
    const q = e.target.value;
    const r = await fetch('/api/v1/direct-shares/users?q=' + encodeURIComponent(q), { credentials: 'same-origin' });
    if (!r.ok) return;
    const items = await r.json();
    const dl = document.getElementById('dsUserList');
    dl.innerHTML = '';
    dsUserCache.clear();
    items.forEach(u => {
        const o = document.createElement('option');
        o.value = u.displayName + ' <' + u.email + '>';
        dl.appendChild(o);
        dsUserCache.set(o.value, u.id);
    });
});
async function ds_loadGroups() {
    const r = await fetch('/api/v1/direct-shares/groups', { credentials: 'same-origin' });
    if (!r.ok) return;
    const items = await r.json();
    const sel = document.getElementById('dsGroupSel');
    sel.innerHTML = '';
    items.forEach(g => { const o = document.createElement('option'); o.value = g.id; o.textContent = g.name; sel.appendChild(o); });
    // If the user isn't in any group there's nothing to grant to — hide the
    // "group" option in the kind picker so a bad POST can't be sent.
    const kindSel = document.getElementById('dsKind');
    const groupOpt = kindSel.querySelector('option[value="group"]');
    if (groupOpt) groupOpt.disabled = items.length === 0;
    if (items.length === 0 && kindSel.value === 'group') { kindSel.value = 'user'; ds_switchKind(); }
}
async function ds_add() {
    if (!dsCurrent) return;
    const kind = document.getElementById('dsKind').value;
    const perm = document.getElementById('dsPerm').value;
    const body = { permission: perm };
    if (dsCurrent.kind === 'file') body.fileId = dsCurrent.id;
    else body.folderId = dsCurrent.id;
    if (kind === 'user') {
        const val = document.getElementById('dsPicker').value;
        const uid = dsUserCache.get(val);
        if (!uid) { alert('Pick a user from the suggestions.'); return; }
        body.userId = uid;
    } else {
        body.groupId = document.getElementById('dsGroupSel').value;
    }
    const r = await fetch('/api/v1/direct-shares', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify(body),
    });
    if (!r.ok) { alert('Failed: ' + r.status); return; }
    document.getElementById('dsPicker').value = '';
    await ds_loadShares();
}
async function ds_loadShares() {
    if (!dsCurrent) return;
    const url = dsCurrent.kind === 'file'
        ? '/api/v1/direct-shares/for-file/' + dsCurrent.id
        : '/api/v1/direct-shares/for-folder/' + dsCurrent.id;
    const r = await fetch(url, { credentials: 'same-origin' });
    if (!r.ok) { document.getElementById('dsList').innerHTML = ''; return; }
    const items = await r.json();
    const out = document.getElementById('dsList');
    if (!items.length) { out.innerHTML = '<p class="muted">' + @Json.Serialize(T["share.none"].Value) + '</p>'; return; }
    out.innerHTML = items.map(i => `
        <div class="row" style="justify-content:space-between;padding:6px 8px;border:1px solid var(--tw-gray-200);border-radius:6px">
            <span>${i.userId ? '👤' : '👥'} ${escapeHtml(i.userDisplayName || i.groupName || '?')}</span>
            <span class="chip ${i.permission === 'Write' ? 'chip-warn' : ''}">${i.permission}</span>
            <button class="btn btn-ghost" onclick="ds_revoke('${i.id}')">✕</button>
        </div>`).join('');
}
async function ds_revoke(id) {
    const r = await fetch('/api/v1/direct-shares/' + id, { method: 'DELETE', credentials: 'same-origin' });
    if (r.ok) await ds_loadShares();
}

// ── Favorite toggle ───────────────────────────────────────────
async function toggleFavorite(target) {
    const body = target.kind === 'file' ? { fileId: target.id } : { folderId: target.id };
    const r = await fetch('/api/v1/favorites/toggle', {
        method: 'POST', headers: {'Content-Type':'application/json'}, credentials: 'same-origin',
        body: JSON.stringify(body),
    });
    if (r.ok) {
        const d = await r.json();
        const row = document.querySelector(`tr.ctx[data-id="${target.id}"]`);
        if (row) row.classList.toggle('is-fav', d.starred);
    }
}

// ── Column sorting (click header, folders always stay grouped on top) ──
(function () {
    let sortKey = 'name', sortDir = 1;
    const tbody = document.querySelector('.fm-list tbody');
    if (!tbody) return;
    const sorters = {
        name: (a, b) => a.dataset.name.localeCompare(b.dataset.name, undefined, { numeric: true, sensitivity: 'base' }),
        size: (a, b) => Number(a.dataset.size) - Number(b.dataset.size),
        date: (a, b) => Number(a.dataset.date) - Number(b.dataset.date),
    };
    function apply() {
        const rows = Array.from(tbody.querySelectorAll('tr'));
        const folders = rows.filter(r => r.dataset.kind === 'folder');
        const files   = rows.filter(r => r.dataset.kind === 'file');
        folders.sort((a, b) => sorters[sortKey](a, b) * sortDir);
        files.sort((a, b) => sorters[sortKey](a, b) * sortDir);
        tbody.innerHTML = '';
        [...folders, ...files].forEach(r => tbody.appendChild(r));
        document.querySelectorAll('.fm-sort .fm-sort-caret').forEach(el => el.textContent = '');
        const active = document.querySelector(`.fm-sort[data-sort="${sortKey}"] .fm-sort-caret`);
        if (active) active.textContent = sortDir === 1 ? '▴' : '▾';
    }
    document.querySelectorAll('.fm-sort').forEach(th => {
        th.addEventListener('click', () => {
            const key = th.dataset.sort;
            if (key === sortKey) sortDir = -sortDir; else { sortKey = key; sortDir = 1; }
            apply();
        });
    });
    // Server already returns name-sorted — no initial reflow needed.
})();
</script>
