@model NimShare.Api.Controllers.LoginViewModel
@{
    ViewData["Title"] = @T["login.title"];
    Layout = "_Layout";
    var entra = Context.Items["EntraConfigured"] as bool? ?? false;
}
<div class="landing-shell">
    <div class="landing-card" style="max-width: 480px">
        <div style="text-align:center;margin-bottom:var(--sp-4)">
            <img src="~/img/logo-400.png" srcset="/img/logo-400.png 1x, /img/logo-800.png 2x"
                 alt="NimShare" style="max-width:280px;width:100%;height:auto;margin:0 auto"/>
        </div>
        <h1 style="text-align:center">@T["login.title"]</h1>

        <form method="post" class="stack" style="margin-top: var(--sp-6)">
            <div asp-validation-summary="All" class="helper" style="color:var(--status-critical)"></div>
            <input type="hidden" name="ReturnUrl" value="@ViewData["ReturnUrl"]"/>
            <div class="field">
                <label for="Email">@T["auth.email"]</label>
                <input type="email" name="Email" id="Email" required autocomplete="email" value="@Model.Email"/>
            </div>
            <div class="field">
                <label for="Password">@T["auth.password"]</label>
                <input type="password" name="Password" id="Password" required autocomplete="current-password"/>
            </div>
            <label style="display:flex;align-items:center;gap:var(--sp-2);font-weight:400">
                <input type="checkbox" name="RememberMe" value="true"/> @T["login.remember_me"]
            </label>
            <button type="submit" class="btn btn-primary">@T["login.sign_in"]</button>
        </form>

        @if (entra)
        {
            <div style="text-align:center;margin:var(--sp-6) 0;color:var(--tw-muted-blue);font-size:.85rem">— @T["login.or"] —</div>
            <a class="btn btn-ghost" style="width:100%;justify-content:center"
               href="/MicrosoftIdentity/Account/SignIn">
                @T["welcome.signin"]
            </a>
        }
        <div style="margin-top:var(--sp-6);text-align:center;font-size:.75rem;color:var(--tw-muted-blue);font-family:var(--font-mono)">
            NimShare v@(NimShare.Api.BuildInfo.Version)
        </div>
        @{
            var langs = new[] { ("en","EN"), ("de","DE"), ("fr","FR"), ("it","IT"), ("es","ES"), ("nl","NL") };
            var cur = System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
        }
        <div class="lang-switcher light" style="margin-top:var(--sp-4)">
            @foreach (var (code, label) in langs)
            {
                var cls = code == cur ? "active" : "";
                <a href="?ui-culture=@code" class="@cls">@label</a>
            }
        </div>
    </div>
</div>
