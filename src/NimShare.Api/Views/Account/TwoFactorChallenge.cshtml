@{
    ViewData["Title"] = "2FA-Code";
    Layout = "_Layout";
}
<div class="landing-shell">
    <div class="landing-card" style="max-width:420px;text-align:center">
        <div style="text-align:center;margin-bottom:16px">
            <img src="~/img/logo-400.png" srcset="/img/logo-400.png 1x, /img/logo-800.png 2x"
                 alt="NimShare" style="max-width:240px;width:100%;height:auto;margin:0 auto"/>
        </div>
        <h1 style="margin-top:0">🔐 2FA-Code</h1>
        <p class="muted">Gib den 6-stelligen Code aus deiner Authenticator-App ein.</p>
        <form method="post" action="/login/2fa" style="margin-top:16px">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="All" class="helper" style="color:var(--status-critical)"></div>
            <input type="text" name="code" pattern="[0-9]{6}" maxlength="6" required autofocus autocomplete="one-time-code" inputmode="numeric" placeholder="123456" style="width:100%;font-size:1.6rem;font-family:var(--font-mono);letter-spacing:.4em;text-align:center;padding:12px;margin:12px 0"/>
            <button type="submit" class="btn btn-primary" style="width:100%">✅ Anmelden</button>
        </form>
        <p class="muted" style="margin-top:16px;font-size:.75rem">
            <a href="/login">← Zurück</a>
        </p>
    </div>
</div>
