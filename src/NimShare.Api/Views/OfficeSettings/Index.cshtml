@model NimShare.Core.Entities.OfficeSettings
@{
    ViewData["Title"] = T["office.title"];
    Layout = "_AppShell";
    var hasSecret = (bool)(ViewData["HasSecret"] ?? false);
}
<div class="page-header">
    <div>
        <a href="/dashboard" class="muted" style="text-decoration:none">← @T["nav.dashboard"]</a>
        <h1 style="margin-top:6px">📝 @T["office.title"]</h1>
        <p class="lede">@T["office.lede"]</p>
    </div>
</div>

@if (TempData["Notice"] is string n) { <div class="card" style="border-left:3px solid var(--status-ok);background:rgba(0,235,134,.06);margin-bottom:16px">@n</div> }

<form method="post" action="/settings/office" class="card">
    @Html.AntiForgeryToken()
    <label style="display:flex;align-items:center;gap:8px;font-weight:500">
        <input type="checkbox" name="enabled" value="true" @(Model.Enabled ? "checked" : "")/>
        <span>@T["office.enable"]</span>
    </label>
    <div class="field" style="margin-top:12px">
        <label>@T["office.doc_server_url"]</label>
        <input type="url" name="documentServerUrl" value="@Model.DocumentServerUrl" placeholder="https://office.example.com"/>
        <div class="helper">@T["office.doc_server_url_hint"]</div>
    </div>
    <div class="field">
        <label>@T["office.jwt_secret"]</label>
        <input type="password" name="jwtSecret" placeholder="@(hasSecret ? @T["office.jwt_placeholder_set"].Value : @T["office.jwt_placeholder_new"].Value)"/>
        <div class="helper">@T["office.jwt_secret_hint"]</div>
    </div>
    <div class="actions">
        <button type="submit" class="btn btn-primary">💾 @T["common.save"]</button>
    </div>
</form>

<div class="card" style="margin-top:12px">
    <h2 class="card-title">@T["office.howto.heading"]</h2>
    <ol style="line-height:1.7">
        <li>@T["office.howto.1"]</li>
        <li>@T["office.howto.2"]</li>
        <li>@T["office.howto.3"]</li>
        <li>@T["office.howto.4"]</li>
    </ol>
</div>
