@{
    ViewData["Title"] = T["dev.title"];
    Layout = "_AppShell";
}
<div class="page-header">
    <div>
        <a href="/dashboard" class="muted" style="text-decoration:none">← @T["nav.dashboard"]</a>
        <h1 style="margin-top:6px">🔧 @T["dev.title"]</h1>
        <p class="lede">@T["dev.lede"]</p>
    </div>
</div>

<div class="card"
    data-t-loading="@T["common.loading"]"
    data-t-error="@T["common.error"]"
    data-t-none-tokens="@T["dev.tokens.none"]"
    data-t-col-name="@T["dev.tokens.col_name"]"
    data-t-col-prefix="@T["dev.tokens.col_prefix"]"
    data-t-col-scopes="@T["dev.tokens.col_scopes"]"
    data-t-col-created="@T["dev.tokens.col_created"]"
    data-t-col-last="@T["dev.tokens.col_last_used"]"
    data-t-scopes-all="@T["dev.tokens.scopes_all"]"
    data-t-chip-revoked="@T["dev.tokens.chip_revoked"]"
    data-t-chip-expired="@T["dev.tokens.chip_expired"]"
    data-t-btn-revoke="@T["dev.tokens.btn_revoke"]"
    data-t-confirm-revoke="@T["dev.tokens.confirm_revoke"]"
    data-t-none-hooks="@T["dev.webhooks.none"]"
    data-t-col-url="@T["dev.webhooks.col_url"]"
    data-t-col-events="@T["dev.webhooks.col_events"]"
    data-t-col-last-hook="@T["dev.webhooks.col_last"]"
    data-t-col-failures="@T["dev.webhooks.col_failures"]"
    data-t-chip-disabled="@T["dev.webhooks.chip_disabled"]"
    data-t-btn-delete="@T["common.delete"]"
    data-t-confirm-delete="@T["dev.webhooks.confirm_delete"]"
    data-t-copied="@T["dev.tokens.copied"]">
    <h2 class="card-title">@T["dev.tokens.heading"]</h2>
    <p class="muted">@T["dev.tokens.lede"]</p>
    <div class="actions" style="margin:8px 0">
        <button class="btn btn-primary" onclick="showCreateToken()">@T["dev.tokens.new_btn"]</button>
    </div>
    <div id="tokens-list" class="muted">@T["common.loading"]</div>
</div>

<div class="card" style="margin-top:12px">
    <h2 class="card-title">@T["dev.webhooks.heading"]</h2>
    <p class="muted">@T["dev.webhooks.lede"]</p>
    <div class="actions" style="margin:8px 0">
        <button class="btn btn-primary" onclick="showCreateHook()">@T["dev.webhooks.new_btn"]</button>
    </div>
    <div id="webhooks-list" class="muted">@T["common.loading"]</div>
</div>

<dialog id="create-token-dlg" style="border:0;border-radius:12px;padding:0;max-width:520px;width:92%">
    <form method="dialog" style="padding:20px" onsubmit="return submitToken(event)">
        <h3 style="margin-top:0">@T["dev.tokens.dialog_new"]</h3>
        <div class="field"><label>@T["dev.tokens.dialog_name_label"]</label><input name="name" required placeholder="@T["dev.tokens.dialog_name_ph"]"/></div>
        <div class="field"><label>@T["dev.tokens.dialog_scopes_label"]</label><input name="scopes" placeholder="@T["dev.tokens.dialog_scopes_ph"]"/></div>
        <div class="field"><label>@T["dev.tokens.dialog_expires"]</label><input name="expiresAt" type="date"/></div>
        <div class="actions"><button type="button" class="btn" onclick="document.getElementById('create-token-dlg').close()">@T["common.cancel"]</button><button class="btn btn-primary">@T["common.create"]</button></div>
    </form>
</dialog>

<dialog id="show-token-dlg" style="border:0;border-radius:12px;padding:0;max-width:600px;width:92%">
    <div style="padding:20px">
        <h3 style="margin-top:0">@T["dev.tokens.dialog_created"]</h3>
        <p class="muted">@T["dev.tokens.copy_once"]</p>
        <textarea id="new-token" readonly style="width:100%;font-family:monospace;font-size:12px;height:70px"></textarea>
        <div class="actions"><button class="btn btn-primary" id="tokenCopyBtn">@T["dev.tokens.copy_btn"]</button><button class="btn" onclick="document.getElementById('show-token-dlg').close()">@T["dev.tokens.done"]</button></div>
    </div>
</dialog>

<dialog id="create-hook-dlg" style="border:0;border-radius:12px;padding:0;max-width:520px;width:92%">
    <form method="dialog" style="padding:20px" onsubmit="return submitHook(event)">
        <h3 style="margin-top:0">@T["dev.webhooks.dialog_new"]</h3>
        <div class="field"><label>@T["dev.webhooks.dialog_url"]</label><input name="url" type="url" required placeholder="https://hooks.example.com/nimshare"/></div>
        <div class="field"><label>@T["dev.webhooks.dialog_secret"]</label><input name="secret" required placeholder="@T["dev.webhooks.dialog_secret_ph"]"/></div>
        <div class="field"><label>@T["dev.webhooks.dialog_events"]</label><input name="events" placeholder="@T["dev.webhooks.dialog_events_ph"]"/></div>
        <div class="actions"><button type="button" class="btn" onclick="document.getElementById('create-hook-dlg').close()">@T["common.cancel"]</button><button class="btn btn-primary">@T["common.create"]</button></div>
    </form>
</dialog>

@section Scripts {
<script>
const DT = document.querySelector('.card[data-t-none-tokens]').dataset;
async function api(m,u,b){const o={method:m,headers:{}};if(b){o.headers['Content-Type']='application/json';o.body=JSON.stringify(b)}
    const r=await fetch(u,o);if(!r.ok)throw new Error(await r.text());return r.status===204?null:r.json()}
function esc(s){return String(s??'').replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]))}
function fmt(d){return d?new Date(d).toLocaleString():'—'}

async function loadTokens(){
    try{const rows=await api('GET','/api/v1/dev/tokens')
        const el=document.getElementById('tokens-list')
        if(rows.length===0){el.textContent=DT.tNoneTokens;return}
        el.innerHTML='<table style="width:100%;font-size:14px"><thead><tr><th style="text-align:left">'+DT.tColName+'</th><th>'+DT.tColPrefix+'</th><th>'+DT.tColScopes+'</th><th>'+DT.tColCreated+'</th><th>'+DT.tColLast+'</th><th></th></tr></thead><tbody>'+
          rows.map(t=>{const revoked=t.revokedAt!=null;const expired=t.expiresAt&&new Date(t.expiresAt)<new Date();
            return `<tr style="opacity:${revoked||expired?0.5:1}"><td>${esc(t.name)}${revoked?' <span class="badge">'+DT.tChipRevoked+'</span>':''}${expired?' <span class="badge">'+DT.tChipExpired+'</span>':''}</td><td><code>${esc(t.prefix)}…</code></td><td>${esc(t.scopes||DT.tScopesAll)}</td><td>${fmt(t.createdAt)}</td><td>${fmt(t.lastUsedAt)}</td><td>${revoked?'':`<button class="btn btn-small" onclick="revokeToken('${t.id}')">${DT.tBtnRevoke}</button>`}</td></tr>`}).join('')+'</tbody></table>'
    }catch(e){document.getElementById('tokens-list').textContent=DT.tError+': '+e.message}
}
async function loadHooks(){
    try{const rows=await api('GET','/api/v1/dev/webhooks')
        const el=document.getElementById('webhooks-list')
        if(rows.length===0){el.textContent=DT.tNoneHooks;return}
        el.innerHTML='<table style="width:100%;font-size:14px"><thead><tr><th style="text-align:left">'+DT.tColUrl+'</th><th>'+DT.tColEvents+'</th><th>'+DT.tColLastHook+'</th><th>'+DT.tColFailures+'</th><th></th></tr></thead><tbody>'+
          rows.map(w=>`<tr style="opacity:${w.isActive?1:0.5}"><td style="word-break:break-all">${esc(w.url)}${w.isActive?'':' <span class="badge">'+DT.tChipDisabled+'</span>'}</td><td>${esc(w.events||DT.tScopesAll)}</td><td>${fmt(w.lastDeliveredAt)}</td><td>${w.failureCount}</td><td><button class="btn btn-small" onclick="deleteHook('${w.id}')">${DT.tBtnDelete}</button></td></tr>`).join('')+'</tbody></table>'
    }catch(e){document.getElementById('webhooks-list').textContent=DT.tError+': '+e.message}
}
function showCreateToken(){document.getElementById('create-token-dlg').showModal()}
function showCreateHook(){document.getElementById('create-hook-dlg').showModal()}
async function submitToken(ev){ev.preventDefault();const f=ev.target;const body={name:f.name.value,scopes:f.scopes.value||null,expiresAt:f.expiresAt.value||null}
    try{const r=await api('POST','/api/v1/dev/tokens',body);document.getElementById('create-token-dlg').close();f.reset();
        document.getElementById('new-token').value=r.rawToken;document.getElementById('show-token-dlg').showModal();
        const cp=document.getElementById('tokenCopyBtn');cp.onclick=()=>{navigator.clipboard.writeText(r.rawToken);cp.textContent=DT.tCopied};
        loadTokens()}
    catch(e){nimAlert(DT.tError+': '+e.message,{kind:'error'})}return false}
async function submitHook(ev){ev.preventDefault();const f=ev.target;const body={url:f.url.value,secret:f.secret.value,events:f.events.value||null}
    try{await api('POST','/api/v1/dev/webhooks',body);document.getElementById('create-hook-dlg').close();f.reset();loadHooks()}
    catch(e){nimAlert(DT.tError+': '+e.message,{kind:'error'})}return false}
async function revokeToken(id){if(!await nimConfirm(DT.tConfirmRevoke,{danger:true}))return;try{await api('DELETE','/api/v1/dev/tokens/'+id);loadTokens()}catch(e){nimAlert(e.message,{kind:'error'})}}
async function deleteHook(id){if(!await nimConfirm(DT.tConfirmDelete,{danger:true}))return;try{await api('DELETE','/api/v1/dev/webhooks/'+id);loadHooks()}catch(e){nimAlert(e.message,{kind:'error'})}}
loadTokens();loadHooks()
</script>
}
