@model IEnumerable<NimShare.Core.Entities.UserNotification>
@{
    ViewData["Title"] = T["nav.notifications"].Value;
    Layout = "_AppShell";
}
<div class="page-header">
    <div>
        <h1>🔔 @T["nav.notifications"]</h1>
        <p class="lede">@T["notifications.lede"]</p>
    </div>
    @if (Model.Any(n => n.ReadAt is null))
    {
        <button class="btn btn-ghost" onclick="markAllRead()">✓ @T["notifications.mark_all_read"]</button>
    }
</div>

@if (!Model.Any())
{
    <div class="fm-empty">
        <div class="fm-empty-art">🔔</div>
        <div class="fm-empty-title">@T["notifications.empty_title"]</div>
        <div class="fm-empty-hint">@T["notifications.empty_hint"]</div>
    </div>
}
else
{
    <div class="stack">
    @foreach (var n in Model)
    {
        var icon = n.Kind switch
        {
            NimShare.Core.Entities.NotificationKind.DirectShareGranted => "🤝",
            NimShare.Core.Entities.NotificationKind.LinkDownloaded => "⬇",
            NimShare.Core.Entities.NotificationKind.InviteAccepted => "✅",
            NimShare.Core.Entities.NotificationKind.QuotaWarning => "⚠",
            NimShare.Core.Entities.NotificationKind.SystemAnnouncement => "📣",
            _ => "🔔"
        };
        var unread = n.ReadAt is null;
        <div class="card notif-item @(unread ? "notif-unread" : "")" data-id="@n.Id"
             style="display:flex;align-items:flex-start;gap:12px;padding:12px 16px">
            <div style="font-size:1.4rem;flex-shrink:0">@icon</div>
            <div style="flex:1">
                <div style="font-weight:600">@n.Title</div>
                @if (!string.IsNullOrEmpty(n.Body))
                {
                    <div class="muted" style="font-size:.9rem;margin-top:2px">@n.Body</div>
                }
                <div class="muted" style="font-size:.75rem;margin-top:6px">@n.CreatedAt.ToString("dd.MM.yyyy HH:mm")</div>
            </div>
            @if (unread)
            {
                <button class="btn btn-ghost btn-sm" onclick="markRead('@n.Id', this)" title="@T["notifications.mark_read"]">✓</button>
            }
            @if (!string.IsNullOrEmpty(n.Href))
            {
                <a class="btn btn-ghost btn-sm" href="@n.Href" onclick="markRead('@n.Id', null)">@T["notifications.open"] ↗</a>
            }
        </div>
    }
    </div>
}

@section Scripts {
<script>
async function markRead(id, btn) {
    try {
        const r = await fetch('/api/v1/notifications/' + id + '/read', { method: 'POST', credentials: 'same-origin' });
        if (!r.ok) return;
        const card = document.querySelector('.notif-item[data-id="' + id + '"]');
        if (card) card.classList.remove('notif-unread');
        if (btn) btn.remove();
    } catch {}
}
async function markAllRead() {
    try {
        const r = await fetch('/api/v1/notifications/read-all', { method: 'POST', credentials: 'same-origin' });
        if (r.ok) location.reload();
    } catch {}
}
</script>
}
