{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "description": "NimShare — self-hosted file sharing. Provisions a Linux App Service Web App running the container from GHCR, plus a storage account with a Blob container for user uploads and a File share mounted at /data for the SQLite metadata database."
  },
  "parameters": {
    "siteName": {
      "type": "string",
      "metadata": {
        "description": "Unique site name. Reachable at https://<siteName>.azurewebsites.net"
      }
    },
    "location": {
      "type": "string",
      "defaultValue": "[resourceGroup().location]",
      "metadata": {
        "description": "Azure region — defaults to the resource group location."
      }
    },
    "sku": {
      "type": "string",
      "defaultValue": "B1",
      "allowedValues": [ "F1", "B1", "B2", "B3", "S1", "P1V3" ],
      "metadata": {
        "description": "App Service Plan SKU. B1 (~10 EUR/month, always-on) is enough for personal use. Custom domains + free managed TLS certs need S1 or higher. F1 is free but sleeps when idle."
      }
    },
    "containerImage": {
      "type": "string",
      "defaultValue": "ghcr.io/mnimtz/nimshare:latest",
      "metadata": {
        "description": "Container image. Use a versioned tag (e.g. ghcr.io/mnimtz/nimshare:0.1.0) for reproducible deployments."
      }
    },
    "tz": {
      "type": "string",
      "defaultValue": "Europe/Berlin",
      "metadata": {
        "description": "IANA timezone for the runtime — affects link timestamps and expiry displays."
      }
    },
    "defaultLang": {
      "type": "string",
      "defaultValue": "en",
      "allowedValues": [ "en", "fr", "it", "de", "es" ],
      "metadata": {
        "description": "Fallback UI language when the visitor's browser preference cannot be resolved."
      }
    }
  },
  "variables": {
    "planName": "[concat(parameters('siteName'), '-plan')]",
    "storageAccountName": "[concat('nimshare', uniqueString(resourceGroup().id))]",
    "dataShareName": "nimshare-data",
    "filesContainerName": "files"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageAccountName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false,
        "supportsHttpsTrafficOnly": true
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('storageAccountName'), '/default')]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ],
      "properties": {
        "cors": {
          "corsRules": [
            {
              "allowedOrigins": [ "[concat('https://', parameters('siteName'), '.azurewebsites.net')]" ],
              "allowedMethods": [ "PUT", "GET", "HEAD" ],
              "allowedHeaders": [ "*" ],
              "exposedHeaders": [ "*" ],
              "maxAgeInSeconds": 3600
            }
          ]
        }
      }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/blobServices/containers",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('storageAccountName'), '/default/', variables('filesContainerName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices', variables('storageAccountName'), 'default')]"
      ],
      "properties": { "publicAccess": "None" }
    },
    {
      "type": "Microsoft.Storage/storageAccounts/fileServices/shares",
      "apiVersion": "2023-05-01",
      "name": "[concat(variables('storageAccountName'), '/default/', variables('dataShareName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName'))]"
      ],
      "properties": { "shareQuota": 5 }
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "[parameters('sku')]" },
      "kind": "linux",
      "properties": { "reserved": true }
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[parameters('siteName')]",
      "location": "[parameters('location')]",
      "kind": "app,linux,container",
      "identity": { "type": "SystemAssigned" },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts/fileServices/shares', variables('storageAccountName'), 'default', variables('dataShareName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts/blobServices/containers', variables('storageAccountName'), 'default', variables('filesContainerName'))]"
      ],
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "linuxFxVersion": "[concat('DOCKER|', parameters('containerImage'))]",
          "alwaysOn": "[if(equals(parameters('sku'), 'F1'), false(), true())]",
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "http20Enabled": true,
          "appSettings": [
            { "name": "WEBSITES_PORT", "value": "8080" },
            { "name": "WEBSITES_ENABLE_APP_SERVICE_STORAGE", "value": "false" },
            { "name": "DOCKER_REGISTRY_SERVER_URL", "value": "https://ghcr.io" },
            { "name": "DOCKER_ENABLE_CI", "value": "true" },
            { "name": "ASPNETCORE_ENVIRONMENT", "value": "Production" },
            { "name": "ASPNETCORE_FORWARDEDHEADERS_ENABLED", "value": "true" },
            { "name": "Database__Provider", "value": "Sqlite" },
            { "name": "ConnectionStrings__Default", "value": "Data Source=/data/nimshare.db;Cache=Shared" },
            { "name": "Storage__ContainerName", "value": "files" },
            { "name": "Storage__UseManagedIdentity", "value": "true" },
            { "name": "Storage__AccountName", "value": "[variables('storageAccountName')]" },
            { "name": "Storage__DownloadSasTtlSeconds", "value": "60" },
            { "name": "Storage__UploadSasTtlMinutes", "value": "30" },
            { "name": "IpHash__Salt", "value": "[uniqueString(resourceGroup().id, parameters('siteName'))]" },
            { "name": "Localization__DefaultCulture", "value": "[parameters('defaultLang')]" },
            { "name": "TZ", "value": "[parameters('tz')]" }
          ],
          "azureStorageAccounts": {
            "data": {
              "type": "AzureFiles",
              "accountName": "[variables('storageAccountName')]",
              "shareName": "[variables('dataShareName')]",
              "mountPath": "/data",
              "accessKey": "[listKeys(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), '2023-05-01').keys[0].value]"
            }
          }
        }
      }
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageAccountName')), parameters('siteName'), 'Storage Blob Data Contributor')]",
      "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageAccountName'))]",
      "dependsOn": [
        "[resourceId('Microsoft.Web/sites', parameters('siteName'))]"
      ],
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Web/sites', parameters('siteName')), '2023-12-01', 'Full').identity.principalId]",
        "principalType": "ServicePrincipal",
        "roleDefinitionId": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'ba92f5b4-2d11-453d-a403-e96b0029c9fe')]"
      }
    }
  ],
  "outputs": {
    "siteUrl": {
      "type": "string",
      "value": "[concat('https://', parameters('siteName'), '.azurewebsites.net')]"
    },
    "storageAccount": {
      "type": "string",
      "value": "[variables('storageAccountName')]"
    },
    "nextSteps": {
      "type": "string",
      "value": "Open the site URL. The welcome page renders without auth. To enable sign-in, create an Entra ID app registration (see docs/DEV_SETUP.md) and set AzureAd__TenantId + AzureAd__ClientId in the App Service Configuration blade, then restart the app."
    }
  }
}
